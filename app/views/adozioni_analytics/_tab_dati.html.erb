<% rows_provincia = @analytics.dati_provincia(provincia: @provincia, filtri: @filtri).first(50) %>
<% rows_nazionali = @analytics.dati_nazionali(filtri: @filtri).first(50) %>

<div class="analytics-columns">
  <div class="analytics-columns__col">
    <h2 class="analytics-columns__heading">Provincia: <%= @provincia %></h2>

    <% if rows_provincia.any? %>
      <% totale_prov = rows_provincia.sum { |r| r.sezioni_count.to_i } %>
      <% rows_provincia.group_by(&:EDITORE).first(10).each do |editore, dati| %>
        <% ed_sez = dati.sum { |r| r.sezioni_count.to_i } %>
        <div class="analytics-group">
          <div class="analytics-group__header">
            <h3 class="analytics-group__title"><%= editore %></h3>
            <span class="analytics-group__badge"><%= ed_sez %> sez. (<%= totale_prov > 0 ? number_to_percentage(ed_sez.to_f / totale_prov * 100, precision: 1) : "-" %>)</span>
          </div>
          <table class="analytics-table">
            <thead>
              <tr>
                <th>Disciplina</th>
                <th class="analytics-table__right">Cl.</th>
                <th class="analytics-table__right">Sez.</th>
              </tr>
            </thead>
            <tbody>
              <% dati.sort_by { |r| -r.sezioni_count.to_i }.first(5).each do |row| %>
                <tr>
                  <td><%= row.DISCIPLINA&.titleize %></td>
                  <td class="analytics-table__right"><%= row.ANNOCORSO %></td>
                  <td class="analytics-table__right font-weight-bold"><%= row.sezioni_count %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% end %>
    <% else %>
      <p class="txt-subtle">Nessun dato provinciale.</p>
    <% end %>
  </div>

  <div class="analytics-columns__col">
    <h2 class="analytics-columns__heading">Nazionale</h2>

    <% if rows_nazionali.any? %>
      <% totale_naz = rows_nazionali.sum { |r| r.sezioni_count.to_i } %>
      <% rows_nazionali.group_by(&:EDITORE).first(10).each do |editore, dati| %>
        <% ed_sez = dati.sum { |r| r.sezioni_count.to_i } %>
        <div class="analytics-group">
          <div class="analytics-group__header">
            <h3 class="analytics-group__title"><%= editore %></h3>
            <span class="analytics-group__badge"><%= ed_sez %> sez. (<%= totale_naz > 0 ? number_to_percentage(ed_sez.to_f / totale_naz * 100, precision: 1) : "-" %>)</span>
          </div>
          <table class="analytics-table">
            <thead>
              <tr>
                <th>Disciplina</th>
                <th class="analytics-table__right">Cl.</th>
                <th class="analytics-table__right">Sez.</th>
              </tr>
            </thead>
            <tbody>
              <% dati.sort_by { |r| -r.sezioni_count.to_i }.first(5).each do |row| %>
                <tr>
                  <td><%= row.DISCIPLINA&.titleize %></td>
                  <td class="analytics-table__right"><%= row.ANNOCORSO %></td>
                  <td class="analytics-table__right font-weight-bold"><%= row.sezioni_count %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% end %>
    <% else %>
      <p class="txt-subtle">Nessun dato nazionale.</p>
    <% end %>
  </div>
</div>
