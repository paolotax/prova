<% grado_labels  = TipoScuola::GRADI.to_h.invert %>
<% totale_sezioni  = @rows.sum { |r| r.sezioni_count.to_i } %>
<% totale_disdette = @rows.sum { |r| r.disdette_count.to_i } %>
<% mercati_keys     = @rows.map { |r| [r.grado, r.disciplina, r.anno_corso] }.uniq %>
<% mercato_zona_tot = mercati_keys.sum { |k| @zone_totals[k].to_i } %>
<% mercato_naz_tot  = mercati_keys.sum { |k| @national_totals[k].to_i } %>
<% naz_sez_tot      = @rows.sum { |r| @national_book[[r.grado, r.disciplina, r.anno_corso, r.codice_isbn]].to_i } %>
<% quota_totale     = mercato_zona_tot > 0 ? 100.0 * totale_sezioni / mercato_zona_tot : 0 %>
<% quota_naz_tot    = mercato_naz_tot  > 0 ? 100.0 * naz_sez_tot    / mercato_naz_tot  : 0 %>
<% quota_delta_tot  = quota_totale - quota_naz_tot %>
<% quota_delta_cls  = if mercato_naz_tot.zero? || quota_delta_tot.abs < 0.5 then "txt-subtle"
                      elsif quota_delta_tot > 0 then "txt-positive"
                      else "txt-negative" end %>

<div class="analytics-summary">
  <div class="analytics-summary__card">
    <p class="analytics-summary__value txt-positive"><%= totale_sezioni %></p>
    <p class="analytics-summary__label">sezioni totali</p>
  </div>
  <div class="analytics-summary__card">
    <p class="analytics-summary__value"><%= totale_sezioni * 18 %></p>
    <p class="analytics-summary__label">copie stimate</p>
  </div>
  <% if mercato_zona_tot > 0 %>
    <div class="analytics-summary__card">
      <p class="analytics-summary__value">
        <%= number_to_percentage(quota_totale, precision: 1) %><% if mercato_naz_tot > 0 %>
          <span class="txt-small <%= quota_delta_cls %>" style="font-weight: normal;">
            Δ <%= "#{quota_delta_tot >= 0 ? '+' : ''}#{number_with_precision(quota_delta_tot, precision: 1)}" %>
          </span>
        <% end %>
      </p>
      <p class="analytics-summary__label">quota mercato zona</p>
    </div>
  <% end %>
  <% if totale_disdette > 0 %>
    <div class="analytics-summary__card">
      <p class="analytics-summary__value txt-negative"><%= totale_disdette %></p>
      <p class="analytics-summary__label">disdette</p>
    </div>
  <% end %>
</div>

<% if @rows.any? %>
  <% @rows.group_by(&:grado).each do |grado, rows_grado| %>
    <% grado_sezioni = rows_grado.sum { |r| r.sezioni_count.to_i } %>
    <h2 class="divider divider--fade txt-small" style="margin-block: 1em 0.5em;">
      <%= grado_labels[grado]&.capitalize || grado %>
      <span class="txt-subtle">(<%= grado_sezioni %> sez.)</span>
    </h2>

    <% rows_grado.group_by { |r| [r.disciplina, r.anno_corso] }.each do |(disciplina, anno_corso), adozioni| %>
      <% mercato_key  = [grado, disciplina, anno_corso] %>
      <% mercato_zona = @zone_totals[mercato_key].to_i %>
      <% mercato_naz  = @national_totals[mercato_key].to_i %>
      <div class="analytics-group">
        <h3 class="analytics-group__title">
          <%= disciplina&.titleize %> · <%= anno_corso %>ª
        </h3>
        <table class="analytics-table">
          <thead>
            <tr>
              <th>Titolo</th>
              <th>Editore</th>
              <th class="analytics-table__right">Sez.</th>
              <th class="analytics-table__right">Mia %</th>
              <th class="analytics-table__right">Naz. %</th>
              <th class="analytics-table__right">Δ</th>
              <th class="analytics-table__right">Copie</th>
              <th class="analytics-table__right">Disd.</th>
            </tr>
          </thead>
          <tbody>
            <% adozioni.each do |row| %>
              <% mia_pct = mercato_zona > 0 ? 100.0 * row.sezioni_count.to_i / mercato_zona : 0 %>
              <% naz_sez = @national_book[mercato_key + [row.codice_isbn]].to_i %>
              <% naz_pct = mercato_naz > 0 ? 100.0 * naz_sez / mercato_naz : 0 %>
              <% delta   = mia_pct - naz_pct %>
              <% delta_cls = if mercato_naz.zero? || delta.abs < 0.5 then "txt-subtle"
                             elsif delta > 0 then "txt-positive"
                             else "txt-negative" end %>
              <tr>
                <td><%= link_to row.titolo&.titleize, titolo_path(codice_isbn: row.codice_isbn), class: "txt-link" %></td>
                <td class="txt-subtle"><%= row.editore %></td>
                <td class="analytics-table__right font-weight-bold"><%= row.sezioni_count %></td>
                <td class="analytics-table__right"><%= mercato_zona > 0 ? number_to_percentage(mia_pct, precision: 1) : "—" %></td>
                <td class="analytics-table__right txt-subtle"><%= mercato_naz > 0 ? number_to_percentage(naz_pct, precision: 1) : "—" %></td>
                <td class="analytics-table__right <%= delta_cls %>">
                  <%= mercato_naz > 0 && mercato_zona > 0 ? "#{delta >= 0 ? '+' : ''}#{number_with_precision(delta, precision: 1)}" : "—" %>
                </td>
                <td class="analytics-table__right"><%= row.copie_stimate %></td>
                <td class="analytics-table__right <%= 'txt-negative' if row.disdette_count.to_i > 0 %>"><%= row.disdette_count.to_i > 0 ? row.disdette_count : "" %></td>
              </tr>
            <% end %>
          </tbody>
          <% tot_sez     = adozioni.sum { |r| r.sezioni_count.to_i } %>
          <% tot_copie   = adozioni.sum { |r| r.copie_stimate.to_i } %>
          <% tot_disd    = adozioni.sum { |r| r.disdette_count.to_i } %>
          <% tot_naz_sez = adozioni.sum { |r| @national_book[mercato_key + [r.codice_isbn]].to_i } %>
          <% tot_mia_pct = mercato_zona > 0 ? 100.0 * tot_sez / mercato_zona : 0 %>
          <% tot_naz_pct = mercato_naz  > 0 ? 100.0 * tot_naz_sez / mercato_naz  : 0 %>
          <% tot_delta   = tot_mia_pct - tot_naz_pct %>
          <% tot_delta_cls = if mercato_naz.zero? || tot_delta.abs < 0.5 then "txt-subtle"
                             elsif tot_delta > 0 then "txt-positive"
                             else "txt-negative" end %>
          <tfoot>
            <tr class="font-weight-bold">
              <td colspan="2">Totale</td>
              <td class="analytics-table__right"><%= tot_sez %></td>
              <td class="analytics-table__right"><%= mercato_zona > 0 ? number_to_percentage(tot_mia_pct, precision: 1) : "—" %></td>
              <td class="analytics-table__right txt-subtle"><%= mercato_naz > 0 ? number_to_percentage(tot_naz_pct, precision: 1) : "—" %></td>
              <td class="analytics-table__right <%= tot_delta_cls %>">
                <%= mercato_naz > 0 && mercato_zona > 0 ? "#{tot_delta >= 0 ? '+' : ''}#{number_with_precision(tot_delta, precision: 1)}" : "—" %>
              </td>
              <td class="analytics-table__right"><%= tot_copie %></td>
              <td class="analytics-table__right <%= 'txt-negative' if tot_disd > 0 %>"><%= tot_disd > 0 ? tot_disd : "" %></td>
            </tr>
          </tfoot>
        </table>
      </div>
    <% end %>
  <% end %>
<% else %>
  <p class="txt-subtle">Nessuna adozione trovata per i filtri selezionati.</p>
<% end %>
