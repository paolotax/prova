    <%= back_link_to @editore.editore, editore_path(@editore) %>
  </div>

  <h1 class="header__title"><%= @page_title %></h1>

  <div class="header__actions header__actions--end"></div>
<% end %>

<section class="panel panel--small shadow center">
  <%= render "form", editore: @editore %>
</section>
