<% @page_title = "Editori" %>

<% content_for :header do %>
  <div class="header__actions header__actions--start"></div>

  <h1 class="header__title"><%= @page_title %></h1>

  <div class="header__actions header__actions--end">
    <%= link_to new_editore_path, class: "btn btn--primary" do %>
      <%= icon_tag "add", size: "small" %>
      <span class="for-screen-reader">Nuovo Editore</span>
    <% end %>
  </div>
<% end %>

<section class="panel panel--wide shadow center">
  <% if @editori.any? %>
    <div class="table-wrapper">
      <table class="table">
        <thead>
          <tr>
            <th>Editore</th>
            <th>Gruppo</th>
            <th></th>
          </tr>
        </thead>
        <tbody id="editori">
          <%= render @editori %>
        </tbody>
      </table>
    </div>

    <p class="txt-subtle txt-x-small margin-block-start-half">Totale editori: <%= @editori.size %></p>
  <% else %>
    <div class="flex flex-column align-center gap-half pad">
      <p class="txt-subtle txt-small">Nessun editore presente.</p>
      <%= link_to "Crea il primo editore", new_editore_path, class: "btn" %>
    </div>
  <% end %>
</section>
