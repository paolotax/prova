<h2>Admin Dashboard</h2>

<div class="admin-cards">
  <%= link_to admin_accounts_path, class: "txt-ink" do %>
    <div class="admin-card">
      <div class="admin-card__value"><%= @accounts_count %></div>
      <div class="admin-card__label">Account</div>
    </div>
  <% end %>
  <%= link_to admin_accounts_path, class: "txt-ink" do %>
    <div class="admin-card">
      <div class="admin-card__value"><%= @users_count %></div>
      <div class="admin-card__label">Utenti</div>
    </div>
  <% end %>
</div>

<h3>Strumenti</h3>
<div class="flex flex-column gap-half align-start">
  <%= link_to "Invia estensione WhatsApp Web", admin_extension_mails_path, class: "txt-link" %>
  <%= link_to "Invita nuovo account", admin_account_invitations_path, class: "txt-link" %>
</div>
