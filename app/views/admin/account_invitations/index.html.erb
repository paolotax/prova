<h2 class="txt-align-center">Invita nuovo account</h2>

<div class="flex justify-center margin-block-end-double">
  <%= form_with url: admin_account_invitations_path, method: :post,
        class: "panel panel--small fill-white shadow flex flex-column gap" do |f| %>
    <div class="flex flex-column gap-quarter">
      <%= f.label :email, "Email", class: "txt-small txt-subtle" %>
      <%= f.email_field :email, placeholder: "nome@esempio.it", required: true, class: "input full-width" %>
    </div>

    <div class="flex flex-column gap-quarter">
      <%= f.label :account_name, class: "txt-small txt-subtle" do %>
        Nome account <span class="txt-subtle">(opzionale)</span>
      <% end %>
      <%= f.text_field :account_name, placeholder: "es. Giunti - Bacherini", class: "input full-width" %>
    </div>

    <div class="flex justify-center margin-block-start-double">
      <%= f.submit "Crea account e invia invito", class: "btn btn--primary" %>
    </div>
  <% end %>
</div>

<h3>Account creati</h3>
<table class="table table--compact admin-table--narrow">
  <thead>
    <tr>
      <th>Nome</th>
      <th>Email</th>
      <th>Account</th>
      <th>Creato</th>
    </tr>
  </thead>
  <tbody>
    <% @invitations.each do |user| %>
      <tr>
        <td><%= user.name %></td>
        <td class="txt-subtle"><%= user.email %></td>
        <td><%= user.accounts.map(&:name).join(", ") %></td>
        <td class="txt-subtle"><%= l(user.created_at, format: :short) %></td>
      </tr>
    <% end %>
  </tbody>
</table>
