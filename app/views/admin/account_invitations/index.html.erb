<h2>Invita nuovo account</h2>

<%= form_with url: admin_account_invitations_path, method: :post, style: "margin-bottom: 2rem; display: flex; gap: 0.5rem; align-items: end;" do |f| %>
  <div>
    <label for="email" style="display: block; font-size: 0.875rem; margin-bottom: 0.25rem; color: var(--color-ink-dark);">Email</label>
    <%= f.email_field :email, placeholder: "nome@esempio.it", required: true, class: "input", style: "width: 320px;" %>
  </div>
  <div>
    <label for="account_name" style="display: block; font-size: 0.875rem; margin-bottom: 0.25rem; color: var(--color-ink-dark);">Nome account <span style="color: var(--color-ink-light);">(opzionale)</span></label>
    <%= f.text_field :account_name, placeholder: "es. Giunti - Bacherini", class: "input", style: "width: 320px;" %>
  </div>
  <%= f.submit "Crea account e invia invito", class: "btn btn--primary" %>
<% end %>

<h3>Account creati</h3>
<table class="table">
  <thead>
    <tr>
      <th>Nome</th>
      <th>Email</th>
      <th>Account</th>
      <th>Creato</th>
    </tr>
  </thead>
  <tbody>
    <% @invitations.each do |user| %>
      <tr>
        <td><%= user.name %></td>
        <td class="txt-subtle"><%= user.email %></td>
        <td><%= user.accounts.map(&:name).join(", ") %></td>
        <td class="txt-subtle"><%= l(user.created_at, format: :short) %></td>
      </tr>
    <% end %>
  </tbody>
</table>
