<% content_for :hide_footer, true %>

<% @page_title = "Agenda" %>

<% content_for :header do %>
  <h1 class="header__title">Agenda</h1>
<% end %>

<div class="agenda-calendar"
     data-controller="agenda-calendar"
     data-agenda-calendar-giorno-value="<%= @giorno.iso8601 %>">

  <%# Oggi button — fixed, shown when current week is out of view %>
  <div class="agenda-calendar__oggi" data-agenda-calendar-target="oggiButton" style="display: none;">
    <button type="button" class="btn btn--positive" data-action="click->agenda-calendar#scrollToToday">
      Oggi
    </button>
  </div>

  <%# Top sentinel for loading past weeks %>
  <div data-agenda-calendar-target="sentinelTop" class="agenda-calendar__sentinel"></div>

  <%# Weeks container %>
  <div id="weeks-container" data-agenda-calendar-target="weeksContainer">
    <%= render "agenda/weeks", settimane: @settimane, tappe_per_giorno: @tappe_per_giorno %>
  </div>

  <%# Bottom sentinel for loading future weeks %>
  <div data-agenda-calendar-target="sentinelBottom" class="agenda-calendar__sentinel"></div>
</div>
