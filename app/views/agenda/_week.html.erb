<%# locals: (settimana:, tappe_per_giorno:) -%>

<% monday = settimana.first %>
<% month_name = I18n.l(monday, format: "%B", locale: :it).upcase %>
<% is_current_week = settimana.include?(Date.today) %>

<div class="agenda-week<%= " agenda-week--current" if is_current_week %>"
     id="week-<%= monday.iso8601 %>"
     data-week="<%= monday.iso8601 %>"
     <%= "data-agenda-calendar-target=currentWeek" if is_current_week %>>

  <%# Month label — left side, rotated %>
  <div class="agenda-week__month">
    <span><%= month_name %></span>
  </div>

  <%# Weekday columns (Mon–Fri) %>
  <% settimana[0..4].each do |giorno| %>
    <% is_today = giorno == Date.today %>
    <% tappe = tappe_per_giorno[giorno] || [] %>

    <div class="agenda-week__day<%= " agenda-week__day--today" if is_today %>"
         data-giorno="<%= giorno.iso8601 %>"
         data-controller="tappa-date"
         data-action="dragover->tappa-date#dragOver dragenter->tappa-date#dragEnter dragleave->tappa-date#dragLeave drop->tappa-date#handleDrop">

      <div class="agenda-week__day-header">
        <%= link_to giorno_path(giorno.iso8601), data: { turbo_frame: "_top" }, class: "agenda-week__day-link" do %>
          <span class="agenda-week__day-name"><%= I18n.l(giorno, format: "%a", locale: :it).upcase %></span>
          <% if is_today %>
            <span class="agenda-week__day-number agenda-week__day-number--today"><%= giorno.day %></span>
          <% else %>
            <span class="agenda-week__day-number"><%= giorno.day %></span>
          <% end %>
        <% end %>
      </div>

      <div class="agenda-week__tappe"
           data-controller="tax-sortable"
           data-tax-sortable-group-value="calendar"
           data-tax-sortable-data-tappa="<%= giorno.iso8601 %>">
        <% tappe.sort_by(&:position).each do |tappa| %>
          <%= render "tappe/tappa_compact", tappa: tappa %>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# Weekend group (SAB + DOM) %>
  <div class="agenda-week__weekend">
    <% settimana[5..6].each do |giorno| %>
      <% is_today = giorno == Date.today %>
      <% tappe = tappe_per_giorno[giorno] || [] %>

      <div class="agenda-week__day--weekend<%= " agenda-week__day--today" if is_today %>"
           data-giorno="<%= giorno.iso8601 %>"
           data-controller="tappa-date"
           data-action="dragover->tappa-date#dragOver dragenter->tappa-date#dragEnter dragleave->tappa-date#dragLeave drop->tappa-date#handleDrop">

        <div class="agenda-week__day-header">
          <%= link_to giorno_path(giorno.iso8601), data: { turbo_frame: "_top" }, class: "agenda-week__day-link" do %>
            <span class="agenda-week__day-name"><%= I18n.l(giorno, format: "%a", locale: :it).upcase %></span>
            <span class="agenda-week__day-number"><%= giorno.day %></span>
          <% end %>
        </div>

        <% if tappe.any? %>
          <div class="agenda-week__tappe">
            <% tappe.sort_by(&:position).each do |tappa| %>
              <%= render "tappe/tappa_compact", tappa: tappa %>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

</div>
