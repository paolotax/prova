<% @page_title = I18n.l(@giorno.to_date, format: :long_with_day, locale: :it) %>

<% content_for :head do %>
    <%= javascript_include_tag "https://api.mapbox.com/mapbox-gl-js/v3.8.0/mapbox-gl.js" %>
    <%= javascript_include_tag "https://api.mapbox.com/mapbox-gl-js/plugins/mapbox-gl-directions/v4.2.0/mapbox-gl-directions.js" %>

    <%= stylesheet_link_tag "https://api.mapbox.com/mapbox-gl-js/v3.8.0/mapbox-gl.css" %>
    <%= stylesheet_link_tag "https://api.mapbox.com/mapbox-gl-js/plugins/mapbox-gl-directions/v4.2.0/mapbox-gl-directions.css" %>
<% end %>

<% content_for :header do %>
  <div class="header__actions header__actions--start">
    <div class="flex items-center gap-1">
      <%= link_to agenda_path(giorno: @giorno),
          class: "btn btn--warning",
          data: { controller: "link-modifier", link_modifier_target: "link" } do %>
        Settimana
      <% end %>

      <%= link_to giorno_path(giorno: (@giorno - 1.day).to_s),
          class: "btn btn--ghost",
          data: { controller: "link-modifier", link_modifier_target: "link" } do %>
        <%= icon_tag "arrow-left", size: "small" %>
      <% end %>

      <div data-controller="date-selector" class="relative">
        <%= date_field_tag :giorno,
            @giorno,
            class: "rounded-md border-0 py-1.5 px-3 text-gray-900 [&::-webkit-calendar-picker-indicator]:bg-transparent [&::-webkit-calendar-picker-indicator]:w-full [&::-webkit-calendar-picker-indicator]:h-full [&::-webkit-calendar-picker-indicator]:cursor-pointer [&::-webkit-calendar-picker-indicator]:absolute [&::-webkit-calendar-picker-indicator]:opacity-0",
            style: "width: 2.5rem; color: transparent;",
            data: {
                action: "change->date-selector#change",
                date_selector_target: "select",
                current_date: @giorno
            } %>
        <%= icon_tag "calendar", class: "w-5 h-5 absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 pointer-events-none text-gray-500" %>
      </div>

      <%= link_to giorno_path(giorno: (@giorno + 1.day).to_s),
          class: "btn btn--ghost",
          data: { controller: "link-modifier", link_modifier_target: "link" } do %>
        <%= icon_tag "arrow-right", size: "small" %>
      <% end %>
    </div>
  </div>

  <h1 class="header__title divider divider--fade full-width">
    <span class="overflow-ellipsis"><%= I18n.l(@giorno.to_date, format: :long_with_day, locale: :it) %></span>
  </h1>

  <div class="header__actions header__actions--end">
    <% if @tappe.size > 1 %>
      <%= link_to url_for(controller: "mappe", action: "calcola_percorso_ottimale", method: :get, params: { giorno: @giorno.to_s }),
          class: "btn btn--ghost" do %>
        Ricalcola
      <% end %>
    <% end %>
    <% if @tappe.any? %>
      <%= render DropdownComponent.new() do |dropdown| %>
        <%= dropdown.with_button do %>
          <div class="btn" style="background: var(--color-notice-lighter); color: var(--color-notice-dark);">
            <%= icon_tag "printer", size: "small" %>
          </div>
        <% end %>

        <%= dropdown.with_item do %>
          <%= link_to tappe_giorno_pdf_path(giorno: @giorno),
              class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 hover:text-gray-900",
              data: { controller: "link-modifier", link_modifier_target: "link" } do %>
            Elenco tappe del giorno
          <% end %>
        <% end %>

        <%= dropdown.with_item do %>
          <%= link_to adozioni_tappe_pdf_path(giorno: @giorno),
              class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 hover:text-gray-900",
              data: { controller: "link-modifier", link_modifier_target: "link" } do %>
            Kit adozioni nel baule
          <% end %>
        <% end %>

        <%= dropdown.with_item do %>
          <%= link_to dettaglio_appunti_documenti_pdf_path(giorno: @giorno),
              class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 hover:text-gray-900",
              data: { controller: "link-modifier", link_modifier_target: "link" } do %>
            Dettaglio appunti e documenti
          <% end %>
        <% end %>

        <%= dropdown.with_item do %>
          <%= link_to fogli_scuola_tappe_pdf_path(giorno: @giorno, tipo_stampa: 'mie_adozioni'),
              class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 hover:text-gray-900",
              data: { controller: "link-modifier", link_modifier_target: "link" } do %>
            Fogli scuola
          <% end %>
        <% end %>

        <%= dropdown.with_item do %>
          <%= link_to fogli_scuola_tappe_pdf_path(giorno: @giorno, tipo_stampa: 'mie_adozioni', con_sovrapacchi: true),
              class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 hover:text-gray-900",
              data: { controller: "link-modifier", link_modifier_target: "link" } do %>
            Fogli scuola + sovrapacchi
          <% end %>
        <% end %>
      <% end %>
    <% end %>
    <%= link_to slideover_path,
        class: "btn btn--primary",
        data: { controller: "link-modifier", link_modifier_target: "link", turbo_frame: "slide-over" } do %>
      <%= icon_tag "add", size: "small" %>
    <% end %>
  </div>
<% end %>


<div data-controller="bulk-actions">
    <div id="giorno-<%= @giorno %>"
        class="group show-navigator pt-2 pb-4"
        data-controller="tax-sortable"
        data-tax-sortable-group-value="calendar"
        data-tax-sortable-param-name-value="position"
        data-tax-sortable-data-tappa="<%= @giorno.to_s %>">

        <%# non riordina bene position col css che nasconde quindi lo devo eliminare nel turbo stream %>
        <% if @tappe.empty? %>
            <div class="no-tappe text-center py-16 px-4 hidden only:block">
                <h2 class="text-xl font-bold"> Ops! Nessuna tappa in programma per oggi! 🗺️</h2>
                <p> Aggiungi una nuova tappa per iniziare: sono i posti dove devi andare. 🚶‍♂️</p>
            </div>
        <% else %>
            <%= render partial: "tappe/tappa", collection: @tappe, as: :tappa, locals: { with_checkbox: false } %>
        <% end %>
    </div>
    <%= render "tappe/bulk_bar/bar" %>
</div>


