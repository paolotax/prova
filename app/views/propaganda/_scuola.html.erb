<%# locals: (cs:) %>
<% stato = propaganda_scuola_stato(cs) %>
<article class="card" style="--card-color: <%= stato[:color] %>; --card-padding-block: 0.6rem; --card-padding-inline: 0.8rem; --border-radius: 0.6rem; inline-size: 100%;">
  <header class="flex align-center gap justify-space-between">
    <%= link_to cs.scuola, class: "font-weight-black", style: "color: var(--card-text-color); text-decoration: none;", data: { turbo_frame: "_top" } do %>
      <%= cs.scuola.denominazione %>
    <% end %>
    <span class="txt-small font-weight-bold" style="white-space: nowrap; color: var(--card-text-color);">
      <%= stato[:label] %><%= " · ⚠ #{cs.mancanti}" if !cs.completata? && cs.mancanti.positive? %>
    </span>
  </header>

  <div class="flex flex-column gap-half margin-block-start-half">
    <% cs.collane.each do |collana| %>
      <%= render "propaganda/collana", collana: collana %>
    <% end %>
  </div>
</article>
