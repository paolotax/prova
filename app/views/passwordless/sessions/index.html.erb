<% @page_title = "Le tue sessioni" %>

<div class="panel panel--centered flex flex-column gap">
  <header class="flex align-center justify-space-between">
    <div>
      <h1 class="txt-x-large font-weight-black margin-none">Le tue sessioni</h1>
      <p class="txt-subtle margin-none-block-start">Gestisci le sessioni attive sul tuo account.</p>
    </div>
    <% if @sessions.count > 1 %>
      <%= button_to "Disconnetti altre",
          destroy_all_passwordless_sessions_path,
          method: :delete,
          data: { turbo_confirm: "Sei sicuro? Verrai disconnesso da tutti gli altri dispositivi." },
          class: "btn btn--danger txt-small" %>
    <% end %>
  </header>

  <div class="flex flex-column gap-half">
    <% @sessions.each do |session| %>
      <div class="flex align-center justify-space-between gap pad border-bottom">
        <div class="flex align-center gap">
          <% if session == @current_session %>
            <span class="circled-text circled-text--small fill-selected">
              <%= icon_tag "check" rescue "✓" %>
            </span>
          <% else %>
            <span class="circled-text circled-text--small fill-shade">
              <%= icon_tag "monitor" rescue "◻" %>
            </span>
          <% end %>

          <div class="flex flex-column">
            <div class="flex align-center gap-half">
              <span class="font-weight-black txt-break">
                <%= session.user_agent.present? ? session.user_agent.truncate(40) : "Dispositivo sconosciuto" %>
              </span>
              <% if session == @current_session %>
                <span class="txt-xx-small txt-uppercase fill-selected pad-inline-half border-radius">Corrente</span>
              <% end %>
            </div>
            <span class="txt-small txt-subtle">
              IP: <%= session.ip_address || "N/A" %> · Account: <%= session.account&.name || "N/A" %>
            </span>
            <span class="txt-x-small txt-subtle">
              Ultima attività: <%= time_ago_in_words(session.last_active_at) %> fa
            </span>
          </div>
        </div>

        <% unless session == @current_session %>
          <%= button_to "Disconnetti",
              passwordless_session_path(session),
              method: :delete,
              data: { turbo_confirm: "Disconnettere questa sessione?" },
              class: "btn btn--secondary txt-small" %>
        <% end %>
      </div>
    <% end %>
  </div>

  <div class="txt-align-center margin-block-start">
    <%= link_to "Esci",
        logout_path,
        data: { turbo_method: :delete, turbo_confirm: "Sei sicuro di voler uscire?" },
        class: "txt-link txt-negative" %>
  </div>
</div>
