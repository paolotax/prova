<% content_for :bulk_bar_buttons do %>
  <%# Duplica %>
  <button type="button" class="btn"
          data-action="bulk-bar#showForm"
          data-bulk-bar-target="menuButton"
          data-form-id="duplica">
    <%= icon_tag "copy" %>
    <span>Duplica</span>
  </button>

  <%# Sposta %>
  <button type="button" class="btn"
          data-action="bulk-bar#showForm"
          data-bulk-bar-target="menuButton"
          data-form-id="sposta">
    <%= icon_tag "calendar" %>
    <span>Sposta</span>
  </button>

  <%# Elimina %>
  <button type="button" class="btn txt-negative"
          data-action="bulk-bar#showForm"
          data-bulk-bar-target="menuButton"
          data-form-id="elimina">
    <%= icon_tag "trash" %>
    <span>Elimina</span>
  </button>
<% end %>

<% content_for :bulk_bar_forms do %>
  <%# Form Duplica %>
  <div class="bulk-bar__form" data-bulk-bar-target="form" data-form-id="duplica">
    <span class="bulk-bar__form-title">Duplica tappe</span>
    <%= form_with url: tappe_duplications_path,
          method: :post,
          data: { bulk_actions_target: "form", action: "turbo:submit-end->bulk-actions#hideAfterSubmit" } do |f| %>
      <div class="bulk-bar__form-row">
        <%= date_input_tag :data_tappa, Date.tomorrow, name: "data_tappa" %>
      </div>
      <div class="bulk-bar__form-actions">
        <button type="button" class="btn" data-action="bulk-bar#hideForm">Annulla</button>
        <%= f.submit "Duplica", class: "btn btn--primary" %>
      </div>
    <% end %>
  </div>

  <%# Form Sposta %>
  <div class="bulk-bar__form" data-bulk-bar-target="form" data-form-id="sposta">
    <span class="bulk-bar__form-title">Sposta tappe</span>
    <%= form_with url: tappe_bulk_updates_path,
          method: :patch,
          data: { bulk_actions_target: "form", action: "turbo:submit-end->bulk-actions#hideAfterSubmit" } do |f| %>
      <div class="bulk-bar__form-row">
        <%= date_input_tag :data_tappa, Date.tomorrow, name: "data_tappa" %>
      </div>
      <div class="bulk-bar__form-actions">
        <button type="button" class="btn" data-action="bulk-bar#hideForm">Annulla</button>
        <%= f.submit "Sposta", class: "btn btn--primary" %>
      </div>
    <% end %>
  </div>

  <%# Form Elimina %>
  <div class="bulk-bar__form" data-bulk-bar-target="form" data-form-id="elimina">
    <span class="bulk-bar__form-title txt-negative">Elimina tappe</span>
    <%= form_with url: tappe_deletions_path,
          method: :post,
          data: { bulk_actions_target: "form", action: "turbo:submit-end->bulk-actions#hideAfterSubmit",
                  turbo_confirm: "Sei sicuro di voler eliminare le tappe selezionate?" } do |f| %>
      <div class="bulk-bar__form-actions">
        <button type="button" class="btn" data-action="bulk-bar#hideForm">Annulla</button>
        <%= f.submit "Elimina", class: "btn btn--negative" %>
      </div>
    <% end %>
  </div>
<% end %>

<%= render "shared/bulk_bar" %>
