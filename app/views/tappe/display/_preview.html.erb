<%# locals: (tappa:, entry: nil, draggable: false) -%>

<% if tappa.present? && tappa.persisted? %>
  <% entry ||= tappa.entry rescue nil %>

  <% card_data = {
    navigable_list_target: "item",
    action: "click->navigable-list#hoverSelect mouseenter->navigable-list#hoverSelect"
  } %>

  <% if draggable %>
    <% card_data[:id] = entry&.id || tappa.id %>
    <% card_data[:drag_and_drop_target] = "item" %>
    <% card_data[:css_variable_counter_target] = "item" %>
  <% end %>

  <% card_data[:tax_sortable_update_url] = tappa_sort_path(tappa) %>

  <%= tag.article id: (entry ? dom_id(entry) : dom_id(tappa)),
      class: class_names("card", tappa_type_modifier(tappa)),
      style: "--card-color: #{tappa_color(tappa)};",
      tabindex: 0,
      draggable: draggable,
      data: card_data do %>
    <div class="flex flex-column flex-item-grow max-inline-size">
      <%= link_to tappa_path(tappa), draggable: false, class: "card__link", data: { turbo_frame: "_top" } do %>
        <span class="for-screen-reader"><%= tappa.tappable.denominazione %></span>
      <% end %>

      <header class="card__header">
        <%= render "tappe/display/preview/board", tappa: tappa %>
        <%= render "tappe/display/perma/tags", tappa: tappa %>

        <% if tappa.entry&.triaged? %>
        <span class="btn justify-start card__column-name card__column-name--current txt-uppercase min-width max-width">
          <span class="overflow-ellipsis"><%= tappa.entry.column.name %></span>
        </span>
      <% end %>
      </header>

      <div class="card__body justify-space-between">
        <div class="card__content">
          <h3 class="card__title overflow-line-clamp card__hide-in-context"><%= tappa.tappable.denominazione %></h3>
          <% if tappa.tappable.respond_to?(:comune) && tappa.tappable.comune.present? %>
            <span class="card__subtitle card__hide-in-context"><%= tappa.tappable.comune&.upcase %></span>
          <% end %>

          <% if tappa.titolo.present? %>
            <div class="txt-x-small margin-inline-start-half overflow-line-clamp" style="margin-top: 0.5ch; --lines: 2; color: var(--card-content-color)">
              <%= tag.span tappa.titolo %>
            </div>
          <% end %>

          <% if tappa.descrizione.present? %>
            <div class="txt-xx-small margin-inline-start-half overflow-line-clamp txt-subtle" style="margin-top: 0.25ch; --lines: 6; white-space: pre-line;">
              <%= tag.span tappa.descrizione %>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <%= render "tappe/display/preview/meta", tappa: tappa %>

    <footer class="card__footer flex gap-half">
    </footer>
  <% end %>
<% end %>
