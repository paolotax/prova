<%# locals: (tappa:) -%>

<div class="card__meta" id="<%= dom_id(tappa, :meta) %>">
  <div class="card__meta-avatars card__meta-avatars--author">
    <% if tappa.data_tappa.present? %>
      <span><%= l(tappa.data_tappa, format: "%A %d/%m", locale: :it) %></span>
    <% else %>
      <span>DA PROGRAMMARE</span>
    <% end %>
  </div>

  <span class="card__meta-text card__meta-text--added overflow-ellipsis">
    <% if tappa.giri.any? %>
      <%= icon_tag "folder" %>
      <%= tappa.giri.first.titolo %>
    <% else %>
      &nbsp;
    <% end %>
  </span>

  <span class="card__meta-text card__meta-text--author overflow-ellipsis">
    <% if tappa.tappable_type == "Scuola" %>
      <%= icon_tag "building" %>
      SCUOLA
    <% elsif tappa.tappable_type == "Cliente" %>
      <%= icon_tag "user" %>
      CLIENTE
    <% else %>
      &nbsp;
    <% end %>
  </span>

  <span class="card__meta-text card__meta-text--updated overflow-ellipsis">
    <% if tappa.entro_il.present? %>
      <span class="text-align-right">ENTRO <%= tappa.entro_il.strftime("%d/%m") %></span>
    <% else %>
      &nbsp;
    <% end %>
  </span>

  <span class="card__meta-text card__meta-text--assignees overflow-ellipsis">
    <% if tappa.descrizione.present? %>
      <span><%= truncate(tappa.descrizione, length: 30) %></span>
    <% else %>
      &nbsp;
    <% end %>
  </span>

  <span class="card__meta-text card__meta-text--copie txt-align-end">
    <% if tappa.bolle_visione.any? %>
      Bolle <strong><%= tappa.bolle_visione.size %></strong>
    <% end %>
  </span>

  <span class="card__meta-text card__meta-text--importo txt-align-end">
    <% libri_count = tappa.bolle_visione.joins(:bolla_visione_righe).count %>
    <% if libri_count > 0 %>
      Libri <strong><%= libri_count %></strong>
    <% end %>
  </span>
</div>
