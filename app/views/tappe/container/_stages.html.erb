<%# locals: (tappa:) -%>

<% if tappa.entry.present? %>
  <div class="card__stages">
    <%# Rimandati (Not Now) - gray %>
    <% if tappa.entry.postponed? %>
      <%= button_to entry_not_now_path(tappa.entry),
          method: :delete,
          class: "btn card__column-name card__column-name--current",
          style: "--btn-color: oklch(0.6 0.01 0); --btn-border-color: oklch(0.6 0.01 0)" do %>
        Rimandato
      <% end %>
    <% else %>
      <%= button_to entry_not_now_path(tappa.entry),
          method: :post,
          class: "btn card__column-name",
          style: "--btn-color: oklch(0.6 0.01 0); --btn-border-color: oklch(0.6 0.01 0)" do %>
        Rimanda
      <% end %>
    <% end %>

    <%# Da gestire (Triage) - blue %>
    <% is_in_triage = tappa.entry.column_id.nil? && !tappa.entry.postponed? && !tappa.entry.closed? %>
    <%= button_to entry_triage_path(tappa.entry),
        method: :delete,
        class: class_names("btn card__column-name", "card__column-name--current": is_in_triage),
        style: "--btn-color: oklch(var(--lch-blue-medium)); --btn-border-color: oklch(var(--lch-blue-medium))",
        disabled: is_in_triage do %>
      Da gestire
    <% end %>

    <%# Columns %>
    <% current_account.columns.ordered.each do |column| %>
      <%= button_to entry_triage_path(tappa.entry, column_id: column.id),
          method: :post,
          class: class_names("btn card__column-name", "card__column-name--current": tappa.entry.column_id == column.id),
          style: "--btn-color: #{column.color}; --btn-border-color: #{column.color}",
          disabled: tappa.entry.column_id == column.id do %>
        <%= column.name %>
      <% end %>
    <% end %>

    <%# Completato (Closed) - gray %>
    <% if tappa.entry.closed? %>
      <%= button_to entry_closure_path(tappa.entry),
          method: :delete,
          class: "btn card__column-name card__column-name--current",
          style: "--btn-color: oklch(0.6 0.01 0); --btn-border-color: oklch(0.6 0.01 0)" do %>
        Completato
      <% end %>
    <% else %>
      <%= button_to entry_closure_path(tappa.entry),
          method: :post,
          class: "btn card__column-name",
          style: "--btn-color: oklch(0.6 0.01 0); --btn-border-color: oklch(0.6 0.01 0)" do %>
        Completa
      <% end %>
    <% end %>
  </div>
<% end %>
