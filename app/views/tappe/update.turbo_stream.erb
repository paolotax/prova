<%= turbo_stream.replace @tappa do %>
  <%= render partial: "tappe/tappa", locals: { tappa: @tappa.reload } %>
<% end %>

<%= turbo_stream.replace dom_id(@tappa, :container),
    partial: "tappe/container",
    locals: { tappa: @tappa } %>

<%= turbo_stream.replace dom_id(@tappa, :footer) do %>
  <%= render "tappe/container/footer", tappa: @tappa %>
<% end %>

<%= turbo_stream.update "flash", partial: "layouts/flash" %>
