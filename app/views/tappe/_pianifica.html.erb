<%# locals: (source:) -%>

<% target = source.tappa_target %>
<% return unless target %>

<div style="position: relative;"
     data-controller="dialog"
     data-action="keydown.esc->dialog#close click@document->dialog#closeOnClickOutside">
  <button type="button" class="btn btn--circle" data-action="dialog#toggle"
          aria-label="Pianifica visita">
    <%= icon_tag "menu-dots-vertical" %>
  </button>
  <dialog class="popup panel fill-white shadow txt-small" data-dialog-target="dialog">
    <ul class="popup__list">
      <% future = Current.user.tappe
           .where(tappable: target)
           .where("data_tappa >= ?", Date.current)
           .includes(:giri)
           .order(:data_tappa) %>

      <% [["Oggi", Date.current], ["Domani", Date.tomorrow]].each do |label, date| %>
        <li class="popup__item">
          <%= button_to tappe_path, method: :post, params: {
                tappa: {
                  tappable_type: target.class.name,
                  tappable_id:   target.id,
                  data_tappa:    date,
                  titolo:        source.default_titolo_tappa
                }
              }, class: "popup__btn btn",
              form: { data: { action: "click->dialog#close" } } do %>
            <%= icon_tag "calendar" %>
            <span><%= label %></span>
          <% end %>
        </li>
      <% end %>
      <li class="popup__item">
        <%= link_to new_tappa_path(
              tappable_type: target.class.name,
              tappable_id:   target.id,
              source_titolo: source.default_titolo_tappa
            ), class: "popup__btn btn",
            data: { turbo_frame: :_top, action: "click->dialog#close" } do %>
          <%= icon_tag "calendar" %>
          <span>Scegli giorno…</span>
        <% end %>
      </li>
      <% if future.any? %>
        <li class="popup__item popup__item--info">
          <div class="txt-small fg-muted padding-inline-3 padding-block-2">
            <div class="font-weight-bold">Già pianificata:</div>
            <% future.each do |t| %>
              <div>
                <%= l(t.data_tappa, format: :short) %>
                <% if t.giri.any? %> — <%= t.giri.map(&:titolo).join(", ") %><% end %>
              </div>
            <% end %>
          </div>
        </li>
      <% end %>
    </ul>
  </dialog>
</div>
