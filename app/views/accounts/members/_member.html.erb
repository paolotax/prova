<li id="<%= dom_id(membership) %>" class="flex align-center gap-half">
  <span class="avatar" aria-hidden="true">
    <%= image_tag user_avatar_url(membership.user, script_name: Current.account.slug), size: 48, title: membership.user.name, aria: { hidden: "true" } %>
  </span>
  <div class="txt-align-start overflow-ellipsis min-width">
    <strong class="txt-small"><%= membership.user.name %></strong>
    <div class="txt-x-small txt-subtle"><%= membership.user.email %></div>
  </div>

  <hr class="separator--horizontal flex-item-grow" style="--border-color: var(--color-ink-medium); --border-style: dashed" aria-hidden="true">

  <%# Scuole count + dialog %>
  <% unless membership.owner? %>
    <div data-controller="dialog" data-dialog-modal-value="true" data-action="keydown.esc->dialog#close:stop">
      <button class="btn btn--circle" data-action="dialog#open" title="Assegna scuole" style="--btn-size: 2.5em;">
        <span class="txt-x-small txt-bold"><%= membership.scuole.count %></span>
      </button>

      <dialog class="dialog panel fill-white shadow gap flex-column" style="--panel-size: 36rem; max-height: 80vh;" data-dialog-target="dialog">
        <h3 class="txt-large txt-bold">Scuole di <%= membership.user.name %></h3>
        <%= render "accounts/members/scuole_dialog", membership: membership %>
        <div class="flex justify-end margin-block-start">
          <button class="btn" data-action="dialog#close">Chiudi</button>
        </div>
      </dialog>
    </div>
  <% end %>

  <%# Role toggle con corona %>
  <% if membership.owner? %>
    <span class="btn btn--circle" style="--btn-size: 2.5em; pointer-events: none;" title="Owner">
      <%= icon_tag "crown" %>
    </span>
  <% else %>
    <%= form_with model: membership, url: accounts_member_path(membership, account_id: membership.account_id), scope: :membership, method: :patch do |form| %>
      <label class="btn btn--circle" for="<%= dom_id(membership, :role) %>" style="--btn-size: 2.5em; cursor: pointer;" title="<%= membership.admin? ? 'Amministratore' : 'Agente' %>">
        <%= icon_tag "crown" %>
        <%= form.check_box :role,
            { data: { controller: "auto-submit", action: "auto-submit#submit" },
              checked: membership.admin?,
              hidden: true,
              id: dom_id(membership, :role) },
            "admin", "member" %>
      </label>
    <% end %>
  <% end %>

  <%# Remove member %>
  <% unless membership.owner? %>
    <%= button_to accounts_member_path(membership, account_id: membership.account_id), method: :delete,
        class: "btn btn--circle btn--negative", style: "--btn-size: 2.5em;",
        data: { turbo_confirm: "Rimuovere #{membership.user.name} dall'account?" } do %>
      <%= icon_tag "minus" %>
    <% end %>
  <% end %>
</li>
