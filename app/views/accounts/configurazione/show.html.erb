<% @page_title = "Configurazione" %>

<%= turbo_stream_from Current.account, "configurazione" %>


<div class="configurazione">

  <% onboarding = Account::Onboarding.new(Current.account) %>
  <% if onboarding.da_completare? && Current.admin? %>
    <div class="panel shadow center fill-shade">
      <p class="txt-small txt-center">
        La configurazione dell'account non è completa.
        <%= link_to "Riprendi la procedura guidata", accounts_onboarding_path, class: "txt-bold" %>
      </p>
    </div>
  <% end %>

  <div class="panel shadow center">

    <h2 class="divider divider--fade margin-block-end">Le mie Zone</h2>

    <%= render partial: "accounts/zone/form", locals: { regioni: @regioni } %>

    <%= button_to accounts_importazione_path, class: "btn margin-block-start-double", style: "--btn-background: oklch(var(--lch-yellow-dark)); --btn-border-color: oklch(var(--lch-yellow-dark));" do %>
      <%= icon_tag "refresh" %>
      <span>Aggiorna zone</span>
    <% end %>

    <div class="margin-block-start-double">
      <%= render partial: "accounts/zone/zone_list", locals: { account_zone: @account_zone } %>
    </div>
  </div>

  <div class="panel shadow center">
    <h2 class="divider divider--fade margin-block-end">I miei Mandati</h2>

    <%= render partial: "accounts/mandati/form", locals: { gruppi: @gruppi, editori: @editori } %>

    <%= render "accounts/configurazione/pulsante_aggiorna_adozioni", account: Current.account %>

    <details class="margin-block-start-double"
             data-controller="details-persist"
             data-details-persist-key-value="configurazione:mandati-list">
      <summary class="accordion-summary">
        <span class="accordion-label">Elenco mandati</span>
        <span class="accordion-count"><%= @mandati.size %></span>
      </summary>
      <%= render partial: "accounts/mandati/mandati_list", locals: { mandati: @mandati } %>
    </details>
  </div>

  <div class="panel shadow center">
    <h2 class="divider divider--fade">I miei Colleghi</h2>
    <p class="txt-small txt-subtle txt-center">Invita i tuoi colleghi per accedere. Potrai assegnare a ciascuno le scuole di competenza e un ruolo (agente o amministratore).</p>

    <%= render "accounts/members/invite_form" %>

    <%= render "accounts/members/members_list", members: @members %>

    <%= link_to accounts_distribuzione_path, class: "btn fit-content center margin-block-start-double" do %>
      <%= icon_tag "users" %>
      <span>Distribusci scuole</span>
    <% end %>
  </div>

</div>
