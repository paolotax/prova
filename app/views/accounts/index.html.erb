<div class="max-w-2xl mx-auto py-12 px-4">
  <h1 class="text-2xl font-bold text-gray-900 mb-8">I tuoi Account</h1>

  <% if @accounts.empty? %>
    <div class="text-center py-12">
      <p class="text-gray-500 mb-4">Non hai ancora nessun account.</p>
      <%= link_to "Crea il tuo primo account", new_account_path, class: "btn btn-primary" %>
    </div>
  <% else %>
    <div class="space-y-4 mb-8">
      <% @accounts.each do |account| %>
        <%= link_to account_root_path(account), class: "block p-4 bg-white rounded-lg shadow hover:shadow-md transition-shadow border border-gray-200" do %>
          <div class="flex items-center justify-between">
            <div>
              <h2 class="text-lg font-semibold text-gray-900"><%= account.name %></h2>
              <p class="text-sm text-gray-500">
                <%= current_user.role_in(account)&.titleize || "Membro" %>
              </p>
            </div>
            <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </div>
        <% end %>
      <% end %>
    </div>

    <div class="text-center">
      <%= link_to "Crea nuovo account", new_account_path, class: "text-blue-600 hover:text-blue-800" %>
    </div>
  <% end %>
</div>
