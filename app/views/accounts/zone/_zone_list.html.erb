<div id="zone-panel">
    <% zone_per_regione = account_zone.group_by(&:regione) %>
    <% gradi_colonne = [["E", "Primaria"], ["M", "I Grado"], ["N", "II Grado"]] %>
    <% account_id = account_zone.first&.account_id %>
    <% altro_per_provincia = account_id ? Scuola.where(account_id: account_id, grado: "altro").group(:provincia).count : {} %>
    <% importate_per_zona = account_id ? Scuola.where(account_id: account_id).group(:provincia, :grado).count : {} %>

    <% zone_per_regione.each do |regione, zone_regione| %>
        <% province = zone_regione.map(&:provincia).uniq.sort %>
        <% zone_lookup = zone_regione.index_by { |z| [z.provincia, z.grado] } %>
        <% show_regione_header = zone_per_regione.size > 1 || regione.present? %>
        <% regione_body = capture do %>
            <div style="overflow-x: auto;">
                <table class="zone-grid">
                    <thead>
                        <tr>
                            <th>Provincia</th>
                            <% gradi_colonne.each do |_code, label| %>
                                <th><%= label %></th>
                            <% end %>
                            <th>Altro</th>
                            <th>Totale</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% province.each do |prov| %>
                            <tr>
                                <td>
                                    <div class="zone-grid__provincia">
                                        <%= prov %>
                                        <%= link_to accounts_aree_path(account_id: account_id, provincia: prov),
                                            class: "btn btn--circle btn--link zone-grid__area-link", style: "--btn-size: 1.6em;",
                                            title: "Gestisci aree" do %>
                                          <%= icon_tag "wrench", class: "icon--small" %>
                                        <% end %>
                                    </div>
                                </td>
                                <% row_total = 0 %>
                                <% gradi_colonne.each do |code, _label| %>
                                    <td>
                                        <% zona = zone_lookup[[prov, code]] %>
                                        <% if zona %>
                                            <% row_total += zona.scuole_count if zona.stato.in?(%w[attiva pronta da_rimuovere]) %>
                                            <% importate = importate_per_zona[[zona.provincia, zona.grado]] || 0 %>
                                            <%= render partial: "accounts/zone/zona_cell", locals: { zona: zona, scuole_importate: importate } %>
                                        <% end %>
                                    </td>
                                <% end %>
                                <% altro_count = altro_per_provincia[prov] || 0 %>
                                <td class="txt-center txt-small txt-subtle"><%= altro_count if altro_count > 0 %></td>
                                <td class="txt-center txt-small txt-subtle"><%= row_total + altro_count if row_total + altro_count > 0 %></td>
                            </tr>
                        <% end %>
                    </tbody>
                    <tfoot>
                        <tr>
                            <td class="txt-bold">Totale</td>
                            <% grand_total = 0 %>
                            <% gradi_colonne.each do |code, _label| %>
                                <% col_total = province.sum { |prov| zone_lookup[[prov, code]]&.then { |z| z.stato.in?(%w[attiva pronta da_rimuovere]) ? z.scuole_count : 0 } || 0 } %>
                                <% grand_total += col_total %>
                                <td class="txt-center txt-small txt-bold"><%= col_total if col_total > 0 %></td>
                            <% end %>
                            <% altro_total = altro_per_provincia.values.sum %>
                            <% grand_total += altro_total %>
                            <td class="txt-center txt-small txt-bold"><%= altro_total if altro_total > 0 %></td>
                            <td class="txt-center txt-small txt-bold"><%= grand_total if grand_total > 0 %></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        <% end %>

        <% if show_regione_header %>
            <details class="zone-regione" open
                     data-controller="details-persist"
                     data-details-persist-key-value="configurazione:zone-region:<%= regione %>">
                <summary class="accordion-summary accordion-summary--provincia">
                    <span class="accordion-label"><%= regione %></span>
                    <span class="accordion-count"><%= zone_regione.size %></span>
                </summary>
                <%= regione_body %>
            </details>
        <% else %>
            <div class="zone-regione"><%= regione_body %></div>
        <% end %>
    <% end %>

</div>
