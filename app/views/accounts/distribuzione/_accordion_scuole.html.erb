<%# locals: (grouped:) -%>

<% grouped.keys.map(&:first).uniq.sort.each do |provincia| %>
  <% gradi = grouped.select { |k, _| k.first == provincia } %>
  <% prov_count = gradi.values.flatten.sum { |u| u[:plessi].any? ? u[:plessi].size : 1 } %>
  <details class="accordion-provincia"
           data-drag-and-drop-target="item"
           data-id="prov:<%= provincia %>">
    <summary class="accordion-summary accordion-summary--provincia"
             draggable="true">
      <span class="accordion-label"><%= provincia %></span>
      <span class="accordion-count"><%= prov_count %></span>
    </summary>
    <% gradi.sort_by(&:first).each do |(_, grado), units| %>
      <details class="accordion-grado"
               data-drag-and-drop-target="item"
               data-id="group:<%= provincia %>:<%= grado %>">
        <summary class="accordion-summary accordion-summary--grado"
                 draggable="true">
          <span class="accordion-label"><%= grado_label(grado) %></span>
          <span class="accordion-count"><%= units.sum { |u| u[:plessi].any? ? u[:plessi].size : 1 } %></span>
        </summary>
        <div class="accordion-items">
          <% units.each do |unit| %>
            <%= render "scuole/direzione_group",
              gruppo: { direzione: unit[:plessi].any? ? unit[:scuola] : nil,
                        plessi: unit[:plessi].any? ? unit[:plessi] : [unit[:scuola]] },
              draggable: true %>
          <% end %>
        </div>
      </details>
    <% end %>
  </details>
<% end %>
