<% @page_title = "Distribuzione Scuole" %>
<% @body_class = "contained-scrolling" %>

<% content_for :header do %>
  <div class="header__actions header__actions--start">
  </div>

  <h1 class="header__title divider divider--fade full-width">
    <span class="overflow-ellipsis">Distribuzione Scuole</span>
  </h1>

  <div class="header__actions header__actions--end">
    <%= link_to scuole_path, class: "btn" do %>
      <%= icon_tag "grid" %>
      <span class="for-screen-reader">Lista scuole</span>
    <% end %>
  </div>
<% end %>

<%= tag.div class: "card-columns hide-scrollbar", data: {
      controller: "collapsible-columns drag-and-drop",
      collapsible_columns_board_value: "distribuzione",
      collapsible_columns_exclusive_value: false,
      collapsible_columns_collapsed_class: "is-collapsed",
      collapsible_columns_expanded_class: "is-expanded",
      collapsible_columns_no_transitions_class: "no-transitions",
      collapsible_columns_title_not_visible_class: "is-off-screen",
      drag_and_drop_dragged_item_class: "drag-and-drop__dragged-item",
      drag_and_drop_hover_container_class: "drag-and-drop__hover-container",
      action: "dragstart->drag-and-drop#dragStart dragover->drag-and-drop#dragOver drop->drag-and-drop#drop dragend->drag-and-drop#dragEnd"
    } do %>

  <%# Colonna "Non assegnate" %>
  <section class="cards is-expanded"
           style="--card-color: oklch(0.6 0.01 0)"
           tabindex="0"
           data-collapsible-columns-target="column maybeColumn"
           data-drag-and-drop-target="container"
           data-column-name="Non assegnate"
           data-drag-and-drop-url="<%= accounts_distribuzione_assegnazione_path(scuola_id: '__id__', rimuovi: true) %>"
           data-drag-and-drop-css-variable-name="--card-color"
           data-drag-and-drop-css-variable-value="oklch(0.6 0.01 0)"
           data-drag-and-drop-avatar="<%= escape_once(avatar_tag(Current.account.owner, hidden_for_screen_reader: true)) if Current.account.owner %>">
    <div class="cards__transition-container">
      <header class="cards__header">
        <% non_assegnate_count = @non_assegnate.sum { |u|
          if u[:plessi].any?
            u[:plessi].size + ((u[:scuola].classi_count.to_i > 0 || u[:scuola].mie_adozioni_count.to_i > 0) ? 1 : 0)
          else
            1
          end
        } %>
        <button type="button" class="cards__expander"
                style="--card-count: <%= [non_assegnate_count, 15].min %>"
                data-collapsible-columns-target="button"
                data-action="click->collapsible-columns#toggle"
                aria-expanded="true">
          <span class="cards__expander-count" data-drag-and-drop-counter><%= non_assegnate_count %></span>
          <h3 class="cards__expander-title" data-collapsible-columns-target="title">
            Non assegnate <span class="txt-light">(<span data-drag-and-drop-counter><%= non_assegnate_count %></span>)</span>
          </h3>
        </button>
      </header>
      <div class="cards__list" data-drag-drop-item-container>
        <%= render "accounts/distribuzione/accordion_scuole", grouped: @non_assegnate_grouped %>
      </div>
    </div>
  </section>

  <%# Colonne agenti %>
  <% @memberships.each do |membership| %>
    <% data = @scuole_by_membership[membership.id] || { list: [], grouped: {} } %>
    <% scuole = data[:list] %>
    <% grouped = data[:grouped] %>
    <section class="cards is-expanded"
             style="--card-color: oklch(0.6 0.15 220)"
             tabindex="0"
             data-collapsible-columns-target="column"
             data-drag-and-drop-target="container"
             data-column-name="<%= membership.user.name %>"
             data-drag-and-drop-url="<%= accounts_distribuzione_assegnazione_path(scuola_id: '__id__', membership_id: membership.id) %>"
             data-drag-and-drop-css-variable-name="--card-color"
             data-drag-and-drop-css-variable-value="oklch(0.6 0.15 220)"
             data-drag-and-drop-avatar="<%= escape_once(avatar_tag(membership.user, hidden_for_screen_reader: true)) %>">
      <div class="cards__transition-container">
        <header class="cards__header">
          <% scuole_count = scuole.sum { |u|
            if u[:plessi].any?
              u[:plessi].size + ((u[:scuola].classi_count.to_i > 0 || u[:scuola].mie_adozioni_count.to_i > 0) ? 1 : 0)
            else
              1
            end
          } %>
          <button type="button" class="cards__expander"
                  style="--card-count: <%= [scuole_count, 15].min %>"
                  data-collapsible-columns-target="button"
                  data-action="click->collapsible-columns#toggle"
                  aria-expanded="true">
            <span class="cards__expander-count" data-drag-and-drop-counter><%= scuole_count %></span>
            <h3 class="cards__expander-title" data-collapsible-columns-target="title">
              <%= membership.user.name %> <span class="txt-light">(<span data-drag-and-drop-counter><%= scuole_count %></span>)</span>
              <%= icon_tag "collapse" %>
              <% total_classi = scuole.sum { |u|
                sedi = u[:plessi].any? ? u[:plessi] : [u[:scuola]]
                dir = u[:scuola]
                sedi.sum(&:classi_count) + ((u[:plessi].any? && dir.classi_count.to_i > 0) ? dir.classi_count : 0)
              } %>
              <% total_adozioni = scuole.sum { |u|
                sedi = u[:plessi].any? ? u[:plessi] : [u[:scuola]]
                dir = u[:scuola]
                sedi.sum(&:mie_adozioni_count) + ((u[:plessi].any? && dir.mie_adozioni_count.to_i > 0) ? dir.mie_adozioni_count : 0)
              } %>
              <span class="txt-xx-small full-width txt-align-center" style="font-weight: normal;" data-drag-and-drop-totals>
                <% if total_classi > 0 %><strong data-drag-and-drop-classi-total><%= total_classi %></strong>cl<% end %>
                <% if total_adozioni > 0 %> <strong class="txt-negative" data-drag-and-drop-adozioni-total><%= total_adozioni %></strong>ado<% end %>
              </span>
            </h3>
          </button>
        </header>
        <div class="cards__list" data-drag-drop-item-container>
          <%= render "accounts/distribuzione/accordion_scuole", grouped: grouped %>
        </div>
      </div>
    </section>
  <% end %>
<% end %>
