<%= turbo_refreshes_with method: :morph, scroll: :preserve %>
<%= turbo_stream_from Current.account, "aree", @provincia %>
<% @page_title = "Aree #{@provincia}" %>
<% @body_class = "contained-scrolling" %>

<%# Helper: conta sedi totali nei gruppi (plessi + direzione se ha classi/adozioni proprie) %>
<% scuole_count = ->(gruppi) {
  gruppi.sum { |g|
    dir = g[:direzione]
    g[:plessi].size + ((dir && (dir.classi_count.to_i > 0 || dir.mie_adozioni_count.to_i > 0)) ? 1 : 0)
  }
} %>
<% column_totals = ->(gruppi) {
  classi = gruppi.sum { |g|
    g[:plessi].sum(&:classi_count) + ((g[:direzione] && g[:direzione].classi_count.to_i > 0) ? g[:direzione].classi_count : 0)
  }
  adozioni = gruppi.sum { |g|
    g[:plessi].sum(&:mie_adozioni_count) + ((g[:direzione] && g[:direzione].mie_adozioni_count.to_i > 0) ? g[:direzione].mie_adozioni_count : 0)
  }
  [classi, adozioni]
} %>

<% content_for :header do %>
  <div class="header__actions header__actions--start">
    <%= link_to accounts_configurazione_path, class: "btn" do %>
      <%= icon_tag "arrow-left" %>
    <% end %>
  </div>

  <h1 class="header__title divider divider--fade full-width">
    <span class="overflow-ellipsis">Aree — <%= @provincia %></span>
  </h1>

  <div class="header__actions header__actions--end">
  </div>
<% end %>

<%= tag.div class: "card-columns hide-scrollbar", data: {
      controller: "collapsible-columns drag-and-drop",
      collapsible_columns_board_value: "aree-#{@provincia}",
      collapsible_columns_exclusive_value: false,
      collapsible_columns_collapsed_class: "is-collapsed",
      collapsible_columns_expanded_class: "is-expanded",
      collapsible_columns_no_transitions_class: "no-transitions",
      collapsible_columns_title_not_visible_class: "is-off-screen",
      drag_and_drop_dragged_item_class: "drag-and-drop__dragged-item",
      drag_and_drop_hover_container_class: "drag-and-drop__hover-container",
      action: "dragstart->drag-and-drop#dragStart dragover->drag-and-drop#dragOver drop->drag-and-drop#drop dragend->drag-and-drop#dragEnd"
    } do %>

  <%# Sinistra: colonna "Da pulire" (rossa) %>
  <div class="card-columns__left">
    <% da_pulire = @scuole_by_area["__da_pulire__"] || [] %>
    <section class="cards is-collapsed"
             id="area-col-da-pulire"
             data-turbo-permanent
             style="--card-color: oklch(0.55 0.2 25)"
             tabindex="0"
             data-collapsible-columns-target="column"
             data-drag-and-drop-target="container"
             data-column-name="Da pulire"
             data-drag-and-drop-url="<%= accounts_aree_assegnazione_path(aree_provincia: @provincia, scuola_id: '__id__', area: '__da_pulire__') %>"
             data-drag-and-drop-css-variable-name="--card-color"
             data-drag-and-drop-css-variable-value="oklch(0.55 0.2 25)">
      <div class="cards__transition-container">
        <header class="cards__header">
          <button type="button" class="cards__expander"
                  style="--card-count: <%= [da_pulire.size, 15].min %>"
                  data-collapsible-columns-target="button"
                  data-action="click->collapsible-columns#toggle"
                  aria-expanded="false">
            <span class="cards__expander-count" data-drag-and-drop-counter><%= scuole_count.(da_pulire) %></span>
            <h3 class="cards__expander-title" data-collapsible-columns-target="title">
              Da pulire <span class="txt-light">(<span data-drag-and-drop-counter><%= scuole_count.(da_pulire) %></span>)</span>
              <%= icon_tag "trash", class: "icon--small" %>
              <% tc, ta = column_totals.(da_pulire) %>
              <span class="txt-xx-small full-width txt-align-center" style="font-weight: normal;" data-drag-and-drop-totals>
                <% if tc > 0 %><strong data-drag-and-drop-classi-total><%= tc %></strong>cl<% end %>
                <% if ta > 0 %> <strong class="txt-negative" data-drag-and-drop-adozioni-total><%= ta %></strong>ado<% end %>
              </span>
            </h3>
          </button>
        </header>
        <div class="cards__list" data-drag-drop-item-container>
          <% da_pulire.each do |gruppo| %>
            <%= render "scuole/direzione_group", gruppo: gruppo, draggable: true %>
          <% end %>
        </div>
      </div>
    </section>
  </div>

  <%# Centro: colonna "Senza area" (sempre espansa) %>
  <% unassigned = @scuole_by_area["__unassigned__"] || [] %>
  <section class="cards cards--maybe is-expanded"
           id="area-col-senza-area"
           data-turbo-permanent
           style="--card-color: oklch(0.6 0.01 0)"
           tabindex="0"
           data-collapsible-columns-target="column"
           data-drag-and-drop-target="container"
           data-column-name="Senza area"
           data-drag-and-drop-url="<%= accounts_aree_assegnazione_path(aree_provincia: @provincia, scuola_id: '__id__', area: '') %>"
           data-drag-and-drop-css-variable-name="--card-color"
           data-drag-and-drop-css-variable-value="oklch(0.6 0.01 0)">
    <div class="cards__transition-container">
      <header class="cards__header">
        <button type="button" class="cards__expander"
                style="--card-count: <%= [unassigned.size, 15].min %>"
                data-collapsible-columns-target="button"
                data-action="click->collapsible-columns#toggle"
                aria-expanded="true">
          <span class="cards__expander-count" data-drag-and-drop-counter><%= scuole_count.(unassigned) %></span>
          <h3 class="cards__expander-title" data-collapsible-columns-target="title">
            Senza area <span class="txt-light">(<span data-drag-and-drop-counter><%= scuole_count.(unassigned) %></span>)</span>
            <%= icon_tag "collapse" %>
            <% tc, ta = column_totals.(unassigned) %>
            <span class="txt-xx-small full-width txt-align-center" style="font-weight: normal;" data-drag-and-drop-totals>
              <% if tc > 0 %><strong data-drag-and-drop-classi-total><%= tc %></strong>cl<% end %>
              <% if ta > 0 %> <strong class="txt-negative" data-drag-and-drop-adozioni-total><%= ta %></strong>ado<% end %>
            </span>
          </h3>
        </button>
      </header>
      <div class="cards__list" data-drag-drop-item-container>
        <% unassigned.each do |gruppo| %>
          <%= render "scuole/direzione_group", gruppo: gruppo, draggable: true %>
        <% end %>
      </div>
    </div>
  </section>

  <%# Destra: colonne aree + pulsante "+" %>
  <div class="card-columns__right">
    <% @aree.each do |area| %>
      <% gruppi = @scuole_by_area[area] || [] %>
      <section class="cards is-collapsed"
               id="area-col-<%= area.parameterize %>"
               data-turbo-permanent
               style="--card-color: oklch(0.6 0.15 160)"
               tabindex="0"
               data-collapsible-columns-target="column"
               data-drag-and-drop-target="container"
               data-column-name="<%= area %>"
               data-drag-and-drop-url="<%= accounts_aree_assegnazione_path(aree_provincia: @provincia, scuola_id: '__id__', area: area) %>"
               data-drag-and-drop-css-variable-name="--card-color"
               data-drag-and-drop-css-variable-value="oklch(0.6 0.15 160)">
        <div class="cards__transition-container">
          <header class="cards__header">
            <button type="button" class="cards__expander"
                    style="--card-count: <%= [gruppi.size, 15].min %>"
                    data-collapsible-columns-target="button"
                    data-action="click->collapsible-columns#toggle"
                    aria-expanded="false">
              <span class="cards__expander-count" data-drag-and-drop-counter><%= scuole_count.(gruppi) %></span>
              <h3 class="cards__expander-title" data-collapsible-columns-target="title">
                <%= area %> <span class="txt-light">(<span data-drag-and-drop-counter><%= scuole_count.(gruppi) %></span>)</span>
                <%= icon_tag "collapse" %>
                <% tc, ta = column_totals.(gruppi) %>
                <span class="txt-xx-small full-width txt-align-center" style="font-weight: normal;" data-drag-and-drop-totals>
                  <% if tc > 0 %><strong data-drag-and-drop-classi-total><%= tc %></strong>cl<% end %>
                  <% if ta > 0 %> <strong class="txt-negative" data-drag-and-drop-adozioni-total><%= ta %></strong>ado<% end %>
                </span>
              </h3>
            </button>
          </header>
            <% gruppi_attivi = @wildcard_gruppi - (@gruppi_esclusi_per_area[area] || []) %>
            <% if gruppi_attivi.any? %>
              <div class="area-mandati-badges flex flex-wrap gap-quarter padding-inline txt-xx-small justify-center">
                <% gruppi_attivi.each do |gruppo| %>
                  <span id="mandato-badge-<%= area.parameterize %>-<%= gruppo.parameterize %>"
                        class="badge badge--rounded" style="background: color-mix(in srgb, var(--card-color) 25%, var(--color-canvas)); color: var(--card-color)">
                    <%= gruppo %>
                    <%= button_to accounts_aree_mandato_path(aree_provincia: @provincia, gruppo: gruppo, area: area),
                          method: :delete,
                          class: "badge__remove",
                          data: { turbo_confirm: "Escludi #{gruppo} da #{area}?" } do %>
                      <%= icon_tag "close", class: "icon--xx-small" %>
                    <% end %>
                  </span>
                <% end %>
              </div>
            <% end %>
          <div class="cards__list" data-drag-drop-item-container>
            <% gruppi.each do |gruppo| %>
              <%= render "scuole/direzione_group", gruppo: gruppo, draggable: true %>
            <% end %>
          </div>
        </div>
      </section>
    <% end %>

    <div id="new_area_button" class="cards__new-column" data-controller="dialog" data-action="keydown.esc->dialog#close click@document->dialog#closeOnClickOutside">
      <button class="btn btn--circle txt-x-small borderless" data-action="click->dialog#open:stop" title="Aggiungi area">
        <%= icon_tag "add", class: "translucent" %>
        <span class="for-screen-reader">Aggiungi area</span>
      </button>
      <dialog class="popup panel flex-column gap-half fill-white shadow txt-small margin-block-double" data-dialog-target="dialog">
        <%= form_with url: accounts_aree_assegnazione_path(aree_provincia: @provincia), method: :post,
              data: { controller: "form", action: "turbo:submit-end->dialog#close turbo:submit-end->form#reset" } do |f| %>
          <%= text_field_tag :area_name, nil,
                class: "input",
                placeholder: "Nome area",
                required: true,
                autocomplete: "off",
                pattern: ".*\\S.*",
                title: "Il nome dell'area non può essere vuoto",
                data: { action: "focus->form#select" } %>
          <%= f.button type: "submit", class: "btn btn--link" do %>
            Aggiungi area
          <% end %>
        <% end %>
      </dialog>
    </div>
  </div>
<% end %>
