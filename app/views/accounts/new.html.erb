<div class="max-w-md mx-auto py-12 px-4">
  <h1 class="text-2xl font-bold text-gray-900 mb-8">Crea nuovo Account</h1>

  <%= form_with model: @account, class: "space-y-6" do |f| %>
    <% if @account.errors.any? %>
      <div class="bg-red-50 border border-red-200 rounded-lg p-4">
        <ul class="list-disc list-inside text-red-600">
          <% @account.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :name, "Nome account", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :name,
          class: "w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500",
          placeholder: "Es. La mia azienda",
          autofocus: true %>
    </div>

    <div class="flex items-center justify-between">
      <%= link_to "Annulla", accounts_path, class: "text-gray-600 hover:text-gray-800" %>
      <%= f.submit "Crea Account", class: "px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 cursor-pointer" %>
    </div>
  <% end %>
</div>
