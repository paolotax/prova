<div id="account-editori">
    <% gradi_colonne = [["E", "Primaria"], ["M", "I Grado"], ["N", "II Grado"]] %>
    <% wildcard_mandati = mandati.select { |m| m.area.nil? } %>
    <% mandati_lookup = wildcard_mandati.index_by { |m| [m.provincia, m.editore_id, m.grado] } %>
    <% province = wildcard_mandati.filter_map(&:provincia).uniq.sort %>
    <% editori_map = wildcard_mandati.map(&:editore).uniq.index_by(&:id) %>
    <% account_id = mandati.first&.account_id %>
    <% grand_totals = Hash.new(0) %>
    <% grand_total = 0 %>

    <% province.each do |provincia| %>
        <% mandati_prov = wildcard_mandati.select { |m| m.provincia == provincia } %>
        <% editori_provincia = mandati_prov.map(&:editore).uniq.sort_by(&:editore) %>
        <% gruppi = editori_provincia.group_by { |e| e.gruppo.presence || "—" } %>

        <div class="zone-regione">
            <strong class="divider txt-small">
                <%= provincia %>
                <%= link_to accounts_aree_path(account_id: account_id, provincia: provincia),
                    class: "btn btn--circle btn--link zone-grid__area-link", style: "--btn-size: 1.6em;",
                    title: "Gestisci aree" do %>
                  <%= icon_tag "wrench", class: "icon--small" %>
                <% end %>
            </strong>
            <div style="overflow-x: auto;">
            <table class="zone-grid zone-grid--left">
                <thead>
                    <tr>
                        <th>Gruppo editoriale</th>
                        <% gradi_colonne.each do |_code, label| %>
                            <th><%= label %></th>
                        <% end %>
                        <th>Totale</th>
                    </tr>
                </thead>
                <% gruppi.sort_by(&:first).each do |gruppo, editori_gruppo| %>
                    <% gruppo_eids = editori_gruppo.map(&:id) %>
                    <% gruppo_mandati = mandati_prov.select { |m| gruppo_eids.include?(m.editore_id) } %>
                    <% gruppo_totals = Hash.new(0) %>
                    <% gruppo_totals_all = Hash.new(0) %>
                    <% gruppo_mandati.each do |m| %>
                        <% gruppo_totals_all[m.grado] += m.sezioni_count.to_i %>
                        <% gruppo_totals[m.grado] += m.sezioni_count.to_i unless m.disdetta? %>
                    <% end %>
                    <% gruppo_total = gruppo_totals.values.sum %>
                    <% gruppo_total_all = gruppo_totals_all.values.sum %>
                    <% grand_totals.merge!(gruppo_totals) { |_k, a, b| a + b } %>
                    <% grand_total += gruppo_total %>
                    <% has_gruppo_row = editori_gruppo.size > 1 || gruppo != "—" %>
                    <tbody data-controller="gruppo-toggle">
                        <% if has_gruppo_row %>
                            <% gruppo_disdetto = gruppo_mandati.all?(&:disdetta?) %>
                            <tr>
                                <td style="padding-block-start: 0.8em;">
                                    <div class="zone-grid__cell">
                                        <button type="button" class="btn btn--circle btn--plain" style="--btn-size: 1.6em;" data-action="gruppo-toggle#toggle" aria-label="Espandi editori">
                                            <%= icon_tag "caret-down", class: "icon--small zone-grid__toggle", data: { "gruppo-toggle-target": "icon" } %>
                                        </button>
                                        <span class="txt-small txt-bold" style="text-transform: uppercase;"><%= gruppo %></span>
                                        <% if gruppo_disdetto %>
                                            <%= button_to accounts_mandati_gruppi_disdetta_path(account_id: account_id, gruppi_id: gruppo, provincia: provincia),
                                                method: :delete,
                                                class: "btn btn--circle btn--link",
                                                style: "--btn-size: 1.6em;",
                                                aria: { label: "Riattiva gruppo" } do %>
                                                <%= icon_tag "refresh", class: "icon--small" %>
                                            <% end %>
                                        <% else %>
                                            <%= button_to accounts_mandati_gruppi_disdetta_path(account_id: account_id, gruppi_id: gruppo, provincia: provincia),
                                                method: :post,
                                                class: "btn btn--circle btn--subtle",
                                                style: "--btn-size: 1.6em;",
                                                aria: { label: "Disdetta gruppo" } do %>
                                                <%= icon_tag "close-circle", class: "icon--small" %>
                                            <% end %>
                                        <% end %>
                                        <%= button_to accounts_mandati_gruppi_path(account_id: account_id, id: gruppo, provincia: provincia),
                                            method: :delete,
                                            class: "btn btn--circle btn--negative",
                                            style: "--btn-size: 1.6em;",
                                            aria: { label: "Elimina gruppo" } do %>
                                            <%= icon_tag "trash", class: "icon--small" %>
                                        <% end %>
                                    </div>
                                </td>
                                <% gradi_colonne.each do |code, _label| %>
                                    <% grado_mandati = gruppo_mandati.select { |m| m.grado == code } %>
                                    <% grado_disdetto = grado_mandati.present? && grado_mandati.all?(&:disdetta?) %>
                                    <% grado_count = grado_disdetto ? gruppo_totals_all[code] : gruppo_totals[code] %>
                                    <td style="padding-block-start: 0.8em;">
                                        <% if grado_mandati.present? %>
                                            <div class="zone-grid__cell" style="<%= "opacity: 0.5;" if grado_disdetto %>">
                                                <% if grado_count > 0 %>
                                                    <span class="zone-grid__count" style="<%= "text-decoration: line-through; color: var(--color-negative);" if grado_disdetto %>">
                                                        <%= grado_count %>
                                                    </span>
                                                <% end %>
                                                <% if grado_disdetto %>
                                                    <%= button_to accounts_mandati_gruppi_disdetta_path(account_id: account_id, gruppi_id: gruppo, provincia: provincia, grado: code),
                                                        method: :delete,
                                                        class: "btn btn--circle btn--link",
                                                        style: "--btn-size: 1.6em;",
                                                        aria: { label: "Riattiva grado" } do %>
                                                        <%= icon_tag "refresh", class: "icon--small" %>
                                                    <% end %>
                                                <% else %>
                                                    <%= button_to accounts_mandati_gruppi_disdetta_path(account_id: account_id, gruppi_id: gruppo, provincia: provincia, grado: code),
                                                        method: :post,
                                                        class: "btn btn--circle btn--subtle",
                                                        style: "--btn-size: 1.6em;",
                                                        aria: { label: "Disdetta grado" } do %>
                                                        <%= icon_tag "close-circle", class: "icon--small" %>
                                                    <% end %>
                                                <% end %>
                                                <%= button_to accounts_mandati_gruppi_path(account_id: account_id, id: gruppo, provincia: provincia, grado: code),
                                                    method: :delete,
                                                    class: "btn btn--circle btn--negative",
                                                    style: "--btn-size: 1.6em;",
                                                    aria: { label: "Elimina grado" } do %>
                                                    <%= icon_tag "trash", class: "icon--small" %>
                                                <% end %>
                                            </div>
                                        <% end %>
                                    </td>
                                <% end %>
                                <td style="padding-block-start: 0.8em;">
                                    <% gruppo_row_total = gruppo_disdetto ? gruppo_total_all : gruppo_total %>
                                    <% if gruppo_row_total > 0 %>
                                        <span class="zone-grid__count" style="<%= "text-decoration: line-through; color: var(--color-negative);" if gruppo_disdetto %>">
                                            <%= gruppo_row_total %>
                                        </span>
                                    <% end %>
                                </td>
                            </tr>
                        <% end %>
                        <% editori_gruppo.each do |editore| %>
                            <tr data-gruppo-toggle-target="row" <%= "hidden" if has_gruppo_row %>>
                                <td<%= " style=\"padding-inline-start: 3.5em;\"".html_safe if has_gruppo_row %>>
                                    <span class="txt-x-small txt-subtle"><%= editore.editore.humanize %></span>
                                </td>
                                <% row_total = 0 %>
                                <% gradi_colonne.each do |code, _label| %>
                                    <td>
                                        <% mandato = mandati_lookup[[provincia, editore.id, code]] %>
                                        <% if mandato %>
                                            <% row_total += mandato.sezioni_count.to_i unless mandato.disdetta? %>
                                            <%= render partial: "accounts/mandati/mandato_cell", locals: { mandato: mandato } %>
                                        <% end %>
                                    </td>
                                <% end %>
                                <td class="txt-x-small txt-subtle"><%= row_total if row_total > 0 %></td>
                            </tr>
                        <% end %>
                    </tbody>
                <% end %>
                <% if provincia == province.last && grand_total > 0 %>
                    <tfoot>
                        <tr class="txt-bold txt-small">
                            <td>Totale</td>
                            <% gradi_colonne.each do |code, _label| %>
                                <td><%= grand_totals[code] if grand_totals[code] > 0 %></td>
                            <% end %>
                            <td><%= grand_total %></td>
                        </tr>
                    </tfoot>
                <% end %>
            </table>
            </div>
        </div>
    <% end %>

    <% if mandati.empty? %>
        <p class="txt-small txt-subtle pad-block">Nessun editore assegnato</p>
    <% end %>
</div>
