<%= form_with model: scuola, class: "space-y-6" do |f| %>
  <% if scuola.errors.any? %>
    <div class="p-4 bg-red-50 border border-red-200 rounded-xl">
      <div class="flex items-start gap-3">
        <svg class="w-5 h-5 text-red-500 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <div>
          <h3 class="text-sm font-medium text-red-800">
            <%= pluralize(scuola.errors.count, "errore", "errori") %> <%= scuola.errors.count == 1 ? "impedisce" : "impediscono" %> il salvataggio:
          </h3>
          <ul class="mt-2 text-sm text-red-700 list-disc list-inside">
            <% scuola.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
  <% end %>

  <%# Denominazione %>
  <div>
    <%= f.label :denominazione, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :denominazione,
        class: "w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 transition-all",
        placeholder: "Nome della scuola",
        autofocus: true %>
  </div>

  <%# Codice ministeriale e Tipo scuola %>
  <div class="grid sm:grid-cols-2 gap-4">
    <div>
      <%= f.label :codice_ministeriale, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :codice_ministeriale,
          class: "w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm font-mono uppercase focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 transition-all",
          placeholder: "es. MIIC123456" %>
    </div>

    <div>
      <%= f.label :tipo_scuola, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.select :tipo_scuola,
          options_for_select([
            ["Seleziona tipo...", ""],
            ["Istituto Comprensivo", "Istituto Comprensivo"],
            ["Scuola Primaria", "Scuola Primaria"],
            ["Scuola Secondaria I grado", "Scuola Secondaria I grado"],
            ["Liceo Scientifico", "Liceo Scientifico"],
            ["Liceo Classico", "Liceo Classico"],
            ["Liceo Linguistico", "Liceo Linguistico"],
            ["Istituto Tecnico", "Istituto Tecnico"],
            ["Istituto Professionale", "Istituto Professionale"],
            ["Altro", "Altro"]
          ], scuola.tipo_scuola),
          {},
          class: "w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 transition-all cursor-pointer" %>
    </div>
  </div>

  <%# Indirizzo %>
  <div>
    <%= f.label :indirizzo, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :indirizzo,
        class: "w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 transition-all",
        placeholder: "Via/Piazza..." %>
  </div>

  <%# CAP, Comune, Provincia %>
  <div class="grid sm:grid-cols-4 gap-4">
    <div>
      <%= f.label :cap, "CAP", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :cap,
          class: "w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 transition-all",
          placeholder: "00000",
          maxlength: 5 %>
    </div>

    <div class="sm:col-span-2">
      <%= f.label :comune, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :comune,
          class: "w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 transition-all",
          placeholder: "Comune" %>
    </div>

    <div>
      <%= f.label :provincia, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :provincia,
          class: "w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm uppercase focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 transition-all",
          placeholder: "MI",
          maxlength: 2 %>
    </div>
  </div>

  <%# Regione %>
  <div>
    <%= f.label :regione, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.select :regione,
        options_for_select([
          ["Seleziona regione...", ""],
          "Abruzzo", "Basilicata", "Calabria", "Campania", "Emilia-Romagna",
          "Friuli-Venezia Giulia", "Lazio", "Liguria", "Lombardia", "Marche",
          "Molise", "Piemonte", "Puglia", "Sardegna", "Sicilia", "Toscana",
          "Trentino-Alto Adige", "Umbria", "Valle d'Aosta", "Veneto"
        ], scuola.regione),
        {},
        class: "w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 transition-all cursor-pointer" %>
  </div>

  <%# Email e PEC %>
  <div class="grid sm:grid-cols-2 gap-4">
    <div>
      <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.email_field :email,
          class: "w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 transition-all",
          placeholder: "email@scuola.edu.it" %>
    </div>

    <div>
      <%= f.label :pec, "PEC", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.email_field :pec,
          class: "w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 transition-all",
          placeholder: "email@pec.scuola.edu.it" %>
    </div>
  </div>

  <%# Telefono %>
  <div>
    <%= f.label :telefono, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.telephone_field :telefono,
        class: "w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 transition-all",
        placeholder: "02 12345678" %>
  </div>

  <%# Stato e Priorita %>
  <div class="grid sm:grid-cols-2 gap-4">
    <div>
      <%= f.label :stato, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.select :stato,
          options_for_select([
            ["Attiva", "attiva"],
            ["Inattiva", "inattiva"],
            ["In sospeso", "sospesa"]
          ], scuola.stato || "attiva"),
          {},
          class: "w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 transition-all cursor-pointer" %>
    </div>

    <div>
      <%= f.label :priorita, "Priorita", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.select :priorita,
          options_for_select((0..5).map { |n| [n == 0 ? "Nessuna" : "#{'★' * n} (#{n})", n] }, scuola.priorita || 0),
          {},
          class: "w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 transition-all cursor-pointer" %>
    </div>
  </div>

  <%# Note %>
  <div>
    <%= f.label :note, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_area :note,
        rows: 3,
        class: "w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 transition-all resize-none",
        placeholder: "Note aggiuntive..." %>
  </div>

  <%# Actions %>
  <div class="flex items-center justify-end gap-3 pt-4 border-t border-gray-100">
    <% cancel_path = scuola.persisted? ? scuola_path(scuola) : scuole_path %>
    <%= link_to "Annulla", cancel_path,
        class: "px-4 py-2.5 text-sm font-medium text-gray-700 hover:text-gray-900 transition-colors" %>

    <%= f.submit scuola.persisted? ? "Salva Modifiche" : "Crea Scuola",
        class: "px-6 py-2.5 bg-emerald-600 text-white text-sm font-medium rounded-lg hover:bg-emerald-700 focus:ring-2 focus:ring-offset-2 focus:ring-emerald-500 transition-all cursor-pointer" %>
  </div>
<% end %>
