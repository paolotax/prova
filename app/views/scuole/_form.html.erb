<%= form_with model: scuola, class: "flex flex-column gap", data: { controller: "form" } do |f| %>

  <% if scuola.errors.any? %>
    <div class="panel pad border-radius txt-negative fill-shade">
      <h3 class="font-weight-black"><%= pluralize(scuola.errors.count, "errore", "errori") %> da correggere:</h3>
      <ul class="margin-block-start-half txt-small">
        <% scuola.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <section class="panel shadow center" style="--panel-size: 55ch;">
    <!-- Dati Scuola -->
    <strong class="divider txt-large">Dati scuola</strong>

    <div class="flex flex-column gap">
      <div class="form-field">
        <%= f.label :denominazione, class: "form-label" %>
        <%= f.text_field :denominazione, class: "input", placeholder: "Nome della scuola", autofocus: true, required: true,
            data: { action: "keydown.esc@document->form#cancel" } %>
      </div>

      <div class="form-grid">
        <div class="form-field">
          <%= f.label :codice_ministeriale, class: "form-label" %>
          <%= f.text_field :codice_ministeriale, class: "input mono txt-uppercase", placeholder: "es. MIIC123456" %>
        </div>

        <div class="form-field">
          <%= f.label :tipo_scuola, class: "form-label" %>
          <%= f.select :tipo_scuola,
              options_for_select(
                [["—", ""]] + tipi_scuola_options,
                scuola.tipo_scuola
              ),
              {},
              class: "input input--select" %>
        </div>
      </div>
    </div>

    <!-- Indirizzo -->
    <strong class="divider txt-large">Indirizzo</strong>

    <div class="flex flex-column gap">
      <div class="form-field">
        <%= f.label :indirizzo, class: "form-label" %>
        <%= f.text_field :indirizzo, class: "input", placeholder: "Via/Piazza..." %>
      </div>

      <div class="form-grid form-grid--3">
        <div class="form-field">
          <%= f.label :cap, "CAP", class: "form-label" %>
          <%= f.text_field :cap, class: "input mono", placeholder: "00000", maxlength: 5 %>
        </div>

        <div class="form-field" style="grid-column: span 2;">
          <%= f.label :comune, class: "form-label" %>
          <%= f.text_field :comune, class: "input", placeholder: "Comune" %>
        </div>
      </div>

      <div class="form-grid">
        <div class="form-field">
          <%= f.label :sigla_provincia, "Provincia", class: "form-label" %>
          <%= f.text_field :sigla_provincia, class: "input txt-uppercase", placeholder: "MI", maxlength: 2 %>
        </div>

        <div class="form-field">
          <%= f.label :regione, class: "form-label" %>
          <%= f.select :regione,
              options_for_select(
                [["—", ""]] + regioni_options,
                scuola.regione
              ),
              {},
              class: "input input--select" %>
        </div>
      </div>
    </div>

    <!-- Contatti -->
    <strong class="divider txt-large">Contatti</strong>

    <div class="flex flex-column gap">
      <div class="form-grid">
        <div class="form-field">
          <%= f.label :telefono, class: "form-label" %>
          <%= f.telephone_field :telefono, class: "input", placeholder: "02 12345678" %>
        </div>

        <div class="form-field">
          <%= f.label :email, class: "form-label" %>
          <%= f.email_field :email, class: "input", placeholder: "email@scuola.edu.it" %>
        </div>
      </div>

      <div class="form-field">
        <%= f.label :pec, "PEC", class: "form-label" %>
        <%= f.email_field :pec, class: "input", placeholder: "email@pec.scuola.edu.it" %>
      </div>
    </div>

    <!-- Email docenti -->
    <strong class="divider txt-large">Email docenti</strong>

    <div class="flex flex-column gap"
         data-controller="email-pattern"
         data-email-pattern-patterns-value="<%= Scuola::EMAIL_PATTERNS.keys.to_json %>">
      <div class="form-grid">
        <div class="form-field">
          <%= f.label :email_pattern, "Formato", class: "form-label" %>
          <%= f.select :email_pattern,
              options_for_select(
                [["—", ""]] +
                Scuola::EMAIL_PATTERNS.keys.map { |p| [p, p] } +
                [["Altro...", "custom"]],
                scuola.email_pattern.presence&.then { |p| Scuola::EMAIL_PATTERNS.key?(p) ? p : "custom" }
              ),
              {},
              class: "input input--select",
              data: { email_pattern_target: "select", action: "email-pattern#update" } %>
        </div>

        <div class="form-field">
          <%= f.label :email_dominio, "Dominio", class: "form-label" %>
          <%= f.text_field :email_dominio, class: "input",
              placeholder: "es. ickennedy.istruzione.it",
              data: { email_pattern_target: "dominio", action: "input->email-pattern#update" } %>
        </div>
      </div>

      <div class="form-field" data-email-pattern-target="customField" style="<%= 'display:none' unless scuola.email_pattern.present? && !Scuola::EMAIL_PATTERNS.key?(scuola.email_pattern) %>">
        <label class="form-label">Pattern personalizzato</label>
        <input type="text" class="input"
               placeholder="es. cognome.n"
               value="<%= scuola.email_pattern unless Scuola::EMAIL_PATTERNS.key?(scuola.email_pattern) %>"
               data-email-pattern-target="customInput"
               data-action="input->email-pattern#update"
               <% if scuola.email_pattern.present? && !Scuola::EMAIL_PATTERNS.key?(scuola.email_pattern) %>
                 name="scuola[email_pattern]"
               <% end %>>
      </div>

      <p class="txt-small txt-muted" data-email-pattern-target="preview"></p>
    </div>

    <!-- Stato e Priorità -->
    <strong class="divider txt-large">Stato e priorità</strong>

    <div class="flex flex-column gap">
      <div class="form-grid">
        <div class="form-field">
          <%= f.label :stato, class: "form-label" %>
          <%= f.select :stato,
              options_for_select([
                ["Attiva", "attiva"],
                ["Inattiva", "inattiva"],
                ["In sospeso", "sospesa"]
              ], scuola.stato || "attiva"),
              {},
              class: "input input--select" %>
        </div>

        <div class="form-field">
          <%= f.label :priorita, "Priorità", class: "form-label" %>
          <%= f.select :priorita,
              options_for_select((0..5).map { |n| [n == 0 ? "Nessuna" : "#{'★' * n} (#{n})", n] }, scuola.priorita || 0),
              {},
              class: "input input--select" %>
        </div>
      </div>

      <div class="form-field">
        <%= f.label :note, class: "form-label" %>
        <%= f.text_area :note, rows: 3, class: "input", placeholder: "Note aggiuntive..." %>
      </div>
    </div>
  </section>

  <div class="flex align-center justify-end gap">
    <%= link_to "Annulla", (scuola.persisted? ? scuola_path(scuola) : scuole_path), class: "btn", data: { form_target: "cancel" } %>
    <%= f.submit scuola.persisted? ? "Salva Modifiche" : "Crea Scuola", class: "btn btn--primary" %>
  </div>
<% end %>
