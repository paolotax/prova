<%# locals: (scuola:) -%>

<div class="card__meta">
  <span class="card__meta-text">
    <% if scuola.codice_ministeriale.present? %>
      <span class="mono txt-uppercase"><%= scuola.codice_ministeriale %></span>
    <% end %>
  </span>
  <span class="card__meta-text">
    <% if scuola.classi.any? %>
      <span class="txt-positive"><strong><%= scuola.classi.count %></strong> classi</span>
    <% end %>
  </span>
  <span class="card__meta-text">
    <% if scuola.priorita.to_i.positive? %>
      <span style="color: var(--color-warning);">
        <% scuola.priorita.times do %><%= icon_tag "star", size: "small" %><% end %>
      </span>
    <% end %>
  </span>
</div>
