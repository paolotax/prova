<%# locals: (scuola:) -%>

<%= tag.article id: dom_id(scuola),
    class: "card",
    style: "--card-color: #{tipo_scuola_color(scuola.tipo_scuola)}; view-transition-name: #{dom_id(scuola)};",
    tabindex: 0,
    data: { navigable_list_target: "item", action: "mouseenter->navigable-list#hoverSelect contextmenu->navigable-list#toggleSelection" } do %>
  <label class="card__checkbox">
    <%= check_box_tag "ids[]", scuola.id, false, data: { action: "change->bulk-actions#count" } %>
  </label>

  <div class="flex flex-column flex-item-grow max-inline-size">
    <%= link_to scuola_path(scuola), class: "card__link", data: { turbo_frame: "_top" } do %>
      <span class="for-screen-reader"><%= scuola.denominazione %></span>
    <% end %>

    <header class="card__header">
      <%= render "scuole/display/preview/board", scuola: scuola %>
    </header>

    <div class="card__body">
      <div class="card__content">
        <h3 class="card__title overflow-line-clamp" style="--lines: 2;">
          <%= scuola.denominazione %>
        </h3>
        <span class="card__subtitle overflow-ellipsis"><%= [scuola.comune, scuola.sigla_provincia].compact_blank.join(", ") %></span>

        <div class="margin-block-start-half txt-xx-small txt-subtle flex flex-column gap-quarter">
          <% if scuola.indirizzo.present? %>
            <span class="margin-inline-start"><%= icon_tag "marker", class: "icon--small" %> <%= [scuola.cap, scuola.indirizzo].compact_blank.join(" - ") %></span>
          <% end %>
          <% if scuola.telefono.present? %>
            <span class="margin-inline-start"><%= icon_tag "phone", class: "icon--small" %> <%= scuola.telefono %></span>
          <% end %>
          <% if scuola.email.present? %>
            <span class="margin-inline-start"><%= icon_tag "envelope", class: "icon--small" %> <%= scuola.email %></span>
          <% end %>
          <% if scuola.pec.present? %>
            <span class="margin-inline-start"><%= icon_tag "lock", class: "icon--small" %> <%= scuola.pec %></span>
          <% end %>
        </div>
      </div>
    </div>

    <footer class="card__footer full-width">
      <%= render "scuole/display/perma/meta", scuola: scuola %>
    </footer>
  </div>

  <div class="card__actions">
    <%= link_to go_to_tappable_path(scuola, current_user.effective_navigator),
        target: "_blank",
        class: "btn btn--small btn--circle",
        data: { controller: "tooltip", tooltip_content_value: "Naviga" } do %>
      <%= icon_tag "globe" %>
    <% end %>
  </div>
<% end %>
