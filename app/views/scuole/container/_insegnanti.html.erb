<%# locals: (scuola:) -%>

<div id="<%= dom_id(scuola, :insegnanti) %>">
<% persone = scuola.persone.docente.includes(persona_classi: :classe).order(Arel.sql("posizione IS NULL, posizione, cognome, nome")) %>

<%
  # Build cattedra → discipline mapping
  tipo_scuola = scuola.classi.pick(:tipo_scuola) || "MM"
  mappings = CattedraDisciplina.where(account: Current.account, tipo_scuola: tipo_scuola)
  cattedra_to_discipline = mappings.pluck(:cattedra, :disciplina).group_by(&:first).transform_values { |pairs| pairs.map(&:last) }

  # Preload adozioni for this school's classi
  classe_ids = scuola.classi.pluck(:id)
  classi_by_id = scuola.classi.index_by(&:id)
  adozioni_by_classe_disciplina = Adozione.where(classe_id: classe_ids)
    .select(:classe_id, :disciplina, :titolo, :editore, :mia, :nuova_adozione, :prezzo_cents)
    .group_by { |a| [a.classe_id, a.disciplina] }

  # Group persone by materia (cattedra), maintaining posizione order
  grouped = persone.group_by { |p| p.persona_classi.first&.materia }.compact_blank
%>

<% if persone.any? %>
  <section class="group margin-block-end-double">
    <div class="header margin-none padding-none">
      <div class="header__actions header__actions--start">
        <%= link_to "Cattedre", scuola_cattedre_path(scuola), class: "btn txt-small" %>
      </div>
      <h3 class="divider divider--fade txt-medium font-weight-black margin-none">
        Insegnanti (<%= persone.size %>)
      </h3>
      <div class="header__actions header__actions--end">
        <%= link_to "Importa", new_scuola_persone_import_path(scuola), class: "btn txt-small" %>
        <div class="position-relative"
            data-controller="dialog"
            data-action="keydown.esc->dialog#close click@document->dialog#closeOnClickOutside">
          <button class="btn btn--circle"
              data-action="click->dialog#toggle:stop"
              data-controller="tooltip"
              data-tooltip-content-value="Nuovo insegnante (P)">
            <%= icon_tag "person-add" %>
            <span class="for-screen-reader">Nuovo insegnante</span>
          </button>
          <dialog class="popup panel flex-column align-start gap-half fill-white shadow"
              data-dialog-target="dialog"
              data-action="turbo:submit-end->dialog#close">
            <strong class="popup__title">Nuovo insegnante</strong>
            <%= form_with url: scuola_persone_path(scuola), method: :post,
                class: "flex flex-column gap-quarter full-width" do |f| %>
              <%= f.text_field :cognome, placeholder: "Cognome", class: "input txt-small", required: true %>
              <%= f.text_field :nome, placeholder: "Nome", class: "input txt-small" %>
              <%= f.text_field :materia, placeholder: "Disciplina", class: "input txt-small" %>
              <button type="submit" class="btn btn--link full-width margin-block-start-half">
                <%= icon_tag "add" %>
                <span>Aggiungi</span>
              </button>
            <% end %>
          </dialog>
        </div>
      </div>
    </div>

    <% grouped.each do |cattedra, docenti| %>
      <% discipline_miur = cattedra_to_discipline[cattedra] || [] %>

      <div data-controller="libro-hover">
        <h4 class="txt-x-small txt-subtle txt-uppercase margin-block-start"><%= cattedra&.titleize %></h4>

        <% if discipline_miur.any? %>
          <%
            all_classe_ids = docenti.flat_map { |p| p.classi.map(&:id) }.uniq
            all_adozioni = discipline_miur.flat_map { |d| all_classe_ids.flat_map { |cid| adozioni_by_classe_disciplina[[cid, d]] || [] } }
            # Build libro → classe_ids map
            libro_classe_ids = all_adozioni.group_by { |a| [a.titolo, a.editore] }
              .transform_values { |aa| aa.map(&:classe_id).uniq }
            libri_per_anno = all_adozioni
              .group_by { |a| classi_by_id[a.classe_id]&.anno_corso }
              .transform_values { |aa| aa.uniq { |a| [a.titolo, a.editore] } }
              .sort_by { |anno, _| anno.to_i }
          %>
          <% if libri_per_anno.any? %>
            <div style="display: grid; grid-template-columns: repeat(<%= libri_per_anno.size %>, minmax(0, 20ch)); gap: 0.5rem; justify-content: center;" class="margin-block-end-half">
              <% libri_per_anno.each do |anno, adozioni| %>
                <div class="flex flex-column gap-half">
                  <span class="txt-xx-small txt-subtle font-weight-bold txt-align-center"><%= anno %>&deg;</span>
                  <% adozioni.each do |adozione| %>
                    <% cids = libro_classe_ids[[adozione.titolo, adozione.editore]] || [] %>
                    <%= adozione_libro_tag(adozione, data: { libro_hover_target: "libro", classe_ids: cids.join(",") }) %>
                  <% end %>
                </div>
              <% end %>
            </div>
          <% end %>
        <% end %>

        <dl class="dl-grid dl-grid--center txt-small">
          <% docenti.each do |persona| %>
            <%
              styles = {}
              if discipline_miur.any?
                persona.classi.each do |c|
                  adozioni = discipline_miur.flat_map { |d| adozioni_by_classe_disciplina[[c.id, d]] || [] }
                  if adozioni.any? { |a| a.nuova_adozione? && a.mia? }
                    styles[c.id] = :nuova_mia
                  elsif adozioni.any?(&:mia?)
                    styles[c.id] = :mia
                  elsif adozioni.any?(&:nuova_adozione?)
                    styles[c.id] = :nuova_altri
                  end
                end
              end
            %>
            <dt class="txt-x-small">
              <%= link_to persona.nome_completo, scuola_persona_path(scuola, persona), class: "txt-undecorated font-weight-bold", style: "color: inherit;" %>
            </dt>
            <dd>
              <div class="flex gap-quarter flex-wrap">
                <%= classi_badge_links(persona.classi, scuola, classe_styles: styles, hover_target: true) %>
              </div>
            </dd>
          <% end %>
        </dl>
      </div>
    <% end %>
  </section>
<% else %>
  <section class="group margin-block-end-double">
    <div class="header margin-none padding-none">
      <div class="header__actions header__actions--start"></div>
      <h3 class="header__title divider divider--fade txt-medium font-weight-black margin-none">
        Insegnanti
      </h3>
      <div class="header__actions header__actions--end">
        <%= link_to "Importa", new_scuola_persone_import_path(scuola), class: "btn txt-small" %>
        <div class="position-relative"
            data-controller="dialog"
            data-action="keydown.esc->dialog#close click@document->dialog#closeOnClickOutside">
          <button class="btn btn--circle"
              data-action="click->dialog#toggle:stop"
              data-controller="tooltip"
              data-tooltip-content-value="Nuovo insegnante (P)">
            <%= icon_tag "person-add" %>
            <span class="for-screen-reader">Nuovo insegnante</span>
          </button>
          <dialog class="popup panel flex-column align-start gap-half fill-white shadow"
              data-dialog-target="dialog"
              data-action="turbo:submit-end->dialog#close">
            <strong class="popup__title">Nuovo insegnante</strong>
            <%= form_with url: scuola_persone_path(scuola), method: :post,
                class: "flex flex-column gap-quarter full-width" do |f| %>
              <%= f.text_field :cognome, placeholder: "Cognome", class: "input txt-small", required: true %>
              <%= f.text_field :nome, placeholder: "Nome", class: "input txt-small" %>
              <%= f.text_field :materia, placeholder: "Disciplina", class: "input txt-small" %>
              <button type="submit" class="btn btn--link full-width margin-block-start-half">
                <%= icon_tag "add" %>
                <span>Aggiungi</span>
              </button>
            <% end %>
          </dialog>
        </div>
      </div>
    </div>
    <p class="txt-small txt-subtle margin-none">Nessun insegnante.</p>
  </section>
<% end %>
</div>
