<%# locals: (scuola:) -%>

<% persone = scuola.persone.docente.includes(persona_classi: :classe).order(Arel.sql("posizione IS NULL, posizione, cognome, nome")) %>

<%
  # Build cattedra → discipline mapping
  tipo_scuola = scuola.classi.pick(:tipo_scuola) || "MM"
  mappings = CattedraDisciplina.where(account: Current.account, tipo_scuola: tipo_scuola)
  cattedra_to_discipline = mappings.pluck(:cattedra, :disciplina).group_by(&:first).transform_values { |pairs| pairs.map(&:last) }

  # Preload adozioni for this school's classi
  classe_ids = scuola.classi.pluck(:id)
  adozioni_by_classe_disciplina = Adozione.where(classe_id: classe_ids)
    .select(:classe_id, :disciplina, :titolo, :editore, :mia, :nuova_adozione)
    .group_by { |a| [a.classe_id, a.disciplina] }

  # Group persone by materia (cattedra), maintaining posizione order
  grouped = persone.group_by { |p| p.persona_classi.first&.materia }.compact_blank
%>

<% if persone.any? %>
  <section class="group">
    <div class="header margin-none padding-none">
      <div class="header__actions header__actions--start">
        <%= link_to "Cattedre", scuola_cattedre_path(scuola), class: "btn txt-small" %>
      </div>
      <h3 class="header__title divider divider--fade divider--card txt-medium font-weight-black margin-none">
        Insegnanti (<%= persone.size %>)
      </h3>
      <div class="header__actions header__actions--end">
        <%= link_to "Importa", new_scuola_persone_import_path(scuola), class: "btn txt-small" %>
      </div>
    </div>

    <% grouped.each do |cattedra, docenti| %>
      <% discipline_miur = cattedra_to_discipline[cattedra] || [] %>

      <h4 class="txt-x-small txt-subtle txt-uppercase margin-block-start"><%= cattedra&.titleize %></h4>

      <% if discipline_miur.any? %>
        <% all_classe_ids = docenti.flat_map { |p| p.classi.map(&:id) }.uniq %>
        <% libri_cattedra = discipline_miur.flat_map { |d| all_classe_ids.flat_map { |cid| adozioni_by_classe_disciplina[[cid, d]] || [] } }.uniq { |a| [a.titolo, a.editore] } %>
        <% if libri_cattedra.any? %>
          <div class="flex gap-quarter flex-wrap margin-block-end-half">
            <% libri_cattedra.each do |adozione| %>
              <%= adozione_libro_tag(adozione) %>
            <% end %>
          </div>
        <% end %>
      <% end %>

      <dl class="dl-grid dl-grid--center txt-small">
        <% docenti.each do |persona| %>
          <dt class="txt-x-small">
            <%= link_to persona.nome_completo, scuola_persona_path(scuola, persona), class: "txt-link" %>
          </dt>
          <dd>
            <div class="flex gap-quarter flex-wrap">
              <%= classi_badge_links(persona.classi.sort_by { |c| [c.sezione, c.anno_corso] }, scuola) %>
            </div>
          </dd>
        <% end %>
      </dl>
    <% end %>
  </section>
<% else %>
  <section class="group">
    <div class="header margin-none padding-none">
      <div class="header__actions header__actions--start"></div>
      <h3 class="header__title divider divider--fade divider--card txt-medium font-weight-black margin-none">
        Insegnanti
      </h3>
      <div class="header__actions header__actions--end">
        <%= link_to "Importa", new_scuola_persone_import_path(scuola), class: "btn txt-small" %>
      </div>
    </div>
    <p class="txt-small txt-subtle margin-none">Nessun insegnante importato.</p>
  </section>
<% end %>
