<%# locals: (scuola:) -%>

<section class="panel shadow">
  <h3 class="divider txt-medium font-weight-black margin-block-end-half">Classi</h3>
  <% if scuola.classi.any? %>
    <%
      classi_grouped = scuola.classi.order(:anno_corso, :sezione).group_by(&:combinazione)
      anni = scuola.classi.pluck(:anno_corso).uniq.sort
      anni_labels = { "1" => "I", "2" => "II", "3" => "III", "4" => "IV", "5" => "V" }
    %>
    <div class="pad-half fill-shade border-radius">
      <table class="txt-xx-small" style="width: 100%; border-collapse: collapse;">
        <thead>
          <tr>
            <th class="txt-left txt-subtle" style="padding: 0.25rem;"></th>
            <% anni.each do |anno| %>
              <th class="txt-center" style="padding: 0.25rem; border-left: 1px solid rgba(0,0,0,0.15);"><%= anni_labels[anno.to_s] || anno %></th>
            <% end %>
          </tr>
        </thead>
        <tbody>
          <% classi_grouped.each do |combinazione, classi_comb| %>
            <% classi_by_anno = classi_comb.group_by(&:anno_corso) %>
            <tr>
              <td class="txt-subtle" style="padding: 0.25rem; border-top: 1px solid rgba(0,0,0,0.15); white-space: nowrap;"><%= combinazione.presence || "—" %></td>
              <% anni.each do |anno| %>
                <td class="txt-center" style="padding: 0.25rem; border-top: 1px solid rgba(0,0,0,0.15); border-left: 1px solid rgba(0,0,0,0.15);">
                  <% (classi_by_anno[anno] || []).each do |classe| %>
                    <%= link_to classe.sezione.presence || "•",
                        scuola_classe_path(scuola, classe),
                        class: "txt-undecorated txt-small font-weight-bold",
                        data: { turbo_frame: :_top },
                        style: "color: var(--color-positive-dark);" %>
                  <% end %>
                </td>
              <% end %>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>

  <div class="flex flex-column gap-half pad">
    <div class="flex justify-space-between align-center">
      <span class="txt-small txt-subtle">Totale</span>
      <strong class="txt-medium"><%= scuola.classi.count %></strong>
    </div>

    <div class="flex justify-space-between align-center pad-half">
      <span class="txt-small txt-subtle">Priorità</span>
      <div class="flex gap-quarter" style="color: var(--color-warning);">
        <% if scuola.priorita.to_i.positive? %>
          <% scuola.priorita.times do %>
            <%= icon_tag "star", size: "small" %>
          <% end %>
        <% else %>
          <span class="txt-small txt-subtle">—</span>
        <% end %>
      </div>
    </div>

    <div class="flex justify-space-between align-center pad-half">
      <span class="txt-small txt-subtle">Stato</span>
      <span class="txt-small"><%= scuola.stato&.capitalize || "Attiva" %></span>
    </div>    
  </div>
</section>

<%
  mie_adozioni = Adozione.joins(:classe)
                         .where(classe_id: scuola.classi.select(:id))
                         .where(mia: true, da_acquistare: true)
                         .order("classi.anno_corso", :titolo)
%>

<% if mie_adozioni.any? %>
  <section class="panel shadow">
    <h3 class="divider txt-medium font-weight-black margin-block-end-half">Mie adozioni</h3>

    <div class="pad-half fill-shade border-radius">
      <table class="txt-xx-small" style="width: 100%; border-collapse: collapse;">
        <thead>
          <tr>
            <th class="txt-left txt-uppercase">Titolo</th>
            <th class="txt-center txt-uppercase">Classe</th>
            <th class="txt-center txt-uppercase">Sez</th>
            <th class="txt-left txt-uppercase">Disciplina</th>
          </tr>
        </thead>
        <tbody>
          <%
            # Raggruppa per titolo e anno, unendo le sezioni
            adozioni_grouped = mie_adozioni.group_by { |a| [a.titolo, a.classe.anno_corso] }
          %>
          <% adozioni_grouped.each do |(titolo, anno), adozioni| %>
            <% disdetta = adozioni.any?(&:disdetta?) %>
            <tr<%= ' class="disdetta"'.html_safe if disdetta %>>
              <td class="txt-x-small"><%= titolo %></td>
              <td class="txt-center txt-small font-weight-bold no-strike"><%= anno %></td>
              <td class="txt-center no-strike" style="white-space: nowrap;" >
                <% adozioni.sort_by { |a| a.classe.sezione.to_s }.each do |adozione| %>
                  <%= link_to adozione.classe.sezione.presence || "•",
                      scuola_classe_path(scuola, adozione.classe),
                      class: "txt-undecorated txt-small font-weight-bold",
                      data: { turbo_frame: :_top },
                      style: "color: var(--color-positive-dark);" %>
                <% end %>
              </td>
              <td class="txt-xx-small txt-subtle" style="padding: 0.25rem; border-top: 1px solid rgba(0,0,0,0.15); border-left: 1px solid rgba(0,0,0,0.15);"><%= adozioni.first.disciplina %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>
<% end %>
