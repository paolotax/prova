<%# locals: (scuola:) -%>

<%= button_tag class: "btn btn--positive", type: :submit, form: dom_id(scuola, :edit_form),
    data: { controller: "hotkey", action: "keydown.s@document->hotkey#click" } do %>
  Salva <kbd class="hide-on-touch">S</kbd>
<% end %>

<%= link_to scuola_path(scuola), class: "btn btn--reversed",
    data: { turbo_method: :get, turbo_stream: true } do %>
  Annulla
<% end %>
