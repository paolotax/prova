<%# locals: (scuola:) -%>

<h1 class="card__title"><%= scuola.denominazione %></h1>
<span class="card__subtitle">
  <%= scuola.codice_ministeriale %> — <%= scuola.tipo_scuola %>
</span>

<% if scuola.import_scuola&.DENOMINAZIONEISTITUTORIFERIMENTO.present? %>
  <div class="txt-small txt-subtle margin-block-start-half">
    <%= scuola.import_scuola.DENOMINAZIONEISTITUTORIFERIMENTO.titleize %>
  </div>
<% end %>

<div class="card__description margin-block-start">
  <dl class="dl-grid txt-small">
    <% if scuola.indirizzo.present? %>
      <dt class="txt-subtle">Indirizzo</dt>
      <dd><%= scuola.indirizzo %></dd>
    <% end %>

    <dt class="txt-subtle">Città</dt>
    <dd><%= [scuola.cap, scuola.comune].compact_blank.join(" ").presence || "—" %> (<%= scuola.provincia %>)</dd>

    <% if scuola.telefono.present? %>
      <dt class="txt-subtle">Telefono</dt>
      <dd><%= link_to scuola.telefono, "tel:#{scuola.telefono}" %></dd>
    <% end %>

    <% if scuola.email.present? %>
      <dt class="txt-subtle">Email</dt>
      <dd><%= mail_to scuola.email %></dd>
    <% end %>

    <% if scuola.pec.present? %>
      <dt class="txt-subtle">PEC</dt>
      <dd><%= mail_to scuola.pec %></dd>
    <% end %>
  </dl>
</div>

<% if scuola.note.present? %>
  <div class="card__description margin-block-start">
    <p class="txt-small margin-none"><%= simple_format(scuola.note) %></p>
  </div>
<% end %>
