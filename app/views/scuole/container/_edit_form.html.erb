<%# locals: (scuola:) -%>

<%= form_with model: scuola, url: scuola_path(scuola),
      id: dom_id(scuola, :edit_form),
      data: { controller: "form",
              action: "keydown.esc->form#cancel:stop" } do |f| %>

  <div class="form-field">
    <%= f.label :denominazione, class: "label txt-small" %>
    <%= f.text_field :denominazione, class: "input", autofocus: true %>
  </div>

  <div class="form-grid">
    <div class="form-field">
      <%= f.label :codice_ministeriale, class: "label txt-small" %>
      <%= f.text_field :codice_ministeriale, class: "input mono txt-uppercase" %>
    </div>

    <div class="form-field">
      <%= f.label :tipo_scuola, class: "label txt-small" %>
      <%= f.select :tipo_scuola,
          options_for_select([
            ["—", ""],
            ["Istituto Comprensivo", "Istituto Comprensivo"],
            ["Scuola Primaria", "Scuola Primaria"],
            ["Scuola Secondaria I grado", "Scuola Secondaria I grado"],
            ["Liceo Scientifico", "Liceo Scientifico"],
            ["Liceo Classico", "Liceo Classico"],
            ["Liceo Linguistico", "Liceo Linguistico"],
            ["Istituto Tecnico", "Istituto Tecnico"],
            ["Istituto Professionale", "Istituto Professionale"],
            ["Altro", "Altro"]
          ], scuola.tipo_scuola),
          {},
          class: "input input--select" %>
    </div>
  </div>

  <div class="form-field">
    <%= f.label :indirizzo, class: "label txt-small" %>
    <%= f.text_field :indirizzo, class: "input" %>
  </div>

  <div class="form-grid form-grid--3">
    <div class="form-field">
      <%= f.label :cap, "CAP", class: "label txt-small" %>
      <%= f.text_field :cap, class: "input mono", maxlength: 5 %>
    </div>

    <div class="form-field" style="grid-column: span 2;">
      <%= f.label :comune, class: "label txt-small" %>
      <%= f.text_field :comune, class: "input" %>
    </div>
  </div>

  <div class="form-grid">
    <div class="form-field">
      <%= f.label :provincia, class: "label txt-small" %>
      <%= f.text_field :provincia, class: "input txt-uppercase", maxlength: 2 %>
    </div>

    <div class="form-field">
      <%= f.label :regione, class: "label txt-small" %>
      <%= f.select :regione,
          options_for_select([
            ["—", ""],
            "Abruzzo", "Basilicata", "Calabria", "Campania", "Emilia-Romagna",
            "Friuli-Venezia Giulia", "Lazio", "Liguria", "Lombardia", "Marche",
            "Molise", "Piemonte", "Puglia", "Sardegna", "Sicilia", "Toscana",
            "Trentino-Alto Adige", "Umbria", "Valle d'Aosta", "Veneto"
          ], scuola.regione),
          {},
          class: "input input--select" %>
    </div>
  </div>

  <div class="form-grid">
    <div class="form-field">
      <%= f.label :telefono, class: "label txt-small" %>
      <%= f.telephone_field :telefono, class: "input" %>
    </div>

    <div class="form-field">
      <%= f.label :email, class: "label txt-small" %>
      <%= f.email_field :email, class: "input" %>
    </div>
  </div>

  <div class="form-field">
    <%= f.label :pec, "PEC", class: "label txt-small" %>
    <%= f.email_field :pec, class: "input" %>
  </div>

  <div class="form-grid">
    <div class="form-field">
      <%= f.label :stato, class: "label txt-small" %>
      <%= f.select :stato,
          options_for_select([
            ["Attiva", "attiva"],
            ["Inattiva", "inattiva"],
            ["In sospeso", "sospesa"]
          ], scuola.stato || "attiva"),
          {},
          class: "input input--select" %>
    </div>

    <div class="form-field">
      <%= f.label :priorita, "Priorità", class: "label txt-small" %>
      <%= f.select :priorita,
          options_for_select((0..5).map { |n| [n == 0 ? "Nessuna" : "#{'★' * n} (#{n})", n] }, scuola.priorita || 0),
          {},
          class: "input input--select" %>
    </div>
  </div>

  <div class="form-field">
    <%= f.label :note, class: "label txt-small" %>
    <%= f.text_area :note, rows: 3, class: "input" %>
  </div>
<% end %>
