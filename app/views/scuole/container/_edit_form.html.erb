<%# locals: (scuola:) -%>

<%= form_with model: scuola, url: scuola_path(scuola),
      id: dom_id(scuola, :edit_form),
      data: { controller: "form",
              action: "keydown.esc->form#cancel:stop" } do |f| %>

  <div class="form-row">
    <div class="form-field" style="--w: 15ch;">
      <%= f.label :codice_ministeriale, "Codice", class: "label txt-small" %>
      <%= f.text_field :codice_ministeriale, class: "input mono txt-uppercase", autofocus: true %>
    </div>

    <div class="form-field">
      <%= f.label :tipo_scuola, class: "label txt-small" %>
      <%= f.select :tipo_scuola,
          options_for_select(
            [["—", ""]] + tipi_scuola_options,
            scuola.tipo_scuola
          ),
          {},
          class: "input input--select" %>
    </div>
  </div>

  <div class="form-field">
    <%= f.label :denominazione, class: "label txt-small" %>
    <%= f.text_field :denominazione, class: "input" %>
  </div>

  <div class="form-field">
    <%= f.label :indirizzo, class: "label txt-small" %>
    <%= f.text_field :indirizzo, class: "input" %>
  </div>

  <div data-controller="provincia-comune" data-provincia-comune-zone-value="<%= zone_data_for_selects.to_json %>">
    <div class="form-row">
      <div class="form-field" style="--w: 15ch;">
        <%= f.label :cap, "CAP", class: "label txt-small" %>
        <%= f.text_field :cap, class: "input mono", maxlength: 5 %>
      </div>

      <div class="form-field">
        <%= f.label :comune, class: "label txt-small" %>
        <%= f.select :comune,
            options_for_select(
              [["—", ""]] + Zona.where(provincia: scuola.provincia).order(:comune).distinct.pluck(:comune).map { |c| [c, c] },
              scuola.comune
            ),
            {},
            class: "input input--select",
            data: { provincia_comune_target: "comune" } %>
      </div>

      <div class="form-field" style="--w: 15ch;">
        <%= f.label :provincia, "Prov.", class: "label txt-small" %>
        <%= f.select :provincia,
            options_for_select(
              [["—", ""]] + province_options,
              scuola.provincia
            ),
            {},
            class: "input input--select",
            data: { provincia_comune_target: "provincia",
                    action: "change->provincia-comune#provinciaChanged" } %>
        <%= f.hidden_field :sigla_provincia, data: { provincia_comune_target: "sigla" } %>
      </div>
    </div>

    <% if account_multi_regione? %>
      <div class="form-field">
        <%= f.label :regione, class: "label txt-small" %>
        <%= f.select :regione,
            options_for_select(
              [["—", ""]] + regioni_options,
              scuola.regione
            ),
            {},
            class: "input input--select" %>
      </div>
    <% end %>
  </div>

  <div class="form-row">
    <div class="form-field">
      <%= f.label :telefono, class: "label txt-small" %>
      <%= f.telephone_field :telefono, class: "input" %>
    </div>

    <div class="form-field">
      <%= f.label :email, class: "label txt-small" %>
      <%= f.email_field :email, class: "input" %>
    </div>
  </div>

  <div class="form-field">
    <%= f.label :pec, "PEC", class: "label txt-small" %>
    <%= f.email_field :pec, class: "input" %>
  </div>

  <div data-controller="email-pattern">
    <div class="form-row">
      <div class="form-field">
        <%= f.label :email_pattern, "Formato email", class: "label txt-small" %>
        <%= f.select :email_pattern,
            options_for_select(
              [["—", ""]] +
              Scuola::EMAIL_PATTERNS.keys.map { |p| [p, p] } +
              [["Altro...", "custom"]],
              scuola.email_pattern.presence&.then { |p| Scuola::EMAIL_PATTERNS.key?(p) ? p : "custom" }
            ),
            {},
            class: "input input--select",
            data: { email_pattern_target: "select", action: "email-pattern#update" } %>
      </div>

      <div class="form-field">
        <%= f.label :email_dominio, "Dominio", class: "label txt-small" %>
        <%= f.text_field :email_dominio, class: "input",
            placeholder: "es. ickennedy.istruzione.it",
            data: { email_pattern_target: "dominio", action: "input->email-pattern#update" } %>
      </div>
    </div>

    <div class="form-field" data-email-pattern-target="customField" style="<%= 'display:none' unless scuola.email_pattern.present? && !Scuola::EMAIL_PATTERNS.key?(scuola.email_pattern) %>">
      <label class="label txt-small">Pattern personalizzato</label>
      <input type="text" class="input"
             placeholder="es. cognome.n"
             value="<%= scuola.email_pattern unless Scuola::EMAIL_PATTERNS.key?(scuola.email_pattern) %>"
             data-email-pattern-target="customInput"
             data-action="input->email-pattern#update"
             <%= 'name="scuola[email_pattern]"'.html_safe if scuola.email_pattern.present? && !Scuola::EMAIL_PATTERNS.key?(scuola.email_pattern) %>>
    </div>

    <p class="txt-small txt-muted" data-email-pattern-target="preview"></p>
  </div>

  <div class="form-row">
    <div class="form-field">
      <%= f.label :stato, class: "label txt-small" %>
      <%= f.select :stato,
          options_for_select([
            ["Attiva", "attiva"],
            ["Inattiva", "inattiva"],
            ["In sospeso", "sospesa"]
          ], scuola.stato || "attiva"),
          {},
          class: "input input--select" %>
    </div>

    <div class="form-field">
      <%= f.label :priorita, "Priorità", class: "label txt-small" %>
      <%= f.select :priorita,
          options_for_select((0..5).map { |n| [n == 0 ? "Nessuna" : "#{'★' * n} (#{n})", n] }, scuola.priorita || 0),
          {},
          class: "input input--select" %>
    </div>
  </div>

  <div class="form-field">
    <%= f.label :area, class: "label txt-small" %>
    <%= f.text_field :area, class: "input",
        list: dom_id(scuola, :aree_list),
        autocomplete: "off" %>
    <datalist id="<%= dom_id(scuola, :aree_list) %>">
      <% Current.account.scuole.where(provincia: scuola.provincia).where.not(area: [nil, ""]).distinct.pluck(:area).sort.each do |a| %>
        <option value="<%= a %>">
      <% end %>
    </datalist>
  </div>

  <div class="form-field">
    <%= f.label :note, class: "label txt-small" %>
    <%= f.text_area :note, rows: 3, class: "input" %>
  </div>
<% end %>
