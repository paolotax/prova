<% content_for :title, @scuola.denominazione %>

<% content_for :header do %>
  <%= render Heading::WithActionsComponent.new do |heading| %>
    <% heading.with_action do %>
      <%= link_to edit_scuola_path(@scuola),
          class: "inline-flex items-center gap-2 px-4 py-2 bg-white border border-gray-200 text-gray-700 text-sm font-medium rounded-lg hover:bg-gray-50 transition-colors" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
        </svg>
        Modifica
      <% end %>
    <% end %>

    <% heading.with_action do %>
      <%= button_to scuola_path(@scuola),
          method: :delete,
          class: "inline-flex items-center gap-2 px-4 py-2 bg-white border border-red-200 text-red-600 text-sm font-medium rounded-lg hover:bg-red-50 transition-colors",
          data: { turbo_confirm: "Sei sicuro di voler eliminare questa scuola?" } do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
        </svg>
        Elimina
      <% end %>
    <% end %>

    <h1 class="text-2xl font-bold tracking-tight text-gray-900"><%= @scuola.denominazione %></h1>
  <% end %>
<% end %>

<div class="space-y-8">

  <%# Breadcrumb %>
  <nav class="flex items-center gap-2 text-sm text-gray-500">
    <%= link_to scuole_path, class: "hover:text-emerald-600 transition-colors" do %>
      Scuole
    <% end %>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
    </svg>
    <span class="text-gray-900 font-medium truncate"><%= @scuola.denominazione %></span>
  </nav>

  <%# Main content grid %>
  <div class="grid lg:grid-cols-3 gap-8">

    <%# Left column - Main info %>
    <div class="lg:col-span-2 space-y-6">

      <%# School header card %>
      <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
        <%# Gradient header %>
        <div class="h-24 bg-gradient-to-r from-emerald-500 via-teal-500 to-cyan-500 relative">
          <div class="absolute inset-0 bg-black/10"></div>
          <div class="absolute -bottom-8 left-6">
            <div class="w-16 h-16 rounded-xl bg-white shadow-lg flex items-center justify-center border-4 border-white">
              <svg class="w-8 h-8 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
              </svg>
            </div>
          </div>
        </div>

        <%# School details %>
        <div class="pt-12 pb-6 px-6">
          <div class="flex flex-wrap items-center gap-3 mb-4">
            <% if @scuola.tipo_scuola.present? %>
              <span class="px-3 py-1 bg-emerald-100 text-emerald-700 rounded-full text-sm font-medium">
                <%= @scuola.tipo_scuola %>
              </span>
            <% end %>
            <% if @scuola.stato.present? %>
              <span class="px-3 py-1 <%= @scuola.stato == 'attiva' ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-600' %> rounded-full text-sm font-medium">
                <%= @scuola.stato.capitalize %>
              </span>
            <% end %>
            <% if @scuola.codice_ministeriale.present? %>
              <span class="px-3 py-1 bg-gray-100 text-gray-600 rounded-full text-sm font-mono">
                <%= @scuola.codice_ministeriale %>
              </span>
            <% end %>
          </div>

          <dl class="grid sm:grid-cols-2 gap-x-8 gap-y-4">
            <% if @scuola.indirizzo.present? %>
              <div>
                <dt class="text-sm font-medium text-gray-500">Indirizzo</dt>
                <dd class="mt-1 text-gray-900"><%= @scuola.indirizzo %></dd>
              </div>
            <% end %>

            <% if @scuola.comune.present? || @scuola.provincia.present? %>
              <div>
                <dt class="text-sm font-medium text-gray-500">Localita</dt>
                <dd class="mt-1 text-gray-900">
                  <%= [@scuola.cap, @scuola.comune, @scuola.provincia].compact.join(" ") %>
                </dd>
              </div>
            <% end %>

            <% if @scuola.regione.present? %>
              <div>
                <dt class="text-sm font-medium text-gray-500">Regione</dt>
                <dd class="mt-1 text-gray-900"><%= @scuola.regione %></dd>
              </div>
            <% end %>

            <% if @scuola.email.present? %>
              <div>
                <dt class="text-sm font-medium text-gray-500">Email</dt>
                <dd class="mt-1">
                  <%= mail_to @scuola.email, @scuola.email, class: "text-emerald-600 hover:text-emerald-700 transition-colors" %>
                </dd>
              </div>
            <% end %>

            <% if @scuola.pec.present? %>
              <div>
                <dt class="text-sm font-medium text-gray-500">PEC</dt>
                <dd class="mt-1">
                  <%= mail_to @scuola.pec, @scuola.pec, class: "text-emerald-600 hover:text-emerald-700 transition-colors" %>
                </dd>
              </div>
            <% end %>

            <% if @scuola.telefono.present? %>
              <div>
                <dt class="text-sm font-medium text-gray-500">Telefono</dt>
                <dd class="mt-1 text-gray-900"><%= @scuola.telefono %></dd>
              </div>
            <% end %>
          </dl>

          <% if @scuola.note.present? %>
            <div class="mt-6 pt-6 border-t border-gray-100">
              <h3 class="text-sm font-medium text-gray-500 mb-2">Note</h3>
              <p class="text-gray-700"><%= simple_format(@scuola.note) %></p>
            </div>
          <% end %>
        </div>
      </div>

      <%# Classes section %>
      <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
        <div class="flex items-center justify-between mb-6">
          <div class="flex items-center gap-3">
            <h2 class="text-lg font-semibold text-gray-900">Classi</h2>
            <span class="px-3 py-1 bg-gray-100 rounded-full text-sm font-medium text-gray-600">
              <%= @classi.count %>
            </span>
          </div>

          <% if @scuola.codice_ministeriale.present? %>
            <%= button_to scuola_classi_path(@scuola),
                method: :post,
                class: "inline-flex items-center gap-2 px-3 py-1.5 bg-emerald-600 text-white text-sm font-medium rounded-lg hover:bg-emerald-700 transition-colors" do %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/>
              </svg>
              Importa Classi
            <% end %>
          <% end %>
        </div>

        <% if @classi.any? %>
          <div class="space-y-2">
            <% @classi.each do |classe| %>
              <%= render "scuole/classi/classe_card", classe: classe, scuola: @scuola %>
            <% end %>
          </div>
        <% else %>
          <div class="text-center py-8">
            <svg class="mx-auto h-12 w-12 text-gray-300 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z"/>
            </svg>
            <h3 class="text-lg font-medium text-gray-900">Nessuna classe registrata</h3>
            <p class="mt-1 text-sm text-gray-500">Importa le classi dal database ministeriale.</p>
            <% if @scuola.codice_ministeriale.present? %>
              <%= button_to scuola_classi_path(@scuola),
                  method: :post,
                  class: "mt-4 inline-flex items-center gap-2 px-4 py-2 bg-emerald-600 text-white text-sm font-medium rounded-lg hover:bg-emerald-700 transition-colors" do %>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/>
                </svg>
                Importa Classi
              <% end %>
            <% else %>
              <p class="mt-2 text-xs text-amber-600">Inserisci il codice ministeriale per importare le classi.</p>
            <% end %>
          </div>
        <% end %>
      </div>

    </div>

    <%# Right column - Sidebar %>
    <div class="space-y-6">

      <%# Priority card %>
      <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
        <h3 class="text-sm font-semibold text-gray-900 mb-4">Priorita</h3>
        <div class="flex items-center gap-1">
          <% 5.times do |i| %>
            <svg class="w-6 h-6 <%= i < (@scuola.priorita || 0) ? 'text-amber-400' : 'text-gray-200' %>" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
          <% end %>
        </div>
      </div>

      <%# Recent notes %>
      <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-sm font-semibold text-gray-900">Appunti Recenti</h3>
          <% if @appunti.any? %>
            <span class="text-xs text-gray-500"><%= @appunti.count %></span>
          <% end %>
        </div>

        <% if @appunti.any? %>
          <div class="space-y-3">
            <% @appunti.limit(5).each do |appunto| %>
              <%= link_to appunto_path(appunto), class: "block p-3 -mx-2 rounded-lg hover:bg-gray-50 transition-colors" do %>
                <p class="text-sm text-gray-900 line-clamp-2"><%= truncate(appunto.corpo, length: 80) %></p>
                <p class="mt-1 text-xs text-gray-400"><%= time_ago_in_words(appunto.created_at) %> fa</p>
              <% end %>
            <% end %>
          </div>
        <% else %>
          <p class="text-sm text-gray-500 text-center py-4">Nessun appunto</p>
        <% end %>
      </div>

      <%# Quick actions %>
      <div class="bg-gradient-to-br from-gray-50 to-gray-100 rounded-2xl p-6">
        <h3 class="text-sm font-semibold text-gray-900 mb-4">Azioni Rapide</h3>
        <div class="space-y-2">
          <%= link_to new_appunto_path(appuntabile_type: "Scuola", appuntabile_id: @scuola.id),
              class: "flex items-center gap-3 p-3 bg-white rounded-xl hover:shadow-sm transition-all" do %>
            <div class="w-8 h-8 rounded-lg bg-blue-100 flex items-center justify-center">
              <svg class="w-4 h-4 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
              </svg>
            </div>
            <span class="text-sm font-medium text-gray-700">Nuovo Appunto</span>
          <% end %>

          <%= link_to edit_scuola_path(@scuola),
              class: "flex items-center gap-3 p-3 bg-white rounded-xl hover:shadow-sm transition-all" do %>
            <div class="w-8 h-8 rounded-lg bg-amber-100 flex items-center justify-center">
              <svg class="w-4 h-4 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
            </div>
            <span class="text-sm font-medium text-gray-700">Modifica Scuola</span>
          <% end %>
        </div>
      </div>

    </div>
  </div>

</div>
