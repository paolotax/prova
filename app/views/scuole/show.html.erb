<% @page_title = @scuola.denominazione %>
<% @body_class = "contained-scrolling" %>

<% content_for :header do %>
  <div class="header__actions header__actions--start">
    <%= back_link_to "Scuole", scuole_path, "keydown.left@document->hotkey#click keydown.esc@document->hotkey#click" %>
  </div>

  <h1 class="header__title divider divider--fade full-width">
    <span class="overflow-ellipsis"><%= @scuola.denominazione %></span>
  </h1>

  <div class="header__actions header__actions--end">
    <%= link_to edit_scuola_path(@scuola), class: "btn" do %>
      <%= icon_tag "pencil" %>
      <span class="for-screen-reader">Modifica scuola</span>
    <% end %>
  </div>
<% end %>

<!-- Main content grid -->
<div class="flex gap" style="flex-wrap: wrap;">

  <!-- Left column - Main info -->
  <div class="flex-item-grow" style="min-width: 0; flex-basis: 600px;">

    <!-- School details card -->
    <section class="panel shadow margin-block-end">
      <div class="pad">
        <dl class="dl-grid">
          <% if @scuola.indirizzo.present? %>
            <div>
              <dt class="txt-small txt-subtle">Indirizzo</dt>
              <dd class="font-weight-bold"><%= @scuola.indirizzo %></dd>
            </div>
          <% end %>

          <% if @scuola.comune.present? || @scuola.provincia.present? %>
            <div>
              <dt class="txt-small txt-subtle">Localita</dt>
              <dd class="font-weight-bold">
                <%= [@scuola.cap, @scuola.comune, @scuola.provincia].compact.join(" ") %>
              </dd>
            </div>
          <% end %>

          <% if @scuola.regione.present? %>
            <div>
              <dt class="txt-small txt-subtle">Regione</dt>
              <dd class="font-weight-bold"><%= @scuola.regione %></dd>
            </div>
          <% end %>

          <% if @scuola.email.present? %>
            <div>
              <dt class="txt-small txt-subtle">Email</dt>
              <dd><%= mail_to @scuola.email, @scuola.email, class: "txt-link" %></dd>
            </div>
          <% end %>

          <% if @scuola.pec.present? %>
            <div>
              <dt class="txt-small txt-subtle">PEC</dt>
              <dd><%= mail_to @scuola.pec, @scuola.pec, class: "txt-link" %></dd>
            </div>
          <% end %>

          <% if @scuola.telefono.present? %>
            <div>
              <dt class="txt-small txt-subtle">Telefono</dt>
              <dd class="font-weight-bold"><%= @scuola.telefono %></dd>
            </div>
          <% end %>
        </dl>

        <% if @scuola.note.present? %>
          <div class="margin-block-start pad-block-start" style="border-top: 1px solid var(--color-ink-lighter);">
            <h3 class="txt-small txt-subtle margin-block-end-quarter">Note</h3>
            <div class="txt-small"><%= simple_format(@scuola.note) %></div>
          </div>
        <% end %>
      </div>
    </section>

    <!-- Classes section -->
    <section class="panel shadow">
      <div class="pad">
        <div class="flex align-center justify-space-between margin-block-end">
          <div class="flex align-center gap-half">
            <h2 class="txt-medium font-weight-bold">Classi</h2>
            <span class="badge txt-xx-small"><%= @classi.count %></span>
          </div>

          <% if @scuola.codice_ministeriale.present? %>
            <%= button_to scuola_classi_path(@scuola),
                method: :post,
                class: "btn btn--primary txt-small" do %>
              <%= icon_tag "download", size: "small" %>
              Importa Classi
            <% end %>
          <% end %>
        </div>

        <% if @classi.any? %>
          <div class="flex flex-column gap-half">
            <% @classi.each do |classe| %>
              <%= render "scuole/classi/classe_card", classe: classe, scuola: @scuola %>
            <% end %>
          </div>
        <% else %>
          <div class="txt-center pad">
            <%= icon_tag "users", size: "large", class: "txt-subtle margin-block-end-half" %>
            <h3 class="txt-medium font-weight-bold">Nessuna classe registrata</h3>
            <p class="txt-small txt-subtle margin-block-end">Importa le classi dal database ministeriale.</p>
            <% if @scuola.codice_ministeriale.present? %>
              <%= button_to scuola_classi_path(@scuola),
                  method: :post,
                  class: "btn btn--primary" do %>
                <%= icon_tag "download", size: "small" %>
                Importa Classi
              <% end %>
            <% else %>
              <p class="txt-xx-small" style="color: var(--color-warning);">Inserisci il codice ministeriale per importare le classi.</p>
            <% end %>
          </div>
        <% end %>
      </div>
    </section>

  </div>

  <!-- Right column - Sidebar -->
  <div style="flex-basis: 280px; flex-shrink: 0;">

    <!-- Priority card -->
    <div class="panel shadow pad margin-block-end">
      <h3 class="txt-small font-weight-bold margin-block-end-half">Priorità</h3>
      <div class="flex gap-quarter" style="color: var(--color-warning);">
        <% 5.times do |i| %>
          <%= icon_tag "star", size: "medium", style: i < (@scuola.priorita || 0) ? "" : "opacity: 0.2;" %>
        <% end %>
      </div>
    </div>

    <!-- Recent notes -->
    <div class="panel shadow pad margin-block-end">
      <div class="flex align-center justify-space-between margin-block-end-half">
        <h3 class="txt-small font-weight-bold">Appunti Recenti</h3>
        <% if @appunti.where.missing(:closure).any? %>
          <span class="txt-xx-small txt-subtle"><%= @appunti.where.missing(:closure).count %></span>
        <% end %>
      </div>

      <% if @appunti.any? %>
        <div class="flex flex-column gap-half">
          <% @appunti.where.missing(:closure).limit(5).each do |appunto| %>
            <%= link_to appunto_path(appunto), class: "panel pad-half border-radius fill-shade", style: "text-decoration: none;" do %>
              <p class="txt-small overflow-ellipsis" style="color: var(--color-ink);"><%= appunto.content %></p>
              <p class="txt-xx-small txt-subtle margin-block-start-quarter"><%= time_ago_in_words(appunto.created_at) %> fa</p>
            <% end %>
          <% end %>
        </div>
      <% else %>
        <p class="txt-small txt-subtle txt-center pad">Nessun appunto</p>
      <% end %>
    </div>

    <!-- Quick actions -->
    <div class="panel pad fill-shade">
      <h3 class="txt-small font-weight-bold margin-block-end-half">Azioni Rapide</h3>
      <div class="flex flex-column gap-half">
        <%= link_to new_appunto_path(appuntabile_type: "Scuola", appuntabile_id: @scuola.id),
            class: "panel pad-half flex align-center gap-half", style: "text-decoration: none;" do %>
          <div class="flex align-center justify-center border-radius" style="width: 2rem; height: 2rem; background: var(--color-link-lighter);">
            <%= icon_tag "pencil", size: "small", style: "color: var(--color-link);" %>
          </div>
          <span class="txt-small font-weight-bold" style="color: var(--color-ink);">Nuovo Appunto</span>
        <% end %>

        <%= link_to edit_scuola_path(@scuola),
            class: "panel pad-half flex align-center gap-half", style: "text-decoration: none;" do %>
          <div class="flex align-center justify-center border-radius" style="width: 2rem; height: 2rem; background: var(--color-warning-lighter);">
            <%= icon_tag "cog", size: "small", style: "color: var(--color-warning);" %>
          </div>
          <span class="txt-small font-weight-bold" style="color: var(--color-ink);">Modifica Scuola</span>
        <% end %>
      </div>
    </div>

  </div>
</div>
