<%# Scuola card partial %>
<%= tag.article id: dom_id(scuola),
    class: "group relative bg-white rounded-xl border border-gray-100 shadow-sm hover:shadow-md hover:border-emerald-200 transition-all duration-200" do %>

  <%= link_to scuola_path(scuola), class: "block p-5", data: { turbo_frame: "_top" } do %>
    <div class="flex items-start gap-4">

      <%# School icon %>
      <div class="shrink-0 w-12 h-12 rounded-xl bg-gradient-to-br from-emerald-100 to-teal-50 flex items-center justify-center group-hover:from-emerald-200 group-hover:to-teal-100 transition-colors">
        <svg class="w-6 h-6 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
        </svg>
      </div>

      <%# School info %>
      <div class="flex-1 min-w-0">
        <h2 class="text-base font-semibold text-gray-900 truncate group-hover:text-emerald-700 transition-colors">
          <%= scuola.denominazione %>
        </h2>

        <div class="mt-1.5 flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-gray-500">
          <% if scuola.comune.present? %>
            <span class="inline-flex items-center gap-1">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              <%= scuola.comune %>
            </span>
          <% end %>

          <% if scuola.provincia.present? %>
            <span class="text-gray-400">(<%= scuola.provincia %>)</span>
          <% end %>

          <% if scuola.tipo_scuola.present? %>
            <span class="px-2 py-0.5 bg-gray-100 rounded text-xs font-medium text-gray-600">
              <%= scuola.tipo_scuola %>
            </span>
          <% end %>
        </div>

        <% if scuola.codice_ministeriale.present? %>
          <p class="mt-2 text-xs text-gray-400 font-mono">
            <%= scuola.codice_ministeriale %>
          </p>
        <% end %>
      </div>

      <%# Right side stats %>
      <div class="shrink-0 text-right">
        <% if scuola.classi.any? %>
          <span class="inline-flex items-center gap-1 text-sm text-gray-500">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z"/>
            </svg>
            <%= scuola.classi.count %> classi
          </span>
        <% end %>

        <% if scuola.priorita && scuola.priorita > 0 %>
          <div class="mt-1">
            <% scuola.priorita.times do %>
              <svg class="inline w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            <% end %>
          </div>
        <% end %>
      </div>

    </div>
  <% end %>

  <%# Hover arrow indicator %>
  <div class="absolute right-4 top-1/2 -translate-y-1/2 opacity-0 group-hover:opacity-100 transition-opacity">
    <svg class="w-5 h-5 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
    </svg>
  </div>

<% end %>
