<%# locals: (scuola:) -%>

<%= tag.article id: dom_id(scuola),
    class: "card",
    style: "--card-color: #{scuola_color(scuola)}",
    tabindex: 0,
    data: { navigable_list_target: "item", action: "mouseenter->navigable-list#hoverSelect contextmenu->navigable-list#toggleSelection" } do %>
  <label class="card__checkbox">
    <%= check_box_tag "ids[]", scuola.id, false, data: { action: "change->bulk-actions#count" } %>
  </label>

  <div class="flex flex-column flex-item-grow max-inline-size">
    <%= link_to scuola_path(scuola), class: "card__link", data: { turbo_frame: "_top" } do %>
      <span class="for-screen-reader"><%= scuola.denominazione %></span>
    <% end %>

    <!-- Header con tipo scuola -->
    <header class="card__header">
      <div class="card__board">
        <span class="card__id"><%= scuola.tipo_scuola&.upcase.presence || "SCUOLA" %></span>
        <span class="card__board-name"><%= [scuola.comune, scuola.provincia].compact_blank.join(", ") %></span>
      </div>
    </header>

    <!-- Body con denominazione -->
    <div class="card__body">
      <div class="card__content">
        <h3 class="card__title overflow-line-clamp" style="--lines: 2;">
          <%= scuola.denominazione %>
        </h3>
        <div class="card__stages txt-small txt-subtle flex flex-column gap-quarter">
          <% if scuola.indirizzo.present? %>
            <span><%= icon_tag "marker", class: "icon--small" %> <%= scuola.indirizzo %></span>
          <% end %>
          <% if scuola.telefono.present? %>
            <span><%= icon_tag "phone", class: "icon--small" %> <%= scuola.telefono %></span>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Footer con stats -->
    <footer class="card__footer full-width">
      <%= render "scuole/display/perma/meta", scuola: scuola %>
    </footer>
  </div>

  <div class="card__actions">
    <%= link_to mappe_path("scuola-#{scuola.id}"),
        class: "btn btn--small btn--circle",
        data: { controller: "tooltip", tooltip_content_value: "Posizione", turbo_frame: "_top" } do %>
      <%= icon_tag "marker" %>
    <% end %>
    <%= link_to go_to_tappable_path(scuola, current_user.effective_navigator),
        target: "_blank",
        class: "btn btn--small btn--circle",
        data: { controller: "tooltip", tooltip_content_value: "Naviga" } do %>
      <%= icon_tag "globe" %>
    <% end %>
  </div>
<% end %>
