<%= link_to scuola_classe_path(scuola, classe),
    class: "panel pad-half fill-shade border-radius flex align-center justify-space-between",
    style: "text-decoration: none;" do %>
  <div class="flex align-center gap-half">
    <div class="flex align-center justify-center border-radius txt-medium font-weight-black" style="width: 2.5rem; height: 2.5rem; background: white; color: var(--color-positive-dark);">
      <%= classe.nome_breve %>
    </div>
    <div>
      <p class="txt-small font-weight-bold" style="color: var(--color-ink);">Classe <%= classe.nome_breve %></p>
      <% if classe.combinazione.present? %>
        <p class="txt-xx-small txt-subtle"><%= classe.combinazione %></p>
      <% end %>
    </div>
  </div>

  <div class="flex align-center gap-half">
    <% adozioni_correnti = classe.adozioni.correnti %>
    <% if adozioni_correnti.any? %>
      <span class="badge badge--positive txt-xx-small">
        <%= adozioni_correnti.count %> adozioni
      </span>
    <% end %>

    <% da_acquistare_count = adozioni_correnti.da_acquistare_flag.count %>
    <% if da_acquistare_count > 0 %>
      <span class="badge txt-xx-small" style="background: var(--color-warning-lighter); color: var(--color-warning-dark);">
        <%= da_acquistare_count %> da acquistare
      </span>
    <% end %>

    <%= icon_tag "chevron-right", size: "small", class: "txt-subtle" %>
  </div>
<% end %>
