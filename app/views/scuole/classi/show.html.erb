<% @page_title = "Classe #{@classe.nome_breve} — #{@scuola.denominazione}" %>
<% @header_class = "header--card" %>
<% content_for :head, tag.meta(name: "turbo-cache-control", content: "no-cache") %>

<% content_for :header do %>
  <div class="header__actions header__actions--start">
    <%= back_link_to_url @scuola.denominazione.capitalize, scuola_path(@scuola) %>
  </div>
<% end %>

<div class="full-width pad group"
     data-controller="swipe"
     <%= "data-swipe-left-value=#{scuola_classe_path(@scuola, @prev_classe_id)}" if @prev_classe_id %>
     <%= "data-swipe-right-value=#{scuola_classe_path(@scuola, @next_classe_id)}" if @next_classe_id %>>
  <%= render "scuole/classi/container", classe: @classe, scuola: @scuola, adozioni: @adozioni,
      prev_classe_id: @prev_classe_id, next_classe_id: @next_classe_id %>
</div>
