<% content_for :title, "Classe #{@classe.nome_breve} - #{@scuola.denominazione}" %>

<div class="sticky top-header z-10">
  <%= render Heading::WithActionsComponent.new do |heading| %>

    <% heading.with_action do %>
      <%= button_to import_adozioni_scuola_classe_path(@scuola, @classe),
          method: :post,
          class: "btn btn--primary" do %>
        <%= icon_tag "download", size: "small" %>
        Importa Adozioni
      <% end %>
    <% end %>

    <% heading.with_action do %>
      <%= component 'tax_button',
        caption: "Indietro",
        svg_file: "icon-arrow-long-left.svg",
        color: "white",
        url: scuola_path(@scuola) %>
    <% end %>

    <%= h1 {"Classe #{@classe.nome_breve}"} %>

  <% end %>
</div>

<!-- Breadcrumb -->
<nav class="flex align-center gap-half txt-small txt-subtle margin-block-end">
  <%= link_to scuole_path, class: "txt-link" do %>
    Scuole
  <% end %>
  <%= icon_tag "chevron-right", size: "small" %>
  <%= link_to @scuola.denominazione, scuola_path(@scuola), class: "txt-link overflow-ellipsis" %>
  <%= icon_tag "chevron-right", size: "small" %>
  <span class="font-weight-bold">Classe <%= @classe.nome_breve %></span>
</nav>

<!-- Info classe -->
<section class="panel shadow pad margin-block-end">
  <div class="flex align-center gap margin-block-end">
    <div class="flex align-center justify-center border-radius txt-x-large font-weight-black" style="width: 4rem; height: 4rem; background: var(--color-positive-lighter); color: var(--color-positive-dark);">
      <%= @classe.nome_breve %>
    </div>
    <div>
      <h2 class="txt-medium font-weight-bold"><%= @scuola.denominazione %></h2>
      <% if @classe.combinazione.present? %>
        <p class="txt-small txt-subtle"><%= @classe.combinazione %></p>
      <% end %>
      <% if @classe.tipo_scuola.present? %>
        <p class="txt-xx-small txt-subtle"><%= @classe.tipo_scuola %></p>
      <% end %>
    </div>
  </div>

  <div class="flex gap-half flex-wrap">
    <span class="badge txt-xx-small"><%= @adozioni.count %> adozioni</span>
    <% if @adozioni.da_acquistare_flag.any? %>
      <span class="badge txt-xx-small" style="background: var(--color-warning-lighter); color: var(--color-warning-dark);">
        <%= @adozioni.da_acquistare_flag.count %> da acquistare
      </span>
    <% end %>
    <% if @adozioni.nuove.any? %>
      <span class="badge txt-xx-small" style="background: var(--color-link-lighter); color: var(--color-link);">
        <%= @adozioni.nuove.count %> nuove
      </span>
    <% end %>
  </div>
</section>

<!-- Tabella adozioni -->
<section class="panel shadow">
  <div class="pad" style="border-bottom: 1px solid var(--color-ink-lighter);">
    <h3 class="txt-medium font-weight-bold">Adozioni</h3>
  </div>

  <% if @adozioni.any? %>
    <div style="overflow-x: auto;">
      <table class="table full-width">
        <thead>
          <tr>
            <th class="txt-left">Titolo</th>
            <th class="txt-left">Editore</th>
            <th class="txt-left">Disciplina</th>
            <th class="txt-right">Prezzo</th>
            <th class="txt-center">Flags</th>
          </tr>
        </thead>
        <tbody>
          <% @adozioni.each do |adozione| %>
            <tr>
              <td>
                <div class="txt-small font-weight-bold overflow-ellipsis" style="max-width: 300px;" title="<%= adozione.titolo %>">
                  <%= adozione.titolo %>
                </div>
                <div class="txt-xx-small txt-subtle mono"><%= adozione.codice_isbn %></div>
              </td>
              <td class="txt-small"><%= adozione.editore %></td>
              <td class="txt-small"><%= adozione.disciplina %></td>
              <td class="txt-small txt-right font-weight-bold">
                <%= number_to_currency(adozione.prezzo, unit: "\u20AC", format: "%n %u") %>
              </td>
              <td class="txt-center">
                <div class="flex align-center justify-center gap-quarter">
                  <% if adozione.nuova_adozione %>
                    <span class="badge txt-xx-small" style="background: var(--color-link-lighter); color: var(--color-link);" title="Nuova adozione">N</span>
                  <% end %>
                  <% if adozione.da_acquistare %>
                    <span class="badge txt-xx-small" style="background: var(--color-warning-lighter); color: var(--color-warning-dark);" title="Da acquistare">A</span>
                  <% end %>
                  <% if adozione.consigliato %>
                    <span class="badge txt-xx-small" style="background: var(--color-notice-lighter); color: var(--color-notice-dark);" title="Consigliato">C</span>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
        <tfoot>
          <tr>
            <td colspan="3" class="txt-small font-weight-bold">Totale</td>
            <td class="txt-small txt-right font-weight-black">
              <%= number_to_currency(@adozioni.sum(:prezzo_cents) / 100.0, unit: "\u20AC", format: "%n %u") %>
            </td>
            <td></td>
          </tr>
        </tfoot>
      </table>
    </div>
  <% else %>
    <div class="pad txt-center">
      <%= icon_tag "book-open", size: "large", class: "txt-subtle margin-block-end-half" %>
      <h3 class="txt-medium font-weight-bold">Nessuna adozione</h3>
      <p class="txt-small txt-subtle margin-block-end">Questa classe non ha ancora adozioni registrate.</p>
      <%= button_to "Importa Adozioni",
          import_adozioni_scuola_classe_path(@scuola, @classe),
          method: :post,
          class: "btn btn--primary" %>
    </div>
  <% end %>
</section>
