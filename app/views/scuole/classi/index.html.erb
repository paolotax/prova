<% content_for :title, "Classi - #{@scuola.denominazione}" %>

<% content_for :header do %>
  <%= render Heading::WithActionsComponent.new do |heading| %>
    <% if @scuola.codice_ministeriale.present? %>
      <% heading.with_action do %>
        <%= button_to scuola_classi_path(@scuola),
            method: :post,
            class: "inline-flex items-center gap-2 px-4 py-2 bg-emerald-600 text-white text-sm font-medium rounded-lg hover:bg-emerald-700 transition-colors" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/>
          </svg>
          Importa Classi
        <% end %>
      <% end %>
    <% end %>

    <h1 class="text-2xl font-bold tracking-tight text-gray-900">
      Classi di <%= @scuola.denominazione %>
    </h1>
  <% end %>
<% end %>

<div class="space-y-6">

  <%# Breadcrumb %>
  <nav class="flex items-center gap-2 text-sm text-gray-500">
    <%= link_to scuole_path, class: "hover:text-emerald-600 transition-colors" do %>
      Scuole
    <% end %>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
    </svg>
    <%= link_to @scuola.denominazione, scuola_path(@scuola), class: "hover:text-emerald-600 transition-colors truncate max-w-xs" %>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
    </svg>
    <span class="text-gray-900 font-medium">Classi</span>
  </nav>

  <%# Lista classi %>
  <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between">
      <h3 class="font-semibold text-gray-900">Tutte le classi</h3>
      <span class="px-3 py-1 bg-gray-100 rounded-full text-sm font-medium text-gray-600">
        <%= @classi.count %>
      </span>
    </div>

    <% if @classi.any? %>
      <div class="divide-y divide-gray-100">
        <% @classi.each do |classe| %>
          <%= render "scuole/classi/classe_card", classe: classe, scuola: @scuola %>
        <% end %>
      </div>
    <% else %>
      <div class="p-12 text-center">
        <svg class="mx-auto h-12 w-12 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z"/>
        </svg>
        <h3 class="mt-4 text-lg font-medium text-gray-900">Nessuna classe</h3>
        <p class="mt-2 text-sm text-gray-500">Questa scuola non ha ancora classi registrate.</p>
        <% if @scuola.codice_ministeriale.present? %>
          <%= button_to scuola_classi_path(@scuola),
              method: :post,
              class: "mt-4 inline-flex items-center gap-2 px-4 py-2 bg-emerald-600 text-white text-sm font-medium rounded-lg hover:bg-emerald-700 transition-colors" do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/>
            </svg>
            Importa Classi
          <% end %>
        <% end %>
      </div>
    <% end %>
  </div>

</div>
