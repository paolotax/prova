<% @page_title = "Cattedre — #{@scuola.denominazione}" %>

<% content_for :header do %>
  <div class="header__actions header__actions--start">
    <%= link_to scuola_path(@scuola), class: "btn" do %>
      <%= icon_tag "arrow-left", size: "small" %>
      <span class="for-screen-reader">Indietro</span>
    <% end %>
  </div>

  <h1 class="header__title divider divider--fade full-width">
    <span class="overflow-ellipsis">Collega cattedre e discipline</span>
  </h1>

  <div class="header__actions header__actions--end">
  </div>
<% end %>

<p class="txt-small txt-subtle text-align-center margin-block-end">
  <%= @scuola.denominazione %> — tipo: <strong><%= @tipo_scuola %></strong>
</p>

<% if @cattedre.empty? %>
  <p class="txt-subtle">Nessuna cattedra trovata. Importa prima gli insegnanti dal PDF ANARPE.</p>
<% elsif @discipline.empty? %>
  <p class="txt-subtle">Nessuna disciplina trovata. Importa prima le adozioni MIUR.</p>
<% else %>
  <div data-controller="cattedra-matcher"
       data-cattedra-matcher-create-url-value="<%= scuola_cattedre_path(@scuola) %>"
       data-cattedra-matcher-delete-url-value="<%= scuola_cattedre_path(@scuola) %>"
       data-cattedra-matcher-tipo-scuola-value="<%= @tipo_scuola %>"
       style="position: relative;">

    <div data-mappings="<%= @mappings.select(:cattedra, :disciplina).map { |m| { cattedra: m.cattedra, disciplina: m.disciplina } }.to_json %>"></div>

    <p class="txt-small txt-subtle text-align-center margin-block-end-half" data-cattedra-matcher-target="status">
      Clicca una cattedra e poi una disciplina per collegarle
    </p>

    <div class="matcher-columns">
      <div class="matcher-column">
        <h3 class="txt-small font-weight-bold margin-block-end-half text-align-end">Cattedre ANARPE</h3>
        <% @cattedre.each do |cattedra| %>
          <button type="button"
                  class="matcher-item matcher-item--cattedra"
                  data-cattedra-matcher-target="item"
                  data-action="click->cattedra-matcher#select"
                  data-side="cattedra"
                  data-item-id="<%= cattedra %>">
            <%= cattedra %>
          </button>
        <% end %>
      </div>

      <svg data-cattedra-matcher-target="canvas"
           class="matcher-canvas"
           style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; z-index: 1;">
      </svg>

      <div class="matcher-column">
        <h3 class="txt-small font-weight-bold margin-block-end-half">Discipline MIUR</h3>
        <% @discipline.each do |disciplina| %>
          <button type="button"
                  class="matcher-item matcher-item--disciplina"
                  data-cattedra-matcher-target="item"
                  data-action="click->cattedra-matcher#select"
                  data-side="disciplina"
                  data-item-id="<%= disciplina %>">
            <%= disciplina %>
          </button>
        <% end %>
      </div>
    </div>
  </div>
<% end %>

<style>
  .matcher-columns {
    display: grid;
    grid-template-columns: 1fr 8rem 1fr;
    max-width: 50rem;
    margin-inline: auto;
    position: relative;
  }
  .matcher-column {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.5rem;
  }
  .matcher-column:last-of-type {
    align-items: flex-start;
    grid-column: 3;
  }
  .matcher-canvas {
    grid-column: 1 / -1;
    grid-row: 1;
  }
  .matcher-item {
    display: inline-block;
    width: auto;
    padding: 0.3rem 0.75rem;
    font-size: var(--txt-small, 0.8125rem);
    text-align: left;
    color: var(--color-text, #1f2937);
    border: 1px solid var(--color-border, #e5e7eb);
    border-radius: var(--radius, 0.375rem);
    background: var(--color-surface, #fff);
    cursor: pointer;
    transition: all 0.15s;
    position: relative;
    z-index: 2;
    white-space: nowrap;
  }
  .matcher-item:hover {
    border-color: var(--color-accent, #3b82f6);
  }
  .matcher-item.selected {
    border-color: var(--color-accent, #3b82f6);
    box-shadow: 0 0 0 2px var(--color-accent, #3b82f6);
  }
  .matcher-item.matched {
    background: var(--color-shade, #f0f4ff);
    border-color: var(--color-accent, #3b82f6);
    font-weight: 600;
  }
  .matcher-canvas g:hover line:last-child {
    stroke: var(--color-danger, #ef4444) !important;
    stroke-width: 3 !important;
  }
</style>
