<% scuola_card_color = tipo_scuola_color(scuola.tipo_scuola) %>

<section class="card-perma" style="--card-color: <%= scuola_card_color %>;">
	<div class="card-perma__actions card-perma__actions--left">
		<%= render "tappe/pianifica", source: scuola %>		

		<%= link_to mappe_path("scuola-#{scuola.id}"),
				class: "btn", data: { controller: "tooltip" } do %>
			<%= icon_tag "mappa" %>
			<span class="for-screen-reader">Posizione nella mappa</span>
		<% end %>
	</div>

	<div class="card-perma__bg">
		<article class="card">
			<header class="card__header">
				<%= render "scuole/display/perma/board", scuola: scuola %>
				<%= render "scuole/display/perma/tags", scuola: scuola %>
			</header>
			
			<div class="card__body">
				<div class="card__content">
					<%= turbo_frame_tag scuola, :edit do %>
						<% if @edit_mode %>
							<%= render "scuole/container/edit_form", scuola: scuola %>
						<% else %>
							<%= render "scuole/container/content_display", scuola: scuola %>
						<% end %>
					<% end %>
				</div>
			</div>

			<%= render "scuole/container/classi", scuola: scuola %>
		
			<footer class="card__footer full-width">
				<%= render "scuole/display/perma/meta", scuola: scuola %>
			</footer>
		</article>
	</div>

	<div class="card-perma__actions card-perma__actions--right">
		<% if scuola.promuovibile? %>
			<%= link_to new_controllo_adozioni_promozione_path(codicescuola: scuola.codice_ministeriale),
					class: "btn", data: { turbo_frame: :modal, controller: "tooltip" } do %>
				<%= icon_tag "academic-cap" %>
				<span class="for-screen-reader">Passaggio anno</span>
			<% end %>
		<% end %>

		<%= link_to scuola_foglio_scuola_path(scuola, format: :pdf),
				target: "_blank", class: "btn", data: { controller: "tooltip", turbo: false } do %>
			<%= icon_tag "printer" %>
			<span class="for-screen-reader">Foglio scuola PDF</span>
		<% end %>
		<%= link_to scuola_foglio_scuola_path(scuola, format: :pdf, solo_sovrapacchi: true),
				target: "_blank", class: "btn", data: { controller: "tooltip", turbo: false } do %>
			<%= icon_tag "tag" %>
			<span class="for-screen-reader">Sovrapacchi PDF</span>
		<% end %>

		<% bolle_aperte_count = scuola.bolle_visione_aperte_count %>
		<% if bolle_aperte_count.positive? %>
			<%= link_to scuola_ritiro_path(scuola), class: "btn btn--negative",
					data: { controller: "tooltip" } do %>
				<%= icon_tag "refresh" %>
				<span class="for-screen-reader">Ritiro bolle in visione(<%= bolle_aperte_count %>)</span>
			<% end %>
		<% end %>
	</div>

	<div class="card-perma__notch card-perma__notch--bottom">
		<%= turbo_frame_tag scuola, :footer do %>
			<% if @edit_mode %>
				<%= render "scuole/container/edit_footer", scuola: scuola %>
			<% else %>
				<%= render "scuole/container/footer", scuola: scuola %>
			<% end %>
		<% end %>
	</div>
</section>

<div class="scuola-show" style="--card-color: <%= scuola_card_color %>;">
	<% propaganda = Propaganda.corrente(user: current_user) %>
	<% cs = propaganda && propaganda.andamento([scuola]).first %>
	<% if cs&.collane&.any? %>
		<div class="margin-block-start">
			<div class="group-header">
				<h3 class="group-header__title divider divider--fade txt-medium font-weight-black margin-none">
					<%= propaganda.nome %> — <%= cs.completata? ? "ritiri completati" : "#{cs.da_ritirare} da ritirare" %>
				</h3>
			</div>
			<div class="flex flex-column gap-half">
				<% cs.collane.each do |collana| %>
					<%= render "propaganda/collana", collana: collana %>
				<% end %>
			</div>
		</div>
	<% end %>

	<%= turbo_frame_tag "scuola_entries", src: scuola_entries_path(scuola) do %>
		<div class="group-header">
			<h3 class="group-header__title divider divider--fade txt-medium font-weight-black margin-none">Aperti</h3>
		</div>
		<p class="txt-small txt-subtle margin-none">Caricamento...</p>
	<% end %>

	<%= render "scuole/container/insegnanti", scuola: scuola %>

	<%= render "scuole/container/prossime_visite", scuola: scuola %>

	<%= render "scuole/container/disponibilita", scuola: scuola %>

	<%= render "scuole/container/adozioni", scuola: scuola %>

	<%#= render "scuole/container/saggi", scuola: scuola %>

	<%= turbo_frame_tag "scuola_closed_entries", src: scuola_closed_entries_path(scuola), loading: :lazy, style: "display: block; min-height: 1px;" do %>
	<% end %>
</div>