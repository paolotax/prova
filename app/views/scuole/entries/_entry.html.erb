<%# locals: (entry:) -%>
<% entryable = entry.entryable %>
<% path = entryable.is_a?(Appunto) ? appunto_path(entryable) : documento_path(entryable) %>
<% icon = entryable.is_a?(Appunto) ? "note" : "document" %>

<%= link_to path, class: "pad-half border-radius fill-shade txt-undecorated flex gap-half align-center" do %>
  <%= icon_tag icon, size: "small", class: "txt-subtle" %>
  <div class="flex-1 overflow-hidden">
    <p class="txt-small overflow-ellipsis margin-none">
      <% if entryable.is_a?(Appunto) %>
        <% text = entryable.content.to_plain_text.presence %>
        <%= text ? truncate(text, length: 60) : content_tag(:span, "Appunto vuoto", class: "txt-subtle") %>
      <% else %>
        <%= entryable.causale&.causale %> #<%= entryable.numero_documento %>
      <% end %>
    </p>
    <p class="txt-xx-small txt-subtle margin-none">
      <%= entryable.class.model_name.human %> · <%= time_ago_in_words(entry.updated_at) %> fa
    </p>
  </div>
  <% if entry.golden? %>
    <%= icon_tag "star", size: "small", class: "txt-warning" %>
  <% end %>
<% end %>
