<%# locals: (gruppo:, draggable: false, card_id: nil, card_drag_id: nil) -%>
<% direzione = gruppo[:direzione] %>
<% plessi = gruppo[:plessi] %>
<% all_sedi = direzione && (direzione.classi_count.to_i > 0 || direzione.mie_adozioni_count.to_i > 0) ? [direzione] + plessi : plessi %>

<% if direzione %>
  <article class="card"
    id="<%= card_id || dom_id(direzione, :card) %>"
    style="--card-color: <%= tipo_scuola_color(direzione.tipo_scuola) %>"
    <% if draggable %>
      draggable="true"
      data-drag-and-drop-target="item"
      data-id="<%= card_drag_id || direzione.id %>"
      data-scuole-count="<%= [all_sedi.size, 1].max %>"
    <% end %>>
    <div class="flex flex-column flex-item-grow max-inline-size">
      <header class="card__header">
        <div class="card__board">
          <span class="card__id"><%= direzione.codice_ministeriale %></span>
          <span class="card__board-name"><%= direzione.tipo_scuola&.upcase.presence || "DIREZIONE" %></span>
        </div>
      </header>

      <div class="card__body">
        <div class="card__content">
          <h3 class="card__title">
            <% if draggable %>
              <%= direzione.denominazione %>
            <% else %>
              <%= link_to direzione.denominazione, scuola_path(direzione), class: "card__title-link", data: { turbo_frame: "_top" } %>
            <% end %>
          </h3>
          <span class="card__subtitle"><%= [direzione.comune, direzione.sigla_provincia].compact_blank.join(", ") %></span>

        </div>
      </div>

      <% if all_sedi.any? %>
        <div class="padding-inline margin-block-end-half">
          <table class="table table--compact table--borderless txt-small" style="width: 100%;">
            <tbody>
              <% all_sedi.each do |plesso| %>
                <tr
                  <% if draggable %>
                    draggable="true"
                    data-drag-and-drop-target="item"
                    data-id="<%= plesso.id %>"
                    data-scuole-count="1"
                    data-action="dragstart->drag-and-drop#dragStart:stop"
                  <% end %>>
                  <td class="overflow-ellipsis" style="max-width: 200px;">
                    <span class="for-screen-reader">Plesso</span>
                    <% if draggable %>
                      <span class="card__board txt-xx-small" style="--card-color: <%= tipo_scuola_color(plesso.tipo_scuola) %>">
                        <%= plesso.denominazione %>
                      </span>
                    <% else %>
                      <%= link_to plesso.denominazione, scuola_path(plesso),
                        class: "card__board txt-xx-small", style: "--card-color: #{tipo_scuola_color(plesso.tipo_scuola)}",
                        data: { turbo_frame: "_top" } %>
                    <% end %>
                  </td>
                  <td class="txt-align-end" style="white-space: nowrap; width: 40px;"
                      data-classi-count="<%= plesso.classi_count %>">
                    <% if plesso.classi_count > 0 %>
                      <span class="txt-xx-small" style="color: <%= tipo_scuola_color(plesso.tipo_scuola) %>"><%= plesso.classi_count %>cl</span>
                    <% end %>
                  </td>
                  <%= render "scuole/mie_adozioni_count", scuola: plesso %>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>

        <% total_classi = all_sedi.sum(&:classi_count) %>
        <% total_mie_adozioni = all_sedi.sum(&:mie_adozioni_count) %>
        <% if total_classi > 0 || total_mie_adozioni > 0 %>
          <div class="card__meta" style="margin-block-start: var(--space-2xs);">
            <div class="card__meta-avatars card__meta-avatars--author">
              <% scuole_assigned_users(all_sedi).each do |user| %>
                <%= avatar_tag(user, hidden_for_screen_reader: true) %>
              <% end %>
            </div>
            <span class="card__meta-text card__meta-text--added">&nbsp;</span>
            <span class="card__meta-text card__meta-text--author">&nbsp;</span>
            <span class="card__meta-text card__meta-text--updated">&nbsp;</span>
            <span class="card__meta-text card__meta-text--assignees">&nbsp;</span>
            <span class="card__meta-text card__meta-text--copie txt-align-end">
              <% if total_classi > 0 %>
                <strong><%= total_classi %></strong> classi
              <% end %>
            </span>
            <span class="card__meta-text card__meta-text--importo txt-align-end">
              <% if total_mie_adozioni > 0 %>
                <strong class="txt-negative"><%= pluralize(total_mie_adozioni, "mia adozione", "mie adozioni") %></strong>
              <% end %>
            </span>
          </div>
        <% end %>
      <% end %>
    </div>
  </article>
<% else %>
  <%# Scuola isolata (senza direzione) — render come card singola %>
  <% plessi.each do |scuola| %>
    <% if draggable %>
      <article class="card"
        id="<%= dom_id(scuola, :card) %>"
        style="--card-color: <%= tipo_scuola_color(scuola.tipo_scuola) %>"
        draggable="true"
        data-drag-and-drop-target="item"
        data-id="<%= scuola.id %>"
        data-scuole-count="1">
        <div class="flex flex-column flex-item-grow max-inline-size">
          <header class="card__header">
            <div class="card__board">
              <span class="card__id"><%= scuola.codice_ministeriale %></span>
              <span class="card__board-name"><%= scuola.tipo_scuola&.upcase.presence || "SCUOLA" %></span>
            </div>
          </header>
          <div class="card__body">
            <div class="card__content">
              <h3 class="card__title overflow-line-clamp" style="--lines: 2;">
                <%= scuola.denominazione %>
              </h3>
              <span class="card__subtitle"><%= [scuola.comune, scuola.sigla_provincia].compact_blank.join(", ") %></span>
            </div>
          </div>

          <footer class="card__footer full-width">
            <%= render "scuole/display/perma/meta", scuola: scuola %>
          </footer>
        </div>
      </article>
    <% else %>
      <%= render scuola %>
    <% end %>
  <% end %>
<% end %>
