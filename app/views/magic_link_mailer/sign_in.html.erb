<div style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; max-width: 600px; margin: 0 auto; padding: 20px;">
  <h2 style="color: #333; margin-bottom: 20px;">Accedi al tuo account</h2>

  <p style="color: #555; font-size: 16px; line-height: 1.5;">
    Ciao <%= @user.name %>,
  </p>

  <p style="color: #555; font-size: 16px; line-height: 1.5;">
    Clicca il pulsante qui sotto per accedere al tuo account.
  </p>

  <div style="text-align: center; margin: 30px 0;">
    <%= link_to "Accedi ora", @sign_in_url, style: "display: inline-block; background-color: #dc2626; color: white; padding: 14px 28px; text-decoration: none; border-radius: 6px; font-weight: 600; font-size: 16px;" %>
  </div>

  <p style="color: #888; font-size: 14px; line-height: 1.5;">
    Questo link scade tra <strong>15 minuti</strong>.
  </p>

  <p style="color: #888; font-size: 14px; line-height: 1.5;">
    Se non hai richiesto questo link, puoi ignorare questa email.
  </p>

  <hr style="border: none; border-top: 1px solid #eee; margin: 30px 0;">

  <p style="color: #aaa; font-size: 12px;">
    Se il pulsante non funziona, copia e incolla questo link nel browser:<br>
    <a href="<%= @sign_in_url %>" style="color: #dc2626; word-break: break-all;"><%= @sign_in_url %></a>
  </p>
</div>
