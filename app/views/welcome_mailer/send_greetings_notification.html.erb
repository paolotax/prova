<%= render Email::Bg::Container.new do |email| %>
  <% email.with_masthead_text(text: "ScagnoZZ", href: "http://ScagnoZZ.com") %>
  <%= render Email::Heading.new(
    text: "Grazie per esserti registrato!",
    size: "30px",
    align: "center",
    margin: "20px auto 30px auto"
  ) %>
  <%= render Email::Divider.new(color: Email::Colors::RED_500, thickness: "4px") %>
  <%= render Email::Text.new do %>
      Grazie <b><%= @user.name %></b> per esserti registrato a ScagnoZZ! Siamo entusiasti di averti a bordo.
  <% end %>
  <%= render Email::Text.new(text: "ScagnoZZ stà muovendo i suoi primi passi. ") %>
  <%# Section 1 %>
  
  <%= render Email::Text.new(text: "Intanto imposta le scuole e i tuoi editori nella pagina del tuo profilo. Al momento puoi inserire appunti di ogni tipo, consultare al volo gli elenchi adozioni e prepararti il giro.") %>

  <%= render Email::Heading.new(
    text: "Scagnozz CLI",
    size: "22px",
    align: "left",
    margin: "30px auto 10px auto"
  ) %>
  <%= render Email::Text.new do %>
    Puoi usare ScagnoZZ anche dal terminale con il <b>CLI</b>: cerca scuole, clienti, libri e crea appunti direttamente dalla riga di comando.
  <% end %>
  <%= render Email::Text.new do %>
    <b>Mac / Linux:</b><br>
    <code>curl -fsSL https://scagnozz.com/cli/install.sh | bash</code>
  <% end %>
  <%= render Email::Text.new do %>
    <b>Windows</b> (PowerShell):<br>
    <code>irm https://scagnozz.com/cli/install.ps1 | iex</code>
  <% end %>
  <%= render Email::Text.new(text: "Dopo l'installazione esegui 'scagnozz setup' per configurare il tuo account.") %>
    
  <%= render Email::Colorblock.new(
    color: Email::Colors::RED_50,
    border_width: "0",
    border_radius: "12px",
    margin: "64px auto auto auto",
    padding: "16px 24px",
  ) do %>
    <%= render Email::Text.new(text: "ScagnoZZ", bold: true, letter_spacing: "-0.0375rem", margin: "8px auto", color: Email::Colors::GRAY_700) %>
    <%= render Email::Text.new(size: "12px", margin: "4px auto", color: Email::Colors::GRAY_600) do %>
      Visita <%= link_to "ScagnoZZ", "http://scagnozz.com" %> per saperne di più.
    <% end %>
    <%= render Email::Text.new(text: "© #{Time.now.year} ScagnoZZ", margin: "4px auto", size: "12px", color: Email::Colors::GRAY_600) %>
  <% end %>
<% end %>



        