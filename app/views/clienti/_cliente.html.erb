<%# locals: (cliente:) -%>

<%= tag.article id: dom_id(cliente),
    class: "card",
    style: "--card-color: #{cliente_color(cliente)}",
    tabindex: 0,
    data: { navigable_list_target: "item", action: "mouseenter->navigable-list#hoverSelect contextmenu->navigable-list#toggleSelection" } do %>

  <label class="card__checkbox">
    <%= check_box_tag "cliente_ids[]", cliente.id, false, data: { action: "change->bulk-actions#count" } %>
  </label>

  <div class="flex flex-column flex-item-grow max-inline-size">
    <%= link_to cliente_path(cliente), class: "card__link", data: { turbo_frame: "_top" } do %>
      <span class="for-screen-reader"><%= cliente.denominazione %></span>
    <% end %>

    <!-- Header con tipo cliente colorato -->
    <header class="card__header">
      <div class="card__board">
        <span class="card__id"><%= cliente.tipo_cliente&.upcase.presence || "CLIENTE" %></span>
        <span class="card__board-name"><%= [cliente.comune, cliente.provincia].compact_blank.join(", ") %></span>
      </div>
    </header>

    <!-- Body con denominazione e contatti -->
    <div class="card__body">
      <div class="card__content">
        <h3 class="card__title overflow-line-clamp" style="--lines: 2;">
          <%= cliente.denominazione %>
        </h3>
        <div class="card__stages txt-small txt-subtle flex flex-column gap-quarter">
          <% if cliente.telefono.present? %>
            <span><%= icon_tag "phone", class: "icon--small" %> <%= cliente.telefono %></span>
          <% end %>
          <% if cliente.email.present? %>
            <span><%= icon_tag "envelope", class: "icon--small" %> <%= cliente.email %></span>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Footer con stats -->
    <footer class="card__footer full-width">
      <%= render "clienti/display/meta", cliente: cliente %>
    </footer>
  </div>
<% end %>
