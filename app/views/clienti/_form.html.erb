<%= form_with model: cliente, class: "flex flex-column gap", data: { controller: "form" } do |f| %>

  <% if cliente.errors.any? %>
    <div class="panel pad border-radius txt-negative fill-shade">
      <h3 class="font-weight-black"><%= pluralize(cliente.errors.count, "errore", "errori") %> da correggere:</h3>
      <ul class="margin-block-start-half txt-small">
        <% cliente.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <section class="panel shadow center" style="--panel-size: 55ch;">
    <!-- Dati Identificativi -->
    <strong class="divider txt-large">Dati identificativi</strong>

    <div class="flex flex-column gap">
      <div class="form-field">
        <%= f.label :denominazione, class: "form-label" %>
        <%= f.text_field :denominazione, class: "input", placeholder: "Ragione sociale", autofocus: true, required: true,
            data: { action: "keydown.esc@document->form#cancel" } %>
      </div>

      <div class="form-grid flex gap">
        <div class="form-field">
          <%= f.label :partita_iva, "Partita IVA", class: "form-label" %>
          <%= f.text_field :partita_iva, class: "input mono", placeholder: "01234567890", maxlength: 11 %>
        </div>

        <div class="form-field">
          <%= f.label :codice_fiscale, class: "form-label" %>
          <%= f.text_field :codice_fiscale, class: "input mono txt-uppercase", placeholder: "RSSMRA80A01H501Z", maxlength: 16 %>
        </div>
      </div>

      <div class="form-grid flex gap">
        <div class="form-field">
          <%= f.label :codice_cliente, class: "form-label" %>
          <%= f.text_field :codice_cliente, class: "input mono", placeholder: "CLI001" %>
        </div>

        <div class="form-field">
          <%= f.label :tipo_cliente, class: "form-label" %>
          <%= f.text_field :tipo_cliente, class: "input", placeholder: "Libreria, Cartolibreria..." %>
        </div>
      </div>

      <div class="form-grid flex gap">
        <div class="form-field">
          <%= f.label :nome, class: "form-label" %>
          <%= f.text_field :nome, class: "input", placeholder: "Nome (per privati)" %>
        </div>

        <div class="form-field">
          <%= f.label :cognome, class: "form-label" %>
          <%= f.text_field :cognome, class: "input", placeholder: "Cognome (per privati)" %>
        </div>
      </div>
    </div>
  </section>

  <section class="panel shadow center" style="--panel-size: 55ch;">
    <!-- Indirizzo -->
    <strong class="divider txt-large">Indirizzo</strong>

    <div class="flex flex-column gap">
      <div class="form-grid flex gap">
        <div class="form-field" style="grid-column: span 2;">
          <%= f.label :indirizzo, class: "form-label" %>
          <%= f.text_field :indirizzo, class: "input", placeholder: "Via/Piazza..." %>
        </div>

        <div class="form-field">
          <%= f.label :numero_civico, "N. Civico", class: "form-label" %>
          <%= f.text_field :numero_civico, class: "input", placeholder: "12/A" %>
        </div>
      </div>

      <div class="form-grid form-grid--3">
        <div class="form-field">
          <%= f.label :cap, "CAP", class: "form-label" %>
          <%= f.text_field :cap, class: "input mono", placeholder: "00000", maxlength: 5 %>
        </div>

        <div class="form-field" style="grid-column: span 2;">
          <%= f.label :comune, class: "form-label" %>
          <%= f.text_field :comune, class: "input", placeholder: "Comune" %>
        </div>
      </div>

      <div class="form-grid">
        <div class="form-field">
          <%= f.label :provincia, class: "form-label" %>
          <%= f.text_field :provincia, class: "input txt-uppercase", placeholder: "MI", maxlength: 2 %>
        </div>

        <div class="form-field">
          <%= f.label :nazione, class: "form-label" %>
          <%= f.text_field :nazione, class: "input", placeholder: "Italia", value: cliente.nazione.presence || "Italia" %>
        </div>

        <div class="form-field">
          <%= f.label :id_paese, "ID Paese", class: "form-label" %>
          <%= f.text_field :id_paese, class: "input txt-uppercase", placeholder: "IT", maxlength: 2, value: cliente.id_paese.presence || "IT" %>
        </div>
      </div>
    </div>

    <!-- Contatti -->
    <strong class="divider txt-large">Contatti</strong>

    <div class="flex flex-column gap">
      <div class="form-grid">
        <div class="form-field">
          <%= f.label :telefono, class: "form-label" %>
          <%= f.telephone_field :telefono, class: "input", placeholder: "02 12345678" %>
        </div>

        <div class="form-field">
          <%= f.label :email, class: "form-label" %>
          <%= f.email_field :email, class: "input", placeholder: "email@cliente.it" %>
        </div>
      </div>

      <div class="form-field">
        <%= f.label :pec, "PEC", class: "form-label" %>
        <%= f.email_field :pec, class: "input", placeholder: "email@pec.cliente.it" %>
      </div>
    </div>
  </section>

  <section class="panel shadow center" style="--panel-size: 55ch;">
    <!-- Fatturazione -->
    <strong class="divider txt-large">Fatturazione</strong>

    <div class="flex flex-column gap">
      <div class="form-grid">
        <div class="form-field">
          <%= f.label :indirizzo_telematico, "Codice SDI", class: "form-label" %>
          <%= f.text_field :indirizzo_telematico, class: "input mono txt-uppercase", placeholder: "0000000", maxlength: 7 %>
        </div>

        <div class="form-field">
          <%= f.label :condizioni_di_pagamento, class: "form-label" %>
          <%= f.select :condizioni_di_pagamento,
              options_for_select([["—", ""], "Pagamento immediato", "30 giorni", "60 giorni", "90 giorni", "Fine mese", "Rimessa diretta"], cliente.condizioni_di_pagamento),
              {}, class: "input input--select" %>
        </div>
      </div>

      <div class="form-grid">
        <div class="form-field">
          <%= f.label :metodo_di_pagamento, class: "form-label" %>
          <%= f.select :metodo_di_pagamento,
              options_for_select([["—", ""], "Contanti", "Bonifico bancario", "Assegno", "Carta di credito", "PayPal", "Satispay"], cliente.metodo_di_pagamento),
              {}, class: "input input--select" %>
        </div>

        <div class="form-field">
          <%= f.label :banca, class: "form-label" %>
          <%= f.text_field :banca, class: "input", placeholder: "Nome banca" %>
        </div>
      </div>

      <div class="form-grid">
        <div class="form-field">
          <%= f.label :beneficiario, class: "form-label" %>
          <%= f.text_field :beneficiario, class: "input", placeholder: "Intestatario conto" %>
        </div>

        <div class="form-field">
          <%= f.label :codice_eori, "Codice EORI", class: "form-label" %>
          <%= f.text_field :codice_eori, class: "input mono txt-uppercase", placeholder: "IT01234567890" %>
        </div>
      </div>
    </div>
  </section>

  <div class="flex align-center justify-end gap">
    <%= link_to "Annulla", (cliente.persisted? ? cliente_path(cliente) : clienti_path), class: "btn", data: { form_target: "cancel" } %>
    <%= f.submit cliente.persisted? ? "Salva Modifiche" : "Crea Cliente", class: "btn btn--primary" %>
  </div>
<% end %>
