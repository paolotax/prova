<%= form_with model: cliente, class: "flex flex-column gap" do |f| %>
  <% if cliente.errors.any? %>
    <div class="panel pad" style="background: var(--color-negative-lighter); border: 1px solid var(--color-negative);">
      <div class="flex gap-half">
        <%= icon_tag "alert-triangle", size: "small", style: "color: var(--color-negative-dark);" %>
        <div>
          <h3 class="txt-small font-weight-bold" style="color: var(--color-negative-dark);">
            <%= pluralize(cliente.errors.count, "errore", "errori") %> <%= cliente.errors.count == 1 ? "impedisce" : "impediscono" %> il salvataggio:
          </h3>
          <ul class="txt-small margin-block-start-half" style="color: var(--color-negative-dark); padding-inline-start: 1em;">
            <% cliente.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Denominazione -->
  <div class="form-field">
    <%= f.label :denominazione, class: "form-label" %>
    <%= f.text_field :denominazione,
        class: "input",
        placeholder: "Ragione sociale",
        autofocus: true %>
  </div>

  <!-- Nome e Cognome (per clienti privati) -->
  <div class="form-grid">
    <div class="form-field">
      <%= f.label :nome, class: "form-label" %>
      <%= f.text_field :nome,
          class: "input",
          placeholder: "Nome" %>
    </div>

    <div class="form-field">
      <%= f.label :cognome, class: "form-label" %>
      <%= f.text_field :cognome,
          class: "input",
          placeholder: "Cognome" %>
    </div>
  </div>

  <!-- Codice cliente e Tipo cliente -->
  <div class="form-grid">
    <div class="form-field">
      <%= f.label :codice_cliente, class: "form-label" %>
      <%= f.text_field :codice_cliente,
          class: "input mono",
          placeholder: "es. CLI001" %>
    </div>

    <div class="form-field">
      <%= f.label :tipo_cliente, class: "form-label" %>
      <%= f.text_field :tipo_cliente,
          class: "input",
          placeholder: "es. Libreria, Cartolibreria..." %>
    </div>
  </div>

  <!-- Partita IVA e Codice Fiscale -->
  <div class="form-grid">
    <div class="form-field">
      <%= f.label :partita_iva, "Partita IVA", class: "form-label" %>
      <%= f.text_field :partita_iva,
          class: "input mono",
          placeholder: "01234567890",
          maxlength: 11 %>
    </div>

    <div class="form-field">
      <%= f.label :codice_fiscale, "Codice Fiscale", class: "form-label" %>
      <%= f.text_field :codice_fiscale,
          class: "input mono txt-uppercase",
          placeholder: "RSSMRA80A01H501Z",
          maxlength: 16 %>
    </div>
  </div>

  <!-- Indirizzo -->
  <div class="form-grid" style="grid-template-columns: 3fr 1fr;">
    <div class="form-field">
      <%= f.label :indirizzo, class: "form-label" %>
      <%= f.text_field :indirizzo,
          class: "input",
          placeholder: "Via/Piazza..." %>
    </div>

    <div class="form-field">
      <%= f.label :numero_civico, "N. Civico", class: "form-label" %>
      <%= f.text_field :numero_civico,
          class: "input",
          placeholder: "12/A" %>
    </div>
  </div>

  <!-- CAP, Comune, Provincia -->
  <div class="form-grid" style="grid-template-columns: 1fr 2fr 1fr;">
    <div class="form-field">
      <%= f.label :cap, "CAP", class: "form-label" %>
      <%= f.text_field :cap,
          class: "input",
          placeholder: "00000",
          maxlength: 5 %>
    </div>

    <div class="form-field">
      <%= f.label :comune, class: "form-label" %>
      <%= f.text_field :comune,
          class: "input",
          placeholder: "Comune" %>
    </div>

    <div class="form-field">
      <%= f.label :provincia, class: "form-label" %>
      <%= f.text_field :provincia,
          class: "input txt-uppercase",
          placeholder: "MI",
          maxlength: 2 %>
    </div>
  </div>

  <!-- Nazione e ID Paese -->
  <div class="form-grid">
    <div class="form-field">
      <%= f.label :nazione, class: "form-label" %>
      <%= f.text_field :nazione,
          class: "input",
          placeholder: "Italia",
          value: cliente.nazione.presence || "Italia" %>
    </div>

    <div class="form-field">
      <%= f.label :id_paese, "ID Paese", class: "form-label" %>
      <%= f.text_field :id_paese,
          class: "input txt-uppercase",
          placeholder: "IT",
          maxlength: 2,
          value: cliente.id_paese.presence || "IT" %>
    </div>
  </div>

  <!-- Email e PEC -->
  <div class="form-grid">
    <div class="form-field">
      <%= f.label :email, class: "form-label" %>
      <%= f.email_field :email,
          class: "input",
          placeholder: "email@cliente.it" %>
    </div>

    <div class="form-field">
      <%= f.label :pec, "PEC", class: "form-label" %>
      <%= f.email_field :pec,
          class: "input",
          placeholder: "email@pec.cliente.it" %>
    </div>
  </div>

  <!-- Telefono e Indirizzo telematico -->
  <div class="form-grid">
    <div class="form-field">
      <%= f.label :telefono, class: "form-label" %>
      <%= f.telephone_field :telefono,
          class: "input",
          placeholder: "02 12345678" %>
    </div>

    <div class="form-field">
      <%= f.label :indirizzo_telematico, "Codice SDI", class: "form-label" %>
      <%= f.text_field :indirizzo_telematico,
          class: "input mono txt-uppercase",
          placeholder: "0000000",
          maxlength: 7 %>
    </div>
  </div>

  <!-- Condizioni di pagamento -->
  <div class="form-grid">
    <div class="form-field">
      <%= f.label :condizioni_di_pagamento, class: "form-label" %>
      <%= f.select :condizioni_di_pagamento,
          options_for_select([
            ["Seleziona...", ""],
            ["Pagamento immediato", "Pagamento immediato"],
            ["30 giorni", "30 giorni"],
            ["60 giorni", "60 giorni"],
            ["90 giorni", "90 giorni"],
            ["Fine mese", "Fine mese"],
            ["Rimessa diretta", "Rimessa diretta"]
          ], cliente.condizioni_di_pagamento),
          {},
          class: "input input--select" %>
    </div>

    <div class="form-field">
      <%= f.label :metodo_di_pagamento, class: "form-label" %>
      <%= f.select :metodo_di_pagamento,
          options_for_select([
            ["Seleziona...", ""],
            ["Contanti", "Contanti"],
            ["Bonifico bancario", "Bonifico bancario"],
            ["Assegno", "Assegno"],
            ["Carta di credito", "Carta di credito"],
            ["PayPal", "PayPal"],
            ["Satispay", "Satispay"]
          ], cliente.metodo_di_pagamento),
          {},
          class: "input input--select" %>
    </div>
  </div>

  <!-- Banca e Beneficiario -->
  <div class="form-grid">
    <div class="form-field">
      <%= f.label :banca, class: "form-label" %>
      <%= f.text_field :banca,
          class: "input",
          placeholder: "Nome banca" %>
    </div>

    <div class="form-field">
      <%= f.label :beneficiario, class: "form-label" %>
      <%= f.text_field :beneficiario,
          class: "input",
          placeholder: "Intestatario conto" %>
    </div>
  </div>

  <!-- Codice EORI -->
  <div class="form-field">
    <%= f.label :codice_eori, "Codice EORI", class: "form-label" %>
    <%= f.text_field :codice_eori,
        class: "input mono txt-uppercase",
        placeholder: "IT01234567890" %>
  </div>

  <!-- Actions -->
  <div class="flex align-center justify-end gap margin-block-start" style="border-top: 1px solid var(--color-ink-lighter); padding-top: var(--block-space);">
    <% cancel_path = cliente.persisted? ? cliente_path(cliente) : clienti_path %>
    <%= link_to "Annulla", cancel_path, class: "btn" %>
    <%= f.submit cliente.persisted? ? "Salva Modifiche" : "Crea Cliente", class: "btn btn--primary" %>
  </div>
<% end %>
