<%# locals: (cliente:) -%>

<%= button_tag class: "btn btn--positive", type: :submit, form: dom_id(cliente, :edit_form),
    data: { controller: "hotkey", action: "keydown.s@document->hotkey#click" } do %>
  Salva <kbd class="hide-on-touch">S</kbd>
<% end %>

<%= link_to cliente_path(cliente), class: "btn btn--reversed",
    data: { turbo_method: :get, turbo_stream: true } do %>
  <span>Annulla</span>
<% end %>
