<%= turbo_stream.replace [@cliente, :edit] do %>
  <%= turbo_frame_tag @cliente, :edit do %>
    <%= render "clienti/container/content_display", cliente: @cliente %>
  <% end %>
<% end %>

<%= turbo_stream.replace [@cliente, :footer] do %>
  <%= turbo_frame_tag @cliente, :footer do %>
    <%= render "clienti/container/footer/display", cliente: @cliente %>
  <% end %>
<% end %>

<%= turbo_stream.replace dom_id(@cliente, :meta) do %>
  <%= render "clienti/display/perma/meta", cliente: @cliente %>
<% end %>
