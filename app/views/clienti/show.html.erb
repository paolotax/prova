<div class="sticky top-header z-10 margin-block-end">
  <%= render Heading::WithActionsComponent.new(level: 'h2') do |heading| %>

    <% heading.with_leader do %>
    <% end %>

    <% heading.with_description do %>
      <%= tag.div simple_format(@cliente.address), class: "txt-small txt-subtle" %>
    <% end %>

    <% if @cliente.can_delete? %>
      <% heading.with_action do %>
        <%= component 'tax_button',
          caption: "Elimina",
          svg_file: "icon-trash-real.svg",
          color: "red",
          url: url_for( controller: "clienti", action: "destroy", model: @cliente, method: :delete ),
          data_attr: {
            turbo_method: "delete",
            turbo_confirm: "Vuoi veramente eliminare questo Cliente?",
            turbo_confirm_theme: "",
            turbo_confirm_confirm_label: "Si, eliminalo!",
            turbo_confirm_cancel_label: "Oops, no annulla…",
          } %>
      <% end %>
    <% end %>

    <% if @cliente.geocoded? %>
      <% heading.with_action do %>
        <%= component 'tax_button',
            caption: "Vai...",
            svg_file: "icon-map-pin.svg",
            color: "pink",
            url:  go_to_tappable_path(@cliente, current_user.navigator),
            target: "_blank"
        %>
      <% end %>

      <% heading.with_action do %>
        <%= component 'tax_button',
            caption: "Mappa",
            svg_file: "icon-mappa.svg",
            color: "pink",
            url:  mappe_path(id: @cliente.class.name.underscore + "-" + @cliente.id.to_s)
        %>
      <% end %>
    <% end %>

    <% heading.with_action do %>
      <%= component 'tax_button',
        caption: "Modifica",
        svg_file: "icon-pencil.svg",
        color: "yellow",
        url: url_for( controller: "clienti", action: "edit", model: @cliente ) %>
    <% end %>

    <% heading.with_action do %>
      <div class="flex gap-half">
        <%= component 'tax_button',
          caption: "prec",
          svg_file: "icon-arrow-left.svg",
          color: "white",
          url: "/clienti/#{@cliente&.previous&.id}" %>

        <%= component 'tax_button',
          caption: "succ",
          svg_file: "icon-arrow-right.svg",
          color: "white",
          url: "/clienti/#{@cliente&.next&.id}" %>
      </div>
    <% end %>

    <% heading.with_action do %>
      <%= component 'tax_button',
        caption: "Indietro",
        svg_file: "icon-arrow-long-left.svg",
        color: "white",
        url: 'javascript:history.back()' %>
    <% end %>

    <% heading.with_action do %>
      <%= render DropdownComponent.new() do |dropdown| %>
        <%= dropdown.with_button do %>
          <%= component 'tax_button',
              caption: "Nuovo",
              svg_file: "icon-plus.svg",
              color: "blue",
              type: :dropdown
          %>
        <% end %>

        <% dropdown.with_item do %>
        <% end %>

        <% dropdown.with_item do %>
          <%= link_to "nuovo ordine",
              new_documento_path( clientable_type: "Cliente", clientable_id: @cliente.id, causale: "Ordine Scuola" ),
              data: { turbo_prefetch: false },
              class: "dropdown-item" %>
        <% end %>

        <% dropdown.with_item do %>
          <%= link_to "Crea Tappa", new_tappa_path( tappable_type: "Cliente", tappable_id: @cliente.id, data_tappa: Date.today ),
              class: "dropdown-item",
              data: hotwire_native_app? ? { turbo_frame: :_top } : { turbo_frame: :modal, action: "click->dialog#open", turbo_prefetch: false } %>
        <% end %>

        <% dropdown.with_item do %>
          <%= link_to "Nuovo sconto",
              new_cliente_sconto_path(@cliente),
              data: { turbo_prefetch: false },
              class: "dropdown-item" %>
        <% end %>
      <% end %>
    <% end %>

    <%= @cliente.denominazione %>

  <% end %>

  <%= render StatComponent.new(title: "Fatturato", width: "full-width", theme: "dark",
            current_value: @cliente.importo_entrate - @cliente.importo_uscite) do |stat| %>
    <% stat.with_current_value_leader { "€ " } %>
  <% end %>

</div>

<!-- Sezione Sconti -->
<% sconti_attivi = @sconti_applicabili.attivi %>
<% sconti_unici_attivi = @sconti_unici.select(&:attivo?) %>

<% if sconti_unici_attivi.any? %>
  <section class="panel pad border-radius shadow margin-block-end fill-highlight">
    <div class="flex align-center justify-space-between margin-block-end-half">
      <div class="flex align-center gap-half">
        <h3 class="txt-medium font-weight-bold">Sconti speciali per questo cliente</h3>
        <span class="badge txt-xx-small" style="background: var(--color-warning); color: var(--color-ink);">
          <%= icon_tag "star", size: "small" %> Differente
        </span>
      </div>
      <%= link_to "Gestisci sconti", cliente_sconti_path(@cliente), class: "txt-link txt-small" %>
    </div>
    <div class="flex flex-column gap-half">
      <% sconti_unici_attivi.each do |sconto| %>
        <div class="panel pad-half border-radius flex align-center justify-space-between">
          <div class="flex align-center gap">
            <span class="txt-large font-weight-black"><%= number_to_percentage(sconto.percentuale_sconto, precision: 1) %></span>
            <div class="flex flex-column">
              <span class="txt-small font-weight-bold">
                <%= sconto.categoria&.nome_categoria || "Tutte le categorie" %>
              </span>
              <% if sconto.scontabile_id.present? %>
                <span class="badge badge--positive txt-xx-small">Sconto dedicato</span>
              <% else %>
                <span class="txt-xx-small txt-subtle">Per tutti i clienti</span>
              <% end %>
            </div>
          </div>
          <div class="flex flex-column align-end gap-half">
            <span class="badge badge--positive txt-xx-small"><%= sconto.tipo_sconto.capitalize %></span>
            <span class="txt-xx-small txt-subtle">
              <% if sconto.data_fine %>
                Fino al <%= l(sconto.data_fine, format: :short) %>
              <% else %>
                Permanente
              <% end %>
            </span>
          </div>
        </div>
      <% end %>
    </div>
  </section>
<% end %>

<% if sconti_attivi.any? && (sconti_attivi.count > sconti_unici_attivi.count) %>
  <details class="margin-block-end">
    <summary class="cursor-pointer txt-small txt-subtle font-weight-bold margin-block-end-half">
      ▸ Mostra anche sconti globali applicabili (<%= sconti_attivi.count - sconti_unici_attivi.count %>)
    </summary>
    <div class="panel pad border-radius fill-shade">
      <div class="flex flex-column gap-half">
        <% (sconti_attivi - sconti_unici_attivi).each do |sconto| %>
          <div class="panel pad-half border-radius flex align-center justify-space-between" style="opacity: 0.6;">
            <div class="flex align-center gap">
              <span class="txt-small font-weight-bold"><%= number_to_percentage(sconto.percentuale_sconto, precision: 1) %></span>
              <div class="flex flex-column">
                <span class="txt-small"><%= sconto.categoria&.nome_categoria || "Tutte le categorie" %></span>
                <span class="txt-xx-small txt-subtle">Sconto globale</span>
              </div>
            </div>
            <span class="txt-xx-small txt-subtle">
              <% if sconto.data_fine %>
                Fino al <%= l(sconto.data_fine, format: :short) %>
              <% else %>
                Permanente
              <% end %>
            </span>
          </div>
        <% end %>
      </div>
    </div>
  </details>
<% end %>


<div class="flex gap" data-controller="bulk-actions">

  <%= render partial: "documenti/bulk_actions/form" %>

  <div class="full-width margin-block-start">
    <% @documenti.group_by { |doc| doc.data_documento.year }.sort.reverse.each do |anno, documenti| %>
      <div class="margin-block-end">
        <h3 class="txt-x-large font-weight-black margin-block-end-half" style="border-block-end: 2px solid var(--color-ink-lighter); padding-block-end: var(--block-space-half);">
          <%= anno %>
        </h3>
        <div id="documenti" class="doc-grid">
          <%= render partial: "documenti/documento_con_figli",
              collection: documenti,
              as: :documento %>
        </div>
      </div>
    <% end %>
  </div>

</div>
