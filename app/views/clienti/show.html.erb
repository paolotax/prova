<% @page_title = @cliente.denominazione %>
<% @header_class = "header--card" %>

<% content_for :header do %>
  <div class="header__actions header__actions--start">
    <% info = referrer_back_info || { label: "Clienti", path: clienti_path } %>
    <%= back_link_to info[:label], info[:path] %>
  </div>

  <div class="header__actions header__actions--end">
  </div>
<% end %>

<%= tag.meta name: "back-refresh-url", content: cliente_path(@cliente, card: true) %>
<%= tag.meta name: "back-refresh-target", content: dom_id(@cliente) %>

<div class="full-width pad group">
  <%= render "clienti/container/container", cliente: @cliente, presenter: @presenter, sconti: @sconti_unici %>
</div>

<div class="full-width pad group" style="--card-color: <%= cliente_color(@cliente) %>;">
  <%= turbo_frame_tag "cliente_entries", src: cliente_entries_path(@cliente) do %>
    <h3 class="divider divider--fade txt-medium font-weight-black">Aperti</h3>
    <p class="txt-small txt-subtle margin-none">Caricamento...</p>
  <% end %>

  <%= turbo_frame_tag "cliente_closed_entries", src: cliente_closed_entries_path(@cliente), loading: :lazy, style: "display: block; min-height: 1px;" do %>
  <% end %>

  <% if @cliente.can_delete? %>
    <footer class="txt-align-center full-width flex flex-column margin-block-start-double">
      <hr class="separator--horizontal full-width margin-block" style="--border-color: var(--color-ink-lighter)">
      <%= render "shared/container/delete", record: @cliente, path: cliente_path(@cliente), label: "questo cliente" %>
    </footer>
  <% end %>
</div>
