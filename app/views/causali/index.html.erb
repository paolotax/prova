<% @page_title = "Causali" %>

<% content_for :header do %>
  <div class="header__actions header__actions--start"></div>

  <h1 class="header__title"><%= @page_title %></h1>

  <div class="header__actions header__actions--end">
    <%= link_to new_causale_path, class: "btn btn--primary" do %>
      <%= icon_tag "add", size: "small" %>
      <span>Nuova</span>
    <% end %>
  </div>
<% end %>

<section class="panel panel--wide shadow center">
  <% if @causali.any? %>
    <table class="txt-small full-width">
      <thead>
        <tr class="txt-subtle txt-x-small txt-uppercase">
          <th class="txt-start">Causale</th>
          <th class="txt-start">Magazzino</th>
          <th class="txt-start">Tipo</th>
          <th class="txt-start">Direzione</th>
          <th class="txt-end">Priorità</th>
          <th class="txt-start">Successive</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @causali.each do |causale| %>
          <%= render causale %>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="txt-subtle txt-small pad">Nessuna causale configurata.</p>
  <% end %>
</section>
