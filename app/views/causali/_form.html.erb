<%= form_with(model: causale) do |form| %>

  <% if causale.errors.any? %>
    <div class="fill-shade border-radius pad margin-block-end-half txt-negative txt-small">
      <% causale.errors.full_messages.each do |message| %>
        <p><%= message %></p>
      <% end %>
    </div>
  <% end %>

  <h3 class="divider divider--fade txt-medium font-weight-black">Informazioni Base</h3>

  <div class="flex flex-wrap gap full-width margin-block-end-half">
    <fieldset class="flex-item-grow" style="flex-basis: 200px;">
      <%= form.label :causale, class: "txt-x-small txt-subtle txt-uppercase" %>
      <%= form.text_field :causale, placeholder: "es. ORD, DDT, TD01...", class: "input full-width" %>
    </fieldset>

    <fieldset class="flex-item-grow" style="flex-basis: 200px;">
      <%= form.label :magazzino, class: "txt-x-small txt-subtle txt-uppercase" %>
      <%= form.text_field :magazzino, placeholder: "es. Principale", class: "input full-width" %>
    </fieldset>

    <fieldset class="flex-item-grow" style="flex-basis: 200px;">
      <%= form.label :tipo_movimento, class: "txt-x-small txt-subtle txt-uppercase" %>
      <%= form.select :tipo_movimento,
          options_for_select(Causale.tipo_movimenti.keys.map { |k| [k, k] }, causale.tipo_movimento),
          { prompt: "Seleziona..." }, class: "input full-width" %>
    </fieldset>

    <fieldset class="flex-item-grow" style="flex-basis: 200px;">
      <%= form.label :movimento, "Direzione", class: "txt-x-small txt-subtle txt-uppercase" %>
      <%= form.select :movimento,
          options_for_select(Causale.movimenti.keys.map { |k| [k, k] }, causale.movimento),
          { prompt: "Seleziona..." }, class: "input full-width" %>
    </fieldset>

    <fieldset class="flex-item-grow" style="flex-basis: 200px;">
      <%= form.label :clientable_type, "Tipo Cliente", class: "txt-x-small txt-subtle txt-uppercase" %>
      <%= form.select :clientable_type,
          options_for_select([["Scuola", "Scuola"], ["Cliente", "Cliente"]], causale.clientable_type),
          { include_blank: "Nessuno" }, class: "input full-width" %>
    </fieldset>

    <fieldset class="flex-item-grow" style="flex-basis: 100px;">
      <%= form.label :priorita, class: "txt-x-small txt-subtle txt-uppercase" %>
      <%= form.number_field :priorita, min: 0, max: 100, class: "input full-width" %>
    </fieldset>
  </div>

  <h3 class="divider divider--fade txt-medium font-weight-black">Workflow</h3>

  <div class="flex flex-wrap gap full-width margin-block-end-half">
    <fieldset class="flex-item-grow" style="flex-basis: 250px;">
      <%= form.label :stato_iniziale, class: "txt-x-small txt-subtle txt-uppercase" %>
      <%= form.select :stato_iniziale,
          options_for_select(
            [["Ordine", "ordine"], ["In consegna", "in_consegna"], ["Da pagare", "da_pagare"],
             ["Da registrare", "da_registrare"], ["Corrispettivi", "corrispettivi"],
             ["Fattura", "fattura"], ["Bozza", "bozza"]],
            causale.stato_iniziale
          ),
          { include_blank: "Nessuno" }, class: "input full-width" %>
    </fieldset>

    <fieldset class="flex-item-grow" style="flex-basis: 250px;">
      <%= form.label :stati_successivi, class: "txt-x-small txt-subtle txt-uppercase" %>
      <%= form.select :stati_successivi,
          options_for_select(
            [["Ordine", "ordine"], ["In consegna", "in_consegna"], ["Da pagare", "da_pagare"],
             ["Da registrare", "da_registrare"], ["Corrispettivi", "corrispettivi"],
             ["Fattura", "fattura"], ["Bozza", "bozza"]],
            causale.stati_successivi
          ),
          {}, { multiple: true, size: 5, class: "input full-width" } %>
    </fieldset>

    <fieldset class="full-width">
      <%= form.label :causali_successive, class: "txt-x-small txt-subtle txt-uppercase" %>
      <%= form.select :causali_successive,
          options_for_select(@causali_options || [], causale.causali_successive),
          {}, { multiple: true, size: 5, class: "input full-width" } %>
      <p class="txt-xx-small txt-subtle margin-block-start-quarter">
        Causali generabili da questa. Es: Ordine → DDT → Fattura
      </p>
    </fieldset>
  </div>

  <div class="flex gap-half">
    <%= form.submit "Salva", class: "btn btn--primary" %>
    <%= link_to "Annulla", causale.persisted? ? causale_path(causale) : causali_path, class: "btn btn--ghost" %>
  </div>
<% end %>
