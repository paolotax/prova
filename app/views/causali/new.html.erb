<% content_for :title, "Nuova Causale" %>

<% content_for :header do %>
  <%= render Heading::WithActionsComponent.new do |heading| %>
    <% heading.with_action do %>
      <%= link_to causali_path, class: "btn" do %>
        <%= icon_tag "arrow-left", size: "small" %>
        Torna alla lista
      <% end %>
    <% end %>

    <%= h1 { "Nuova Causale" } %>
  <% end %>
<% end %>

<div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
  <%= render "form", causale: @causale %>
</div>
