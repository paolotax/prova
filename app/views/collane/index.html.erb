<% @page_title = "Collane" %>

<% content_for :header do %>
  <div class="header__actions header__actions--start">
  </div>
  <h1 class="header__title divider divider--fade full-width"><%= @page_title %></h1>
  <div class="header__actions header__actions--end">
    <%= link_to new_collana_path, class: "btn btn--link", data: { controller: "tooltip" }  do %>
      <%= icon_tag "add" %>
      <span class="for-screen-reader">Nuova Collana</span>
    <% end %>
  </div>
<% end %>

<section class="panel panel--wide shadow center margin-block-start">
  <% if @collane.any? %>
    <ul class="flex flex-column gap-half unpad margin-none">
      <% @collane.each do |collana| %>
        <li class="list-style-none flex align-center gap full-width">
          <%= link_to collana_path(collana), class: "txt-ink flex gap-half align-center min-width txt-medium" do %>
            <strong class="overflow-ellipsis"><%= collana.nome %></strong>
          <% end %>
          <hr class="separator--horizontal flex-item-grow" style="--border-color: var(--color-ink-medium); --border-style: dashed" aria-hidden="true">
          <span class="txt-small txt-subtle flex-item-no-shrink"><%= collana.collana_libri.size %> libri</span>
        </li>
      <% end %>
    </ul>
  <% else %>
    <%= blank_slate_for(:collane, filtering: @user_filtering) %>
  <% end %>
</section>
