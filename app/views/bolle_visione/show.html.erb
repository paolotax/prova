<% @page_title = "BV-#{@bolla_visione.numero}" %>

<% content_for :header do %>
  <div class="header__actions header__actions--start">
    <% if @bolla_visione.tappa_id.present? %>
      <%= back_link_to_url "Tappa", tappa_path(@bolla_visione.tappa_id) %>
    <% else %>
      <%= back_link_to "Bolle", bolle_visione_path %>
    <% end %>
  </div>
  
  <h1 class="header__title"><%= @page_title %></h1>
  
  <div class="header__actions header__actions--end">
    <%= button_to rigenera_bolla_visione_path(@bolla_visione), method: :post, class: "btn",
        data: { turbo_confirm: "Svuota e rigenera le righe dalla collana?", controller: "tooltip" } do %>
      <%= icon_tag "refresh" %>
      <span class="for-screen-reader">Rigenera</span>
    <% end %>
    <% if @bolla_visione.contatto&.email.present? %>
      <% mail_subject = "Consegna volumi GIUNTI Scuola 2026" %>
      <% mail_body = "Buongiorno, \n\nallego la lista dei testi consegnati in visione in data #{l(@bolla_visione.data_bolla, format: :short)}.\nInvierò nei prossimi giorni un dettaglio delle nostre proposte con i link per visionare i contenuti digitali.\n\nGrazie.\n\nPaolo Tassinari\ncel: 347 2371680\nmail: p.tassinari@giunti-ag.it" %>
      <button type="button" class="btn"
          data-controller="mailto-pdf tooltip"
          data-mailto-pdf-pdf-url-value="<%= bolla_visione_path(@bolla_visione, format: :pdf) %>"
          data-mailto-pdf-to-value="<%= @bolla_visione.contatto.email %>"
          data-mailto-pdf-subject-value="<%= mail_subject %>"
          data-mailto-pdf-body-value="<%= mail_body %>"
          data-action="click->mailto-pdf#send">
        <%= icon_tag "envelope" %>
        <span class="for-screen-reader">Invia al contatto</span>
      </button>
    <% end %>
    <%= link_to bolla_visione_path(@bolla_visione, format: :pdf), target: "_blank", class: "btn",
        data: { controller: "tooltip" } do %>
      <%= icon_tag "printer" %>
      <span class="for-screen-reader">Stampa</span>
    <% end %>
  </div>
<% end %>

<section class="panel panel--wide shadow center">
  <div class="flex align-center gap-half">
    <h3 class="divider divider--fade txt-medium font-weight-black margin-none" style="flex: 1;">
      <%= link_to @bolla_visione.scuola.denominazione, scuola_path(@bolla_visione.scuola) %>
    </h3>

    <%= render "persone/search_dialog", scuola: @bolla_visione.scuola,
        form_url: bolla_visione_persone_path(@bolla_visione),
        select_url: bolla_visione_path(@bolla_visione),
        assign_url: bolla_visione_persone_path(@bolla_visione),
        ruolo: "referente" %>
  </div>

  <div class="flex flex-wrap gap full-width">
    <div class="flex-item-grow" style="flex-basis: 120px;">
      <span class="txt-x-small txt-subtle txt-uppercase">Data</span>
      <div class="txt-medium"><%= l(@bolla_visione.data_bolla, format: :short) %></div>
    </div>
    <div class="flex-item-grow" style="flex-basis: 120px;">
      <span class="txt-x-small txt-subtle txt-uppercase">Collana</span>
      <div class="txt-medium"><%= @bolla_visione.collana.nome %></div>
    </div>
    <% if @bolla_visione.contatto.present? %>
      <div class="flex-item-grow" style="flex-basis: 120px;">
        <span class="txt-x-small txt-subtle txt-uppercase">Contatto</span>
        <div class="txt-medium"><%= link_to @bolla_visione.contatto.nome_completo, persona_path(@bolla_visione.contatto) %></div>
        <% if @bolla_visione.contatto.classi.any? %>
          <div class="txt-x-small txt-subtle"><%= @bolla_visione.contatto.classi.map(&:nome_breve).join(", ") %></div>
        <% end %>
        <% if @bolla_visione.contatto.email.present? %>
          <% mail_subject = "Bolla visione #{@bolla_visione.collana.nome} - #{@bolla_visione.scuola.denominazione}" %>
          <div class="txt-x-small"><%= mail_to @bolla_visione.contatto.email, @bolla_visione.contatto.email, subject: mail_subject %></div>
        <% end %>
      </div>
    <% end %>
  </div>

  <% if @bolla_visione.note.present? %>
    <p class="txt-small txt-subtle margin-block-start-half"><%= @bolla_visione.note %></p>
  <% end %>

  <div id="bolla_visione_righe_list">
    <% @righe.group_by { |r| @gruppo_per_libro[r.libro_id] }.each do |gruppo, righe_per_gruppo| %>
      <% targets = righe_per_gruppo.map { |r| @target_per_libro[r.libro_id] }.compact.flat_map { |t| t.split(",").map(&:strip) }.uniq %>
      <% classi_gruppo = @classi_per_anno.values_at(*targets).compact.flatten %>

      <div class="flex align-center gap-half margin-block-start">
        <h3 class="divider divider--fade txt-medium font-weight-black margin-none" style="flex: 1;">
          <%= gruppo.presence || "Altro" %>
        </h3>

        <%= render "persone/search_dialog", scuola: @bolla_visione.scuola,
        form_url: bolla_visione_persone_path(@bolla_visione),
        select_url: bolla_visione_path(@bolla_visione) %>
      </div>

      <ul class="flex flex-column unpad margin-none">
        <% righe_per_gruppo.each do |riga| %>
          <% riga_targets = @target_per_libro[riga.libro_id].to_s.split(",").map(&:strip) %>
          <% riga_classi = @classi_per_anno.values_at(*riga_targets).compact.flatten %>
          <% riga_persone = riga_classi.any? ? Persona.docente.joins(:classi).where(classi: { id: riga_classi.map(&:id) }).distinct.order(:cognome) : Persona.none %>
          <%= render "bolla_visione_righe/bolla_visione_riga", riga: riga, classi: riga_classi, persone: riga_persone %>
        <% end %>
      </ul>
    <% end %>
  </div>

  <div id="bolla_visione_righe_form">
    <%= form_with url: bolla_visione_bolla_visione_righe_path(@bolla_visione), scope: :bolla_visione_riga, class: "margin-block-start" do |f| %>
      <div class="flex gap-half align-center">
        <div class="form-field cb-tax" style="flex: 1;">
          <%= combobox_tag "bolla_visione_riga[libro_id]", libri_path,
              placeholder: "Aggiungi libro...",
              mobile_at: "0px" %>
        </div>
        <%= f.button type: :submit, class: "btn btn--link btn--circle-mobile" do %>
          <%= icon_tag "add", size: "small" %>
          <span>Aggiungi</span>
        <% end %>
      </div>
    <% end %>
  </div>

  <div id="bolla_visione_totale" class="flex justify-space-between align-center margin-block-start pad-block txt-medium font-weight-black" style="border-block-start: 2px solid var(--color-ink-light);">
    <span>Totale copie</span>
    <span><%= @bolla_visione.bolla_visione_righe.sum(:quantita) %></span>
  </div>
</section>
