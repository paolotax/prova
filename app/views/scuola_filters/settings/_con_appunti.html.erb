<% filter = user_filtering.filter %>

<%= tag.div class: class_names("quick-filter quick-filter--checkbox", { "quick-filter--active": filter.con_appunti? }),
      data: { filter_show: true } do %>
  <label class="btn input input--select flex-inline txt-x-small gap-half">
    <%= check_box_tag :con_appunti, "true", filter.con_appunti?,
          class: "checkbox",
          data: {
            filter_settings_target: "field",
            action: "change->filter-settings#change change->form#submit"
          } %>
    <span>Con appunti</span>
  </label>
<% end %>
