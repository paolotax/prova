<% content_for :hide_footer, true %>
<% @page_title = @giro.titolo %>

<%= content_for :header do %>
  <div class="header__actions header__actions--start">
    <%= link_to giri_path, class: "btn" do %>
      <%= icon_tag "arrow-left", size: "small" %>
      <span class="for-screen-reader">Indietro</span>
    <% end %>
  </div>

  <h1 class="header__title divider divider--fade full-width">
    <span class="overflow-ellipsis">Giro: <%= @giro.titolo %></span>
    
  </h1>

  <div class="header__actions header__actions--end">
    <%= link_to edit_giro_path(@giro),
        class: "btn",
        data: hotwire_native_app? ? {} : { turbo_frame: :modal, action: "click->dialog#open" } do %>
      <%= icon_tag "pencil", size: "small" %>
      <span class="for-screen-reader">Modifica</span>
    <% end %>

    <%= button_to giro_generate_tappe_path(@giro),
        method: :post,
        class: "btn btn--link",
        data: { turbo_confirm: "Generare tappe per tutte le scuole elementari?" } do %>
      <%= icon_tag "add", size: "small" %>
      <span class="hide-on-touch">Genera tappe</span>
    <% end %>

    <% if @giro.can_delete? %>
      <%= button_to giro_path(@giro),
          method: :delete,
          class: "btn btn--negative",
          data: { turbo_confirm: "Eliminare questo giro?" } do %>
        <%= icon_tag "trash", size: "small" %>
        <span class="for-screen-reader">Elimina</span>
      <% end %>
    <% end %>
  </div>
<% end %>

<div id="<%= dom_id(@giro, "show") %>" class="giro-board"
     data-controller="tappa-dropzone"
     data-tappa-dropzone-giro-id-value="<%= @giro.id %>">

  <%# Colonna: Da programmare %>
  <div class="giro-board__column">
    <div class="giro-board__column-header">
      <h2 class="txt-bold">Da programmare</h2>
      <span class="badge"><%= @conteggio_da_programmare %></span>
    </div>

    <div class="giro-board__column-body">
      <% if @tappe_da_programmare&.any? %>
        <% @tappe_da_programmare.each do |data, comuni| %>
          <%= render "tappe_del_giorno", data: data, comuni: comuni %>
        <% end %>
      <% end %>
    </div>

    <% if @giro.excluded_ids.present? %>
      <details class="giro-board__excluded">
        <summary class="txt-small txt-subtle">
          <%= pluralize(@giro.excluded_ids.count, "scuola", "scuole") %> escluse
        </summary>
        <div class="flex flex-wrap gap-quarter pad-block-half">
          <% current_account.scuole.where(id: @giro.excluded_ids).order(:posizione).each do |scuola| %>
            <div class="giro-board__badge">
              <%= link_to scuola.denominazione, scuola_path(scuola), class: "txt-x-small" %>
              <%= button_to include_school_giro_path(@giro, school_id: scuola.id),
                  method: :post,
                  class: "btn btn--circle btn--plain",
                  style: "--btn-size: 1.4em;",
                  data: { turbo_confirm: "Includere questa scuola nel giro?" } do %>
                <%= icon_tag "add", class: "icon--small" %>
              <% end %>
            </div>
          <% end %>
        </div>
      </details>
    <% end %>
  </div>

  <%# Colonna: Programmate %>
  <div class="giro-board__column">
    <div class="giro-board__column-header">
      <h2 class="txt-bold">Programmate</h2>
      <span class="badge"><%= @tappe_programmate.sum { |_d, c| c.values.flatten.count } %></span>
    </div>

    <%= form_tag bulk_create_tappe_giro_path(@giro.id),
        data: { tappa_dropzone_target: "form" },
        class: "giro-board__dropzone-form" do %>
      <%= hidden_field_tag :giro_id, @giro.id %>
      <div class="giro-board__dropzone" data-tappa-dropzone-target="dropzone">
        <p class="txt-small txt-subtle txt-center">Trascina qui le scuole</p>
      </div>
      <div class="flex gap-half margin-block-start-half">
        <%= date_field_tag :data, nil, class: "input input--date txt-small", required: true, data: { tappa_dropzone_target: "date" } %>
        <%= button_tag "Crea tappe", type: "submit", class: "btn btn--link txt-small" %>
      </div>
    <% end %>

    <div class="giro-board__column-body">
      <% if @tappe_programmate&.any? %>
        <% @tappe_programmate.each do |data, comuni| %>
          <%= render "tappe_del_giorno", data: data, comuni: comuni %>
        <% end %>
      <% end %>
    </div>
  </div>

  <%# Colonna: Completate %>
  <div class="giro-board__column">
    <div class="giro-board__column-header">
      <h2 class="txt-bold">Completate</h2>
      <span class="badge"><%= @tappe_completate.sum { |_d, c| c.values.flatten.count } %></span>
    </div>

    <div class="giro-board__column-body">
      <% if @tappe_completate&.any? %>
        <% @tappe_completate.each do |data, comuni| %>
          <%= render "tappe_del_giorno", data: data, comuni: comuni %>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
