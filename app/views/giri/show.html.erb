<% content_for :hide_footer, true %>
<% @page_title = @giro.titolo %>

<% content_for :header do %>
  <div class="header__actions header__actions--start">
    <%= link_to giri_path, class: "btn btn--back" do %>
      <%= icon_tag "arrow-left" %>
      <span>Giri</span>
    <% end %>
  </div>

  <h1 class="header__title divider divider--fade full-width" style="min-inline-size: 0;">
    <div style="position: relative;"
         data-controller="dialog"
         data-action="keydown.esc->dialog#close click@document->dialog#closeOnClickOutside">
      <button type="button"
              style="background: transparent; border: 0; padding: 0; color: inherit; font: inherit; cursor: pointer; display: inline-flex; align-items: center; gap: 0.5em; max-inline-size: 100%;"
              data-action="dialog#toggle">
        <span style="background: <%= @giro.color %>; border-radius: 50%; display: inline-block; block-size: 0.6em; inline-size: 0.6em; flex-shrink: 0;"></span>
        <span style="overflow: hidden; text-overflow: ellipsis; white-space: nowrap; min-inline-size: 0;"><%= @giro.titolo %></span>
        <%= icon_tag "caret-down", style: "--icon-size: 0.6em;" %>
      </button>

      <dialog class="popup panel fill-white shadow txt-small" data-dialog-target="dialog">
        <ul class="popup__list">
          <% current_user.giri.attivi.where.not(id: @giro.id).order(created_at: :desc).each do |g| %>
            <li class="popup__item">
              <%= link_to giro_path(g),
                  class: "popup__btn btn flex align-center gap-half",
                  data: { turbo_frame: "_top", action: "click->dialog#close" } do %>
                <span style="background: <%= g.color %>; border-radius: 50%; display: inline-block; block-size: 0.6em; inline-size: 0.6em; flex-shrink: 0;"></span>
                <span class="overflow-ellipsis"><%= g.titolo %></span>
              <% end %>
            </li>
          <% end %>
        </ul>
      </dialog>
    </div>
  </h1>

  <div class="header__actions header__actions--end">
    <%= link_to edit_giro_path(@giro), class: "btn btn--circle borderless",
        data: { turbo_frame: :modal, controller: "tooltip" } do %>
      <%= icon_tag "pencil", class: "icon--small" %>
      <span class="for-screen-reader">Modifica giro</span>
    <% end %>

    <% if @giro.can_delete? %>
      <%= button_to giro_path(@giro), method: :delete,
          class: "btn btn--circle btn--plain txt-negative",
          data: { turbo_confirm: "Eliminare questo giro?" } do %>
        <%= icon_tag "trash", class: "icon--small" %>
      <% end %>
    <% end %>
  </div>
<% end %>

<%= render "giri/planner", giro: @giro, tappe_per_area: @tappe_per_area, total_count: @planner_total %>

<%= render "giri/info_panel", giro: @giro, giorni_timeline: @giro.giorni_timeline(@tappe_per_giorno), tappe_totali: @giro.tappe_totali, tappe_completate: @giro.tappe_completate %>

<% if @giro.settimane.any? %>
  <div class="agenda-calendar">
    <div id="weeks-container">
      <% @giro.settimane.each do |settimana| %>
        <%= render "agenda/week",
            settimana: settimana,
            tappe_per_giorno: @tappe_per_giorno,
            altre_tappe_per_giorno: @altre_tappe_per_giorno %>
      <% end %>
    </div>
  </div>
<% else %>
  <div class="blank-slate margin-block-start">
    Imposta le date del giro (dal/al) per visualizzare il calendario.
  </div>
<% end %>
