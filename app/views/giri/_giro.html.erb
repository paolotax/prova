<%# locals: (giro:) -%>

<% totali = giro.tappe.size %>
<% completate = giro.tappe.completate.size %>
<% percentuale = totali > 0 ? (completate * 100.0 / totali).round : 0 %>
<% completo = totali > 0 && completate == totali %>

<%= link_to giro_path(giro), id: dom_id(giro),
    class: class_names("giro-item", "giro-item--complete": completo),
    style: "--giro-color: #{giro.color};",
    data: { turbo_frame: "_top" } do %>

  <div class="giro-item__main">
    <span class="giro-item__dot"></span>
    <h3 class="giro-item__title"><%= giro.titolo %></h3>
    <% if totali > 0 %>
      <span class="giro-item__count"><%= completate %>/<%= totali %></span>
    <% end %>
  </div>

  <% if giro.descrizione.present? %>
    <p class="giro-item__desc"><%= giro.descrizione %></p>
  <% end %>

  <div class="giro-item__sub">
    <% if giro.iniziato_il.present? %>
      <span><%= l giro.iniziato_il, format: "%-d %b" %> — <%= l giro.finito_il, format: "%-d %b" %></span>
    <% end %>
    <% if giro.tipo_giro.present? %>
      <span class="giro-item__tipo"><%= t("giri.tipi.#{giro.tipo_giro}", default: giro.tipo_giro.humanize) %></span>
    <% end %>
    <% if giro.collana.present? %>
      <span class="giro-item__collana"><%= giro.collana.nome %></span>
    <% end %>
  </div>

  <% if totali > 0 %>
    <div class="giro-item__progress-bar">
      <div class="giro-item__progress-fill" style="inline-size: <%= percentuale %>%;"></div>
    </div>
  <% end %>
<% end %>
