<%= turbo_frame_tag :modal do %>
  <div data-controller="dialog"
       data-dialog-modal-value="true"
       data-dialog-auto-open-value="true">
    <dialog class="dialog panel shadow" style="--panel-size: 36rem;"
            data-dialog-target="dialog"
            data-action="keydown.esc->dialog#close:stop">
      <h3 class="txt-medium txt-bold margin-block-end-half">Genera tappe</h3>
      <p class="txt-small txt-subtle margin-block-end">
        Seleziona le scuole da aggiungere al giro.
      </p>

      <%= form_with url: giro_tappe_generazione_path(@giro), method: :post,
          class: "flex flex-column gap",
          data: { controller: "scuole-tree",
                  scuole_tree_submit_template_value: "Genera {count} tappe",
                  action: "turbo:submit-end->dialog#close" } do |f| %>

        <div class="wizard__school-list" style="max-block-size: 55vh;">
          <%= render "giri/scuole_tree",
              gerarchia: @gerarchia,
              scuole_scartate: @scuole_scartate,
              initial_checked: false %>
        </div>

        <div class="flex gap-half justify-center margin-block-start">
          <button type="button" class="btn" data-action="dialog#close">Annulla</button>
          <%= f.submit "Genera 0 tappe", class: "btn btn--link", disabled: true,
              data: { scuole_tree_target: "submit" } %>
        </div>
      <% end %>
    </dialog>
  </div>
<% end %>
