<%# locals: (data:, comuni:) -%>

<div class="giro-board__day">
  <% if data %>
    <div class="giro-board__day-header">
      <%= link_to giorno_path(data), class: "txt-small txt-bold" do %>
        <%= l(data, format: :long) %>
      <% end %>
      <span class="badge badge--small"><%= comuni.values.flatten.count %></span>
    </div>
  <% end %>

  <% comuni.each do |comune, items| %>
    <div class="giro-board__comune">
      <span class="txt-x-small txt-subtle txt-bold"><%= comune %></span>
      <div class="flex flex-wrap gap-quarter">
        <% items.each do |item| %>
          <% scuola = item.respond_to?(:tappable) ? item.tappable : item %>
          <div class="giro-board__badge"
               id="<%= item.respond_to?(:tappable) ? dom_id(item) : nil %>"
               draggable="true"
               data-school-id="<%= scuola.id %>"
               data-tappable-type="Scuola"
               data-tappa-id="<%= item.respond_to?(:tappable) ? item.id : nil %>"
               data-action="dragstart->tappa-dropzone#handleDragStart dragend->tappa-dropzone#handleDragEnd">

            <%= link_to scuola.denominazione, scuola_path(scuola), class: "txt-x-small" %>

            <% if item.respond_to?(:tappable) %>
              <%= button_to remove_tappa_giro_path(@giro, tappa_id: item),
                  method: :delete,
                  class: "btn btn--circle btn--plain",
                  style: "--btn-size: 1.4em;",
                  data: { turbo_confirm: "Rimuovere questa tappa?" } do %>
                <%= icon_tag "close", class: "icon--small" %>
              <% end %>
            <% elsif data.nil? %>
              <%= button_to exclude_school_giro_path(@giro, school_id: scuola.id),
                  method: :post,
                  class: "btn btn--circle btn--plain",
                  style: "--btn-size: 1.4em;",
                  data: { turbo_confirm: "Escludere questa scuola?" } do %>
                <%= icon_tag "close", class: "icon--small" %>
              <% end %>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
