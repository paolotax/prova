<% @page_title = "Giri" %>

<% content_for :header do %>
  <div class="header__actions header__actions--start"></div>

  <h1 class="header__title divider divider--fade full-width">
    <span class="overflow-ellipsis">Giri</span>
  </h1>

  <div class="header__actions header__actions--end">
    <%= link_to url_for(controller: "giri", action: "new", model: nil),
        class: "btn btn--primary",
        data: hotwire_native_app? ? {} : { turbo_frame: :modal, action: "click->dialog#open" } do %>
      <%= icon_tag "add", size: "small" %>
      <span class="for-screen-reader">Nuovo Giro</span>
    <% end %>
  </div>
<% end %>

<%= turbo_stream_from current_user, "giri" %>

<%= link_to "Nuovo Giro", new_giro_path, data: { controller: "bridge--button", bridge_title: "Nuovo" }, class: "hidden" %>

<div id="giri-lista" role="list" class="py-5 grid grid-cols-1 lg:grid-cols-2 gap-x-6 gap-y-2 xl:gap-x-8">
	<p class="only:block hidden py-8  px-4 lg:col-span-2 2xl:col-span-3 text-center mx-auto">Whoops! Non ci sono giri organizzati.</p>									
	<%= render @giri %>
</div>












