<% @page_title = "Nuovo giro" %>

<% content_for :header do %>
  <div class="header__actions header__actions--start">
    <%= link_to giri_path, class: "btn btn--back" do %>
      <%= icon_tag "arrow-left" %>
      <span>Giri</span>
    <% end %>
  </div>

  <h1 class="header__title divider divider--fade full-width">
    <span class="overflow-ellipsis">Nuovo giro</span>
  </h1>

  <div class="header__actions header__actions--end"></div>
<% end %>

<%= form_tag create_wizard_giri_path, method: :post, id: "wizard-form",
    data: { controller: "wizard", wizard_step_value: "tipo" } do %>

  <div class="wizard">
    <!-- Steps indicator -->
    <nav class="wizard__steps-bar">
      <ol class="wizard__steps">
        <li class="wizard__step wizard__step--active" data-wizard-target="stepIndicator" data-step="tipo">
          <span class="wizard__step-number">1</span>
          <span class="wizard__step-label">Tipo</span>
        </li>
        <li class="wizard__step" data-wizard-target="stepIndicator" data-step="info">
          <span class="wizard__step-number">2</span>
          <span class="wizard__step-label">Dettagli</span>
        </li>
        <li class="wizard__step" data-wizard-target="stepIndicator" data-step="scuole">
          <span class="wizard__step-number">3</span>
          <span class="wizard__step-label">Scuole</span>
        </li>
        <li class="wizard__step" data-wizard-target="stepIndicator" data-step="riepilogo">
          <span class="wizard__step-number">4</span>
          <span class="wizard__step-label">Conferma</span>
        </li>
      </ol>
    </nav>

    <!-- Main content -->
    <div class="wizard__content">
      <!-- Step 1: Tipo giro -->
      <div class="wizard__panel" data-wizard-target="panel" data-step="tipo">
        <div class="wizard__panel-header">
          <h3 class="wizard__heading">Che tipo di giro vuoi creare?</h3>
          <p class="wizard__subheading">Scegli il tipo di giro per iniziare</p>
        </div>
        <div class="wizard__options">
          <% [
            ["kit_adozioni", "Kit adozioni", "Consegna kit nelle scuole con le tue adozioni", "book"],
            ["collane", "Consegna collane", "Porta le collane in visione nelle scuole", "clipboard"],
            ["ritiro_collane", "Ritiro collane", "Ritira le collane date in visione", "arrow-left"],
            ["consegne", "Consegne", "Consegna documenti e DDT", "truck"],
            ["visite", "Visite", "Giro di visite commerciali", "marker"]
          ].each do |value, label, desc, icon_name| %>
            <label class="wizard__option" data-action="click->wizard#selectTipo">
              <%= radio_button_tag :tipo_giro, value, false,
                  data: { wizard_target: "tipoInput" }, class: "for-screen-reader" %>
              <span class="wizard__option-icon"><%= icon_tag icon_name %></span>
              <span class="wizard__option-text">
                <span class="wizard__option-label"><%= label %></span>
                <span class="wizard__option-desc"><%= desc %></span>
              </span>
              <span class="wizard__option-check"><%= icon_tag "check" %></span>
            </label>
          <% end %>
        </div>
      </div>

      <!-- Step 2: Info giro -->
      <div class="wizard__panel" data-wizard-target="panel" data-step="info" hidden>
        <div class="wizard__panel-header">
          <h3 class="wizard__heading">Dettagli del giro</h3>
          <p class="wizard__subheading">Imposta titolo, date e colore</p>
        </div>
        <div class="wizard__form">
          <div class="wizard__field">
            <label class="wizard__label">Titolo</label>
            <%= text_field_tag :titolo, "", class: "input", placeholder: "Es. Kit Adozioni Settembre", data: { wizard_target: "titoloInput" } %>
          </div>

          <div class="wizard__field">
            <label class="wizard__label">Descrizione</label>
            <%= text_area_tag :descrizione, "", class: "input", rows: 3, placeholder: "Note o dettagli sul giro..." %>
          </div>

          <div class="wizard__field" data-wizard-target="collanaField" hidden>
            <label class="wizard__label">Collana</label>
            <%= select_tag :collana_id,
                options_from_collection_for_select(@collane, :id, :nome),
                include_blank: "Seleziona collana...",
                class: "input input--select" %>
          </div>

          <div class="wizard__field-row">
            <div class="wizard__field">
              <label class="wizard__label">Data inizio</label>
              <%= date_field_tag :iniziato_il, Date.today, class: "input" %>
            </div>
            <div class="wizard__field">
              <label class="wizard__label">Data fine</label>
              <%= date_field_tag :finito_il, 4.weeks.from_now.to_date, class: "input" %>
            </div>
          </div>

          <div class="wizard__field">
            <label class="wizard__label">Colore</label>
            <div class="wizard__colors">
              <% Color::COLORS.each do |color| %>
                <label class="wizard__color-swatch" style="--swatch-color: <%= color.value %>;">
                  <%= radio_button_tag :color, color.value, color.value == "var(--color-card-default)", class: "for-screen-reader" %>
                  <span class="wizard__color-check"><%= icon_tag "check" %></span>
                </label>
              <% end %>
            </div>
          </div>
        </div>
      </div>

      <!-- Step 3: Scuole (loaded via Turbo Frame) -->
      <div class="wizard__panel" data-wizard-target="panel" data-step="scuole" hidden>
        <%= turbo_frame_tag "wizard_scuole" do %>
          <div class="wizard__panel-header">
            <h3 class="wizard__heading">Scuole</h3>
            <p class="wizard__subheading">Caricamento...</p>
          </div>
        <% end %>
      </div>

      <!-- Step 4: Riepilogo (loaded via Turbo Frame) -->
      <div class="wizard__panel" data-wizard-target="panel" data-step="riepilogo" hidden>
        <%= turbo_frame_tag "wizard_riepilogo" do %>
          <div class="wizard__panel-header">
            <h3 class="wizard__heading">Riepilogo</h3>
            <p class="wizard__subheading">Caricamento...</p>
          </div>
        <% end %>
      </div>

      <!-- Footer navigation -->
      <div class="wizard__footer">
        <button type="button" class="btn" data-action="wizard#prevStep"
                data-wizard-target="prevBtn" hidden>
          <%= icon_tag "arrow-left" %> Indietro
        </button>
        <button type="button" class="btn btn--link" data-action="wizard#nextStep"
                data-wizard-target="nextBtn">
          Avanti <%= icon_tag "arrow-right" %>
        </button>
        <button type="submit" class="btn btn--link" data-wizard-target="submitBtn" hidden
                data-turbo-submits-with="Creazione in corso...">
          Crea giro <%= icon_tag "check" %>
        </button>
      </div>
    </div>
  </div>
<% end %>
