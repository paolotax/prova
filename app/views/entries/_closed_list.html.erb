<%# locals: (closed_entries:, frame_id: nil, group_by: :month) -%>

<% content = capture do %>
  <% if closed_entries.any? %>
    <% months = I18n.t("date.month_names").compact %>
    <% grouped = closed_entries.group_by { |e|
         d = e.entryable_type == "Documento" && e.entryable&.data_documento ? e.entryable.data_documento : e.created_at
         group_by == :month ? [d.year, d.month] : [d.year]
       }
       .sort_by { |key, _| key.map { |k| -k } } %>

    <div data-controller="bulk-actions" data-action="click->bulk-actions#toggleCard">
      <div class="group-header margin-block-start">
        <h4 class="group-header__title divider divider--fade txt-small txt-subtle txt-uppercase margin-none">
          Chiusi <span class="txt-xx-small"><span data-bulk-actions-target="listCounter">(<%= closed_entries.size %>)</span></span>
        </h4>
        <div class="group-header__actions group-header__actions--end">
          <button type="button" class="btn btn--circle" data-action="bulk-actions#enterSelectionMode"
              data-controller="tooltip" data-tooltip-content-value="Seleziona">
            <%= icon_tag "check-circle" %>
            <span class="for-screen-reader">Seleziona</span>
          </button>
        </div>
      </div>

      <%= render "entries/bulk_bar/bar" %>

      <% grouped.each do |key, group_entries| %>
        <div class="group-header margin-block-start">
          <h4 class="group-header__title divider divider--fade txt-small txt-subtle txt-uppercase margin-none">
            <% if group_by == :month %>
              <%= months[key[1] - 1] %> <%= key[0] %>
            <% else %>
              <%= key[0] %>
            <% end %>
            <span class="txt-xx-small">(<%= group_entries.size %>)</span>
          </h4>
        </div>
        <div class="cards cards--grid cards--in-context">
          <div class="cards__list">
            <% group_entries.each do |entry| %>
              <%= render "entries/entry", entry: entry, draggable: false %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
<% end %>

<% if frame_id %>
  <%= turbo_frame_tag frame_id do %><%= content %><% end %>
<% else %>
  <%= content %>
<% end %>
