<% content_for :title, "Adozioni" %>


<% content_for :head do %>
  <%= stylesheet_link_tag "tailwind", "inter-font", "data-turbo-track": "reload" %>
  <%= combobox_style_tag "data-turbo-track": "reload" %>
<% end %>

<% content_for :header do %>
	<%= render Heading::WithActionsComponent.new do |heading| %>

		<%# button export excel %>
		<% heading.with_action do %>
			<%= link_to url_for(controller: "import_adozioni", action: "index", format: :xlsx, params: request.query_parameters),
				class: "btn btn--positive",
				data: { controller: "link-modifier", link_modifier_target: "link" } do %>
				<%= icon_tag "document", size: "small" %>
				Excel
			<% end %>
		<% end %>

		<% heading.with_action do %>
			<%= link_to "javascript:history.back()", class: "btn" do %>
				<%= icon_tag "arrow-left", size: "small" %>
				Indietro
			<% end %>
		<% end %>

        <% heading.with_action do %>
            <%= tag.div class: "block xl:hidden" do %>
                <%= link_to filtra_import_adozioni_path(params: request.query_parameters),
                    class: "btn",
                    data: { controller: "link-modifier", link_modifier_target: "link", turbo_frame: "slide-over" } do %>
                    <%= icon_tag "funnel", size: "small" %>
                    Filtra
                <% end %>
            <% end %>
        <% end %>
		
		<%= h1 {"Adozioni"} %>

	<% end %>
<% end %>


<% if hotwire_native_app? %>
  <%= render "shared/native_search_filter",
      url: import_adozioni_path,
      filter_url: filtra_import_adozioni_path(params: request.query_parameters),
      placeholder: "Cerca adozioni..." %>
<% end %>

<%= turbo_frame_tag "search_results" do %>
	
	<div class="sticky hotwire-native:top-0 not-hotwire-native:top-[13rem] not-hotwire-native:sm:top-[182px]">
		<%= render partial: "import_adozioni/stats" %>
	</div>
	
	<%= tag.div class: "w-full flex flex-col xl:pr-[17rem]", data: {controller: 'bulk-actions'} do %>
				
		<div class="sticky z-20 hotwire-native:top-[calc(5rem+6px)] not-hotwire-native:top-[17rem] mb-2">
			<div class="flex items-center justify-center gap-3 px-4 pt-1 pb-3">
				<span class="text-sm font-medium text-gray-700">Raggruppa per:</span>
				<div class="inline-flex rounded-lg border border-gray-300 p-1 bg-gray-50">
					<%= link_to "Titolo",
							import_adozioni_path(request.query_parameters.merge(grouped_by: "titolo").except(:page)),
							data: { turbo_action: "advance" },
							class: "px-4 py-1.5 text-sm font-medium rounded-md transition-colors #{params[:grouped_by] == 'titolo' || params[:grouped_by].nil? ? 'bg-gray-900 text-white shadow-sm' : 'text-gray-700 hover:bg-gray-100'}" %>
					<%= link_to "Classe",
							import_adozioni_path(request.query_parameters.merge(grouped_by: "classe").except(:page)),
							data: { turbo_action: "advance" },
							class: "px-4 py-1.5 text-sm font-medium rounded-md transition-colors #{params[:grouped_by] == 'classe' ? 'bg-gray-900 text-white shadow-sm' : 'text-gray-700 hover:bg-gray-100'}" %>
				</div>
			</div>
		</div>

		<%= render "shared/active_filters", collection: @import_adozioni %>
		<%= render "import_adozioni/bulk_actions/form" %>

		<% if @page.used? %>
			<%= with_automatic_pagination :import_adozioni, @page, class: "w-full" do %>
				<%= render "grouped_adozioni", import_adozioni: @page.records, grouped_by: (params[:grouped_by] || 'titolo').to_sym %>
			<% end %>
		<% else %>
			<p class="py-8 px-4 text-center">
				Whoops! Non ci sono adozioni.
				<%= link_to "Devi impostare la Zona nel tuo profilo", user_path(current_user), data: { turbo_frame: "_top"}, class: "underline font-semibold" unless params[:search] || !current_user.import_scuole.empty? %>
			</p>
		<% end %>

	<% end %>

	<aside class="fixed inset-y-0 right-0 hidden w-80 overflow-y-auto pt-[17rem] xl:px-8 xl:block">
		<%= render partial: "filter_form", locals: { reload: true } %>
	</aside>


<% end %>



		

		





  


