<% @page_title = @tappable.denominazione %>

<% content_for :header do %>
  <div class="header__actions header__actions--start">
    <%= link_to "javascript:history.back()", class: "btn" do %>
      <%= icon_tag "arrow-left", size: "small" %>
      <span class="for-screen-reader">Indietro</span>
    <% end %>
  </div>

  <h1 class="header__title divider divider--fade full-width">
    <span class="overflow-ellipsis"><%= @tappable.denominazione %></span>
  </h1>

  <div class="header__actions header__actions--end">
    <%= link_to go_to_tappable_path(@tappable, 'google'),
        class: "btn", target: "_blank", data: { controller: "tooltip" } do %>
      <%= icon_tag "world", size: "small" %>
      <span class="for-screen-reader">Apri in Google Maps</span>
    <% end %>
  </div>
<% end %>

<div data-controller="mappa-posizione"
     data-mappa-posizione-mapbox-access-token="<%= ENV['MAPBOX_ACCESS_TOKEN'] %>"
     data-mappa-posizione-latitude="<%= @tappable.latitude %>"
     data-mappa-posizione-longitude="<%= @tappable.longitude %>"
     data-mappa-posizione-id="<%= @tappable.class.name.underscore %>-<%= @tappable.id %>"
     data-mappa-posizione-update-url-value="<%= mappe_path("#{@tappable.class.name.underscore}-#{@tappable.id}") %>"
     data-mappa-posizione-denominazione-value="<%= @tappable.denominazione %>"
     data-mappa-posizione-indirizzo-value="<%= @tappable.try(:indirizzo_completo) || @tappable.try(:indirizzo_navigator) || '' %>"
     style="position: relative; height: calc(100dvh - 4rem);">

  <div style="position: absolute; top: 0.5rem; left: 0.5rem; z-index: 1;">
    <select data-action="change->mappa-posizione#changeStyle"
            class="input txt-small" style="padding: 0.25rem 0.5rem; background-color: oklch(1 0 0 / 0.85); border-radius: 0.25rem;">
      <option value="satellite-streets-v12">Satellite e strade</option>
      <option value="streets-v12">Strade</option>
      <option value="satellite-v9">Satellite</option>
      <option value="outdoors-v12">Outdoors</option>
    </select>
  </div>

  <div id="map" data-mappa-posizione-target="map" style="height: 100%;"></div>

  <pre id="coordinates"
       data-mappa-posizione-target="coordinates"
       style="position: absolute; bottom: 0.5rem; left: 0.5rem; z-index: 1; background: oklch(0 0 0 / 0.6); color: white; padding: 0.25rem 0.5rem; margin: 0; font-size: var(--text-x-small); border-radius: 0.25rem;"></pre>
</div>
