<% @page_title = "Import MIUR #{anno_scolastico_label(@run.anno_scolastico)}" %>

<% content_for :header do %>
  <h1 class="header__title divider divider--fade full-width">
    <span class="overflow-ellipsis">Import <%= anno_scolastico_label(@run.anno_scolastico) %></span>
  </h1>
<% end %>

<div class="ca-page">
  <p class="txt-subtle">
    <%= link_to "← Tutti gli import", miur_import_runs_path(account_id: params[:account_id]) %>
    <% if @run.completed_at %>&middot; <%= l(@run.completed_at, format: :short) %><% end %>
    <% if @provincia %>&middot; provincia: <strong><%= @provincia %></strong>
      (<%= link_to "tutte", miur_import_run_path(@run, account_id: params[:account_id]) %>)<% end %>
  </p>

  <div class="badges">
    <span class="badge"><%= @esistenti.count %> esistenti (rettifiche)</span>
    <span class="badge"><%= @nuove_count %> nuove</span>
    <span class="badge"><%= @sparite.count %> sparite</span>
  </div>

  <% unless @run.diff? %>
    <p class="notice">Nessun diff per questo import (primo import dell'anno o nessuna differenza).</p>
  <% end %>

  <% if @riepilogo_province.any? %>
    <section class="margin-block-end">
      <h2 class="txt-medium">Riepilogo per provincia</h2>
      <table class="libri-table txt-small">
        <thead>
          <tr>
            <th class="pad-inline">Provincia</th>
            <th class="pad-inline">Categoria</th>
            <th class="pad-inline txt-align-end">Scuole</th>
            <th class="pad-inline txt-align-end">+ righe</th>
            <th class="pad-inline txt-align-end">− righe</th>
          </tr>
        </thead>
        <tbody>
          <% @riepilogo_province.sort_by { |prov, cat, *| [prov.to_s, cat] }.each do |prov, cat, n, agg, rim| %>
            <tr>
              <td class="pad-inline">
                <%= link_to prov.presence || "—",
                      miur_import_run_path(@run, account_id: params[:account_id], provincia: prov) %>
              </td>
              <td class="pad-inline"><%= cat %></td>
              <td class="pad-inline txt-align-end"><%= n %></td>
              <td class="pad-inline txt-align-end"><%= agg.to_i %></td>
              <td class="pad-inline txt-align-end"><%= rim.to_i %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </section>
  <% end %>

  <% if @esistenti.any? %>
    <section class="margin-block-end">
      <h2 class="txt-medium">Scuole con rettifiche</h2>
      <% if @provincia %>
        <%= button_to "Ri-reconcilia #{@provincia}",
              miur_import_run_reconcile_path(@run, account_id: params[:account_id], provincia: @provincia),
              method: :post, class: "btn btn--small" %>
      <% end %>
      <table class="libri-table txt-small">
        <thead>
          <tr>
            <th class="pad-inline">Codice scuola</th>
            <th class="pad-inline">Provincia</th>
            <th class="pad-inline">Grado</th>
            <th class="pad-inline txt-align-end">+ righe</th>
            <th class="pad-inline txt-align-end">− righe</th>
          </tr>
        </thead>
        <tbody>
          <% @esistenti.each do |s| %>
            <tr>
              <td class="pad-inline">
                <%= link_to s.codicescuola,
                      miur_import_run_path(@run, account_id: params[:account_id],
                                           provincia: @provincia, codicescuola: s.codicescuola) %>
              </td>
              <td class="pad-inline"><%= s.provincia %></td>
              <td class="pad-inline"><%= s.tipogradoscuola %></td>
              <td class="pad-inline txt-align-end"><%= s.righe_aggiunte %></td>
              <td class="pad-inline txt-align-end"><%= s.righe_rimosse %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </section>
  <% end %>

  <% if @nuove_count.positive? %>
    <section class="margin-block-end">
      <h2 class="txt-medium">Scuole nuove</h2>
      <p class="txt-subtle">
        <%= @nuove_count %> scuole comparse ora nel MIUR.
        <%= link_to "Promuovile dal Controllo adozioni →",
              controllo_adozioni_index_path(account_id: params[:account_id]) %>
      </p>
    </section>
  <% end %>

  <% if @sparite.any? %>
    <section class="margin-block-end">
      <h2 class="txt-medium">Scuole sparite (possibili cambi codice)</h2>
      <div class="badges">
        <% @sparite.each do |s| %>
          <span class="badge"><%= s.codicescuola %><%= " · #{s.provincia}" if s.provincia %></span>
        <% end %>
      </div>
    </section>
  <% end %>

  <% if @scuola_focus.present? %>
    <section class="margin-block-end">
      <h2 class="txt-medium">Dettaglio righe: <%= @scuola_focus %></h2>

      <% if @sostituzioni.present? && @sostituzioni.any? %>
        <p class="notice notice--warning">
          <%= @sostituzioni.size %> sostituzioni da verificare
          (stessa classe: un ISBN tolto e uno aggiunto).
        </p>
      <% end %>

      <table class="libri-table txt-small">
        <thead>
          <tr>
            <th class="pad-inline"></th>
            <th class="pad-inline">Classe</th>
            <th class="pad-inline">Disciplina</th>
            <th class="pad-inline">ISBN</th>
            <th class="pad-inline">Titolo</th>
          </tr>
        </thead>
        <tbody>
          <% @righe.each do |r| %>
            <tr>
              <td class="pad-inline"><strong><%= r.segno %></strong></td>
              <td class="pad-inline"><%= "#{r.annocorso}#{r.sezioneanno}" %></td>
              <td class="pad-inline"><%= r.disciplina %></td>
              <td class="pad-inline"><%= r.codiceisbn %></td>
              <td class="pad-inline"><%= r.titolo %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </section>
  <% end %>
</div>
