<% @page_title = "Statistiche" %>

<% content_for :header do %>
  <div class="header__actions header__actions--start"></div>

  <h1 class="header__title divider divider--fade full-width">
    <span class="overflow-ellipsis">Statistiche</span>
  </h1>

  <div class="header__actions header__actions--end">
    <% if policy(Stat).create? %>
      <%= link_to new_stat_path, class: "btn btn--link", data: { controller: "tooltip", tooltip_content_value: "Nuova statistica" } do %>
        <%= icon_tag "add", size: "small" %>
        <span class="for-screen-reader">Nuova statistica</span>
      <% end %>
    <% end %>
  </div>
<% end %>

<div class="stats-container">

<% if current_user.admin? %>
  <%= render "stats/admin_bar",
      stati_filtro: @stati_filtro,
      counts_per_stato: @counts_per_stato,
      stats_in_errore: @stats_in_errore %>
<% end %>

<nav class="stats-nav" aria-label="Categorie statistiche">
  <% admin_extra = current_user.admin? ? { stati: @stati_filtro } : {} %>


    <%= link_to stats_path(admin_extra), class: "stats-nav__link #{'is-active' if params[:categoria].blank?}" do %>
      <%= icon_tag "globe", class: "icon--small" %>
      <span>Tutte</span>
    <% end %>


  <% [
       ["utenti",    "Le mia zona", "cash"],
       ["editori",   "Per editore",     "building-library"],
       ["province",  "Per provincia",   "mappa"],
       ["titoli",    "Per titolo",      "book"],
       ["operativo", "Operativo",       "chart"],
       ["altre", "Altre", "bell"]
     ].each do |cat, label, icon| %>
    <% next if (@counts_per_categoria[cat].to_i.zero?) && !current_user.admin? %>
    <%= link_to stats_path(admin_extra.merge(categoria: cat)),
                class: "stats-nav__link #{'is-active' if params[:categoria] == cat}" do %>
      <%= icon_tag icon, class: "icon--small" %>
      <span><%= label %></span>
      <% if (n = @counts_per_categoria[cat].to_i) > 0 %>
        <span class="txt-small txt-subtle">(<%= n %>)</span>
      <% end %>
    <% end %>
  <% end %>
</nav>

<%= turbo_frame_tag "search_results" do %>
  <% if @stats.any? %>
    <div class="stats-table">
      <table class="stats-table__table">
        <thead class="stats-table__header">
          <tr>
            <th class="stats-table__th"></th>
            <th class="stats-table__th">Categoria</th>
            <th class="stats-table__th">Descrizione</th>


            <% if current_user.admin? %>
              <th class="stats-table__th stats-table__td--hidden-mobile">Stato</th>
              <th class="stats-table__th stats-table__td--hidden-mobile">Sorgente</th>
              <th class="stats-table__th stats-table__td--hidden-mobile">Verifica</th>
              <th class="stats-table__th"></th>
              <th class="stats-table__th"></th>
            <% end %>
          </tr>
        </thead>

        <tbody data-controller="tax-sortable anchor-highlight" data-tax-sortable-group-value="stats"
               data-action="dragstart->tax-sortable#dragStart dragover->tax-sortable#dragOver dragenter->tax-sortable#dragEnter dragleave->tax-sortable#dragLeave drop->tax-sortable#drop dragend->tax-sortable#dragEnd">
          <%= render @stats %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="blank-slate blank-slate--empty">
      <h3 class="txt-large font-weight-bold">Nessuna statistica trovata</h3>
      <p class="txt-small txt-subtle margin-block-end">
        <% if params[:categoria].present? %>
          Non ci sono statistiche in questa categoria.
        <% else %>
          Inizia creando la prima statistica.
        <% end %>
      </p>
      <% if policy(Stat).create? && params[:categoria].blank? %>
        <%= link_to new_stat_path, class: "btn btn--primary" do %>
          <%= icon_tag "plus", size: "small" %>
          Crea Statistica
        <% end %>
      <% end %>
    </div>
  <% end %>
<% end %>

</div>
