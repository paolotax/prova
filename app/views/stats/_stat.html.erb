<%# locals: (stat:) -%>

<tr id="<%= dom_id stat %>"
    class="stats-table__row"
    draggable="<%= policy(stat).update? %>"
    data-tax-sortable-target="item"
    data-id="<%= stat.id %>"
    data-tax-sortable-update-url="<%= stat_position_path(stat) %>">

  <% if policy(stat).update? %>
    <td class="stats-table__td stats-table__td--actions">
      <div class="handle" style="cursor: move;">
        <%= icon_tag "drag-handle", class: "icon--small txt-subtle" %>
      </div>
    </td>
  <% end %>

  <td class="stats-table__td stats-table__td--actions">
    <%= link_to stat_path(stat), class: "stats-table__execute", data: { turbo_frame: "_top", controller: "tooltip", tooltip_content_value: "Esegui" } do %>
      <%= icon_tag "bolt", class: "icon--small" %>
    <% end %>
  </td>

  <td class="stats-table__td">
    <span class="txt-small font-weight-bold"><%= stat.categoria&.capitalize %></span>
  </td>

  <td class="stats-table__td">
    <div class="flex flex-column gap-quarter">
      <span class="font-weight-bold"><%= stat.titolo %></span>
      <% if stat.descrizione.present? %>
        <span class="txt-small txt-subtle"><%= stat.descrizione %></span>
      <% end %>
    </div>
  </td>

  <% if policy(stat).update? %>
    <td class="stats-table__td stats-table__td--hidden-mobile stats-table__td--stato">
      <div class="stats-stato-actions">
        <span class="chip chip--stato-<%= stat.stato %>"><%= stat.stato.capitalize %></span>
        <% (Stat::STATI - [stat.stato]).each do |s| %>
          <%= button_to stat_stato_path(stat), method: :patch, params: { stato: s },
                        class: "btn btn--small",
                        form_class: "inline-block",
                        data: { controller: "tooltip", tooltip_content_value: "Sposta in #{s.capitalize}" } do %>
            <%= { "produzione" => "→ Prod", "lab" => "→ Lab", "archiviata" => "→ Arch" }[s] %>
          <% end %>
        <% end %>
      </div>
    </td>

    <td class="stats-table__td stats-table__td--hidden-mobile">
      <% usa_new = stat.testo.to_s.match?(/\bnew_adozioni\b/i) %>
      <% usa_import = stat.testo.to_s.match?(/\bimport_adozioni\b/i) %>
      <% sorgente_label, sorgente_icon =
           if usa_new && usa_import then ["mix", "🟡"]
           elsif usa_new            then ["new", "🟢"]
           elsif usa_import         then ["import", "⚪"]
           else                          ["—", ""]
           end %>
      <span class="txt-small txt-subtle" title="<%= sorgente_label %>">
        <%= sorgente_icon %> <%= sorgente_label %>
      </span>
    </td>

    <td class="stats-table__td stats-table__td--hidden-mobile">
      <% if stat.ultima_verifica %>
        <span class="txt-small <%= 'txt-danger' if stat.ultimo_errore.present? %>"
              title="<%= l(stat.ultima_verifica, format: :long) %><%= " — #{stat.ultimo_errore.to_s.truncate(200)}" if stat.ultimo_errore.present? %>">
          <%= stat.ultimo_errore.present? ? "✗" : "✓" %>
          <%= time_ago_in_words(stat.ultima_verifica) %> fa
        </span>
      <% else %>
        <span class="txt-small txt-subtle">mai</span>
      <% end %>
    </td>

    <td class="stats-table__td stats-table__td--actions">
      <%= link_to edit_stat_path(stat), class: "btn btn--small", data: { turbo_frame: "_top", controller: "tooltip", tooltip_content_value: "Modifica SQL" } do %>
        <%= icon_tag "pencil", class: "icon--small" %>
      <% end %>
    </td>
  <% end %>
</tr>
