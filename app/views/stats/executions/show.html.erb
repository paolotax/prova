<%= turbo_frame_tag "stat_results" do %>
  <%
    extras_by_label = @stat.aggregazioni.select { |a| a[:kind] == :extra }.index_by { |a| a[:label] }

    format_extra = ->(value, format) do
      if value.nil?
        "—"
      elsif format == :pct
        number_to_percentage(value, precision: 1, separator: ",", delimiter: ".")
      else
        number_with_precision(value, precision: 3, separator: ",", delimiter: ".")
      end
    end

    format_cell = ->(value) do
      if value.is_a?(Integer)
        number_with_delimiter(value, delimiter: ".")
      elsif value.is_a?(Numeric)
        number_to_currency(value, unit: "", separator: ",", delimiter: ".")
      else
        value
      end
    end

    base_headers = (@result.first&.keys || []).reject { |h| @stat.raggruppa.include?(h) }
    columns_count = base_headers.size
  %>

  <div class="stats-result" data-controller="indice-tabella">

    <% if @stat.raggruppa.any? %>
      <div class="stats-result__filter print-hidden">
        <%= select_tag "group_index_select",
            options_for_select(@raggruppamento.keys.map { |r| [r.join(" → "), r.join.gsub(" ", "-").downcase] }),
            data: { action: "change->indice-tabella#changeGroup" },
            class: "field" %>
      </div>
    <% end %>

    <table class="stats-result__table">
      <tbody>
        <% @raggruppamento.each do |group, group_result| %>
          <% group_key = group.join.gsub(" ", "-").downcase %>
          <% agg = Stats::Aggregator.call(group_result, @stat.aggregazioni, grand_totals: @grand_totals) %>
          <% extras_by_label_in_agg = agg.extras.index_by(&:label) %>

          <%# Group title %>
          <tr data-group="<%= group_key %>" class="stats-result__group-title">
            <th colspan="<%= columns_count %>" class="stats-result__group-name">
              <%= group.join(" → ") %>
            </th>
          </tr>

          <%# Column headers %>
          <tr data-group="<%= group_key %>">
            <% base_headers.each do |header| %>
              <th class="stats-result__th"><%= header.humanize %></th>
            <% end %>
          </tr>

          <%# Data rows (valori dal SQL, niente sovrascritture) %>
          <% group_result.each do |row| %>
            <%= tag.tr class: ["stats-result__row", ("is-highlighted" if @miei_editori.include?(row["editore"]))],
                       data: { group: group_key } do %>
              <% base_headers.each do |header| %>
                <td class="stats-result__td"><%= format_cell.call(row[header]) %></td>
              <% end %>
            <% end %>
          <% end %>

          <%# Totals row: :extra ha priorità su :col, fallback vuoto %>
          <tr data-group="<%= group_key %>" class="stats-result__footer">
            <% base_headers.each do |header| %>
              <th class="stats-result__th">
                <% if (extra = extras_by_label_in_agg[header]) %>
                  <%= format_extra.call(extra.value, extra.format) %>
                <% elsif (value = agg.cells[header]) %>
                  <%= format_cell.call(value) %>
                <% end %>
              </th>
            <% end %>
          </tr>
        <% end %>
      </tbody>

      <%# Grand total — fuori dal tbody, non viene filtrato da indice-tabella %>
      <% if @raggruppamento.any? %>
        <% grand_agg = Stats::Aggregator.call(@result, @stat.aggregazioni, grand_totals: @grand_totals) %>
        <% grand_extras_by_label = grand_agg.extras.index_by(&:label) %>
        <tfoot class="stats-result__grand">
          <tr class="stats-result__group-title">
            <th colspan="<%= columns_count %>" class="stats-result__group-name">Totale generale</th>
          </tr>
          <tr class="stats-result__footer">
            <% base_headers.each do |header| %>
              <th class="stats-result__th">
                <% if (extra = grand_extras_by_label[header]) %>
                  <%= format_extra.call(extra.value, extra.format) %>
                <% elsif (value = grand_agg.cells[header]) %>
                  <%= format_cell.call(value) %>
                <% end %>
              </th>
            <% end %>
          </tr>
        </tfoot>
      <% end %>
    </table>
  </div>

  <% @result.clear %>
<% end %>
