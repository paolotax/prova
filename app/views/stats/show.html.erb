<% @page_title = @stat.titolo %>

<% content_for :header do %>
  <div class="header__actions header__actions--start print-hidden">
    <%= back_link_to "Statistiche", stats_path, "keydown.left@document->hotkey#click keydown.esc@document->hotkey#click" %>
  </div>

  <h1 class="header__title divider divider--fade full-width">
    <span class="overflow-ellipsis"><%= @stat.titolo %></span>
  </h1>

  <div class="header__actions header__actions--end print-hidden">
    <%= link_to stat_execution_path(@stat, format: :xlsx), class: "btn btn--positive", data: { controller: "tooltip", tooltip_content_value: "Esporta Excel" } do %>
      <%= icon_tag "document", size: "small" %>
      <span class="for-screen-reader">Esporta Excel</span>
    <% end %>

    <%= link_to "javascript:window.print()", class: "btn", data: { controller: "tooltip", tooltip_content_value: "Stampa" } do %>
      <%= icon_tag "printer", size: "small" %>
      <span class="for-screen-reader">Stampa</span>
    <% end %>

    <% if policy(@stat).update? %>
      <%= link_to edit_stat_path(@stat), class: "btn", data: { controller: "tooltip hotkey", action: "keydown.e@document->hotkey#click", tooltip_content_value: "Modifica SQL" } do %>
        <%= icon_tag "pencil", size: "small" %>
        <span class="for-screen-reader">Modifica SQL</span>
      <% end %>
    <% end %>

    <% if policy(@stat).destroy? %>
      <%= link_to stat_path(@stat), class: "btn btn--negative", data: { turbo_method: :delete, turbo_confirm: "Eliminare questa statistica?", controller: "tooltip", tooltip_content_value: "Elimina" } do %>
        <%= icon_tag "trash", size: "small" %>
        <span class="for-screen-reader">Elimina</span>
      <% end %>
    <% end %>
  </div>
<% end %>

<div class="stats-container">
  <%= turbo_frame_tag :stat_results, src: stat_execution_path(@stat) do %>
    <div class="panel" style="padding: var(--block-space); text-align: center;">
      <span class="txt-subtle">Caricamento risultati...</span>
    </div>
  <% end %>
</div>