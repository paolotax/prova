<% @page_title = "Ritiro" %>

<% content_for :header do %>
  <div class="header__actions header__actions--start">
    <%= back_link_to "Scuola", scuola_path(@scuola) %>
  </div>
  <h1 class="header__title"><%= @page_title %></h1>
<% end %>

<section class="panel panel--wide shadow center">
  <div class="flex align-center gap-half">
    <h3 class="divider divider--fade txt-medium font-weight-black margin-none" style="flex: 1;">
      <%= link_to @scuola.denominazione, scuola_path(@scuola) %>
    </h3>
  </div>

  <div class="flex flex-wrap gap full-width">
    <div class="flex-item-grow" style="flex-basis: 120px;">
      <span class="txt-x-small txt-subtle txt-uppercase">Bolle aperte</span>
      <div class="txt-medium"><%= @ritiro.bolle_aperte.size %></div>
    </div>
    <div class="flex-item-grow" style="flex-basis: 120px;">
      <span class="txt-x-small txt-subtle txt-uppercase">Bolle chiuse</span>
      <div class="txt-medium"><%= @ritiro.bolle_chiuse.size %></div>
    </div>
    <div class="flex-item-grow" style="flex-basis: 120px;">
      <span class="txt-x-small txt-subtle txt-uppercase">Copie totali</span>
      <div class="txt-medium"><%= @ritiro.copie_totali %></div>
    </div>
  </div>

  <% esiti_brevi = { "in_saggio" => "In saggio", "venduto_fattura" => "Vendute",
                     "venduto_corrispettivi" => "Ordine", "mancante" => "Mancanti",
                     "rientrato" => "Rientrate" } %>
  <% copie_aperte = @ritiro.copie_per_esito[nil].to_i %>
  <% breakdown = esiti_brevi.filter_map { |k, label|
       copie = @ritiro.copie_per_esito[k].to_i
       "#{label} #{copie}" if copie.positive?
     } %>
  <% if copie_aperte.positive? || breakdown.any? %>
    <p class="txt-small margin-block-start-half margin-block-end-none">
      <% if copie_aperte.positive? %>
        <strong class="font-weight-black">Aperte <%= copie_aperte %></strong>
      <% end %>
      <% if breakdown.any? %>
        <% if copie_aperte.positive? %><span class="txt-subtle"> · </span><% end %>
        <span class="txt-subtle"><%= breakdown.join(" · ") %></span>
      <% end %>
    </p>
  <% end %>

  <% if @ritiro.bolle_aperte.any? %>
    <div class="flex align-center gap-half margin-block-start">
      <h3 class="divider divider--fade txt-medium font-weight-black margin-none" style="flex: 1;">
        Bolle aperte
      </h3>
    </div>
    <ul class="flex flex-column unpad margin-none">
      <% @ritiro.bolle_aperte.each do |bolla| %>
        <%= render "ritiri/bolla_link", bolla: bolla %>
      <% end %>
    </ul>
  <% end %>

  <% if @ritiro.bolle_chiuse.any? %>
    <details class="margin-block-start">
      <summary class="txt-medium font-weight-black cursor-pointer">
        Bolle chiuse (<%= @ritiro.bolle_chiuse.size %>)
      </summary>
      <ul class="flex flex-column unpad margin-none margin-block-start-half">
        <% @ritiro.bolle_chiuse.each do |bolla| %>
          <%= render "ritiri/bolla_link", bolla: bolla %>
        <% end %>
      </ul>
    </details>
  <% end %>

  <% if @ritiro.empty? %>
    <p class="txt-subtle margin-block-start">Nessuna bolla visione per questa scuola.</p>
  <% end %>

</section>

<%= render "crea_bolle_da_collane", scuola: @scuola %>
