<%= tag.li id: dom_id(riga),
    class: "card ritiro__riga",
    data: { bolla_visione_riga_id: riga.id } do %>
  <label class="card__checkbox">
    <%= check_box_tag "bolla_visione_riga_ids[]", riga.id, false,
          data: { action: "change->bulk-actions#count" } %>
  </label>

  <div class="flex flex-column flex-item-grow max-inline-size">
    <strong class="txt-medium overflow-ellipsis"><%= riga.libro_titolo %></strong>
    <div class="txt-x-small txt-subtle flex flex-wrap gap-half align-center">
      <span><%= riga.libro_codice_isbn %></span>
      <% if riga.libro.fascicoli.any? %>
        <span>&middot; <%= riga.libro.fascicoli.size %> fasc.</span>
      <% end %>
      <% if riga.quantita > 1 %>
        <span class="badge">x<%= riga.quantita %></span>
      <% end %>
    </div>
  </div>

  <div class="card__actions flex gap-half align-center flex-item-no-shrink">
    <span class="txt-medium font-weight-black">
      <%= number_to_currency(riga.libro.prezzo_in_cents.to_f / 100, unit: "&euro;") %>
    </span>

    <% if riga.libro.fascicoli.any? %>
      <%= render "ritiri/dialog_fascicoli", riga: riga %>
    <% end %>

    <%= link_to riga_rientro_scuola_ritiro_path(scuola_id: scuola.id, id: riga.id),
          class: "btn btn--small",
          data: { turbo_method: :patch, turbo_frame: "_top" } do %>
      <%= icon_tag "arrow-uturn-left", size: "small" %>
      <span>Rientro</span>
    <% end %>
  </div>
<% end %>
