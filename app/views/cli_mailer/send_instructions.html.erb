<%= render Email::Bg::Container.new do |email| %>
  <% email.with_masthead_text(text: "ScagnoZZ", href: "https://scagnozz.com") %>

  <%= render Email::Heading.new(
    text: "Scagnozz AI",
    size: "26px",
    align: "center",
    margin: "20px auto 8px auto"
  ) %>
  <%= render Email::Text.new(align: "center", size: "16px", color: Email::Colors::GRAY_600, margin: "0 auto 30px auto") do %>
    Il tuo assistente AI per adozioni, ordini e contatti
  <% end %>

  <%= render Email::Divider.new(color: Email::Colors::RED_500, thickness: "4px") %>

  <%= render Email::Text.new do %>
    Ciao <b><%= @user.name %></b>,
  <% end %>

  <%= render Email::Text.new do %>
    Scagnozz AI ti permette di usare l'intelligenza artificiale per lavorare con i tuoi dati
    su Scagnozz — adozioni, scuole, clienti, ordini e contatti. Parli in italiano e l'AI fa il resto.
  <% end %>

  <%= render Email::Text.new do %>
    Puoi collegarlo in due modi: dal <b>telefono o browser</b> (il più semplice e veloce),
    oppure installando il <b>CLI sul computer</b> (per chi preferisce lavorare dal terminale).
  <% end %>

  <%# ===== COSA PUO FARE ===== %>

  <%= render Email::Heading.new(text: "Cosa puoi fare", size: "20px", margin: "32px auto 16px auto") %>

  <%= render Email::Text.new do %>
    <b>Statistiche adozioni</b> — classifica editori per provincia, scopri dove è adottato un titolo,
    confronta province e materie. Chiedi cose come <i>"quali sono gli editori più adottati in provincia
    di Torino per matematica in terza?"</i>
  <% end %>
  <%= render Email::Text.new do %>
    <b>Cercare scuole, clienti e persone</b> — cerca per nome e trova subito quello che ti serve
  <% end %>
  <%= render Email::Text.new do %>
    <b>Gestire insegnanti e contatti</b> — lista insegnanti per anno di corso, importa contatti
    da file Excel, CSV o anche da una foto
  <% end %>
  <%= render Email::Text.new do %>
    <b>Creare ordini e documenti</b> — crea ordini scuola, ordini cliente, DDT, anche partendo da un file
  <% end %>
  <%= render Email::Text.new do %>
    <b>Creare appunti e note</b> — aggiungi note veloci su scuole, clienti o persone
  <% end %>
  <%= render Email::Text.new do %>
    <b>Importare libri e clienti</b> — importa cataloghi e anagrafiche da qualsiasi formato
  <% end %>
  <%= render Email::Text.new(margin: "8px auto 32px auto", color: Email::Colors::GRAY_600) do %>
    Tutto questo lo fai parlando in italiano all'AI, che usa Scagnozz dietro le quinte.
  <% end %>

  <%= render Email::Divider.new(color: Email::Colors::GRAY_300) %>

  <%# ===== GENERA TOKEN ===== %>

  <%= render Email::Heading.new(text: "Prima di tutto: genera il tuo token", size: "20px", margin: "32px auto 16px auto") %>

  <%= render Email::Text.new do %>
    Per collegare Scagnozz all'AI ti serve un <b>Access Token</b> — una chiave personale
    che collega il tuo account. Serve sia per il metodo semplice che per il CLI.
  <% end %>

  <%= render Email::Colorblock.new(
    color: "#EFF6FF",
    border_color: "#3B82F6",
    border_width: "1px",
    border_radius: "12px",
    margin: "8px auto 16px auto",
    padding: "16px 24px"
  ) do %>
    <%= render Email::Text.new(bold: true, margin: "8px auto 12px auto") do %>
      Come generare il tuo Access Token
    <% end %>
    <%= render Email::Text.new(size: "14px", margin: "4px auto") do %>
      1. Vai su <b><%= link_to "scagnozz.com", "https://scagnozz.com" %></b> — inserisci la tua email
      e clicca <b>"Invia link"</b>. Riceverai un'email con un link per accedere — cliccalo.
    <% end %>
    <%= render Email::Text.new(size: "14px", margin: "4px auto") do %>
      2. Una volta dentro, clicca il logo <b>ScagnoZZ</b> in alto per aprire il menu,
      poi vai su <b>Impostazioni</b> → <b>Il mio profilo</b>
    <% end %>
    <%= render Email::Text.new(size: "14px", margin: "4px auto") do %>
      3. Scorri in basso fino alla sezione "Estensione WhatsApp" e clicca <b>"Gestisci token"</b>
    <% end %>
    <%= render Email::Text.new(size: "14px", margin: "4px auto") do %>
      4. Clicca <b>"Genera un nuovo token"</b>
    <% end %>
    <%= render Email::Text.new(size: "14px", margin: "4px auto") do %>
      5. Come descrizione scrivi <i>"Scagnozz AI"</i> e clicca <b>"Genera token"</b>
    <% end %>
    <%= render Email::Text.new(size: "14px", margin: "4px auto") do %>
      6. <b>Copia il token</b> che appare — clicca il pulsante "Copia" accanto al token
    <% end %>
    <%= render Email::Text.new(size: "14px", margin: "8px auto 4px auto", color: Email::Colors::GRAY_600) do %>
      Conserva il token — ti servirà nel prossimo passaggio.
      Se lo perdi, puoi generarne uno nuovo tutte le volte che vuoi.
    <% end %>
  <% end %>

  <%= render Email::Divider.new(color: Email::Colors::GRAY_300, margin: "32px auto") %>

  <%# ===== METODO 1: CLAUDE WEB / MOBILE ===== %>

  <%= render Email::Colorblock.new(
    color: "#F0FDF4",
    border_color: "#86EFAC",
    border_width: "2px",
    border_radius: "12px",
    margin: "0 auto 32px auto",
    padding: "16px 24px"
  ) do %>
    <%= render Email::Text.new(size: "12px", bold: true, margin: "8px auto 4px auto", color: Email::Colors::GRAY_500) do %>
      CONSIGLIATO
    <% end %>
    <%= render Email::Heading.new(text: "Metodo 1: Da telefono o browser", size: "20px", margin: "0 auto 12px auto") %>

    <%= render Email::Text.new do %>
      Il modo più semplice e veloce. Non devi installare nulla — funziona subito
      dal telefono, tablet o computer. Ideale per chi lavora in mobilità.
    <% end %>

    <%= render Email::Text.new(bold: true, margin: "16px auto 8px auto") do %>
      Su Claude (claude.ai o app mobile):
    <% end %>
    <%= render Email::Text.new(size: "14px", margin: "4px auto") do %>
      1. Vai su <b>Personalizza</b> (icona ingranaggio o menu)
    <% end %>
    <%= render Email::Text.new(size: "14px", margin: "4px auto") do %>
      2. Nella sezione <b>"Autorizzazioni strumenti"</b> clicca <b>"Aggiungi connettore personalizzato"</b>
    <% end %>
    <%= render Email::Text.new(size: "14px", margin: "4px auto") do %>
      3. Come nome scrivi <b>Scagnozz</b>
    <% end %>
    <%= render Email::Text.new(size: "14px", margin: "4px auto") do %>
      4. Come URL incolla (sostituendo IL_TUO_TOKEN con il token che hai generato):
    <% end %>

    <%= render Email::Colorblock.new(
      color: Email::Colors::GRAY_100,
      border_radius: "8px",
      padding: "12px 16px",
      margin: "8px auto 12px auto"
    ) do %>
      <%= render Email::Text.new(size: "13px", font: "monospace") do %>
        https://scagnozz.com/api/mcp?api_key=IL_TUO_TOKEN
      <% end %>
    <% end %>

    <%= render Email::Text.new(size: "14px", margin: "4px auto") do %>
      5. Clicca <b>"Aggiungi"</b> — i tool verranno caricati automaticamente
    <% end %>

    <%= render Email::Text.new(size: "14px", margin: "12px auto 4px auto", color: Email::Colors::GRAY_600) do %>
      Fatto! Ora apri una nuova chat su Claude e prova a chiedere
      <i>"Cerca la scuola Zibordi"</i> o <i>"Quali editori sono più adottati a Torino?"</i>
    <% end %>

    <%= render Email::Text.new(bold: true, margin: "16px auto 8px auto") do %>
      Su ChatGPT:
    <% end %>
    <%= render Email::Text.new(size: "14px", margin: "4px auto") do %>
      1. Vai su <b>Settings → Apps → Developer Mode</b>
    <% end %>
    <%= render Email::Text.new(size: "14px", margin: "4px auto") do %>
      2. Clicca <b>"Create app"</b> e incolla lo stesso URL
    <% end %>
  <% end %>

  <%= render Email::Divider.new(color: Email::Colors::GRAY_300, margin: "32px auto") %>

  <%# ===== METODO 2: CLI ===== %>

  <%= render Email::Heading.new(text: "Metodo 2: Installare il CLI sul computer", size: "20px", margin: "0 auto 12px auto") %>

  <%= render Email::Text.new do %>
    Se usi <b>Claude Desktop</b>, <b>Claude Code</b>, <b>Cursor</b> o <b>OpenCode</b> sul computer,
    puoi installare Scagnozz CLI per un'integrazione più profonda. Il CLI si collega
    direttamente al tuo programma AI e permette anche di importare file dal disco.
  <% end %>

  <%= render Email::Text.new(bold: true, margin: "16px auto 8px auto") do %>
    Installazione — Mac o Linux:
  <% end %>
  <%= render Email::Text.new do %>
    1. Apri il <b>Terminale</b><br>
    &nbsp;&nbsp;&nbsp;Su Mac: cerca "Terminale" con Spotlight (la lente in alto a destra),
    oppure lo trovi in Applicazioni → Utility<br>
    &nbsp;&nbsp;&nbsp;Su Linux: cerca "Terminal" nel menu applicazioni
  <% end %>
  <%= render Email::Text.new do %>
    2. Copia e incolla questo comando e premi Invio:
  <% end %>

  <%= render Email::Colorblock.new(
    color: Email::Colors::GRAY_100,
    border_radius: "8px",
    padding: "12px 16px",
    margin: "8px auto 16px auto"
  ) do %>
    <%= render Email::Text.new(size: "14px", font: "monospace") do %>
      curl -fsSL https://scagnozz.com/cli/install.sh | bash
    <% end %>
  <% end %>

  <%= render Email::Text.new do %>
    3. Chiudi e riapri il Terminale. Scrivi <code>scagnozz</code> e premi Invio.
    Se vedi un messaggio di benvenuto, è tutto ok!
  <% end %>

  <%= render Email::Text.new(bold: true, margin: "24px auto 8px auto") do %>
    Installazione — Windows:
  <% end %>
  <%= render Email::Text.new do %>
    1. Apri <b>PowerShell</b> — cerca "PowerShell" nel menu Start
  <% end %>
  <%= render Email::Text.new do %>
    2. Copia e incolla questo comando e premi Invio:
  <% end %>

  <%= render Email::Colorblock.new(
    color: Email::Colors::GRAY_100,
    border_radius: "8px",
    padding: "12px 16px",
    margin: "8px auto 16px auto"
  ) do %>
    <%= render Email::Text.new(size: "14px", font: "monospace") do %>
      irm https://scagnozz.com/cli/install.ps1 | iex
    <% end %>
  <% end %>

  <%= render Email::Text.new do %>
    3. Chiudi e riapri PowerShell. Scrivi <code>scagnozz</code> e premi Invio.
  <% end %>

  <%= render Email::Text.new(size: "14px", margin: "8px auto 16px auto", color: Email::Colors::GRAY_600) do %>
    In alternativa puoi <%= link_to "scaricare il file direttamente", "https://scagnozz.com/cli/scagnozz-windows-amd64.exe" %>,
    rinominarlo in <code>scagnozz.exe</code> e metterlo in una cartella nel PATH.
  <% end %>

  <%= render Email::Text.new(bold: true, margin: "24px auto 8px auto") do %>
    Primo accesso:
  <% end %>

  <%= render Email::Text.new do %>
    Dopo l'installazione, scrivi nel terminale:
  <% end %>

  <%= render Email::Colorblock.new(
    color: Email::Colors::GRAY_100,
    border_radius: "8px",
    padding: "12px 16px",
    margin: "8px auto 16px auto"
  ) do %>
    <%= render Email::Text.new(size: "14px", font: "monospace") do %>
      scagnozz setup
    <% end %>
  <% end %>

  <%= render Email::Text.new do %>
    Ti chiederà l'<b>URL del server</b> (scrivi <code>https://scagnozz.com</code>)
    e l'<b>Access Token</b> (incolla il token che hai generato prima).
  <% end %>

  <%= render Email::Text.new(margin: "16px auto 8px auto") do %>
    Poi collega Scagnozz al tuo programma AI:
  <% end %>

  <%= render Email::Colorblock.new(
    color: Email::Colors::GRAY_100,
    border_radius: "8px",
    padding: "12px 16px",
    margin: "8px auto 16px auto"
  ) do %>
    <%= render Email::Text.new(size: "14px", font: "monospace", margin: "4px auto") do %>
      scagnozz mcp install
    <% end %>
    <%= render Email::Text.new(size: "14px", font: "monospace", margin: "4px auto") do %>
      scagnozz skill install
    <% end %>
  <% end %>

  <%= render Email::Text.new do %>
    Il primo collega Scagnozz al tuo programma AI — ti mostrerà un menu dove scegliere quale usi.
    Il secondo installa le istruzioni che insegnano all'AI come usare Scagnozz.
    Riavvia il programma AI e sei pronto!
  <% end %>

  <%= render Email::Divider.new(color: Email::Colors::GRAY_300, margin: "32px auto") %>

  <%# ===== COSA POSSO CHIEDERE ===== %>

  <%= render Email::Colorblock.new(
    color: "#F0FDF4",
    border_color: "#86EFAC",
    border_width: "1px",
    border_radius: "12px",
    margin: "0 auto 32px auto",
    padding: "16px 24px"
  ) do %>
    <%= render Email::Text.new(bold: true, margin: "8px auto 12px auto") do %>
      Cosa posso chiedere?
    <% end %>
    <%= render Email::Text.new(size: "14px", margin: "4px auto", color: Email::Colors::GRAY_700) do %>
      <i>"Cosa mi permette di fare Scagnozz?"</i>
    <% end %>
    <%= render Email::Text.new(size: "14px", margin: "4px auto", color: Email::Colors::GRAY_700) do %>
      <i>"Quali sono gli editori più adottati in provincia di Torino?"</i>
    <% end %>
    <%= render Email::Text.new(size: "14px", margin: "4px auto", color: Email::Colors::GRAY_700) do %>
      <i>"Cerca la scuola Zibordi"</i>
    <% end %>
    <%= render Email::Text.new(size: "14px", margin: "4px auto", color: Email::Colors::GRAY_700) do %>
      <i>"Fammi vedere gli insegnanti di terza e quinta con email"</i>
    <% end %>
    <%= render Email::Text.new(size: "14px", margin: "4px auto", color: Email::Colors::GRAY_700) do %>
      <i>"Confronta le adozioni di matematica tra Torino e Milano"</i>
    <% end %>
    <%= render Email::Text.new(size: "14px", margin: "8px auto 4px auto", color: Email::Colors::GRAY_600) do %>
      Parla in italiano, come faresti con un collega. L'AI capisce cosa vuoi e usa Scagnozz per te.
    <% end %>
  <% end %>

  <%# ===== BOX AGGIORNAMENTO ===== %>

  <%= render Email::Colorblock.new(
    color: "#FFF7ED",
    border_color: "#FB923C",
    border_width: "1px",
    border_radius: "12px",
    margin: "32px auto",
    padding: "16px 24px"
  ) do %>
    <%= render Email::Text.new(bold: true, margin: "8px auto 8px auto") do %>
      Hai già Scagnozz CLI installato?
    <% end %>
    <%= render Email::Text.new(size: "14px", margin: "4px auto") do %>
      Per aggiornare all'ultima versione basta rieseguire il comando di installazione:
    <% end %>
    <%= render Email::Colorblock.new(
      color: Email::Colors::GRAY_100,
      border_radius: "8px",
      padding: "8px 12px",
      margin: "8px auto"
    ) do %>
      <%= render Email::Text.new(size: "14px", font: "monospace") do %>
        curl -fsSL https://scagnozz.com/cli/install.sh | bash
      <% end %>
    <% end %>
    <%= render Email::Text.new(size: "14px", margin: "4px auto") do %>
      Su Windows, riesegui in PowerShell: <code>irm https://scagnozz.com/cli/install.ps1 | iex</code>
    <% end %>
  <% end %>

  <%# ===== FOOTER ===== %>

  <%= render Email::Colorblock.new(
    color: Email::Colors::RED_50,
    border_width: "0",
    border_radius: "12px",
    margin: "64px auto auto auto",
    padding: "16px 24px",
  ) do %>
    <%= render Email::Text.new(text: "ScagnoZZ", bold: true, letter_spacing: "-0.0375rem", margin: "8px auto", color: Email::Colors::GRAY_700) %>
    <%= render Email::Text.new(size: "12px", margin: "4px auto", color: Email::Colors::GRAY_600) do %>
      Visita <%= link_to "ScagnoZZ", "https://scagnozz.com" %> per saperne di più.
    <% end %>
    <%= render Email::Text.new(text: "© #{Time.now.year} ScagnoZZ", margin: "4px auto", size: "12px", color: Email::Colors::GRAY_600) %>
  <% end %>
<% end %>
