<% @page_title = "Importa Clienti" %>

<% content_for :header do %>
  <div class="header__actions header__actions--start">
    <%= back_link_to "Clienti", clienti_path, "keydown.left@document->hotkey#click keydown.esc@document->hotkey#click" %>
  </div>

  <h1 class="header__title"><%= @page_title %></h1>
<% end %>

<% if @result %>
  <article class="panel panel--wide shadow center txt-align-start margin-block-end">
    <div class="flex flex-column gap">
      <div class="flex align-center gap">
        <% if @result['success'] %>
          <%= icon_tag "check-circle", class: "txt-positive", size: "large" %>
          <strong class="txt-large txt-positive">Importazione completata</strong>
        <% else %>
          <%= icon_tag "alert-triangle", class: "txt-alert", size: "large" %>
          <strong class="txt-large txt-alert">Importazione completata con avvisi</strong>
        <% end %>
      </div>

      <div class="flex gap">
        <div class="flex-1 pad fill-shade border-radius txt-align-center">
          <p class="txt-xx-large font-weight-black txt-positive margin-none"><%= @result['imported_count'] %></p>
          <p class="txt-small txt-subtle margin-none">Nuovi clienti</p>
        </div>
        <div class="flex-1 pad fill-shade border-radius txt-align-center">
          <p class="txt-xx-large font-weight-black txt-link margin-none"><%= @result['updated_count'] %></p>
          <p class="txt-small txt-subtle margin-none">Aggiornati</p>
        </div>
        <div class="flex-1 pad fill-shade border-radius txt-align-center">
          <p class="txt-xx-large font-weight-black <%= @result['errors_count'].to_i > 0 ? 'txt-negative' : 'txt-subtle' %> margin-none"><%= @result['errors_count'] %></p>
          <p class="txt-small txt-subtle margin-none">Errori</p>
        </div>
      </div>

      <% if @result['errors'].present? %>
        <div class="flex flex-column gap-half pad fill-shade border-radius">
          <strong class="txt-small txt-negative">Errori riscontrati:</strong>
          <ul class="txt-small margin-none" style="padding-inline-start: 1.5em;">
            <% @result['errors'].each do |error| %>
              <li><%= error %></li>
            <% end %>
          </ul>
        </div>
      <% end %>
    </div>
  </article>
<% end %>

<article class="panel panel--wide shadow center txt-align-start">
  <%= form_for @import, url: clienti_importer_path, method: :post, html: { class: "flex flex-column gap", multipart: true }, data: { controller: "form" } do |f| %>
    <h2 class="txt-large margin-none font-weight-black">Importa da file</h2>

    <p class="txt-subtle margin-none">
      Carica un file CSV o Excel contenente i dati dei clienti. Il sistema aggiorna automaticamente i clienti esistenti in base alla Partita IVA o Codice Fiscale.
    </p>

    <div class="flex flex-column gap-half">
      <strong><%= f.label :file, "Seleziona file" %></strong>
      <%= f.file_field :file,
          accept: 'text/csv,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/vnd.ms-excel',
          class: "input",
          data: { action: "keydown.esc@document->form#cancel" } %>
    </div>

    <%= f.button type: :submit, class: "btn btn--link center txt-medium" do %>
      <%= icon_tag "arrow-down-tray" %>
      <span>Importa file</span>
    <% end %>

    <%= link_to "Annulla", clienti_path, data: { form_target: "cancel" }, hidden: true %>
  <% end %>
</article>

<article class="panel panel--wide center txt-align-start margin-block-start">
  <div class="flex flex-column gap-half txt-small txt-subtle">
    <strong class="txt-ink">Formati supportati</strong>
    <p class="margin-none">CSV (.csv), Excel (.xlsx, .xls)</p>

    <strong class="txt-ink margin-block-start-half">Colonne richieste</strong>
    <p class="margin-none">denominazione, partita_iva o codice_fiscale</p>

    <strong class="txt-ink margin-block-start-half">Gestione duplicati</strong>
    <p class="margin-none">Il sistema cerca clienti esistenti tramite P.IVA o CF. Se trova un match, aggiorna i dati; altrimenti crea un nuovo cliente.</p>
  </div>
</article>
