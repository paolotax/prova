<div id="<%= dom_id(mandato) %>" class="flex justify-between align-center padding-block-half" style="border-bottom: var(--border);">

    <div class="flex align-center gap-half flex-1">
        <span class="txt-small"><%= mandato.editore.editore %></span>
        <span class="txt-x-small txt-subtle"><%= mandato.editore.gruppo.titleize %></span>
    </div>

    <%= button_to mandato_path(mandato), method: :delete,
        class: "btn btn--circle btn--negative", aria: { label: "Rimuovi editore" } do %>
        <%= icon_tag "trash" %>
    <% end %>

</div>
