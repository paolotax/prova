<%= turbo_frame_tag :mandati_form do %>
    <div class="flex flex-wrap gap-half align-center margin-block-start">

        <%= render partial: "mandati/mandati_select", locals: { gruppi: gruppi, editori: editori } %>

        <div data-controller="dialog" data-dialog-modal-value="true" data-action="keydown.esc->dialog#close:stop">
            <button type="button" class="btn btn--circle btn--link" data-action="dialog#open" aria-label="Aggiungi editore">
                <%= icon_tag "add" %>
            </button>
            <dialog class="dialog panel fill-white shadow gap flex-column" style="width: min(90vw, 24rem);" data-dialog-target="dialog">
                <%= form_with url: mandati_path, method: :post do |f| %>
                    <h3 class="txt-large txt-bold">Seleziona le zone</h3>
                    <p class="txt-small txt-subtle">Per quali zone hai il mandato?</p>

                    <%= hidden_field_tag "hgruppo" %>
                    <%= hidden_field_tag "heditore" %>

                    <div class="flex flex-column gap-half pad-inline margin-block-start">
                        <% zone_attive.each do |zona| %>
                            <label class="flex align-center gap-half" style="cursor: pointer;">
                                <%= check_box_tag "zone_ids[]", zona.id, false %>
                                <span class="txt-small txt-align-start"><%= zona.provincia %> — <%= zona.grado_label %></span>
                            </label>
                        <% end %>
                    </div>

                    <div class="flex gap-half justify-end margin-block-start">
                        <button type="button" class="btn" data-action="dialog#close">Annulla</button>
                        <%= f.button type: "submit", class: "btn btn--link" do %>
                            Aggiungi
                        <% end %>
                    </div>
                <% end %>
            </dialog>
        </div>

    </div>

    <div class="margin-block-start">
        <%= button_to mandati_sincronizzazione_adozioni_path, class: "btn txt-small" do %>
            Aggiorna mie adozioni
        <% end %>
    </div>
<% end %>
