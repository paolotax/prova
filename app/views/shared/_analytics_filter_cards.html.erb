<%# locals: (cards:, current:, url:, param:, multi: false) -%>
<%# Card KPI che filtrano server-side: vivono DENTRO il frame search_results
    (così i filtri, che submittano nel frame, le aggiornano), ma ogni card con
    key è un link _top (aggiorna anche il pannello filtri fuori dal frame);
    la card attiva linka l'URL senza il param (toggle off). key nil = KPI
    non cliccabile.
    Con multi: true, `current` è un array di chiavi (logica OR); il click
    toggla la chiave nel set additivamente (`stati[]`). %>
<% base_params = request.query_parameters.except("page", param.to_s) %>

<div class="analytics-summary">
  <% cards.each do |card| %>
    <% if card[:key] %>
      <% if multi %>
        <% active = current.include?(card[:key]) %>
        <% nuovi = active ? current - [card[:key]] : current + [card[:key]] %>
        <% merge_hash = nuovi.any? ? { param => nuovi } : {} %>
      <% else %>
        <% active = current == card[:key] %>
        <% merge_hash = active ? {} : { param => card[:key] } %>
      <% end %>
      <% query = base_params.merge(merge_hash).compact_blank %>
      <%= link_to (query.present? ? "#{url}?#{query.to_query}" : url),
            class: class_names("analytics-summary__card", "analytics-summary__card--link",
                               "analytics-summary__card--active": active),
            aria: { pressed: active },
            data: { turbo_frame: "_top", turbo_action: "advance" } do %>
        <p class="analytics-summary__value <%= card[:value_class] %>"><%= card[:value] %></p>
        <p class="analytics-summary__label"><%= card[:label] %></p>
      <% end %>
    <% else %>
      <div class="analytics-summary__card">
        <p class="analytics-summary__value <%= card[:value_class] %>"><%= card[:value] %></p>
        <p class="analytics-summary__label"><%= card[:label] %></p>
      </div>
    <% end %>
  <% end %>
</div>
