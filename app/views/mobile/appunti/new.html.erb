<%= form_with model: @appunto,
        url: mobile_appunti_path,
        class: "flex flex-column gap",
        data: { controller: "mobile-form", mobile_form_target: "form" } do |f| %>

  <section class="panel shadow center" style="--panel-size: 55ch;"
           data-controller="conditional-field">
    <strong class="divider txt-medium margin-block">Appunto</strong>

    <div class="form-field margin-block-end">
      <label class="label">Titolo</label>
      <%= f.text_field :nome, class: "input", placeholder: "Titolo" %>
    </div>

    <div class="flex flex-column gap" data-controller="speech">
      <div class="form-field">
        <%= f.text_area :content,
            class: "input input--textarea",
            rows: 5,
            placeholder: "Scrivi o detta...",
            data: { speech_target: "output" } %>
      </div>

      <div class="flex align-center justify-center gap-half">
        <button type="button"
                class="btn btn--small btn--reversed"
                data-speech-target="button"
                data-action="speech#toggle"
                hidden>
          <span data-speech-target="label">Microfono</span>
        </button>
      </div>
    </div>


    <strong class="divider txt-medium margin-block">Destinatario</strong>

    <div class="flex flex-column gap">
      <div class="form-field">
        <div class="cb-tax">
          <%= combobox_tag "appunto[appuntabile_value]",
              destinatari_index_path(account_id: Current.account.id),
              placeholder: "cerca scuola, cliente, classe o persona...",
              mobile_at: "0px",
              data: {
                action: "hw-combobox:selection->conditional-field#update"
              } %>
        </div>
      </div>
    </div>

    <strong class="divider txt-medium margin-block">Nuova persona</strong>

    <div class="flex flex-column gap">
      <div class="form-row">
        <div class="form-field">
          <%= text_field_tag "persona[nome]", nil, class: "input", placeholder: "Nome" %>
        </div>
        <div class="form-field">
          <%= text_field_tag "persona[cognome]", nil, class: "input", placeholder: "Cognome" %>
        </div>
      </div>
      <div class="form-row">
        <div class="form-field">
          <%= select_tag "persona[ruolo]",
              options_for_select([["Docente", "docente"], ["Dirigente", "dirigente"], ["Segretario", "segretario"], ["Referente", "referente"], ["Altro", "altro"]]),
              class: "input input--select", include_blank: "Ruolo" %>
        </div>
        <div class="form-field" data-conditional-field-target="item" hidden>
          <%= text_field_tag "persona[materia]", nil, class: "input", placeholder: "Materia" %>
        </div>
      </div>
      <div class="form-field">
        <%= telephone_field_tag "persona[cellulare]", nil, class: "input", placeholder: "Cellulare" %>
      </div>
      <div class="form-field">
        <%= email_field_tag "persona[email]", nil, class: "input", placeholder: "Email" %>
      </div>
    </div>


    <strong class="divider txt-medium margin-block">Allegati</strong>

    <div class="flex align-center justify-center gap-half flex-wrap">
      <button type="button"
              class="btn btn--small"
              data-controller="audio-recorder"
              data-action="audio-recorder#toggle"
              data-audio-recorder-target="button">
        <span data-audio-recorder-target="label">Registra vocale</span>
      </button>

      <label class="btn btn--small">
        Foto / File
        <%= f.file_field :attachments,
            multiple: true,
            class: "visually-hidden",
            direct_upload: true,
            data: { mobile_form_target: "fileInput" } %>
      </label>
    </div>

    <div data-mobile-form-target="previews" class="flex gap-half flex-wrap margin-block-start-half"></div>
  </section>



  <div class="flex align-center justify-center gap">
    <%= link_to "Annulla", root_path, class: "btn" %>
    <%= f.submit "Salva bozza", class: "btn btn--reversed", data: { mobile_form_target: "submit" } %>
  </div>
<% end %>
