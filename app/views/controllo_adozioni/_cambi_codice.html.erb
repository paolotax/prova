<%# Sezione "Codici nuovi / cambi codice" — target stabile per aggiornamento via stream. %>
<%= tag.div id: "controllo_adozioni_cambi" do %>
  <% mancanti = panoramica.cambi_codice %>
  <% if mancanti.any? %>
    <% per_tipo = mancanti.group_by(&:tipo) %>
    <section class="margin-block-end">
      <h2 class="txt-medium">Codici nuovi (<%= mancanti.size %>)</h2>
      <p class="txt-subtle txt-small">
        Codici presenti nel ministeriale (new_scuole + new_adozioni) della tua zona ma non in account.
      </p>
      <% con_predecessore = per_tipo.fetch(:match, []).size %>
      <% if con_predecessore.positive? %>
        <div class="margin-block-end">
          <%= button_to controllo_adozioni_aggiorna_cambi_codice_path(account_id: account_id, provincia: local_assigns[:provincia]),
                class: "btn btn--small btn--accent",
                data: { turbo_confirm: "Aggiornare i #{con_predecessore} cambi codice con predecessore suggerito?" } do %>
            Aggiorna tutti i cambi codice (<%= con_predecessore %>)
          <% end %>
        </div>
      <% end %>

      <% { match:        "Cambi codice — predecessore trovato",
           suggerimento: "Da scegliere — piu' candidati possibili",
           nuova:        "Nuove scuole — senza corrispondenze" }.each do |tipo, titolo| %>
        <% righe = per_tipo[tipo] %>
        <% next if righe.blank? %>
        <div class="flex align-center gap margin-block-start-half">
          <h3 class="txt-small txt-subtle"><%= titolo %> (<%= righe.size %>)</h3>
          <% if tipo == :nuova %>
            <%= button_to controllo_adozioni_aggiungi_scuole_nuove_path(account_id: account_id, provincia: local_assigns[:provincia]),
                  class: "btn btn--small btn--accent",
                  data: { turbo_confirm: "Aggiungere le #{righe.size} nuove scuole all'anagrafe, con classi e adozioni dal ministeriale?" } do %>
              Aggiungi tutte (<%= righe.size %>)
            <% end %>
          <% end %>
        </div>
        <div class="flex flex-column gap-quarter">
          <%= render partial: "controllo_adozioni/cambio_codice", collection: righe, as: :cambio,
                locals: { account_id: account_id, panoramica: panoramica } %>
        </div>
      <% end %>
    </section>
  <% end %>
<% end %>
