<%# Sequenza guidata del passaggio anno: 4 step-card (.ca-step) con stato derivato dai
    contatori (ControlloAdozioni::PassaggioAnno). Con provincia i job partono scoped.
    interattivo (default true): le card filtrano la lista (data-step-key => stato filtro).
    Quando la lista non e' in pagina (scope grande) le card restano informative: senza
    filter-target, cosi' apply() non le nasconde e i contatori server restano visibili. %>
<% interattivo = local_assigns.fetch(:interattivo, true) %>
<% if passaggio.disponibile? %>
  <section class="ca-guide passaggio-anno">
    <div class="analytics-group__header">
      <h2 class="txt-medium">
        Passaggio anno <%= anno_scolastico_label(passaggio.anno) %><%= " · #{provincia}" if provincia %>
      </h2>
    </div>

    <div class="ca-steps">
      <% passaggio.steps.reject(&:done?).each do |step| %>
        <% key = step_filter_key(step) %>
        <div class="ca-step"<%= " role=button tabindex=0 aria-current=false".html_safe if interattivo %>
             data-step-key="<%= key %>"
             <%= "data-controllo-adozioni-filter-target=step".html_safe if interattivo %>
             <%= 'data-action="click->controllo-adozioni-filter#toggleStep keydown.enter->controllo-adozioni-filter#toggleStep"'.html_safe if interattivo %>>
          <div class="ca-step__top">
            <span class="ca-step__num"><%= step.numero %></span>
            <span class="ca-step__count" data-count><%= step.count %></span>
          </div>
          <div class="ca-step__title"><%= step.titolo %></div>
          <div class="ca-step__desc"><%= step.descrizione %></div>
          <div class="ca-step__actions" data-action="click->controllo-adozioni-filter#stop">
            <% if step.key == :anomalie %>
              <% if step.count.positive? %>
                <%= link_to "Vedi anomalie",
                      controllo_adozioni_index_path(account_id: account_id, provincia: provincia, filtro: "anomalie"),
                      class: "btn btn--small" %>
              <% end %>
              <%= button_to "Ricalcola",
                    controllo_adozioni_anomalie_path(account_id: account_id),
                    class: "btn btn--small",
                    data: { turbo_confirm: "Ricostruire tutte le anomalie dallo snapshot MIUR corrente? Il ricalcolo è globale, non solo per questo account." } %>
            <% else %>
              <% label = step.key == :scuole_nuove ? "Aggiungi le scuole nuove" : "Avvia" %>
              <% if step.azionabile? %>
                <%= button_to passaggio_step_path(step, account_id: account_id, provincia: provincia),
                      class: "btn btn--small btn--accent",
                      data: { turbo_confirm: "#{label} (#{step.bulk})#{" — #{provincia}" if provincia}: avviare?" } do %>
                  <%= label %>
                <% end %>
              <% end %>
              <% if step.key == :scuole_nuove && step.verifica.positive? %>
                <button type="button" class="btn btn--small"
                        data-action="click->controllo-adozioni-filter#selectChip" data-filter="verifica">
                  Da verificare (<%= step.verifica %>)
                </button>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <div class="ca-guide__done" data-controllo-adozioni-filter-target="guideDone" hidden>
      <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 10.5l4 4 8-9"/></svg>
      Passaggio anno completato per il filtro corrente.
    </div>
  </section>
<% end %>
