<%# Barra di freschezza dei dati MIUR: ultimo import adozioni (Miur::ImportRun). %>
<% run = Miur::ImportRun.adozioni.order(:completed_at).last %>
<% if run&.completed_at %>
  <div class="ca-freshness center">
    <span class="ca-freshness__dot"></span>
    <% data = "#{run.completed_at.day} #{I18n.t("date.abbr_month_names")[run.completed_at.month]}" %>
    Dati MIUR aggiornati al
    <% if Current.admin? %>
      <%= link_to miur_import_run_path(run, account_id: params[:account_id]) do %><strong><%= data %></strong><% end %>
    <% else %>
      <strong><%= data %></strong>
    <% end %>
    <% if run.righe_totali %>
      · <strong><%= number_with_delimiter(run.righe_totali) %></strong> adozioni
    <% end %>
    <% if run.delta_righe.to_i.positive? %>
      <span class="ca-freshness__delta">(+<%= number_with_delimiter(run.delta_righe) %> dall'ultimo)</span>
    <% end %>
    <% if Current.admin? && run.diff? %>
      <% cats = run.diff_scuole.group(:categoria).count %>
      <%= link_to miur_import_run_path(run, account_id: params[:account_id]), class: "ca-freshness__badge" do %>
        <%= number_with_delimiter(cats["esistente"].to_i) %> rettifiche
        <% if cats["nuova"].to_i.positive? %> · <%= cats["nuova"] %> nuove<% end %>
        <% if cats["sparita"].to_i.positive? %> · <%= cats["sparita"] %> sparite<% end %>
      <% end %>
    <% end %>
    <% if run.regioni_stale.present? %>
      · <span class="ca-freshness__stale">
        <%= Array(run.regioni_stale).join(", ") %>: dati non aggiornati
      </span>
    <% end %>
  </div>
<% else %>
  <div class="ca-freshness">
    <span class="txt-subtle">Nessun import MIUR registrato.</span>
  </div>
<% end %>
