<%# Card KPI sopra gli step. La prima card "province" (solo 2+ province, vista account-wide)
    linka la tabella per provincia (#ca-province). Le altre, in modalita' interactive, sono
    FILTRI client-side della lista (data-filter => controllo-adozioni-filter#select): cliccarle
    mostra solo quelle righe, senza ricaricare la pagina. I valori sono calcolati lato server
    (scope = provincia) e restano fissi. Con una provincia in drill i numeri sono di quella. %>
<% interactive = local_assigns.fetch(:interactive, false) %>
<% riga = provincia && dashboard.righe.find { |r| r.provincia == provincia } %>
<% totali = dashboard.totali %>
<% scuole   = riga ? riga.scuole        : totali[:scuole] %>
<% promosse = riga ? riga.promosse      : totali[:promosse] %>
<% mancanti = riga ? riga.mancanti_miur : totali[:mancanti_miur] %>

<div class="analytics-summary">
  <% if province_count.to_i >= 2 && provincia.blank? %>
    <div class="analytics-summary__card">
      <a href="#ca-province" class="analytics-summary__toggle">
        <p class="analytics-summary__value"><%= province_count %></p>
        <p class="analytics-summary__label">province</p>
      </a>
    </div>
  <% end %>

  <% [
       ["all",           scuole,   "scuole con adozioni", nil],
       ["promosse",      promosse, "promosse",            "txt-positive"],
       ["mancanti_miur", mancanti, "mancanti MIUR",       "txt-negative"]
     ].each do |key, value, label, value_class| %>
    <% if interactive %>
      <div class="analytics-summary__card" role="button" tabindex="0"
           data-controllo-adozioni-filter-target="card" data-filter="<%= key %>"
           data-action="click->controllo-adozioni-filter#select keydown.enter->controllo-adozioni-filter#select">
        <p class="analytics-summary__value <%= value_class %>"><%= value %></p>
        <p class="analytics-summary__label"><%= label %></p>
      </div>
    <% else %>
      <div class="analytics-summary__card">
        <p class="analytics-summary__value <%= value_class %>"><%= value %></p>
        <p class="analytics-summary__label"><%= label %></p>
      </div>
    <% end %>
  <% end %>
</div>
