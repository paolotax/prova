<%# Filtri lista scuole con conteggi — target stabile per aggiornamento via stream. %>
<% filtro = local_assigns[:filtro] %>
<%= tag.div id: "controllo_adozioni_filtri" do %>
  <% if panoramica.gruppi.any? %>
    <% conteggi = panoramica.conteggi_stati %>
    <% voci = [["", "Tutte", nil],
               ["promosse", "Promosse", conteggi["promosse"]],
               ["da_promuovere", "Da promuovere", conteggi["da_promuovere"]],
               ["mancanti_miur", "Mancanti MIUR", conteggi["mancanti_miur"]],
               ["anomalie", "Con anomalie", conteggi["anomalie"]]] %>
    <nav class="flex gap-half flex-wrap margin-block-end">
      <% voci.each do |val, label, n| %>
        <%= link_to controllo_adozioni_index_path(filtro: val.presence, account_id: account_id),
              class: "btn btn--small #{'btn--accent' if filtro.to_s == val}" do %>
          <%= label %><% if n %> <span class="txt-subtle">(<%= n %>)</span><% end %>
        <% end %>
      <% end %>
    </nav>
  <% end %>
<% end %>
