<% @page_title = "Dashboard - Controllo adozioni" %>

<% content_for :header do %>
  <h1 class="header__title divider divider--fade full-width">
    <span class="overflow-ellipsis"><%= @page_title %></span>
  </h1>
<% end %>

<%# Refresh (morph) della dashboard man mano che il fan-out promozioni/cambi codice avanza. %>
<%= turbo_stream_from Current.account, "controllo_adozioni_dashboard" %>

<div class="stats-container" data-controller="dashboard-filter">
  <% totali = @dashboard.totali %>
  <% cards = [
       { metric: "scuole",        label: "scuole con adozioni" },
       { metric: "promosse",      label: "promosse",       filtro: "promosse",      value_class: "txt-positive" },
       { metric: "da_promuovere", label: "da promuovere",  filtro: "da_promuovere" },
       { metric: "mancanti_miur", label: "mancanti MIUR",  filtro: "mancanti_miur", value_class: "txt-negative" },
       { metric: "anomalie",      label: "con anomalie",   filtro: "anomalie" },
       { metric: "codici_nuovi",  label: "codici nuovi" }
     ] %>

  <div class="analytics-summary">
    <% cards.each do |c| %>
      <%= tag.div class: "analytics-summary__card", data: { dashboard_filter_target: "card", metric: c[:metric], filtro: c[:filtro] }.compact do %>
        <button type="button" class="analytics-summary__toggle" data-action="dashboard-filter#toggle">
          <p class="analytics-summary__value <%= c[:value_class] %>"><%= totali[c[:metric].to_sym] %></p>
          <p class="analytics-summary__label"><%= c[:label] %></p>
        </button>
        <% if c[:metric] == "codici_nuovi" && totali[:codici_nuovi].positive? %>
          <%= button_to controllo_adozioni_aggiorna_cambi_codice_path(account_id: params[:account_id]),
                class: "btn btn--small btn--accent margin-block-start-half",
                data: { turbo_confirm: "Aggiornare tutti i cambi codice con predecessore suggerito, in tutte le province?" } do %>
            Promuovi i match
          <% end %>
        <% end %>
      <% end %>
    <% end %>
  </div>

  <p class="txt-subtle txt-small margin-block-end">
    Snapshot MIUR <%= @dashboard.anno %> · <%= @dashboard.righe.size %> province.
    Clicca una card per filtrare le province, poi apri quella che ti serve.
  </p>

  <section class="margin-block-end">
    <h2 class="txt-medium">Per provincia</h2>
    <table class="txt-small full-width">
      <thead>
        <tr class="txt-subtle txt-x-small txt-uppercase">
          <th class="txt-start">Provincia</th>
          <th class="txt-end">Scuole</th>
          <th class="txt-end">Promosse</th>
          <th class="txt-end">Da promuovere</th>
          <th class="txt-end">Mancanti MIUR</th>
          <th class="txt-end">Anomalie</th>
          <th class="txt-end">Codici nuovi</th>
        </tr>
      </thead>
      <tbody>
        <% @dashboard.righe.each do |r| %>
          <% counts = { scuole: r.scuole, promosse: r.promosse, da_promuovere: r.da_promuovere,
                        mancanti_miur: r.mancanti_miur, anomalie: r.anomalie, codici_nuovi: r.codici_nuovi } %>
          <tr data-dashboard-filter-target="row" data-counts="<%= counts.to_json %>">
            <td class="txt-start">
              <% base = controllo_adozioni_index_path(provincia: r.provincia, account_id: params[:account_id]) %>
              <%= link_to r.provincia, base, data: { dashboard_filter_target: "provinciaLink", base_href: base } %>
            </td>
            <td class="txt-end"><%= r.scuole %></td>
            <td class="txt-end">
              <%= link_to_if r.promosse.positive?, r.promosse,
                    controllo_adozioni_index_path(provincia: r.provincia, filtro: "promosse", account_id: params[:account_id]) %>
            </td>
            <td class="txt-end">
              <%= link_to_if r.da_promuovere.positive?, r.da_promuovere,
                    controllo_adozioni_index_path(provincia: r.provincia, filtro: "da_promuovere", account_id: params[:account_id]) %>
            </td>
            <td class="txt-end">
              <%= link_to_if r.mancanti_miur.positive?, r.mancanti_miur,
                    controllo_adozioni_index_path(provincia: r.provincia, filtro: "mancanti_miur", account_id: params[:account_id]) %>
            </td>
            <td class="txt-end">
              <%= link_to_if r.anomalie.positive?, r.anomalie,
                    controllo_adozioni_index_path(provincia: r.provincia, filtro: "anomalie", account_id: params[:account_id]) %>
            </td>
            <td class="txt-end">
              <%# I cambi codice/nuove scuole si gestiscono nel drill-down della provincia. %>
              <%= link_to_if r.codici_nuovi.positive?, r.codici_nuovi,
                    controllo_adozioni_index_path(provincia: r.provincia, account_id: params[:account_id]) %>
            </td>
          </tr>
        <% end %>
      </tbody>
      <tfoot>
        <tr class="txt-medium">
          <td class="txt-start">Totale</td>
          <td class="txt-end"><%= totali[:scuole] %></td>
          <td class="txt-end"><%= totali[:promosse] %></td>
          <td class="txt-end"><%= totali[:da_promuovere] %></td>
          <td class="txt-end"><%= totali[:mancanti_miur] %></td>
          <td class="txt-end"><%= totali[:anomalie] %></td>
          <td class="txt-end"><%= totali[:codici_nuovi] %></td>
        </tr>
      </tfoot>
    </table>
  </section>

  <section class="margin-block-end">
    <h2 class="txt-medium">Agenti</h2>
    <% if @dashboard.agenti.any? %>
      <table class="txt-small full-width">
        <thead>
          <tr class="txt-subtle txt-x-small txt-uppercase">
            <th class="txt-start">Agente</th>
            <th class="txt-end">Scuole assegnate</th>
          </tr>
        </thead>
        <tbody>
          <% @dashboard.agenti.each do |a| %>
            <tr>
              <td class="txt-start"><%= a.membership.user.name %></td>
              <td class="txt-end"><%= a.scuole_count %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p class="txt-subtle">Nessun agente nell'account.</p>
    <% end %>
    <p class="txt-subtle txt-small"><%= @dashboard.non_assegnate_count %> scuole non assegnate.</p>
  </section>
</div>
