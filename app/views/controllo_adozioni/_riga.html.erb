<% scuola = riga.scuola %>
<%= tag.article id: dom_id(scuola, :controllo),
      class: "flex align-center gap txt-small",
      style: "padding: .35rem .6rem; border: 1px solid var(--color-border); border-radius: var(--radius);" do %>
  <div class="flex align-center justify-center" style="inline-size: 1.8rem; flex: 0 0 auto;">
    <% if riga.promuovibile? %>
      <%= link_to new_controllo_adozioni_promozione_path(codicescuola: scuola.codice_ministeriale, account_id: scuola.account_id),
            class: "btn btn--small", data: { turbo_frame: :modal, controller: "tooltip", tooltip_content_value: "Promuovi" } do %>
        <%= icon_tag "academic-cap" %>
      <% end %>
    <% elsif riga.promossa? %>
      <span style="color: var(--color-positive);" data-controller="tooltip" data-tooltip-content-value="Già promossa">
        <%= icon_tag "check" %>
      </span>
    <% end %>
  </div>

  <div class="flex-item-grow max-inline-size">
    <%= link_to scuola_path(scuola, account_id: scuola.account_id), 
      style: "color: inherit;", 
      data: { turbo_frame:"_top" } do %>
      <div class="overflow-ellipsis"><strong><%= scuola.denominazione.presence || "—" %></strong></div>
    <% end %>
    <div class="txt-subtle overflow-ellipsis">
      <%= scuola.comune %> (<%= scuola.sigla_provincia %>) · <%= scuola.codice_ministeriale %>
    </div>
    
    <% if riga.anomalie? %>
      <% riga.anomalie_tipi.split(",").each do |tipo| %>
        <%= link_to tipo, controllo_adozioni_path(scuola.codice_ministeriale, account_id: scuola.account_id), 
            class: "badge #{anomalia_badge_colore(tipo)}",
            data: { turbo_frame: "_top" } %>
      <% end %>
    <% end %>
  </div>

  <% anno_corrente = Miur.anno_corrente %>
  <% anno_precedente = anno_corrente && format("%d%02d", anno_corrente[0, 4].to_i - 1, anno_corrente[0, 4].to_i % 100) %>
  <div class="txt-align-end" style="flex: 0 0 auto; white-space: nowrap;">
    <span class="txt-subtle">Scagnozz <%= riga.correnti_classi %>/<%= riga.correnti_adozioni %></span>
    <%= link_to controllo_adozioni_anteprima_path(scuola.codice_ministeriale, anno: anno_corrente, account_id: scuola.account_id),
          style: (riga.disallineata? ? "color: var(--color-negative);" : nil),
          data: { turbo_frame: "_top", controller: "tooltip", tooltip_content_value: "Anteprima adozioni (#{anno_scolastico_label(anno_corrente)})" } do %>
      · <%= anno_scolastico_label(anno_corrente) %> <strong><%= riga.new_classi %>/<%= riga.new_adozioni %></strong>
    <% end %>
    <%= link_to anno_scolastico_label(anno_precedente), controllo_adozioni_anteprima_path(scuola.codice_ministeriale, anno: anno_precedente, account_id: scuola.account_id),
          class: "txt-x-small txt-subtle", style: "margin-inline-start: .25rem;",
          data: { turbo_frame: "_top", controller: "tooltip", tooltip_content_value: "Anteprima adozioni (#{anno_scolastico_label(anno_precedente)})" } %>
  </div>
<% end %>
