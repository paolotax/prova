<%# Riga unificata "stato-centrica": un badge di stato + una azione contestuale.
    Guidata da ControlloAdozioniHelper#stato_riga (priorita' promuovi > anomalie > disall > fuori > ok). %>
<% scuola = riga.scuola %>
<% s = stato_riga(riga) %>
<%# data-filters: chiavi filtro (card + step) che questa riga soddisfa, dai predicati grezzi
    (non dallo stato a priorita'). Il controller mostra la riga se il filtro attivo e' tra queste. %>
<% filtri = [] %>
<% filtri << "promuovi"      if riga.promuovibile? %>
<% filtri << "anomalie"      if riga.anomalie? %>
<% filtri << "promosse"      if riga.promossa? %>
<% filtri << "mancanti_miur" if riga.mancante_miur? %>
<%= tag.article id: dom_id(scuola, :controllo),
      class: "ca-row",
      data: {
        controllo_adozioni_filter_target: "row",
        state: s[:stato],
        filters: filtri.join(" "),
        prov: scuola.provincia,
        grado: grado_riga(scuola.codice_ministeriale, scuola.grado),
        txt: "#{scuola.denominazione} #{scuola.codice_ministeriale} #{scuola.comune}".downcase
      } do %>
  <div class="ca-row__main">
    <div class="ca-row__name">
      <%= link_to scuola.denominazione.presence || "—",
            scuola_path(scuola, account_id: scuola.account_id), data: { turbo_frame: "_top" } %>
    </div>
    <div class="ca-row__meta">
      <%= scuola.comune %> (<%= sigla_o_provincia(scuola) %>) ·
      <span class="ca-row__code"><%= scuola.codice_ministeriale %></span>
    </div>
  </div>

  <div class="ca-row__right">
    <span class="badge <%= s[:badge_class] %>">
      <% if s[:stato] == "ok" %>
        <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 10.5l4 4 8-9"/></svg>
      <% else %>
        <span class="badge__dot"></span>
      <% end %>
      <%= s[:badge_label] %>
    </span>

    <span class="ca-row__action">
      <% if s[:azione] == :promuovi %>
        <%= link_to "Promuovi",
              new_controllo_adozioni_promozione_path(codicescuola: scuola.codice_ministeriale, account_id: scuola.account_id),
              class: "btn btn--small btn--accent", data: { turbo_frame: :modal } %>
      <% end %>
    </span>

    <%= link_to controllo_adozioni_path(scuola.codice_ministeriale, account_id: scuola.account_id),
          class: "btn btn--circle btn--small", data: { turbo_frame: "_top", controller: "tooltip", tooltip_content_value: "Vedi la scheda" } do %>
      <%= icon_tag "eye" %>
      <span class="for-screen-reader">Vedi la scheda</span>
    <% end %>
  </div>
<% end %>
