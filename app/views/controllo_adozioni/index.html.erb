<% @page_title = "Controllo adozioni" %>

<% content_for :header do %>
  <h1 class="header__title divider divider--fade full-width">
    <span class="overflow-ellipsis">Controllo adozioni</span>
  </h1>
<% end %>

<%= turbo_stream_from Current.account, "controllo_adozioni" %>

<div class="stats-container">
  <% if Current.admin? %>
    <%= render "controllo_adozioni/cambi_codice", panoramica: @panoramica, account_id: params[:account_id] %>
  <% end %>

  <%# ===== Panoramica scuole per direzione ===== %>
  <% if @panoramica.gruppi.empty? %>
    <p class="txt-subtle">Nessuna scuola con adozioni.</p>
  <% else %>
    <%= render "controllo_adozioni/filtri", panoramica: @panoramica, account_id: params[:account_id], filtro: @filtro %>
  <% end %>

  <% if Current.admin? %>
    <%= render "controllo_adozioni/promuovi_tutte", panoramica: @panoramica, account_id: params[:account_id] %>
  <% end %>

  <% gruppi = @panoramica.gruppi_filtrati(@filtro) %>
  <% if gruppi.empty? && @filtro.present? %>
    <p class="txt-subtle">Nessuna scuola per questo filtro.</p>
  <% end %>

  <% gruppi.each do |gruppo| %>
    <section class="margin-block-end">
      <% if (dir = gruppo[:direzione]) %>
        <h3 class="txt-small txt-subtle">
          <%= dir.denominazione %> · <%= dir.comune %> (<%= dir.provincia %>)
        </h3>
      <% elsif gruppo[:private] %>
        <h3 class="txt-small txt-subtle">Scuole private</h3>
      <% end %>

      <div class="flex flex-column gap-quarter">
        <%= render partial: "controllo_adozioni/riga",
              collection: gruppo[:scuole].map { |s| @panoramica.riga(s) }, as: :riga %>
      </div>
    </section>
  <% end %>
</div>
