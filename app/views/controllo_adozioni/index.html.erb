<% @page_title = "Controllo adozioni" %>

<% content_for :header do %>

  <% if @provincia.present? %>
    <div class="header__actions header__actions--start">
      <%= back_link_to "Province", controllo_adozioni_index_path(account_id: params[:account_id]) %>
    </div>
  <% end %>

  <h1 class="header__title divider divider--fade full-width">
    <span class="overflow-ellipsis">Controllo adozioni</span>
  </h1>
<% end %>

<%= turbo_stream_from Current.account, "controllo_adozioni" %>
<%= turbo_stream_from Current.account, "controllo_adozioni_riepilogo", (@provincia.presence || "_all") %>

<div class="ca-page">
  <%= render "controllo_adozioni/freshness" %>

  <% if Current.admin? && @provincia.present? %>
      <h2 class="divider divider--fade margin-block"><%= @provincia.to_s.titleize %></h2>
  <% end %>

  <%# ===== Riepilogo (card KPI) ===== %>
  <% if Current.admin? && @dashboard %>
    <%= render "controllo_adozioni/riepilogo", dashboard: @dashboard, provincia: @provincia,
          province_count: @province_count, account_id: params[:account_id] %>
  <% end %>

  <% if @lista_visibile %>
    <%# ===== Vista operativa: step interattivi + tabella + lista filtrabile ===== %>
    <div data-controller="controllo-adozioni-filter">
      <% if Current.admin? && @passaggio %>
        <%= render "controllo_adozioni/passaggio_anno", passaggio: @passaggio,
              account_id: params[:account_id], provincia: @provincia, interattivo: true %>
      <% end %>

      <% if Current.admin? && @province_count.to_i >= 2 && @provincia.blank? %>
        <%= render "controllo_adozioni/province", dashboard: @dashboard, account_id: params[:account_id] %>
      <% end %>

      <% if @panoramica.gruppi.empty? %>
        <p class="txt-subtle">Nessuna scuola con adozioni.</p>
      <% else %>
        <%# ===== Ricerca testo ===== (chip di stato e filtri provincia/grado rimossi:
            gli step-card fanno da filtro di stato; la ricerca filtra la lista per testo) %>
        <div class="ca-refine">
          <input class="input ca-refine__search" type="search" placeholder="Cerca scuola, comune o codice…" aria-label="Cerca"
                 data-controllo-adozioni-filter-target="search"
                 data-action="input->controllo-adozioni-filter#changeSearch">
        </div>

        <p class="ca-scope">
          <b data-controllo-adozioni-filter-target="scopeCount">0</b> scuole in lista ·
          gli Avvia agiscono su tutta la zona
        </p>

        <%# ===== Lista unificata: gruppi scuole (_gruppo) + codici nuovi (_riga_mancante) ===== %>
        <% if @paginata %>
          <%= with_automatic_pagination :controllo_adozioni, @page do %>
            <% @page.records.each do |leader| %>
              <%= render "controllo_adozioni/gruppo", leader: leader,
                    gruppi_per_leader: @gruppi_per_leader, panoramica: @panoramica %>
            <% end %>
          <% end %>
        <% else %>
          <% @leaders.each do |leader| %>
            <%= render "controllo_adozioni/gruppo", leader: leader,
                  gruppi_per_leader: @gruppi_per_leader, panoramica: @panoramica %>
          <% end %>
        <% end %>

        <% if Current.admin? && (mancanti = @panoramica.cambi_codice).any? %>
          <section class="ca-group margin-block-end" data-controllo-adozioni-filter-target="group">
            <div class="group-hd">
              <h3 class="txt-small txt-subtle">Nel MIUR, non ancora tue (<%= mancanti.size %>)</h3>
            </div>
            <div class="flex flex-column gap-quarter">
              <%= render partial: "controllo_adozioni/riga_mancante", collection: mancanti, as: :riga_mancante,
                    locals: { account_id: params[:account_id], panoramica: @panoramica } %>
            </div>
          </section>
        <% end %>

        <div class="ca-empty" data-controllo-adozioni-filter-target="empty">
          Nessuna scuola con questi filtri.
        </div>
      <% end %>
    </div>
  <% else %>
    <%# ===== Overview account grande: step informativi + tabella navigatore ===== %>
    <% if Current.admin? && @passaggio %>
      <%= render "controllo_adozioni/passaggio_anno", passaggio: @passaggio,
            account_id: params[:account_id], provincia: nil, interattivo: false %>
    <% end %>

    <% if Current.admin? && @province_count.to_i >= 2 %>
      <%= render "controllo_adozioni/province", dashboard: @dashboard, account_id: params[:account_id] %>
    <% end %>

    <p class="txt-subtle margin-block-start">
      Scegli una provincia dalla tabella per vederne le scuole e le operazioni.
    </p>
  <% end %>
</div>
