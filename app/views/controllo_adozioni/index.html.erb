<% @page_title = "Controllo adozioni" %>

<% content_for :header do %>
  <h1 class="header__title divider divider--fade full-width">
    <span class="overflow-ellipsis">Controllo adozioni</span>
  </h1>
<% end %>

<%= turbo_stream_from Current.account, "controllo_adozioni" %>
<%= turbo_stream_from Current.account, "controllo_adozioni_riepilogo", (@provincia.presence || "_all") %>

<div class="stats-container">
  <% if Current.admin? && @provincia.present? %>
    <p class="margin-block-end-half">
      <%= link_to controllo_adozioni_index_path(account_id: params[:account_id]), class: "btn btn--small" do %>
        ← Tutte le province
      <% end %>
      <span class="txt-medium margin-inline-start-half"><%= @provincia %></span>
    </p>
  <% end %>

  <% if Current.admin? %>
    <%= render "controllo_adozioni/cambi_codice", panoramica: @panoramica, account_id: params[:account_id], provincia: @provincia %>
  <% end %>

  <%# ===== Panoramica scuole per direzione ===== %>
  <% if @panoramica.gruppi.empty? %>
    <p class="txt-subtle">Nessuna scuola con adozioni.</p>
  <% else %>
    <%= render "controllo_adozioni/filtri", panoramica: @panoramica, account_id: params[:account_id], filtro: @filtro, provincia: @provincia %>
  <% end %>

  <% if Current.admin? %>
    <%= render "controllo_adozioni/promuovi_tutte", panoramica: @panoramica, account_id: params[:account_id], provincia: @provincia %>
  <% end %>

  <% if @page.used? %>
    <p class="txt-small txt-subtle margin-block-end-half">
      <%= @total_count %> <%= @total_count == 1 ? "scuola" : "scuole" %>
    </p>

    <%= with_automatic_pagination :controllo_adozioni, @page do %>
      <% @page.records.each do |leader| %>
        <% gruppo = @gruppi_per_leader[leader.id] %>
        <section class="margin-block-end">
          <% if (dir = gruppo[:direzione]) %>
            <h3 class="txt-small txt-subtle">
              <%= dir.denominazione %> · <%= dir.comune %> (<%= dir.provincia %>)
            </h3>
          <% elsif gruppo[:private] %>
            <h3 class="txt-small txt-subtle">Scuole private</h3>
          <% end %>

          <div class="flex flex-column gap-quarter">
            <%= render partial: "controllo_adozioni/riga",
                  collection: gruppo[:scuole].map { |s| @panoramica.riga(s) }, as: :riga %>
          </div>
        </section>
      <% end %>
    <% end %>
  <% elsif @filtro.present? && @panoramica.gruppi.any? %>
    <p class="txt-subtle">Nessuna scuola per questo filtro.</p>
  <% end %>
</div>
