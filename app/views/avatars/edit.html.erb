<div class="max-w-md mx-auto px-4 py-8">
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-gray-900">Modifica Avatar</h1>
    <p class="mt-1 text-sm text-gray-500">Carica una nuova immagine per il tuo profilo.</p>
  </div>

  <div class="bg-white shadow rounded-lg p-8" data-controller="avatar-preview">
    <div class="flex flex-col items-center space-y-6">
      <%# Current avatar or preview %>
      <div id="avatar_display" data-avatar-preview-target="display">
        <%= render "avatars/avatar_display", user: current_user %>
      </div>

      <%# Preview container (hidden by default) %>
      <div data-avatar-preview-target="preview" class="hidden flex-col items-center space-y-4">
        <div class="h-30 w-30 rounded-full overflow-hidden bg-gray-100">
          <img data-avatar-preview-target="image" src="" alt="Preview" class="h-full w-full object-cover">
        </div>
        <p class="text-sm text-green-600 font-medium">Nuova immagine selezionata</p>
      </div>

      <%# Upload form %>
      <%= form_with url: avatar_path, method: :patch, local: false, data: { avatar_preview_target: "form" } do |form| %>
        <div class="flex flex-col items-center space-y-4">
          <label class="relative cursor-pointer rounded-md bg-white font-medium text-blue-600 hover:text-blue-500 focus-within:outline-none">
            <span class="inline-flex items-center px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50">
              <svg class="-ml-1 mr-2 h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              Scegli immagine
            </span>
            <%= form.file_field :avatar,
                  accept: "image/*",
                  class: "sr-only",
                  data: { avatar_preview_target: "input", action: "change->avatar-preview#preview" } %>
          </label>

          <p class="text-xs text-gray-500">PNG, JPG, GIF fino a 5MB</p>

          <div data-avatar-preview-target="actions" class="hidden flex items-center space-x-4">
            <%= form.submit "Salva avatar", class: "rounded-lg py-2 px-4 bg-blue-600 text-white font-medium hover:bg-blue-700 cursor-pointer" %>
            <button type="button" data-action="avatar-preview#cancel" class="text-sm text-gray-500 hover:text-gray-700">
              Annulla
            </button>
          </div>
        </div>
      <% end %>

      <% if current_user.avatar.attached? %>
        <div class="pt-4 border-t border-gray-200 w-full">
          <%= button_to "Rimuovi avatar", avatar_path, method: :delete, class: "w-full text-center text-sm text-red-600 hover:text-red-500", data: { turbo_confirm: "Sei sicuro di voler rimuovere l'avatar?" } %>
        </div>
      <% end %>
    </div>
  </div>

  <div class="mt-4 text-center">
    <%= link_to "Torna alle informazioni personali", personal_info_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
  </div>
</div>
