<% @page_title = "Giacenze" %>

<% content_for :header do %>
  <div class="header__actions header__actions--start">
    <%= back_link_to "", :back %>
  </div>
  <h1 class="header__title divider divider--fade full-width">
    <span class="overflow-ellipsis">Giacenze di magazzino</span>
  </h1>
  <div class="header__actions header__actions--end"></div>
<% end %>

<div class="ca-page">
<%= render "filters/settings",
      filter_url: giacenze_path,
      filter_type: "giacenza_filter",
      user_filtering: @user_filtering,
      no_filtering_url: giacenze_path %>

<%= turbo_frame_tag :search_results do %>
  <%= render "shared/analytics_filter_cards",
        url: giacenze_path,
        param: :stati,
        current: @filter.stati,
        multi: true,
        cards: [
          { key: "adottati",      value: number_with_delimiter(@totali.fetch(:adottati)),      label: "adottati" },
          { key: "campionario",   value: number_with_delimiter(@totali.fetch(:campionario)),   label: "campionario" },
          { key: "scarico_saggi", value: number_with_delimiter(@totali.fetch(:scarico_saggi)), label: "scarico saggi" },
          { key: "venduti",       value: number_with_delimiter(@totali.fetch(:venduti)),       label: "vendute", value_class: "txt-positive" },
          { key: "impegnati",     value: number_with_delimiter(@totali.fetch(:da_consegnare)), label: "da consegnare" },
          { key: nil,             value: number_to_currency(@totali.fetch(:venduto_cents) / 100.0, locale: :it), label: "venduto", value_class: "txt-positive" }
        ] %>

  <p class="txt-small txt-subtle margin-block-end-half">
    <%= @total_count %> <%= @total_count == 1 ? "titolo" : "titoli" %>
  </p>

  <%= tag.div class: "data-table data-table--scroller", style: Giacenza::Columns.style(@columns) do %>
    <%= render "shared/data_table/header", columns: @columns, sort: @sort, registry: Giacenza::Columns, url: giacenze_path %>

    <%= with_automatic_pagination :giacenze, @page, id: "giacenze-lista" do %>
      <% @page.records.each do |libro| %>
        <%= render "giacenze/table/row", libro: libro, columns: @columns %>
      <% end %>
    <% end %>
  <% end %>
<% end %>
</div>
