<%# locals: (libro:) -%>
<style>
  .fascicolo-tile { position: relative; }
  .fascicolo-tile__remove {
    position: absolute; top: -6px; right: -6px;
    opacity: 0; transition: opacity .15s ease;
  }
  .fascicolo-tile:hover .fascicolo-tile__remove,
  .fascicolo-tile:focus-within .fascicolo-tile__remove { opacity: 1; }
</style>

<div id="<%= dom_id(libro, :fascicoli_tiles) %>" class="flex gap-half flex-wrap align-center">
  <% libro.confezione_righe.includes(:fascicolo).order(:row_order).each do |pivot| %>
    <div class="fascicolo-tile">
      <%= link_to pivot.fascicolo, class: "flex flex-column align-center gap-quarter", style: "max-width: 100px; text-decoration: none;", data: { turbo_frame: "_top" } do %>
        <%= image_tag pivot.fascicolo.avatar_url,
            style: "width: 80px; aspect-ratio: 3/4; object-fit: cover; border-radius: var(--border-radius); box-shadow: 0 1px 3px rgba(0,0,0,.2);",
            alt: pivot.fascicolo.titolo %>
        <span class="txt-xx-small txt-subtle overflow-ellipsis" style="max-width: 80px; text-align: center;"><%= pivot.fascicolo.disciplina %></span>
        <span class="txt-xx-small font-weight-bold"><%= number_to_currency(pivot.fascicolo.prezzo) %></span>
      <% end %>

      <%= button_to libro_fascicolo_path(libro, pivot),
            method: :delete,
            class: "fascicolo-tile__remove btn btn--negative btn--remove txt-x-small",
            data: { controller: "tooltip", tooltip_content_value: "Rimuovi fascicolo" } do %>
        <%= icon_tag "close" %>
        <span class="for-screen-reader">Rimuovi</span>
      <% end %>
    </div>
  <% end %>

  <button type="button" class="btn btn--circle btn--small"
          style="align-self: center; margin-inline-start: 0.5em;"
          data-action="dialog#open"
          data-controller="tooltip"
          data-tooltip-content-value="Aggiungi fascicolo">
    <%= icon_tag "add", size: "small" %>
    <span class="for-screen-reader">Aggiungi fascicolo</span>
  </button>
</div>
