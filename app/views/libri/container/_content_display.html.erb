<%# locals: (libro:, suggeriti: nil) -%>

<style>
  .fascicolo-tile { position: relative; }
  .fascicolo-tile__remove {
    position: absolute; top: -6px; right: -6px;
    opacity: 0; transition: opacity .15s ease;
  }
  .fascicolo-tile:hover .fascicolo-tile__remove,
  .fascicolo-tile:focus-within .fascicolo-tile__remove { opacity: 1; }
</style>

<div class="flex gap">
  <!-- Copertina -->
  <div class="flex-item-shrink">
    <%= image_tag libro.avatar_url,
        style: "width: 100px; aspect-ratio: 3/4; object-fit: cover; border-radius: var(--border-radius);",
        alt: libro.titolo %>
  </div>

  <!-- Info principale -->
  <div class="flex-item-grow flex flex-column gap-half">
    <h2 class="card__title txt-large margin-none" style="line-height: 1.2;">
      <%= libro.titolo %>
    </h2>

    <!-- Prezzi -->
    <div class="flex align-center gap margin-block-start-half">
      <span class="txt-x-large font-weight-black">
        <%= number_to_currency(libro.prezzo) %>
      </span>
      <% if libro.prezzo_suggerito_cents.present? && libro.prezzo_suggerito_cents > 0 %>
        <span class="flex flex-column">
          <span class="txt-small txt-subtle">Suggerito</span>
          <span class="txt-medium font-weight-bold txt-link"><%= number_to_currency(libro.prezzo_suggerito) %></span>
        </span>
        <% sconto = libro_sconto_percentuale(libro) %>
        <% if sconto > 0 %>
          <span class="badge badge--large" style="background: var(--card-color); color: white;">
            -<%= sconto %>%
          </span>
        <% end %>
      <% end %>
    </div>

    <!-- Note -->
    <% if libro.note.present? %>
      <div class="txt-small txt-subtle margin-block-start-half">
        <%= truncate(libro.note, length: 150) %>
      </div>
    <% end %>
  </div>
</div>

<% if suggeriti %>
  <div class="margin-block-start" data-controller="dialog" data-dialog-modal-value="true">
    <span class="txt-x-small txt-subtle txt-uppercase">Fascicoli</span>
    <div class="margin-block-start-quarter">
      <%= render "libri/container/fascicoli_tiles", libro: libro %>
    </div>
    <%= render "libri/fascicoli/dialog", libro: libro, suggeriti: suggeriti %>
  </div>
<% elsif libro.fascicoli_count.positive? %>
  <div class="margin-block-start">
    <span class="txt-x-small txt-subtle txt-uppercase">Fascicoli</span>
    <div class="flex gap-half flex-wrap margin-block-start-quarter">
      <% libro.fascicoli.each do |fascicolo| %>
        <%= link_to fascicolo, class: "flex flex-column align-center gap-quarter", style: "max-width: 100px; text-decoration: none;", data: { turbo_frame: "_top" } do %>
          <%= image_tag fascicolo.avatar_url,
              style: "width: 80px; aspect-ratio: 3/4; object-fit: cover; border-radius: var(--border-radius); box-shadow: 0 1px 3px rgba(0,0,0,.2);",
              alt: fascicolo.titolo %>
          <span class="txt-xx-small txt-subtle overflow-ellipsis" style="max-width: 80px; text-align: center;"><%= fascicolo.disciplina %></span>
          <span class="txt-xx-small font-weight-bold"><%= number_to_currency(fascicolo.prezzo) %></span>
        <% end %>
      <% end %>
    </div>
  </div>
<% end %>

<% if libro.confezioni_count.positive? %>
  <div class="margin-block-start">
    <span class="txt-x-small txt-subtle txt-uppercase">Contenuto di</span>
    <div class="flex gap-half flex-wrap margin-block-start-quarter">
      <% libro.fascicolo_righe.includes(:confezione).each do |pivot| %>
        <div id="<%= dom_id(pivot) %>" class="fascicolo-tile">
          <%= link_to pivot.confezione, class: "flex flex-column align-center gap-quarter", style: "max-width: 100px; text-decoration: none;", data: { turbo_frame: "_top" } do %>
            <%= image_tag pivot.confezione.avatar_url,
                style: "width: 80px; aspect-ratio: 3/4; object-fit: cover; border-radius: var(--border-radius); box-shadow: 0 1px 3px rgba(0,0,0,.2);",
                alt: pivot.confezione.titolo %>
            <span class="txt-xx-small txt-subtle overflow-ellipsis" style="max-width: 80px; text-align: center;"><%= truncate(pivot.confezione.titolo, length: 20) %></span>
            <span class="txt-xx-small font-weight-bold"><%= number_to_currency(pivot.confezione.prezzo) %></span>
          <% end %>

          <%= button_to libro_fascicolo_path(pivot.confezione, pivot),
                method: :delete,
                class: "fascicolo-tile__remove btn btn--negative btn--remove txt-x-small",
                data: { controller: "tooltip", tooltip_content_value: "Rimuovi da #{truncate(pivot.confezione.titolo, length: 30)}" } do %>
            <%= icon_tag "close" %>
            <span class="for-screen-reader">Rimuovi dalla confezione</span>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
