<%= turbo_stream.update "flash", partial: "layouts/shared/flash" %>
<% @libri.includes(:editore, :categoria).each do |libro| %>
  <%= turbo_stream.replace dom_id(libro) do %>
    <% if cookies[:libri_vista] == "tabella" %>
      <%= render "libri/table/row", libro: libro %>
    <% else %>
      <%= render "libri/libro", libro: libro %>
    <% end %>
  <% end %>
<% end %>
