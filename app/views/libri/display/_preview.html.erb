<%# locals: (libro:) -%>

<%= tag.article id: dom_id(libro),
    class: "card",
    style: "--card-color: #{libro_color(libro)}; view-transition-name: #{dom_id(libro)};",
    tabindex: 0,
    data: { navigable_list_target: "item", action: "mouseenter->navigable-list#hoverSelect contextmenu->navigable-list#toggleSelection" } do %>

  <label class="card__checkbox">
    <%= check_box_tag "ids[]", libro.id, false, data: { action: "change->bulk-actions#count" } %>
  </label>

  <div class="flex gap-half max-inline-size">
    <%# Copertina thumbnail %>
    <div class="flex-item-shrink">
      <%= copertina_tag libro, style: "--copertina-size: 60px;" %>
    </div>

    <div class="flex flex-column flex-item-grow">
      <%= link_to libro_path(libro), class: "card__link", data: { turbo_frame: "_top" } do %>
        <span class="for-screen-reader"><%= libro.titolo %></span>
      <% end %>

      <header class="card__header">
        <%= render "libri/display/preview/board", libro: libro %>
        <span class="txt-small font-weight-bold txt-negative"><%= number_to_currency(libro.prezzo) %></span>
      </header>

      <div class="card__body">
        <div class="card__content">
          <h3 class="card__title overflow-line-clamp" style="--lines: 2;">
            <%= libro.titolo %>
          </h3>
          <% if libro.classe.present? || libro.disciplina.present? %>
            <p class="txt-xsmall txt-subtle margin-block-end-half" style="margin-top: 0;">
              <% if libro.classe.present? %>Cl. <%= libro.classe %><% end %>
              <% if libro.classe.present? && libro.disciplina.present? %> · <% end %>
              <% if libro.disciplina.present? %><%= truncate(libro.disciplina.upcase, length: 25) %><% end %>
            </p>
          <% end %>
        </div>
      </div>

      <% if libro.fascicoli_count > 0 || libro.confezioni_count > 0 %>
        <div class="flex gap-quarter margin-block-start-quarter">
          <% unless libro.fascicoli_count.zero? %>
            <span class="badge badge--yellow"><%= libro.fascicoli_count %> fasc</span>
          <% end %>
          <% unless libro.confezioni_count.zero? %>
            <span class="badge badge--blue"><%= libro.confezioni_count %> conf</span>
          <% end %>
        </div>
      <% end %>

      <footer class="card__footer full-width">
        <%= render "libri/display/preview/meta", libro: libro %>
      </footer>
    </div>
  </div>
<% end %>
