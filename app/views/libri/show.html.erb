<% @page_title = @libro.titolo %>
<% @body_class = "contained-scrolling" %>

<% content_for :header do %>
  <div class="header__actions header__actions--start">
    <%= back_link_to "Libri", libri_path, "keydown.left@document->hotkey#click keydown.esc@document->hotkey#click" %>
  </div>

  <h1 class="header__title divider divider--fade full-width">
    <span class="overflow-ellipsis"><%= @libro.titolo %></span>
  </h1>

  <div class="header__actions header__actions--end">
    <%= link_to edit_libro_path(@libro), class: "btn" do %>
      <%= icon_tag "pencil" %>
      <span class="for-screen-reader">Modifica libro</span>
    <% end %>
  </div>
<% end %>

<!-- Main content grid -->
<div class="flex gap" style="flex-wrap: wrap;">

  <!-- Left column - Main info -->
  <div class="flex-item-grow" style="min-width: 0; flex-basis: 600px;">

    <!-- Book details card -->
    <section class="panel shadow margin-block-end">
      <div class="pad flex gap">
        <!-- Cover thumbnail -->
        <div class="flex-item-shrink">
          <%= image_tag @libro.avatar_url,
              style: "width: 120px; aspect-ratio: 3/4; object-fit: cover; border-radius: var(--border-radius);",
              alt: @libro.titolo %>
        </div>

        <!-- Details -->
        <div class="flex-item-grow">
          <dl class="dl-grid">
            <% if @libro.editore&.editore.present? %>
              <div>
                <dt class="txt-small txt-subtle">Editore</dt>
                <dd class="font-weight-bold"><%= @libro.editore.editore %></dd>
              </div>
            <% end %>

            <div>
              <dt class="txt-small txt-subtle">ISBN</dt>
              <dd class="font-weight-bold mono"><%= @libro.codice_isbn %></dd>
            </div>

            <div>
              <dt class="txt-small txt-subtle">Prezzo</dt>
              <dd>
                <span class="font-weight-bold" style="color: var(--color-negative);"><%= number_to_currency(@libro.prezzo) %></span>
                <% if @libro.prezzo_suggerito_cents.present? && @libro.prezzo_suggerito_cents > 0 %>
                  <span class="txt-small txt-subtle margin-inline-start-half">
                    Suggerito: <span style="color: var(--color-link);"><%= number_to_currency(@libro.prezzo_suggerito) %></span>
                  </span>
                <% end %>
              </dd>
            </div>

            <% if @libro.categoria&.nome_categoria.present? %>
              <div>
                <dt class="txt-small txt-subtle">Categoria</dt>
                <dd class="font-weight-bold"><%= @libro.categoria.nome_categoria %></dd>
              </div>
            <% end %>

            <% if @libro.classe.present? || @libro.disciplina.present? %>
              <div>
                <dt class="txt-small txt-subtle">Classe / Disciplina</dt>
                <dd class="font-weight-bold">
                  <%= [@libro.classe.present? ? "Classe #{@libro.classe}" : nil, @libro.disciplina&.titleize].compact.join(" - ") %>
                </dd>
              </div>
            <% end %>

            <% if @libro.cm.present? %>
              <div>
                <dt class="txt-small txt-subtle">CM</dt>
                <dd class="font-weight-bold mono"><%= @libro.cm %></dd>
              </div>
            <% end %>
          </dl>

          <!-- Badges -->
          <% if @libro.fascicoli_count > 0 || @libro.confezioni_count > 0 || @libro.has_confezioni? %>
            <div class="flex gap-half margin-block-start">
              <% unless @libro.fascicoli_count.zero? %>
                <%= component('badge', text: pluralize(@libro.fascicoli_count, "fascicolo", "fascicoli"), color: "yellow") %>
              <% end %>
              <% unless @libro.confezioni_count.zero? %>
                <%= component('badge', text: pluralize(@libro.confezioni_count, "confezione", "confezioni"), color: "blue") %>
              <% end %>
              <% if @libro.has_confezioni? %>
                <% @libro.confezioni.each do |c| %>
                  <%= link_to c do %>
                    <%= component('badge', text: c.titolo, color: "blue") %>
                  <% end %>
                <% end %>
              <% end %>
            </div>
          <% end %>

          <!-- Confezionator -->
          <div class="margin-block-start">
            <%= turbo_frame_tag "confezione_#{@libro.id}",
                src: fascicoli_libro_path(@libro),
                refresh: "morph",
                loading: :lazy %>
            <%= render partial: "confezionator/form", locals: { libro: @libro } %>
          </div>
        </div>
      </div>

      <% if @libro.note.present? %>
        <div class="pad pad-block-start" style="border-top: 1px solid var(--color-ink-lighter);">
          <h3 class="txt-small txt-subtle margin-block-end-quarter">Note</h3>
          <div class="txt-small"><%= simple_format(@libro.note) %></div>
        </div>
      <% end %>
    </section>

    <!-- Stats sections -->
    <div class="flex gap" style="flex-wrap: wrap;">

      <!-- Ordini -->
      <section class="panel shadow flex-item-grow" style="flex-basis: 200px;">
        <div class="pad">
          <div class="flex align-center justify-space-between margin-block-end-half">
            <h3 class="txt-small font-weight-bold">Ordini</h3>
            <span class="txt-large font-weight-bold" style="color: var(--color-negative);"><%= @giacenza&.ordini || 0 %></span>
          </div>
          <% if @libro.documento_righe.any? { |dr| dr.documento.ordine? } %>
            <ul class="flex flex-column gap-quarter">
              <% @libro.documento_righe.select { |dr| dr.documento.ordine? }.each do |documento_riga| %>
                <li class="flex align-center justify-space-between txt-small pad-half border-radius fill-shade">
                  <div class="overflow-ellipsis">
                    <% if documento_riga.documento.clientable.present? %>
                      <%= link_to documento_riga.documento.clientable.denominazione, documento_riga.documento.clientable, class: "txt-link" %>
                    <% end %>
                  </div>
                  <span class="font-weight-bold"><%= documento_riga.riga.quantita %></span>
                </li>
              <% end %>
            </ul>
          <% end %>
        </div>
      </section>

      <!-- Vendite -->
      <section class="panel shadow flex-item-grow" style="flex-basis: 200px;">
        <div class="pad">
          <div class="flex align-center justify-space-between margin-block-end-half">
            <h3 class="txt-small font-weight-bold">Vendite</h3>
            <span class="txt-large font-weight-bold" style="color: var(--color-link);"><%= @giacenza&.vendite || 0 %></span>
          </div>
          <% if @libro.documento_righe.any? { |dr| dr.documento.vendita? } %>
            <ul class="flex flex-column gap-quarter">
              <% @libro.documento_righe.select { |dr| dr.documento.vendita? }.each do |documento_riga| %>
                <li class="flex align-center justify-space-between txt-small pad-half border-radius fill-shade">
                  <div class="overflow-ellipsis">
                    <% if documento_riga.documento.clientable.present? %>
                      <%= link_to documento_riga.documento.clientable.denominazione, documento_riga.documento.clientable, class: "txt-link" %>
                    <% end %>
                  </div>
                  <span class="font-weight-bold"><%= documento_riga.riga.quantita %></span>
                </li>
              <% end %>
            </ul>
          <% end %>
        </div>
      </section>

      <!-- Carichi -->
      <section class="panel shadow flex-item-grow" style="flex-basis: 200px;">
        <div class="pad">
          <div class="flex align-center justify-space-between margin-block-end-half">
            <h3 class="txt-small font-weight-bold">Carichi</h3>
            <span class="txt-large font-weight-bold" style="color: var(--color-accent);"><%= @giacenza&.carichi || 0 %></span>
          </div>
          <% if @libro.documento_righe.any? { |dr| dr.documento.causale&.carico? } %>
            <ul class="flex flex-column gap-quarter">
              <% @libro.documento_righe.select { |dr| dr.documento.causale&.carico? }.each do |documento_riga| %>
                <li class="flex align-center justify-space-between txt-small pad-half border-radius fill-shade">
                  <div class="overflow-ellipsis">
                    <% if documento_riga.documento.clientable.present? %>
                      <%= link_to documento_riga.documento.clientable.denominazione, documento_riga.documento.clientable, class: "txt-link" %>
                    <% end %>
                  </div>
                  <span class="font-weight-bold"><%= documento_riga.riga.quantita %></span>
                </li>
              <% end %>
            </ul>
          <% end %>
        </div>
      </section>

    </div>

  </div>

  <!-- Right column - Sidebar -->
  <div style="flex-basis: 300px; flex-shrink: 0;">

    <!-- Adozioni card -->
    <div class="panel shadow pad margin-block-end">
      <div class="flex align-center justify-space-between margin-block-end-half">
        <h3 class="txt-small font-weight-bold">Adozioni</h3>
        <span class="txt-large font-weight-bold" style="color: var(--color-positive);"><%= @libro.adozioni_count %></span>
      </div>

      <% if @adozioni.any? %>
        <ul class="flex flex-column gap-half">
          <% @adozioni.each do |adozione| %>
            <li class="panel pad-half border-radius fill-shade">
              <div class="flex align-center justify-space-between">
                <span class="txt-small font-weight-bold"><%= adozione.classe_e_sezione %></span>
                <%= render partial: "import_adozioni/card_menu", locals: { import_adozione: adozione } %>
              </div>
              <%= link_to adozione.scuola, adozione.import_scuola, class: "txt-small txt-link overflow-ellipsis" %>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="txt-small txt-subtle txt-center">Nessuna adozione</p>
      <% end %>
    </div>

    <!-- Quick actions -->
    <div class="panel pad fill-shade">
      <h3 class="txt-small font-weight-bold margin-block-end-half">Azioni</h3>
      <div class="flex flex-column gap-half">
        <%= link_to edit_libro_path(@libro),
            class: "panel pad-half flex align-center gap-half", style: "text-decoration: none;" do %>
          <div class="flex align-center justify-center border-radius" style="width: 2rem; height: 2rem; background: var(--color-warning-lighter);">
            <%= icon_tag "pencil", size: "small", style: "color: var(--color-warning);" %>
          </div>
          <span class="txt-small font-weight-bold" style="color: var(--color-ink);">Modifica Libro</span>
        <% end %>

        <% if @libro.can_delete? %>
          <%= button_to libro_path(@libro),
              method: :delete,
              form: { data: { turbo_confirm: "Sei sicuro di voler eliminare questo libro?" } },
              class: "panel pad-half flex align-center gap-half", style: "text-decoration: none; border: none; cursor: pointer; width: 100%;" do %>
            <div class="flex align-center justify-center border-radius" style="width: 2rem; height: 2rem; background: var(--color-negative-lighter);">
              <%= icon_tag "trash", size: "small", style: "color: var(--color-negative);" %>
            </div>
            <span class="txt-small font-weight-bold" style="color: var(--color-ink);">Elimina Libro</span>
          <% end %>
        <% end %>
      </div>
    </div>

  </div>
</div>
