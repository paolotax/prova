<% @page_title = @libro.titolo %>
<% @header_class = "header--card" %>

<% content_for :header do %>
  <div class="header__actions header__actions--start">
    <% info = referrer_back_info || { label: "Libri", path: libri_path } %>
    <%= header_back_link info[:path], label: info[:label] %>
  </div>

  <div class="header__actions header__actions--end" id="libro-header-actions">
    <%= link_to new_libro_path, class: "btn btn--link", data: { controller: "tooltip" } do %>
      <%= icon_tag "add" %>
      <span class="for-screen-reader">Nuovo libro</span>
    <% end %>
  </div>
<% end %>

<div class="full-width card-grid pad group show-navigator">
  <%= render "libri/container/container", libro: @libro, giacenza: @giacenza, suggeriti: @suggeriti_fascicoli %>
</div>

<div class="scuola-show" style="--card-color: <%= libro_sconto_color(@libro) %>;">
  <%= render "libri/container/footer", libro: @libro, movimenti: @movimenti %>
  <%= render "libri/container/fascicoli", libro: @libro %>

  <% if @libro.adozioni_count.zero? && @movimenti.da_consegnare.none? && @movimenti.completati.none? %>
    <div class="margin-block-start">
      <%= render "shared/container/delete", record: @libro, path: libro_path(@libro), label: "questo libro" %>
    </div>
  <% end %>
</div>
