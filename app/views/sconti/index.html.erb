<% @page_title = "Sconti" %>

<% content_for :header do %>
  <div class="header__actions header__actions--start"></div>

  <h1 class="header__title">
    <%= @page_title %>
    <% if @scontabile %>
      <span class="txt-subtle">
        per <%= @scontabile.class.model_name.human %>
        <%= @scontabile.respond_to?(:denominazione) ? @scontabile.denominazione : @scontabile.to_s %>
      </span>
    <% end %>
  </h1>

  <div class="header__actions header__actions--end">
    <%= link_to @scontabile ? new_polymorphic_path([ @scontabile, :sconto ]) : new_sconto_path, class: "btn btn--primary" do %>
      <%= icon_tag "add", size: "small" %>
      <span>Nuovo</span>
    <% end %>
  </div>
<% end %>

<section class="panel panel--wide shadow center">
  <% if @sconti.any? %>
    <div class="table-wrapper">
      <table class="table">
        <thead>
          <tr>
            <th>Applicato a</th>
            <th>Categoria</th>
            <th class="txt-align-end">Sconto</th>
            <th>Tipo</th>
            <th>Inizio</th>
            <th>Fine</th>
            <th>Stato</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @sconti.each do |sconto| %>
            <tr id="<%= dom_id(sconto) %>">
              <td>
                <% desc = sconto.scontabile_description %>
                <% case desc[:scope] %>
                <% when :specific %>
                  <span class="badge fill-shade"><%= sconto.scontabile.class.model_name.human %></span>
                  <%= link_to sconto.scontabile.respond_to?(:denominazione) ? sconto.scontabile.denominazione : sconto.scontabile.to_s,
                      polymorphic_path(sconto.scontabile), class: "txt-link" %>
                <% when :all %>
                  <span class="badge fill-shade"><%= desc[:type] %></span>
                  <span class="font-weight-bold"><%= desc[:name] %></span>
                <% when :global %>
                  <span class="badge fill-selected">Globale</span>
                <% end %>
              </td>
              <td class="txt-subtle">
                <%= sconto.categoria&.nome_categoria || "Tutte" %>
              </td>
              <td class="txt-align-end font-weight-bold">
                <%= number_to_percentage(sconto.percentuale_sconto, precision: 2) %>
              </td>
              <td><%= sconto.tipo_sconto&.humanize %></td>
              <td class="txt-subtle"><%= l(sconto.data_inizio, format: :short) %></td>
              <td class="txt-subtle">
                <%= sconto.data_fine ? l(sconto.data_fine, format: :short) : "—" %>
              </td>
              <td>
                <% if sconto.attivo? %>
                  <span class="badge fill-shade txt-positive">Attivo</span>
                <% else %>
                  <span class="badge fill-shade txt-subtle">Non attivo</span>
                <% end %>
              </td>
              <td>
                <div class="table__actions">
                  <%= link_to sconto.scontabile ? edit_polymorphic_path([ sconto.scontabile, sconto ]) : edit_sconto_path(sconto),
                      class: "btn btn--circle btn--small borderless" do %>
                    <%= icon_tag "pencil", size: "small" %>
                    <span class="for-screen-reader">Modifica</span>
                  <% end %>
                  <%= button_to sconto.scontabile ? polymorphic_path([ sconto.scontabile, sconto ]) : sconto_path(sconto),
                      method: :delete,
                      data: { turbo_confirm: "Sei sicuro di voler eliminare questo sconto?" },
                      class: "btn btn--circle btn--small borderless txt-negative" do %>
                    <%= icon_tag "trash", size: "small" %>
                    <span class="for-screen-reader">Elimina</span>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <p class="txt-subtle txt-x-small margin-block-start-half">Totale sconti: <%= @sconti.count %></p>
  <% else %>
    <div class="flex flex-column align-center gap-half pad">
      <p class="txt-subtle txt-small">Nessuno sconto configurato.</p>
      <%= link_to "Crea il primo sconto",
          @scontabile ? new_polymorphic_path([ @scontabile, :sconto ]) : new_sconto_path,
          class: "btn" %>
    </div>
  <% end %>
</section>
