<%= turbo_frame_tag dom_id(@column, :entries) do %>
  <%= with_automatic_pagination dom_id(@column, :entries), @page,
      class: "cards__list",
      data: { drag_drop_item_container: true } do %>
    <%= render partial: "entries/entry", collection: @page.records, as: :entry %>
  <% end %>
<% end %>
