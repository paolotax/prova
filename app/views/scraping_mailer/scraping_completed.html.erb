<!DOCTYPE html>
<html>
  <head>
    <meta content='text/html; charset=UTF-8' http-equiv='Content-Type' />
  </head>
  <body>
    <h1>Scraping Adozioni Completato</h1>

    <h2>Regioni Aggiornate (<%= @regioni_aggiornate.count %>)</h2>
    <ul>
      <% @regioni_aggiornate.each do |regione| %>
        <li><%= regione %></li>
      <% end %>
    </ul>

    <h2>Regioni Saltate (<%= @regioni_saltate.count %>)</h2>
    <ul>
      <% @regioni_saltate.each do |regione| %>
        <li><%= regione %></li>
      <% end %>
    </ul>

    <h2>Regioni Nuove (<%= @regioni_nuove.count %>)</h2>
    <ul>
      <% @regioni_nuove.each do |regione| %>
        <li><%= regione %></li>
      <% end %>
    </ul>

    <% if @regioni_fallite&.any? %>
      <h2 style="color: #c00;">Regioni Fallite (<%= @regioni_fallite.count %>)</h2>
      <ul>
        <% @regioni_fallite.each do |regione| %>
          <li><%= regione %></li>
        <% end %>
      </ul>
      <p style="color: #c00;">
        Le regioni fallite verranno ritentate al prossimo run dello scraper.
      </p>
    <% end %>

    <p>Totale adozioni nel database: <%= NewAdozione.count %></p>
  </body>
</html>