<!DOCTYPE html>
<html>
  <head>
    <meta content='text/html; charset=UTF-8' http-equiv='Content-Type' />
  </head>
  <body>
    <h1>Scraping Adozioni Completato</h1>

    <h2>Regioni Aggiornate (<%= @regioni_aggiornate.count %>)</h2>
    <ul>
      <% @regioni_aggiornate.each do |regione| %>
        <li><%= regione %></li>
      <% end %>
    </ul>

    <h2>Regioni Saltate (<%= @regioni_saltate.count %>)</h2>
    <ul>
      <% @regioni_saltate.each do |regione| %>
        <li><%= regione %></li>
      <% end %>
    </ul>

    <h2>Regioni Nuove (<%= @regioni_nuove.count %>)</h2>
    <ul>
      <% @regioni_nuove.each do |regione| %>
        <li><%= regione %></li>
      <% end %>
    </ul>

    <% if @regioni_fallite&.any? %>
      <h2 style="color: #c00;">Regioni Fallite (<%= @regioni_fallite.count %>)</h2>
      <ul>
        <% @regioni_fallite.each do |regione| %>
          <li><%= regione %></li>
        <% end %>
      </ul>
      <p style="color: #c00;">
        Le regioni fallite verranno ritentate al prossimo run dello scraper.
      </p>
    <% end %>

    <% if @regioni_stale&.any? %>
      <h2 style="color: #b80;">Regioni con dati stale (<%= @regioni_stale.count %>)</h2>
      <ul>
        <% @regioni_stale.each do |regione| %>
          <li><%= regione %></li>
        <% end %>
      </ul>
      <p style="color: #b80;">
        Per queste regioni il MIUR non risponde: stiamo usando l'ultimo CSV archiviato.
      </p>
    <% end %>

    <% if @ultimo_run&.diff? %>
      <% s = @ultimo_run.diff_scuole %>
      <h3>Rettifiche di questo import</h3>
      <p>
        +<%= s.sum(:righe_aggiunte) %> / -<%= s.sum(:righe_rimosse) %> righe
        su <%= s.esistenti.count %> scuole esistenti ·
        <%= s.nuove.count %> nuove da promuovere ·
        <%= s.sparite.count %> sparite.<br>
        Province più toccate:
        <%= s.esistenti.group(:provincia).order(Arel.sql("SUM(righe_aggiunte + righe_rimosse) DESC"))
             .limit(3).sum(Arel.sql("righe_aggiunte + righe_rimosse")).keys.compact.join(", ") %><br>
        Dettaglio: apri <em>/miur/import_runs</em> nell'app.
      </p>
    <% end %>

    <p>Totale adozioni nel database: <%= Miur::Adozione.correnti.count %></p>
  </body>
</html>