<%# Sezione Navigazione %>
<%= collapsible_nav_section "Principale" do %>
    <%= filter_place_menu_item account_root_path(Current.account), "Bacheca", "home" %>
    <%= filter_place_menu_item agenda_path(Current.account), "Agenda", "calendar" %>
    <%= filter_place_menu_item persone_path(Current.account), "Contatti", "person" %>
    <% if (baule = Current.account.columns.find_by(name: "Nel Baule")) %>
      <%= filter_place_menu_item column_path(Current.account, baule), "Nel Baule", "truck" %>
    <% end %>
<% end %>

<%= collapsible_nav_section "Adozioni" do %>
    <%= filter_place_menu_item adozioni_analytics_path, "Adozioni", "cash" %>
    <%= filter_place_menu_item controllo_adozioni_index_path(Current.account), "Controllo adozioni e passaggio A.S.", "alert-triangle" %>
    <%= filter_place_menu_item stats_path(Current.account), "Stats (exit poll 2026)", "chart" %>
<% end %>

<%= collapsible_nav_section "Magazzino" do %>
    <%= filter_place_menu_item documenti_path(Current.account), "Documenti", "document" %>
    <%= filter_place_menu_item giacenze_path(Current.account), "Giacenze", "table" %>
    <%#= filter_place_menu_item ordini_in_corso_path(Current.account), "Ordini" %>
    <%= filter_place_menu_item clienti_path(Current.account), "Clienti", "users" %>
    <%= filter_place_menu_item libri_path(Current.account), "i miei Librini", "book" %>
    <%= filter_place_menu_item new_import_path(Current.account), "Importazioni", "arrow-down-tray" %>
<% end %>
    
<%= collapsible_nav_section "Giri" do %>
    <%= filter_place_menu_item giri_path(Current.account), "Giri", "truck" %>
    <%= filter_place_menu_item propaganda_index_path(Current.account), "Propaganda", "table" %>
    <%= filter_place_menu_item collane_path(Current.account), "Collane", "book" %>
<% end %>

<% if Current.user.admin? %>
  <%= collapsible_nav_section "Tabelle" do %>
      <%= filter_place_menu_item causali_path(Current.account), "Causali", "receipt" %>
      <%= filter_place_menu_item sconti_path(Current.account), "Sconti", "cash" %>
      <%= filter_place_menu_item categorie_path(Current.account), "Categorie", "tag" %>
      <%= filter_place_menu_item editori_path(Current.account), "Editori", "building-library" %>
  <% end %>
<% end %>
