<% @page_title = @user.name %>
<% me_or_you = Current.user == @user ? "me" : @user.first_name %>

<div class="settings settings--profile">
  <section class="settings__panel panel shadow text-align-center">
    <div class="flex flex-column gap position-relative">
      <% if Current.user == @user %>
        <%= link_to edit_user_personal_info_path(@user), class: "user-edit-link btn", data: { controller: "tooltip" } do %>
          <%= icon_tag "pencil" %>
          <span class="for-screen-reader">Modifica profilo</span>
        <% end %>
      <% end %>

      <div class="avatar txt-xx-large center fill-white btn--circle hide-focus-ring">
        <%= image_tag user_avatar_path(Current.user), alt: "Profilo avatar per #{Current.user.name}" %>
      </div>

      <div class="flex flex-column gap-half margin-block-end">
        <h1 class="txt-x-large margin-none"><%= @user.name %></h1>
        <div class="txt-medium">
          <% if !@user.active? %>
            <%= @user.name %> is no longer on this account
          <% elsif !@user.verified? %>
            Non verificato
            <div class="txt-small txt-tinted">Un codice di accesso è stato inviato a questo indirizzo email, ma l'utente non ha ancora effettuato l'accesso per confermare la propria identità.</div>
          <% else %>
            <%= mail_to @user.email %>
          <% end %>
        </div>
      </div>

      <% if @personal_info %>

        <header>
          <h2 class="divider">Dati personali</h2>
        </header>
        <dl class="dl-grid">
          <div>
            <dt class="txt-small txt-subtle">Nome</dt>
            <dd class="txt-small"><%= @personal_info.nome %></dd>
          </div>

          <div>
            <dt class="txt-small txt-subtle">Cognome</dt>
            <dd class="txt-small"><%= @personal_info.cognome %></dd>
          </div>

          <div>
            <dt class="txt-small txt-subtle">Cellulare</dt>
            <dd class="txt-small mono"><%= @personal_info.cellulare || "-" %></dd>
          </div>

          <div>
            <dt class="txt-small txt-subtle">Email personale</dt>
            <dd class="txt-small"><%= @personal_info.email_personale || "-" %></dd>
          </div>
        </dl>
      <% end %>
    </div>

    <% if Current.user == @user %>
      <hr class="separator--horizontal full-width flex-item-grow" style="--border-color: var(--color-ink-light);" aria-hidden="true">

      <%= button_to logout_path, method: :delete, class: "btn txt-x-small center", data: { turbo: false } do %>
        <span>Esci da ScagnoZZ da questo device</span>
      <% end %>
    <% end %>
  </section>

  <% if Current.user == @user %>
    <section class="settings__panel panel shadow hide-on-native">
      <%= render "users/theme" %>

      <section class="settings__section">
        <header>
          <h2 class="divider">Preferenze</h2>
        </header>
        <dl class="dl-grid">
          <div>
            <dt class="txt-small txt-subtle">Navigatore preferito</dt>
            <dd class="txt-small"><%= @personal_info&.navigator&.humanize || "-" %></dd>
          </div>
        </dl>
      </section>

      <section class="settings__section">
        <header>
          <h2 class="divider">Token di accesso</h2>
        </header>

        <p class="txt-small">
          I token di accesso permettono di collegare strumenti AI e
          integrazioni esterne al tuo account Scagnozz.
        </p>

        <div class="flex-inline center justify-center flex-wrap gap">
          <%= link_to access_tokens_path(account_id: Current.account), class: "btn btn--link" do %>
            <span>Gestisci token</span>
          <% end %>
        </div>
      </section>

      <section class="settings__section">
        <header>
          <h2 class="divider">Integrazioni</h2>
        </header>

        <div class="flex flex-column gap">
          <div>
            <h3 class="txt-small txt-bold">Estensione WhatsApp per Chrome</h3>
            <p class="txt-small txt-subtle">Crea appunti su Scagnozz direttamente da WhatsApp Web: seleziona un messaggio, clicca il pulsante e l'appunto viene creato con il testo e il contatto.</p>
            <%= button_to user_send_setup_mail_path(Current.user, type: "extension"), method: :post, class: "btn txt-x-small" do %>
              <span>Inviami le istruzioni via email</span>
            <% end %>
          </div>

          <div>
            <h3 class="txt-small txt-bold">Claude Desktop / Claude Code</h3>
            <p class="txt-small txt-subtle">Collega Scagnozz al tuo assistente AI per cercare scuole, adozioni, clienti e creare appunti direttamente dalla chat.</p>
            <%= button_to user_send_setup_mail_path(Current.user, type: "cli"), method: :post, class: "btn txt-x-small" do %>
              <span>Inviami le istruzioni via email</span>
            <% end %>
          </div>
        </div>
      </section>
    </section>
  <% end %>
</div>
