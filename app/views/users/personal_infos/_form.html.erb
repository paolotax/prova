<%= form_with(model: [Current.user, personal_info],
      method: personal_info&.persisted? ? :patch : :post,
      multipart: true,
      data: { controller: "form upload-preview" }, class: "flex flex-column gap") do |form| %>
  <% if personal_info.errors.any? %>
    <div class="panel pad border-radius txt-negative fill-shade">
      <h3 class="font-weight-black"><%= pluralize(personal_info.errors.count, "errore", "errori") %> da correggere:</h3>
      <ul class="margin-block-start-half txt-small">
        <% personal_info.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <!-- Avatar -->
  <section class="flex flex-column gap txt-medium">
      <div class="align-center center avatar__form gap">
        <span class="btn btn--placeholder txt-small"></span>

        <label class="avatar btn btn--circle input--file txt-xx-large center fill-white">
          <%= image_tag user_avatar_path(@user), aria: { hidden: "true" }, class: "avatar", size: 128, data: { upload_preview_target: "image" } %>
          <%= form.file_field :avatar, id: "file", class: "input", accept: User::Avatar::ALLOWED_AVATAR_CONTENT_TYPES.join(","),
                data: { upload_preview_target: "input", action: "upload-preview#previewImage" } %>
          <span class="for-screen-reader">Profile avatar for <%= @user.name %></span>
        </label>

        <% if @user.avatar.attached? %>
          <%= tag.button type: :submit, form: "avatar-delete-form", class: "btn btn--negative txt-small", data: { turbo_confirm: "Are you sure you want to remove your avatar? This can't be undone." } do %>
            <%= icon_tag "minus" %>
            <span class="for-screen-reader">Delete avatar</span>
          <% end %>
        <% end %>
      </div>
  </section>

  <!-- Dati personali -->
  <section class="flex flex-column gap txt-medium">
    <strong class="divider txt-large">Dati personali</strong>

    <div class="flex flex-column gap">
      <div class="form-grid">
        <div class="form-field">
          <%= form.label :nome, class: "form-label" %>
          <%= form.text_field :nome, class: "input", placeholder: "Mario" %>
        </div>

        <div class="form-field">
          <%= form.label :cognome, class: "form-label" %>
          <%= form.text_field :cognome, class: "input", placeholder: "Rossi" %>
        </div>
      </div>

      <div class="form-grid">
        <div class="form-field">
          <%= form.label :cellulare, class: "form-label" %>
          <%= form.telephone_field :cellulare, class: "input mono", placeholder: "+39 333 1234567" %>
        </div>

        <div class="form-field">
          <%= form.label :email_personale, "Email personale", class: "form-label" %>
          <%= form.email_field :email_personale, class: "input", placeholder: "mario.rossi@email.com" %>
        </div>
      </div>
    </div>
  </section>

  <!-- Preferenze -->
  <section class="flex flex-column gap txt-medium">
    <strong class="divider txt-large">Preferenze</strong>
    
    <div class="form-field">
      <%= form.label :navigator, "Navigatore preferito", class: "form-label" %>
      <%= form.select :navigator,
            options_for_select([
              ["Google Maps", "google_maps"],
              ["Apple Maps", "apple_maps"],
              ["Waze", "waze"]
            ], personal_info.navigator),
            { include_blank: "Seleziona..." },
            class: "input input--select" %>
    </div>
  </section>

  <button type="submit" id="log_in" class="btn btn--reversed center" data-form-target="submit">
    <span>Salvamodifiche</span>
  </button>

  <%= link_to "Annulla", user_personal_info_path(@user), data: { form_target: "cancel", turbo_frame: "_top" }, hidden: true %>

<% end %>

<%= form_with url: user_avatar_path(Current.user), method: :delete, id: "avatar-delete-form" %>
