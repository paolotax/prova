<% if personal_info.present? %>
  <div class="bg-white shadow rounded-lg divide-y divide-gray-200">
    <div class="px-4 py-5 sm:px-6">
      <div class="flex items-center space-x-4">
        <%= render "users/avatars/avatar_badge", user: current_user, size: :large %>
        <div>
          <h3 class="text-lg font-medium text-gray-900"><%= personal_info.nome_completo %></h3>
          <p class="text-sm text-gray-500"><%= current_user.email %></p>
        </div>
      </div>
    </div>

    <dl class="divide-y divide-gray-200">
      <div class="px-4 py-4 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
        <dt class="text-sm font-medium text-gray-500">Nome</dt>
        <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0"><%= personal_info.nome %></dd>
      </div>

      <div class="px-4 py-4 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
        <dt class="text-sm font-medium text-gray-500">Cognome</dt>
        <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0"><%= personal_info.cognome %></dd>
      </div>

      <div class="px-4 py-4 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
        <dt class="text-sm font-medium text-gray-500">Cellulare</dt>
        <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0"><%= personal_info.cellulare || "-" %></dd>
      </div>

      <div class="px-4 py-4 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
        <dt class="text-sm font-medium text-gray-500">Email personale</dt>
        <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0"><%= personal_info.email_personale || "-" %></dd>
      </div>

      <div class="px-4 py-4 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
        <dt class="text-sm font-medium text-gray-500">Navigatore preferito</dt>
        <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0"><%= personal_info.navigator&.humanize || "-" %></dd>
      </div>
    </dl>
  </div>
<% else %>
  <div class="text-center py-12">
    <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
    </svg>
    <h3 class="mt-2 text-sm font-medium text-gray-900">Nessuna informazione personale</h3>
    <p class="mt-1 text-sm text-gray-500">Inizia aggiungendo le tue informazioni personali.</p>
    <div class="mt-6">
      <%= link_to "Aggiungi informazioni", new_personal_info_path, class: "inline-flex items-center rounded-md bg-blue-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-blue-700" %>
    </div>
  </div>
<% end %>
