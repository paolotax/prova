<div class="max-w-md mx-auto px-4 py-8">
  <div class="flex items-center justify-between mb-8">
    <h1 class="text-2xl font-bold text-gray-900">Avatar</h1>
    <%= link_to "Modifica", edit_user_avatar_path(Current.user), class: "rounded-lg py-2 px-4 bg-blue-600 text-white font-medium hover:bg-blue-700" %>
  </div>

  <div class="bg-white shadow rounded-lg p-8">
    <%= render "users/avatars/avatar_display", user: Current.user %>
  </div>

  <div class="mt-4 text-center">
    <%= link_to "Torna alle informazioni personali", user_personal_info_path(Current.user), class: "text-sm text-gray-500 hover:text-gray-700" %>
  </div>
</div>
