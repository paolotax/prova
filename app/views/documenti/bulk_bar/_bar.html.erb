<% content_for :bulk_bar_buttons do %>
  <%# Stampa %>
  <button type="button" class="btn"
          data-action="bulk-bar#showForm"
          data-bulk-bar-target="menuButton"
          data-form-id="stampa">
    <%= icon_tag "printer" %>
    <span>Stampa</span>
  </button>

  <%# Gestione - apre dialog %>
  <div data-controller="dialog bulk-gestione" data-dialog-modal-value="true" data-action="keydown.esc->dialog#close:stop">
    <button type="button" class="btn"
            data-bulk-bar-target="menuButton"
            data-action="dialog#open bulk-gestione#loadContent">
      <%= icon_tag "settings" %>
      <span>Gestione</span>
    </button>
    <dialog class="dialog panel fill-white shadow gap flex-column"
            style="width: min(95vw, 40rem); max-height: 85vh; overflow-y: auto;"
            data-dialog-target="dialog">
      <turbo-frame id="bulk-gestione-frame" data-bulk-gestione-target="frame">
        <div class="flex justify-center padding">
          <span class="txt-subtle">Caricamento...</span>
        </div>
      </turbo-frame>
    </dialog>
  </div>

  <%# Elimina %>
  <button type="button" class="btn txt-negative"
          data-action="bulk-bar#showForm"
          data-bulk-bar-target="menuButton"
          data-form-id="elimina">
    <%= icon_tag "trash" %>
    <span>Elimina</span>
  </button>
<% end %>

<% content_for :bulk_bar_forms do %>
  <%# Form Stampa %>
  <div class="bulk-bar__form" data-bulk-bar-target="form" data-form-id="stampa">
    <span class="bulk-bar__form-title">Stampa PDF</span>
    <%= form_with url: documenti_prints_path(format: :pdf),
          method: :post,
          data: { bulk_actions_target: "form", turbo: false, controller: "pdf-print", action: "submit->pdf-print#submit" } do |f| %>
      <div class="bulk-bar__form-actions">
        <button type="button" class="btn" data-action="bulk-bar#hideForm">Annulla</button>
        <%= f.submit "Stampa", class: "btn btn--primary" %>
      </div>
    <% end %>
  </div>

  <%# Form Elimina %>
  <div class="bulk-bar__form" data-bulk-bar-target="form" data-form-id="elimina">
    <span class="bulk-bar__form-title txt-negative">Elimina documenti</span>
    <%= form_with url: documenti_deletions_path,
          method: :post,
          data: { bulk_actions_target: "form", action: "turbo:submit-end->bulk-actions#hideAfterSubmit",
                  turbo_confirm: "Sei sicuro di voler eliminare i documenti selezionati?" } do |f| %>
      <div class="bulk-bar__form-actions">
        <button type="button" class="btn" data-action="bulk-bar#hideForm">Annulla</button>
        <%= f.submit "Elimina", class: "btn btn--negative" %>
      </div>
    <% end %>
  </div>
<% end %>

<%= render "shared/bulk_bar" %>
