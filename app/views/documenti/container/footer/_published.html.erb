<%# locals: (documento:) -%>

<%= link_to edit_documento_path(documento), class: "btn",
    data: { turbo_method: :get, turbo_stream: true } do %>
  <%= icon_tag "pencil" %>
  Modifica
<% end %>

<% if %w[TD01 TD04 TD24].include?(documento.causale&.causale) %>
  <%= link_to "Esporta XML", esporta_xml_documento_path(documento, format: :xml), class: "btn" %>
<% end %>
