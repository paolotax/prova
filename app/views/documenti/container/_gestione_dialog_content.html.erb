<%# locals: (documento:) -%>

<div id="<%= dom_id(documento, :gestione_dialog) %>">
  <header class="flex justify-space-between align-center">
    <h4 class="txt-large txt-subtle">Gestione Documento</h4>
    <button type="button" tabindex="-1" class="btn btn--circle txt-xx-small borderless btn--reversed" data-controller="tooltip" data-action="dialog#close">
      <%= icon_tag "close" %>
      <span class="for-screen-reader">Chiudi [esc]</span>
    </button>
  </header>

  <%# === SEZIONE CONSEGNA === %>
  <section class="padding-block border-block-end" data-controller="inline-edit">
    <h2 class="divider gap txt-medium txt-subtle">Consegna</h2>

    <% if documento.consegnato? %>
      <%# View mode %>
      <div data-inline-edit-target="view" class="flex flex-column align-center gap-half">
        <span class="flex align-center gap-half">
          <%= icon_tag "truck" %>
          Consegnato il <strong><%= documento.consegnato_il&.strftime("%d/%m/%Y") %></strong>
        </span>
        <div class="flex gap-half align-center">
          <button type="button" class="btn btn--circle txt-small" data-controller="tooltip" data-action="inline-edit#showEdit">
            <%= icon_tag "pencil" %>
            <span class="for-screen-reader">Modifica</span>
          </button>
          <%= button_to documento_consegna_path(documento),
                method: :delete,
                class: "btn btn--circle txt-small btn--reversed txt-negative",
                data: { controller: "tooltip" } do %>
            <%= icon_tag "trash" %>
            <span class="for-screen-reader">Elimina</span>
          <% end %>
        </div>
      </div>

      <%# Edit mode %>
      <div data-inline-edit-target="edit" hidden>
        <%= form_with url: documento_consegna_path(documento),
              method: :patch,
              class: "flex flex-column align-center gap-half" do |f| %>
          <div class="flex flex-column align-center" data-controller="date-input">
            <%= f.label :consegnato_il, "Data consegna", class: "txt-small txt-subtle" %>
            <div class="date-input" style="max-width: 16ch;">
              <input type="text"
                     data-date-input-target="display"
                     placeholder="gg/mm/aaaa"
                     class="input input--date"
                     style="text-align: center;"
                     autocomplete="off"
                     data-action="input->date-input#parseText blur->date-input#formatOnBlur">
              <input type="date"
                     data-date-input-target="picker"
                     class="date-input__picker"
                     tabindex="-1"
                     data-action="change->date-input#pickerChanged">
              <%= f.hidden_field :consegnato_il, value: documento.consegnato_il&.to_date, data: { date_input_target: "hidden" } %>
              <button type="button" class="date-input__trigger" data-action="date-input#openPicker" tabindex="-1">
                <span class="for-screen-reader">Apri calendario</span>
              </button>
            </div>
          </div>
          <div class="flex gap-half">
            <button type="submit" class="btn btn--circle txt-small" data-controller="tooltip">
              <%= icon_tag "check" %>
              <span class="for-screen-reader">Salva</span>
            </button>
            <button type="button" class="btn btn--circle txt-small btn--reversed" data-controller="tooltip" data-action="inline-edit#showView">
              <%= icon_tag "close" %>
              <span class="for-screen-reader">Annulla</span>
            </button>
          </div>
        <% end %>
      </div>
    <% else %>
      <%= form_with url: documento_consegna_path(documento),
            method: :post,
            class: "flex flex-column align-center gap-half" do |f| %>
        <div class="flex flex-column align-center" data-controller="date-input">
          <%= f.label :consegnato_il, "Data consegna", class: "txt-small txt-subtle" %>
          <div class="date-input" style="max-width: 16ch;">
            <input type="text"
                   data-date-input-target="display"
                   placeholder="gg/mm/aaaa"
                   class="input input--date"
                   style="text-align: center;"
                   autocomplete="off"
                   data-action="input->date-input#parseText blur->date-input#formatOnBlur">
            <input type="date"
                   data-date-input-target="picker"
                   class="date-input__picker"
                   tabindex="-1"
                   data-action="change->date-input#pickerChanged">
            <%= f.hidden_field :consegnato_il, value: Date.today, data: { date_input_target: "hidden" } %>
            <button type="button" class="date-input__trigger" data-action="date-input#openPicker" tabindex="-1">
              <span class="for-screen-reader">Apri calendario</span>
            </button>
          </div>
        </div>
        <div class="">
          <%= f.submit "Segna consegnato", class: "btn txt-small" %>
        </div>
      <% end %>
    <% end %>
  </section>

  <%# === SEZIONE PAGAMENTO === %>
  <section class="padding-block border-block-end" data-controller="inline-edit">
    <h4 class="divider txt-medium txt-subtle">Pagamento</h4>

    <% if documento.pagato? %>
      <%# View mode %>
      <div data-inline-edit-target="view" class="flex flex-column align-center gap-half">
        <span class="flex align-center gap-half txt-nowrap">
          <%= icon_tag "cash" %>
          Pagato il <strong><%= documento.pagato_il&.strftime("%d/%m/%Y") %></strong>
          <% if documento.tipo_pagamento.present? %>
            (<span class="overflow-ellipsis" style="max-width: 10ch;"><%= documento.tipo_pagamento.humanize %></span>)
          <% end %>
        </span>
        <div class="flex gap-half align-center">
          <button type="button" class="btn btn--circle txt-small" data-controller="tooltip" data-action="inline-edit#showEdit">
            <%= icon_tag "pencil" %>
            <span class="for-screen-reader">Modifica</span>
          </button>
          <%= button_to documento_pagamento_path(documento),
                method: :delete,
                class: "btn btn--circle txt-small btn--reversed txt-negative",
                data: { controller: "tooltip" } do %>
            <%= icon_tag "trash" %>
            <span class="for-screen-reader">Elimina</span>
          <% end %>
        </div>
      </div>

      <%# Edit mode %>
      <div data-inline-edit-target="edit" hidden>
        <%= form_with url: documento_pagamento_path(documento),
              method: :patch,
              class: "flex flex-column align-center gap-half" do |f| %>
          <div class="flex flex-column align-center" data-controller="date-input">
            <%= f.label :pagato_il, "Data pagamento", class: "txt-small txt-subtle" %>
            <div class="date-input" style="max-width: 16ch;">
              <input type="text"
                     data-date-input-target="display"
                     placeholder="gg/mm/aaaa"
                     class="input input--date"
                     style="text-align: center;"
                     autocomplete="off"
                     data-action="input->date-input#parseText blur->date-input#formatOnBlur">
              <input type="date"
                     data-date-input-target="picker"
                     class="date-input__picker"
                     tabindex="-1"
                     data-action="change->date-input#pickerChanged">
              <%= f.hidden_field :pagato_il, value: documento.pagato_il&.to_date, data: { date_input_target: "hidden" } %>
              <button type="button" class="date-input__trigger" data-action="date-input#openPicker" tabindex="-1">
                <span class="for-screen-reader">Apri calendario</span>
              </button>
            </div>
          </div>
          <div class="flex flex-column align-center">
            <%= f.label :tipo_pagamento, "Tipo", class: "txt-small txt-subtle" %>
            <%= f.select :tipo_pagamento,
                  options_for_select([
                    ["Contanti", "contanti"],
                    ["Bonifico", "bonifico"],
                    ["Assegno", "assegno"],
                    ["Bancomat", "bancomat"],
                    ["Carta di credito", "carta_di_credito"],
                    ["Cedole", "cedole"]
                  ], documento.tipo_pagamento),
                  {},
                  class: "input input--select" %>
          </div>
          <div class="flex gap-half">
            <button type="submit" class="btn btn--circle txt-small" data-controller="tooltip">
              <%= icon_tag "check" %>
              <span class="for-screen-reader">Salva</span>
            </button>
            <button type="button" class="btn btn--circle txt-small btn--reversed" data-controller="tooltip" data-action="inline-edit#showView">
              <%= icon_tag "close" %>
              <span class="for-screen-reader">Annulla</span>
            </button>
          </div>
        <% end %>
      </div>
    <% else %>
      <%= form_with url: documento_pagamento_path(documento),
            method: :post,
            class: "flex flex-column align-center gap-half" do |f| %>
        <div class="flex flex-column align-center" data-controller="date-input">
          <%= f.label :pagato_il, "Data pagamento", class: "txt-small txt-subtle" %>
          <div class="date-input" style="max-width: 16ch;">
            <input type="text"
                   data-date-input-target="display"
                   placeholder="gg/mm/aaaa"
                   class="input input--date"
                   style="text-align: center;"
                   autocomplete="off"
                   data-action="input->date-input#parseText blur->date-input#formatOnBlur">
            <input type="date"
                   data-date-input-target="picker"
                   class="date-input__picker"
                   tabindex="-1"
                   data-action="change->date-input#pickerChanged">
            <%= f.hidden_field :pagato_il, value: Date.today, data: { date_input_target: "hidden" } %>
            <button type="button" class="date-input__trigger" data-action="date-input#openPicker" tabindex="-1">
              <span class="for-screen-reader">Apri calendario</span>
            </button>
          </div>
        </div>
        <div class="flex flex-column align-center">
          <%= f.label :tipo_pagamento, "Tipo", class: "txt-small txt-subtle" %>
          <%= f.select :tipo_pagamento,
                options_for_select([
                  ["Contanti", "contanti"],
                  ["Bonifico", "bonifico"],
                  ["Assegno", "assegno"],
                  ["Bancomat", "bancomat"],
                  ["Carta di credito", "carta_di_credito"],
                  ["Cedole", "cedole"]
                ], "contanti"),
                {},
                class: "input input--select" %>
        </div>
        <div>
          <%= f.submit "Segna pagato", class: "btn txt-small" %>
        </div>
      <% end %>
    <% end %>
  </section>

  <%# === SEZIONE REGISTRAZIONE === %>
  <% causali_successive = documento.causale&.causali_successive_records %>
  <% if causali_successive&.any? %>
    <section class="padding-block-start">
      <h4 class="divider gap txt-medium txt-subtle margin-block-end-half">Registra come</h4>

      <div class="flex flex-wrap gap-half justify-center">
        <% causali_successive.each do |causale| %>
          <%= button_to documento_derivazione_path(documento),
                method: :post,
                class: "btn",
                style: "--btn-background: #{causale_color(causale)}; --btn-border-color: #{causale_color(causale)};",
                params: { causale_id: causale.id },
                form: { data: { turbo_frame: "_top" } } do %>
            <%= causale.causale %>
          <% end %>
        <% end %>
      </div>
    </section>
  <% end %>
</div>
