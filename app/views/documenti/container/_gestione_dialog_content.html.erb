<%# locals: (documento:) -%>

<div id="<%= dom_id(documento, :gestione_dialog) %>">
  <header class="flex justify-space-between align-center">
    <h4 class="txt-large txt-subtle">Gestione Documento</h4>
    <button type="button" tabindex="-1" class="btn btn--circle txt-xx-small borderless btn--reversed" data-controller="tooltip" data-action="dialog#close">
      <%= icon_tag "close" %>
      <span class="for-screen-reader">Chiudi [esc]</span>
    </button>
  </header>

  <%# === SEZIONE CONSEGNA === %>
  <% if documento.consegna_applicabile? %>
  <section class="pad-block border-block-end" data-controller="inline-edit">
    <h2 class="divider gap txt-medium txt-subtle margin-block-end">Consegna</h2>

    <% if documento.consegnato? %>
      <%# View mode %>
      <div data-inline-edit-target="view" class="flex flex-column align-center gap-half">
        <span class="flex align-center gap-half">
          <%= icon_tag "truck" %>
          Consegnato il <strong><%= documento.consegnato_il&.strftime("%d/%m/%Y") %></strong>
        </span>
        <div class="flex gap-half align-center">
          <button type="button" class="btn btn--circle txt-small" data-controller="tooltip" data-action="inline-edit#showEdit">
            <%= icon_tag "pencil" %>
            <span class="for-screen-reader">Modifica</span>
          </button>
          <%= button_to documento_consegna_path(documento),
                method: :delete,
                class: "btn btn--circle txt-small btn--reversed txt-negative",
                data: { controller: "tooltip" } do %>
            <%= icon_tag "trash" %>
            <span class="for-screen-reader">Elimina</span>
          <% end %>
        </div>
      </div>

      <%# Edit mode %>
      <div data-inline-edit-target="edit" hidden>
        <%= form_with url: documento_consegna_path(documento),
              method: :patch,
              class: "flex flex-column align-center gap-half" do |f| %>
          <div class="flex flex-column align-center">
            <%= label_tag :consegnato_il, "Data consegna", class: "txt-small txt-subtle" %>
            <%= date_input_tag(:consegnato_il, documento.consegnato_il, style: "max-width: 16ch;") %>
          </div>
          <div class="flex gap-half">
            <button type="submit" class="btn btn--circle txt-small" data-controller="tooltip">
              <%= icon_tag "check" %>
              <span class="for-screen-reader">Salva</span>
            </button>
            <button type="button" class="btn btn--circle txt-small btn--reversed" data-controller="tooltip" data-action="inline-edit#showView">
              <%= icon_tag "close" %>
              <span class="for-screen-reader">Annulla</span>
            </button>
          </div>
        <% end %>
      </div>
    <% else %>
      <%= form_with url: documento_consegna_path(documento),
            method: :post,
            class: "flex flex-column align-center gap" do |f| %>
        <div class="flex flex-column align-center">
          <%= label_tag :consegnato_il, "Data consegna", class: "txt-small txt-subtle" %>
          <%= date_input_tag(:consegnato_il, Date.today, style: "max-width: 16ch;") %>
        </div>
        <div class="flex flex-wrap gap-half justify-center">
          <%= f.submit "Segna consegnato", class: "btn txt-small" %>
          <% if documento.data_documento.present? %>
            <%= f.button "In data doc. (#{documento.data_documento.strftime('%d/%m')})",
                  name: "usa_data_documento", value: "1", class: "btn txt-small" %>
          <% end %>
        </div>
      <% end %>
    <% end %>
  </section>
  <% end %>

  <%# === SEZIONE PAGAMENTO === %>
  <% if documento.pagamento_applicabile? %>
  <section class="pad-block border-block-end" data-controller="inline-edit">
    <h4 class="divider txt-medium txt-subtle margin-block-end">Pagamento</h4>

    <% if documento.pagato? %>
      <%# View mode %>
      <div data-inline-edit-target="view" class="flex flex-column align-center gap-half">
        <span class="flex align-center gap-half txt-nowrap">
          <%= icon_tag "cash" %>
          Pagato il <strong><%= documento.pagato_il&.strftime("%d/%m/%Y") %></strong>
          <% if documento.tipo_pagamento.present? %>
            (<span class="overflow-ellipsis" style="max-width: 10ch;"><%= documento.tipo_pagamento.humanize %></span>)
          <% end %>
        </span>
        <div class="flex gap-half align-center">
          <button type="button" class="btn btn--circle txt-small" data-controller="tooltip" data-action="inline-edit#showEdit">
            <%= icon_tag "pencil" %>
            <span class="for-screen-reader">Modifica</span>
          </button>
          <%= button_to documento_pagamento_path(documento),
                method: :delete,
                class: "btn btn--circle txt-small btn--reversed txt-negative",
                data: { controller: "tooltip" } do %>
            <%= icon_tag "trash" %>
            <span class="for-screen-reader">Elimina</span>
          <% end %>
        </div>
      </div>

      <%# Edit mode %>
      <div data-inline-edit-target="edit" hidden>
        <%= form_with url: documento_pagamento_path(documento),
              method: :patch,
              class: "flex flex-column align-center gap-half" do |f| %>
          <div class="flex flex-column align-center">
            <%= label_tag :pagato_il, "Data pagamento", class: "txt-small txt-subtle" %>
            <%= date_input_tag(:pagato_il, documento.pagato_il, style: "max-width: 16ch;") %>
          </div>
          <div class="flex flex-column align-center">
            <%= label_tag :tipo_pagamento, "Tipo", class: "txt-small txt-subtle" %>
            <%= select_tag :tipo_pagamento,
                  options_for_select(tipi_pagamento_options, documento.tipo_pagamento),
                  class: "input input--select" %>
          </div>
          <div class="flex gap-half">
            <button type="submit" class="btn btn--circle txt-small" data-controller="tooltip">
              <%= icon_tag "check" %>
              <span class="for-screen-reader">Salva</span>
            </button>
            <button type="button" class="btn btn--circle txt-small btn--reversed" data-controller="tooltip" data-action="inline-edit#showView">
              <%= icon_tag "close" %>
              <span class="for-screen-reader">Annulla</span>
            </button>
          </div>
        <% end %>
      </div>
    <% else %>
      <%= form_with url: documento_pagamento_path(documento),
            method: :post,
            class: "flex flex-column align-center gap" do |f| %>
        <div class="flex flex-column align-center">
          <%= label_tag :pagato_il, "Data pagamento", class: "txt-small txt-subtle" %>
          <%= date_input_tag(:pagato_il, Date.today, style: "max-width: 16ch;") %>
        </div>
        <div class="flex flex-column align-center">
          <%= label_tag :tipo_pagamento, "Tipo", class: "txt-small txt-subtle" %>
          <%= select_tag :tipo_pagamento,
                options_for_select(tipi_pagamento_options, "contanti"),
                class: "input input--select" %>
        </div>
        <div class="flex flex-wrap gap-half justify-center">
          <%= f.submit "Segna pagato", class: "btn txt-small" %>
          <% if documento.data_documento.present? %>
            <%= f.button "In data doc. (#{documento.data_documento.strftime('%d/%m')})",
                  name: "usa_data_documento", value: "1", class: "btn txt-small" %>
          <% end %>
        </div>
      <% end %>
    <% end %>
  </section>
  <% end %>

  <%# === SEZIONE REGISTRAZIONE === %>
  <% causali_successive = documento.causale&.causali_successive_records %>
  <% if causali_successive&.any? %>
    <section class="pad-block-start">
      <h4 class="divider gap txt-medium txt-subtle margin-block-end">Registra come</h4>

      <div class="flex flex-wrap gap-half justify-center">
        <% causali_successive.each do |causale| %>
          <%= button_to documento_derivazione_path(documento),
                method: :post,
                class: "btn",
                style: "--btn-background: #{causale_color(causale)}; --btn-border-color: #{causale_color(causale)};",
                params: { causale_id: causale.id },
                form: { data: { turbo_frame: "_top" } } do %>
            <%= causale.causale %>
          <% end %>
        <% end %>
      </div>
    </section>
  <% end %>
</div>
