<%# locals: (documento:, editing: false) -%>

<%# Edit mode content - always rendered for persisted docs (toggled client-side), always visible for new docs %>
<div data-documento-editor-target="editContent" <%= 'hidden' unless editing %>>
  <%= form_with model: documento,
                url: documento.persisted? ? documento_path(documento) : documenti_path,
                method: documento.persisted? ? :patch : :post,
                id: dom_id(documento, :edit_form),
                data: {
                  turbo: false,
                  documento_editor_target: "form"
                } do |form| %>

    <% if documento.errors.any? %>
      <div class="flash flash--error margin-block">
        <%= t('misc.errori', count: documento.errors.count) %>
        <ul class="txt-small">
          <% documento.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="documento-edit-form">
      <%# Cliente/Scuola combobox %>
      <div class="documento-edit-form__cliente">
        <div class="form-field cb-tax" data-controller="toggle-class" data-toggle-class-toggle-class="editing">
          <% if documento.clientable.present? && !documento.clientable.is_a?(Domain::NessunCliente) %>
            <div class="flex gap-half align-center hide-when-editing">
              <span class="txt-subtle txt-small">[<%= documento.clientable.class.model_name.human %>]</span>
              <span><%= documento.clientable.to_combobox_display %></span>
              <button type="button" class="btn btn--circle btn--small borderless txt-small" data-action="toggle-class#toggle">
                <%= icon_tag "pencil", class: "icon--small" %>
              </button>
            </div>
            <div class="show-when-editing">
              <%= combobox_tag "documento[clientable_value]",
                  destinatari_index_path,
                  id: "documento_clientable_value_edit",
                  placeholder: "cerca scuola, cliente, classe...",
                  mobile_at: "0px" %>
            </div>
          <% else %>
            <%= form.combobox :clientable_value, destinatari_index_path,
                placeholder: "cerca scuola, cliente, classe...",
                mobile_at: "0px" %>
          <% end %>
        </div>
      </div>

      <div class="divider" style="margin-block: 2ch; --divider-color: var(--card-color);"></div>

      <%# Causale, Numero, Data %>
      <div class="flex gap align-end"
           data-controller="documento-causale"
           data-documento-causale-url-value="<%= documento_numero_path %>">
        <div class="form-field" style="flex: 1 1 50%;">
          <%= form.label :causale_id, "Causale documento", class: "form-label" %>
          <%= form.select :causale_id,
              options_from_collection_for_select(Causale.all, :id, :causale, documento.causale_id),
              { include_blank: "seleziona..." },
              class: "input input--select",
              data: { action: "change->documento-causale#change" } %>
        </div>

        <div class="form-field" style="flex: 1 1 25%;">
          <%= form.label :numero_documento, "Nr.", class: "form-label" %>
          <%= form.number_field :numero_documento, class: "input",
              data: { documento_causale_target: "numero" } %>
        </div>

        <div class="form-field" style="flex: 1 1 25%;">
          <%= form.label :data_documento, "Data", class: "form-label" %>
          <%= date_input(form, :data_documento) %>
        </div>

        <div class="form-field" style="flex: 1 1 25%;">
          <%= form.label :tipo_pagamento_previsto, "Pagamento previsto", class: "form-label" %>
          <%= form.select :tipo_pagamento_previsto,
              options_for_select(Pagamento::TIPI_PAGAMENTO.map { |k, v| [v, k] }, documento.tipo_pagamento_previsto),
              { include_blank: "nessuno" },
              class: "input input--select" %>
        </div>
      </div>

      <div class="divider" style="margin-block: 2ch; --divider-color: var(--card-color);"></div>

      <%# Referente e Note %>
      <div class="documento-edit-form__details">
        <div class="form-field">
          <%= form.label :referente, "Referente", class: "form-label" %>
          <%= form.text_field :referente, class: "input", placeholder: "Nome referente..." %>
        </div>

        <div class="form-field">
          <%= form.label :note, "Note", class: "form-label" %>
          <%= form.text_area :note, class: "input", rows: 2, placeholder: "Note..." %>
        </div>
      </div>
    </div>

    <%# Hidden fields for nested righe attributes - populated by Stimulus %>
    <div data-documento-editor-target="hiddenFields"></div>
  <% end %>
</div>

<%# View mode content (only for persisted documents) %>
<% if documento.persisted? %>
  <div data-documento-editor-target="viewContent" <%= 'hidden' if editing %>>
    <%= turbo_frame_tag documento, :edit do %>
      <%= render "documenti/container/content_display", documento: documento %>
    <% end %>
  </div>
<% end %>
