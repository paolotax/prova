<%# locals: (documento:, editing: false) -%>

<div class="documento-content">
  <div class="documento-content__cliente">
    <% if documento.clientable.present? %>
      <%= render partial: "clientables/#{documento.clientable.class.name.underscore}_card",
                 locals: { clientable: documento.clientable } %>
    <% end %>

    <% if documento.referente.present? %>
      <%= tag.div documento.referente, class: "documento-content__referente txt-small txt-muted" %>
    <% end %>
    
    <% if documento.note.present? %>
      <%= tag.div class: "documento-content__notes txt-small" do %>
        <%= simple_format documento.note %>
      <% end %>
    <% end %>
  </div>

</div>
