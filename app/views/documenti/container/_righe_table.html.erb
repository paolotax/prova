<%# locals: (documento:, editing: false) -%>

<%
  # Helper per raccogliere tutte le righe dei documenti derivati
  def collect_all_descendant_righe_recursive(doc, collected = {})
    doc.documenti_derivati.each do |figlio|
      figlio.righe.each { |riga| collected[riga.id] = riga }
      collect_all_descendant_righe_recursive(figlio, collected)
    end
    collected
  end

  tutte_righe_derivati = collect_all_descendant_righe_recursive(documento)
  righe_solo_documento = documento.righe.reject { |riga| tutte_righe_derivati.key?(riga.id) }
%>

<div class="documento-table" data-documento-editor-target="tableWrapper">
  <table class="documento-table__table">
    <thead>
      <tr class="documento-table__header">
        <th class="documento-table__th">Titolo</th>
        <th class="documento-table__th documento-table__th--right">ISBN</th>
        <th class="documento-table__th documento-table__th--right">Qt</th>
        <th class="documento-table__th documento-table__th--right">Prezzo</th>
        <th class="documento-table__th documento-table__th--right">Sc%</th>
        <th class="documento-table__th documento-table__th--right">Importo</th>
        <% if editing == true %>
          <th class="documento-table__th documento-table__th--right documento-table__th--actions"></th> %>
        <% end %>
      </tr>
    </thead>

    <tbody data-documento-editor-target="righeContainer">
      <%# Righe esclusive del documento %>
      <% righe_solo_documento.each do |riga| %>
        <%= render "documenti/container/riga_row", riga: riga, documento: documento, editing: false %>
      <% end %>

      <%# Righe raggruppate per documento derivato %>
      <% documento.documenti_derivati.order(:data_documento).each do |doc_derivato| %>
        <%
          righe_derivato_ids = doc_derivato.righe.pluck(:id)
          righe_per_derivato = documento.righe.select { |riga| righe_derivato_ids.include?(riga.id) }
        %>

        <% if doc_derivato.documenti_derivati.any? %>
          <tr class="documento-table__section documento-table__section--derivato">
            <td colspan="7" style="--card-color: <%= causale_color(doc_derivato.causale) %>; display: flex; align-items: center; justify-content: space-between;">
              <%= link_to documento_path(doc_derivato), data: { turbo_frame: :_top }, style: "text-decoration: none; color: inherit; display: inline-flex; align-items: center; gap: 0.5ch;" do %>
                <%= render "documenti/display/preview/board", documento: doc_derivato %>
                <span style="color: var(--card-color); font-size: var(--text-x-small);"><%= doc_derivato.data_documento&.strftime("%d/%m/%Y") %></span>
              <% end %>
              <div data-controller="dialog" data-dialog-modal-value="true" data-action="keydown.esc->dialog#close:stop" style="display: inline-flex;">
                <button type="button" class="btn btn--circle txt-xx-small btn--reversed" data-action="dialog#open">
                  <%= icon_tag "unlink" %>
                </button>
                <dialog class="dialog panel fill-white shadow gap flex-column" style="max-width: 40ch; text-transform: none; font-size: var(--text-medium);" data-dialog-target="dialog">
                  <h3 class="txt-large txt-bold">Scollegare questo documento?</h3>
                  <p class="txt-medium margin-block-half"><%= doc_derivato.causale&.causale %> #<%= doc_derivato.numero_documento %> del <%= doc_derivato.data_documento&.strftime("%d/%m/%Y") %></p>
                  <div class="flex gap-half justify-center margin-block-start">
                    <button type="button" class="btn" data-action="dialog#close">Annulla</button>
                    <%= button_to documento_derivazione_path(documento, figlio_id: doc_derivato.id),
                        method: :delete,
                        class: "btn txt-negative",
                        data: { action: "click->dialog#close" } do %>
                      <span>Scollega</span>
                    <% end %>
                  </div>
                </dialog>
              </div>
            </td>
          </tr>

          <% doc_derivato.documenti_derivati.order(:data_documento).each do |doc_nipote| %>
            <%
              righe_nipote_ids = doc_nipote.righe.pluck(:id)
              righe_per_nipote = documento.righe.select { |riga| righe_nipote_ids.include?(riga.id) }
            %>

            <% if righe_per_nipote.any? %>
              <tr class="documento-table__section documento-table__section--nipote">
                <td colspan="7" style="--card-color: <%= causale_color(doc_nipote.causale) %>;">
                  <%= link_to documento_path(doc_nipote), data: { turbo_frame: :_top }, style: "text-decoration: none; color: inherit; display: inline-flex; align-items: center; gap: 0.5ch;" do %>
                    <%= render "documenti/display/preview/board", documento: doc_nipote %>
                    <span style="color: var(--card-color); font-size: var(--text-x-small);"><%= doc_nipote.data_documento&.strftime("%d/%m/%Y") %></span>
                  <% end %>
                </td>
              </tr>

              <% righe_per_nipote.each do |riga| %>
                <%= render "documenti/container/riga_row", riga: riga, documento: documento, editing: false %>
              <% end %>
            <% end %>
          <% end %>

        <% elsif righe_per_derivato.any? %>
          <tr class="documento-table__section documento-table__section--derivato">
            <td colspan="7" style="--card-color: <%= causale_color(doc_derivato.causale) %>; display: flex; align-items: center; justify-content: space-between;">
              <%= link_to documento_path(doc_derivato), data: { turbo_frame: :_top }, style: "text-decoration: none; color: inherit; display: inline-flex; align-items: center; gap: 0.5ch;" do %>
                <%= render "documenti/display/preview/board", documento: doc_derivato %>
                <span style="color: var(--card-color); font-size: var(--text-x-small);"><%= doc_derivato.data_documento&.strftime("%d/%m/%Y") %></span>
              <% end %>
              <div data-controller="dialog" data-dialog-modal-value="true" data-action="keydown.esc->dialog#close:stop" style="display: inline-flex;">
                <button type="button" class="btn btn--circle txt-xx-small btn--reversed" data-action="dialog#open">
                  <%= icon_tag "unlink" %>
                </button>
                <dialog class="dialog panel fill-white shadow gap flex-column" style="max-width: 40ch; text-transform: none; font-size: var(--text-medium);" data-dialog-target="dialog">
                  <h3 class="txt-large txt-bold">Scollegare questo documento?</h3>
                  <p class="txt-medium margin-block-half"><%= doc_derivato.causale&.causale %> #<%= doc_derivato.numero_documento %> del <%= doc_derivato.data_documento&.strftime("%d/%m/%Y") %></p>
                  <div class="flex gap-half justify-center margin-block-start">
                    <button type="button" class="btn" data-action="dialog#close">Annulla</button>
                    <%= button_to documento_derivazione_path(documento, figlio_id: doc_derivato.id),
                        method: :delete,
                        class: "btn txt-negative",
                        data: { action: "click->dialog#close" } do %>
                      <span>Scollega</span>
                    <% end %>
                  </div>
                </dialog>
              </div>
            </td>
          </tr>

          <% righe_per_derivato.each do |riga| %>
            <%= render "documenti/container/riga_row", riga: riga, documento: documento, editing: false %>
          <% end %>
        <% end %>
      <% end %>

      <% if documento.righe.empty? %>
        <tr>
          <td colspan="7" class="documento-table__empty">Nessuna riga</td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <%# Controlli editing (nascosti di default, mostrati dal JS) %>
  <div class="margin-block-start flex gap align-center" data-documento-editor-target="editControls" hidden>
    <button type="button"
            class="btn btn--small"
            data-action="documento-editor#openNewDialog">
      + Nuova riga <kbd class="kbd">Ins</kbd>
    </button>
  </div>

  <%# Dialog per nuova/modifica riga %>
  <dialog class="dialog panel fill-white shadow"
          style="max-width: 50ch; padding: 1rem; overflow: visible;"
          data-documento-editor-target="rigaDialog"
          data-action="close->documento-editor#dialogClosed libro:loaded->documento-editor#onLibroLoaded">
    <div data-controller="combobox-libro dialog-form"
         data-combobox-libro-url-value="<%= get_prezzo_e_sconto_libro_path('__ID__') %>"
         data-combobox-libro-clientable-id-value="<%= documento.clientable_id %>"
         data-combobox-libro-clientable-type-value="<%= documento.clientable_type %>"
         data-dialog-form-submit-on-enter-value="true">
      <header class="flex justify-between align-center margin-block-end">
        <h3 class="txt-large" data-documento-editor-target="dialogTitle">Nuova riga</h3>
        <button type="button"
                class="btn btn--circle btn--small borderless"
                data-action="documento-editor#closeDialog"
                aria-label="Chiudi">
          <%= icon_tag "x", class: "icon--small" %>
        </button>
      </header>

      <%= form_with model: Riga.new, url: "#", scope: :riga, local: true,
                    data: { action: "submit->documento-editor#saveRigaFromDialog" } do |f| %>
        <div class="flex flex-column gap">
          <div class="cb-tax">
            <label class="txt-small txt-muted margin-block-end-quarter">Libro</label>
            <%= f.combobox :libro_id, libri_path,
                placeholder: "Cerca libro...",
                autofocus: true,
                data: {
                  documento_editor_target: "libroCombobox",
                  action: "hw-combobox:selection->combobox-libro#change hw-combobox:selection->documento-editor#onLibroSelected",
                  combobox_libro_target: "combobox"
                } %>
            <div class="txt-small txt-muted margin-block-start-quarter"
                 data-documento-editor-target="isbnDisplay"></div>
          </div>

          <div class="flex gap flex-wrap">
            <div class="flex flex-column" style="flex: 1 1 80px;">
              <label class="txt-small txt-muted margin-block-end-quarter">Qt</label>
              <%= f.number_field :quantita, value: 1, min: 1,
                  data: { documento_editor_target: "quantitaField", combobox_libro_target: "quantita", action: "keydown.enter->documento-editor#focusNextField" },
                  class: "input", style: "text-align: right;" %>
            </div>
            <div class="flex flex-column" style="flex: 1 1 100px;">
              <label class="txt-small txt-muted margin-block-end-quarter">Prezzo</label>
              <%= f.number_field :prezzo, step: 0.01,
                  data: { documento_editor_target: "prezzoField", combobox_libro_target: "prezzo", action: "keydown.enter->documento-editor#focusNextField" },
                  class: "input", style: "text-align: right;" %>
            </div>
            <div class="flex flex-column" style="flex: 1 1 80px;">
              <label class="txt-small txt-muted margin-block-end-quarter">Sc%</label>
              <%= f.number_field :sconto, value: 0, step: 0.01,
                  data: { documento_editor_target: "scontoField", combobox_libro_target: "sconto", action: "keydown.enter->documento-editor#submitDialog" },
                  class: "input", style: "text-align: right;" %>
            </div>
          </div>

          <div class="flex gap justify-end margin-block-start">
            <button type="button" class="btn" data-action="documento-editor#closeDialog">Annulla</button>
            <button type="submit" class="btn btn--positive">Salva</button>
          </div>
        </div>
      <% end %>
    </div>
  </dialog>
</div>
