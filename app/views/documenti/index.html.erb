<% @page_title = "Documenti" %>
<% @body_class = "contained-scrolling" %>

<% content_for :head do %>
  <style>
    .cards--grid {
      --cards-gap: 1rem;
      --card-grid-columns: 1;
      container-type: inline-size;
    }
    @media (min-width: 640px) {
      .cards--grid { --card-grid-columns: 2; }
    }
    @media (min-width: 960px) {
      .cards--grid { --card-grid-columns: 3; }
    }
    .cards--grid .cards__list {
      display: flex;
      flex-wrap: wrap;
      gap: var(--cards-gap);
      justify-content: center;
      padding: 1ch;
    }
    .cards--grid .documento {
      --text-xx-large: 1.6em;
      --text-small: 1em;
      font-size: clamp(0.6rem, 0.85cqi, 100px);
      inline-size: calc((100% - var(--cards-gap) * (var(--card-grid-columns) - 1)) / var(--card-grid-columns));
    }
    .documento__location {
      color: var(--documento-content-color);
      font-size: 0.85em;
      margin-block-start: 0.1em;
    }
    .documento__body {
      display: block !important;
      flex-direction: column !important;
    }
    .documento__content {
      inline-size: 100% !important;
      display: block !important;
    }
    .documento__content > a {
      display: block !important;
    }
    .documento__stages {
      color: var(--documento-text-color);
      font-size: var(--text-small, 0.9em);
      margin-block-start: 0.5em;
      padding-inline-start: 1em;
      display: block !important;
      text-align: start !important;
      justify-self: start !important;
      max-inline-size: none !important;
      inline-size: auto !important;
    }
  </style>
<% end %>

<% content_for :header do %>
	<div class="header__actions header__actions--start">
    <%= link_to documenti_path(format: :xlsx, params: request.query_parameters), class: "btn",
        data: { controller: "link-modifier", link_modifier_target: "link" } do %>
      <%= icon_tag "document" %>
      <span class="for-screen-reader">Esporta in excel</span>
    <% end %>
  </div>

  <h1 class="header__title divider divider--fade full-width">
    <span class="overflow-ellipsis">Documenti</span>
  </h1>

  <div class="header__actions header__actions--end">
    <%= link_to new_documento_path, class: "btn" do %>
      <%= icon_tag "add" %>
      <span class="for-screen-reader">Nuova documento</span>
    <% end %>
  </div>
<% end %>

<% if hotwire_native_app? %>
	<%= link_to new_documento_path, class: "hidden",
			data: { controller: "bridge--button", bridge_title: "Nuovo" } do %>
			<%= icon "plus", class: "documento-icon--medium" %>
	<% end %>
	<%= render "shared/native_search_filter",
		url: documenti_path,
		filter_url: filtra_documenti_path(params: request.query_parameters),
		placeholder: "Cerca documenti..." %>
<% end %>

<%= render "filters/settings",
      filter_url: documenti_path,
      user_filtering: @user_filtering,
      no_filtering_url: documenti_path,
      filter_type: "documento" %>

<%= turbo_frame_tag "search_results", data: { controller: 'bulk-actions' } do %>
    <%= render "documenti/bulk_actions/form" %>

    <% if @page.used? %>
      <p class="txt-small txt-subtle margin-block-end-half center">
        <%= @total_count %> <%= @total_count == 1 ? "documento trovato" : "documenti trovati" %>
      </p>

      <div class="cards--grid" data-controller="bulk-actions">
        <%= with_automatic_pagination :documenti, @page,
            id: "documenti-lista",
            class: "cards__list" do %>
          <%= render @page.records %>
        <% end %>
      </div>
  <% else %>
    <div class="blank-slate blank-slate--empty">
      <%= icon_tag "note", size: "large", class: "txt-subtle margin-block-end-half" %>
      <h3 class="txt-large font-weight-bold">Nessun documento trovato</h3>
      <p class="txt-small txt-subtle margin-block-end">
        <% if @user_filtering.filters_active? %>
          Prova a modificare i filtri di ricerca.
        <% else %>
          Inizia aggiungendo il primo documento.
        <% end %>
      </p>
      <% unless @user_filtering.filters_active? %>
        <%= link_to new_appunto_path, class: "btn btn--primary" do %>
          <%= icon_tag "plus", size: "small" %>
          Aggiungi Appunto
        <% end %>
      <% end %>
    </div>
  <% end %>
<% end %>

<div class="documento-loading">
  <%= icon "bouncing-dots", library: :animated, class: "documento-loading__spinner" %>
  <span class="documento-loading__text">Loading...</span>
</div>









