<% @page_title = "Documenti" %>
<% @body_class = "contained-scrolling" %>

<% content_for :header do %>
	<div class="header__actions header__actions--start">
    <%= link_to new_import_path(type: :documenti),
        class: "btn",
        data: { controller: "tooltip" } do %>
      <%= icon_tag "arrow-down-tray" %>
      <span class="for-screen-reader">Importa Documenti</span>
    <% end %>
  </div>

  <div class="header__action--mobile-title">
    <%= link_to documenti_path(format: :xlsx, params: request.query_parameters), class: "btn",
        data: { controller: "link-modifier tooltip", link_modifier_target: "link" } do %>
      <%= icon_tag "table-cells" %>
      <span class="for-screen-reader">Esporta in excel</span>
    <% end %>
  </div>

  <h1 class="header__title divider divider--fade full-width">
    <span class="overflow-ellipsis"><%= @page_title %></span>
    <%= render "shared/vista_toggle", url: documenti_path, vista: @vista %>
  </h1>

  <div class="header__actions header__actions--end">
    <%= link_to new_documento_path, class: "btn btn--link" , data: { controller: "tooltip" } do %>
      <%= icon_tag "add" %>
      <span class="for-screen-reader">Nuovo documento</span>
    <% end %>
  </div>
<% end %>

<% if hotwire_native_app? %>
	<%= link_to new_documento_path, class: "hidden",
			data: { controller: "bridge--button", bridge_title: "Nuovo" } do %>
			<%= icon_tag "plus", class: "card-icon--medium" %>
	<% end %>
	<%= render "shared/native_search_filter",
		url: documenti_path,
		filter_url: filtra_documenti_path(params: request.query_parameters),
		placeholder: "Cerca documenti..." %>
<% end %>



<%= render "filters/settings",
    filter_url: documenti_path,
    user_filtering: @user_filtering,
    no_filtering_url: documenti_path,
    filter_type: "documento_filter" %>

<%= turbo_frame_tag :search_results do %>
  <%= render "shared/analytics_filter_cards",
        url: documenti_path,
        param: :stato_documento,
        current: @filter.stato_documento.presence || "attivi",
        cards: [
          { key: "tutti",         value: number_with_delimiter(@stato_counts["tutti"]),         label: "tutti" },
          { key: "attivi",        value: number_with_delimiter(@stato_counts["attivi"]),        label: "attivi" },
          { key: "da_consegnare", value: number_with_delimiter(@stato_counts["da_consegnare"]), label: "da consegnare" },
          { key: "da_pagare",     value: number_with_delimiter(@stato_counts["da_pagare"]),     label: "da pagare" },
          { key: "completati",    value: number_with_delimiter(@stato_counts["completati"]),    label: "completati", value_class: "txt-positive" }
        ] %>

  <% unless @page.used? %>
    <%= blank_slate_for(:documenti, filtering: @user_filtering) %>
  <% else %>
    <p class="txt-small txt-subtle margin-block-end-half center">
      <%= @total_count %> <%= @total_count == 1 ? "documento trovato" : "documenti trovati" %>
    </p>

    <%= tag.div class: "flex flex-column", data: { controller: "bulk-actions" } do %>
      <%= render "documenti/bulk_bar/bar" %>

      <% if @vista == "card" %>
        <div class="cards cards--grid">
          <%= with_automatic_pagination :documenti, @page,
              id: "cards-lista",
              class: "cards__list",
              data: { controller: "navigable-list",
                  navigable_list_auto_select_value: false,
                  navigable_list_actionable_items_value: true,
                  navigable_list_prevent_handled_keys_value: true,
                  action: "keydown->navigable-list#navigate"
                } do %>
            <% mese_corrente = nil %>
            <% @page.records.each do |documento| %>
              <% if @filter.sorted_by.per_cliente? %>
                <% chiave = documento.data_documento&.year %>
              <% else %>
                <% chiave = documento.data_documento ? I18n.l(documento.data_documento, format: "%B %Y").capitalize : nil %>
              <% end %>
              <% if chiave != mese_corrente %>
                <% mese_corrente = chiave %>
                <h2 class="divider divider--fade txt-large full-width margin-block-start"><%= chiave %></h2>
              <% end %>
              <%= render documento %>
            <% end %>
          <% end %>
        </div>
      <% else %>
        <%= tag.div class: "data-table data-table--scroller", style: Documento::Columns.style(@columns) do %>
          <%= render "shared/data_table/header", columns: @columns, sort: @sort, registry: Documento::Columns, url: documenti_path %>

          <%= with_automatic_pagination :documenti, @page,
              id: "documenti-lista",
              data: { controller: "navigable-list",
                  navigable_list_auto_select_value: false,
                  navigable_list_actionable_items_value: true,
                  navigable_list_prevent_handled_keys_value: true,
                  action: "keydown->navigable-list#navigate"
                } do %>
            <% @page.records.each do |documento| %>
              <%= render "documenti/table/row", documento: documento, columns: @columns %>
            <% end %>
          <% end %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>
<% end %>








