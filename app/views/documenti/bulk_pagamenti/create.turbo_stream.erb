<%# Aggiorna il contenuto della dialog %>
<%= turbo_stream.update "bulk-gestione-frame" do %>
  <%= render "documenti/bulk_gestione/content", documenti: @documenti, documenti_per_cliente: @documenti_per_cliente %>
<% end %>

<%# Aggiorna ogni documento nella lista, nella variante corrente (row/card) %>
<% @documenti.each do |documento| %>
  <% target_id = documento.entry ? dom_id(documento.entry) : dom_id(documento) %>
  <%= turbo_stream.replace target_id do %>
    <%= render_documento_list_item(documento, entry: documento.entry) %>
  <% end %>
<% end %>

<%# Aggiorna il meta dei clienti coinvolti (saldo) %>
<% @documenti_per_cliente.each_key do |clientable| %>
  <% next unless clientable.is_a?(Cliente) %>
  <% clientable.reload %>
  <%= turbo_stream.replace dom_id(clientable, :meta) do %>
    <%= render "clienti/display/meta", cliente: clientable %>
  <% end %>
<% end %>
