<%# locals: (documento:, entry: nil, draggable: false) -%>

<% entry ||= documento.entry %>

<% card_data = {
  navigable_list_target: "item",
  action: "mouseenter->navigable-list#hoverSelect contextmenu->navigable-list#toggleSelection"
} %>

<% if entry && draggable %>
  <% card_data[:id] = entry.id %>
  <% card_data[:drag_and_drop_target] = "item" %>
  <% card_data[:css_variable_counter_target] = "item" %>
<% end %>

<%= tag.article id: (entry ? dom_id(entry) : dom_id(documento)),
    class: class_names("card", documento_causale_modifier(documento), documento_golden_class(documento)),
    style: "--card-color: #{documento_color(documento)}; view-transition-name: #{dom_id(documento)};",
    tabindex: 0,
    draggable: (draggable && entry.present?),
    data: card_data do %>
  <label class="card__checkbox">
    <%= check_box_tag "ids[]", (entry&.id || documento.id), false, data: { action: "change->bulk-actions#count" } %>
  </label>

  <div class="flex flex-column flex-item-grow max-inline-size">
  <header class="card__header">
    <%= render "documenti/display/preview/board", documento: documento %>

    <% if documento.clientable.is_a?(Classe) %>
      <span class="card__classe-badge"><%= documento.clientable.anno_corso %><%= documento.clientable.sezione %></span>
    <% end %>

    <% if documento.triaged? %>
      <span class="btn justify-start card__column-name card__column-name--current txt-uppercase min-width max-width">
        <span class="overflow-ellipsis"><%= documento.column.name %></span>
      </span>
    <% end %>
  </header>

  <%= link_to documento_path(documento), draggable: false, class: "card__link", data: { turbo_frame: "_top" } do %>
    <span class="for-screen-reader"><%= documento.causale&.causale %> #<%= documento.numero_documento %></span>
  <% end %>

  <div class="card__body">
    <div class="card__content">
      <% if documento.clientable.is_a?(Classe) %>
        <%# Index: denominazione + comune. In-context (scuola): solo anno+sezione %>
        <h3 class="card__title card__hide-in-context overflow-line-clamp"><%= documento.clientable.denominazione %></h3>
        <% if documento.clientable.comune.present? %>
          <span class="card__subtitle card__hide-in-context overflow-ellipsis"><%= documento.clientable.comune.upcase %></span>
        <% end %>
        <h3 class="card__title card__show-in-context overflow-line-clamp"><%= documento.clientable.anno_corso %><%= documento.clientable.sezione %></h3>
      <% elsif documento.clientable.present? %>
        <h3 class="card__title card__hide-on-index"><%= documento.clientable.denominazione %></h3>
        <% if documento.clientable.respond_to?(:comune) && documento.clientable.comune.present? %>
          <span class="card__subtitle card__hide-on-index overflow-ellipsis"><%= documento.clientable.comune.upcase %></span>
        <% end %>
      <% else %>
        <h3 class="card__title overflow-line-clamp">
          <%= documento.causale&.causale %>
          nr. <%= documento.numero_documento %>
        </h3>
      <% end %>

      <% if documento.referente.present? %>
        <div class="card__referente txt-x-small overflow-ellipsis" style="color: var(--card-content-color)">
          <%= documento.referente %>
        </div>
      <% end %>

      <% righe = documento.documento_righe.sort_by { |dr| dr.posizione || 0 } %>
      <% if righe.any? %>
        <div class="card__righe txt-xx-small txt-subtle margin-inline-start margin-block-start-half">
          <% righe.first(3).each do |dr| %>
            <div class="overflow-ellipsis"><%= dr.riga.quantita %> - <%= dr.riga.libro.titolo %></div>
          <% end %>
          <% if righe.size > 3 %>
            <div class="txt-subtle" style="font-style: italic;">segue…</div>
          <% end %>
        </div>
      <% end %>
    </div>

    <%# questo è display: none in index %>
    <%= render "documenti/display/preview/columns", documento: documento %>
  </div>
  </div>

  <footer class="card__footer flex gap-half">
    <%= render "documenti/display/preview/meta", documento: documento %>
  </footer>
<% end %>
