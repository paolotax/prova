<%# locals: (filter:, counts:) -%>
<% current = filter.stato_documento.presence || "attivi" %>
<% base_params = request.query_parameters.except("page") %>

<nav class="doc-stato-tabs" role="tablist" aria-label="Stato documenti">
  <% { "tutti" => "Tutti", "attivi" => "Attivi", "da_consegnare" => "Da consegnare", "da_pagare" => "Da pagare", "completati" => "Completati" }.each do |key, label| %>
    <%= link_to documenti_path(base_params.merge("stato_documento" => key)),
          role: "tab",
          aria: { selected: current == key },
          class: class_names("doc-stato-tab", "doc-stato-tab--active": current == key),
          data: { turbo_frame: "search_results", turbo_action: "advance" } do %>
      <span class="doc-stato-tab__label"><%= label %></span>
      <span class="doc-stato-tab__count"><%= counts[key] %></span>
    <% end %>
  <% end %>
</nav>
