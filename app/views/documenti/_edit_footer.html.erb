<%# locals: (documento:) -%>

<%= button_tag class: "btn btn--positive", type: :submit, form: dom_id(documento, :edit_form) do %>
  <%= icon_tag "check" %>
  <span>Salva</span>
<% end %>

<%= link_to documento_path(documento), class: "btn btn--reversed",
    data: { turbo_method: :get, turbo_stream: true } do %>
  <span>Annulla</span>
<% end %>
