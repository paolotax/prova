<%# locals: (documento:, editing: false, is_new: false, documento_json: nil, righe_json: nil) -%>

<%
  # Prepara JSON per il controller (sempre necessario)
  doc_json = documento_json || {
    id: documento.id,
    causale_id: documento.causale_id,
    clientable_id: documento.clientable_id,
    clientable_type: documento.clientable_type,
    numero_documento: documento.numero_documento,
    data_documento: documento.data_documento,
    referente: documento.referente,
    note: documento.note
  }.to_json

  righe_json_data = righe_json || documento.documento_righe.includes(riga: :libro).map { |doc_riga|
    riga = doc_riga.riga
    {
      documento_riga_id: doc_riga.id,
      riga_id: riga.id,
      libro_id: riga.libro_id,
      libro: {
        id: riga.libro&.id,
        titolo: riga.libro&.titolo,
        codice_isbn: riga.libro&.codice_isbn
      },
      titolo: riga.libro&.titolo,
      codice_isbn: riga.libro&.codice_isbn,
      quantita: riga.quantita,
      prezzo_cents: riga.prezzo_cents,
      sconto: riga.sconto
    }
  }.to_json
%>

<section id="<%= dom_id(documento, :container) %>"
         class="card-perma"
         style="--card-color: <%= documento_color(documento) %>;"
         data-controller="documento-editor"
         data-documento-editor-documento-value="<%= doc_json %>"
         data-documento-editor-righe-value="<%= righe_json_data %>"
         data-documento-editor-is-new-value="<%= is_new %>"
         data-documento-editor-editing-value="<%= editing %>"
         data-documento-editor-libri-path-value="<%= libri_path %>"
         data-documento-editor-documento-path-value="<%= documento.persisted? ? documento_path(documento) : '' %>"
         data-documento-editor-documenti-path-value="<%= documenti_path %>"
         data-action="keydown->documento-editor#navigate"
         tabindex="0"
         style="outline: none;">
  <div class="card-perma__actions card-perma__actions--left">
    <%# actions left %>
  </div>

  <div class="card-perma__bg">
    <article class="card">
      <header class="card__header">
        <div id="<%= dom_id(documento, :board) %>">
          <%= render "documenti/display/perma/board", documento: documento %>
        </div>
        <%#= render "documenti/display/perma/tags", documento: documento %>
      </header>

      <div class="card__body justify-space-between">
        <div class="card__content full-width">
          <%= render "documenti/container/content", documento: documento, editing: editing %>
        </div>
      </div>

      <footer class="card__footer full-width flex align-start gap">
        <%= render "documenti/display/perma/meta", documento: documento %>
      </footer>
    </article>
  </div>

  <div class="card-perma__actions card-perma__actions--right">
    <% if documento.persisted? && documento.numero_documento.present? && !editing %>
      <%= render "documenti/container/actions", documento: documento %>
    <% end %>
  </div>

  <div class="card-perma__notch card-perma__notch--bottom">
    <%# View footer (shown when not editing) %>
    <div data-documento-editor-target="viewFooter" <%= 'hidden' if editing %>>
      <%= render "documenti/container/footer", documento: documento %>
    </div>

    <%# Edit footer (shown when editing) %>
    <div data-documento-editor-target="editFooter" <%= 'hidden' unless editing %>>
      <%= render "documenti/edit_footer", documento: documento, is_new: is_new %>
    </div>
  </div>
</section>
