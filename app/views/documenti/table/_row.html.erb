<%# locals: (documento:, entry: nil, columns: nil) -%>

<% entry ||= (documento.entry rescue nil) %>
<%# I turbo_stream dei bulk rendono la riga senza columns: risolvile dal cookie %>
<% columns ||= Documento::Columns.visible(cookies[:documenti_colonne].to_s.split(",")) %>

<%= tag.div id: (entry ? dom_id(entry) : dom_id(documento)),
      class: class_names("data-row", documento_causale_modifier(documento), documento_golden_class(documento),
                         "data-row--closed": documento.closed?,
                         "data-row--selected": @documento == documento),
      style: "--card-color: #{documento_color(documento)}; --cols: #{Documento::Columns.grid_template(columns)}; view-transition-name: #{dom_id(documento)};",
      role: "row",
      tabindex: 0,
      data: {
        navigable_list_target: "item",
        action: "click->navigable-list#hoverSelect mouseenter->navigable-list#hoverSelect contextmenu->navigable-list#toggleSelection"
      } do %>

  <%# Link overlay: apre il dettaglio %>
  <%= link_to documento_path(documento), class: "data-row__link", tabindex: -1,
        data: { turbo_frame: "_top" } do %>
    <span class="for-screen-reader"><%= documento.causale&.causale %> #<%= documento.numero_documento %></span>
  <% end %>

  <div class="data-row__cell data-row__cell--check">
    <label>
      <%= check_box_tag "ids[]", (entry&.id || documento.id), false, data: { action: "change->bulk-actions#count" } %>
    </label>
  </div>

  <% columns.each do |column| %>
    <%= render column.partial, documento: documento %>
  <% end %>
<% end %>
