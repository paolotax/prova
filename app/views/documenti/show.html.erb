<% @page_title = "#{@documento.causale || 'Documento'} ##{@documento.numero_documento || 'BOZZA'}" %>

<% content_for :header do %>
  <div class="header__actions header__actions--start">
    <% info = referrer_back_info || { label: "Documenti", path: documenti_path } %>
    <%= back_link_to info[:label], info[:path], "keydown.left@document->hotkey#click keydown.esc@document->hotkey#click" %>
  </div>

  <h1 class="header__title divider divider--fade full-width">
    <span class="overflow-ellipsis"><%= @documento.causale || "Documento Bozza" %></span>
    <span class="txt-small txt-subtle">nr <%= @documento.numero_documento || 'BOZZA' %> del <%= @documento.data_documento&.strftime('%d-%m-%y') %></span>
  </h1>

  <div class="header__actions header__actions--end">
    <%= link_to documento_step_path(@documento, Documento.form_steps.keys.first), class: "btn" do %>
      <%= icon_tag "pencil" %>
      <span class="for-screen-reader">Modifica</span>
    <% end %>

    <%= link_to documento_path(@documento, format: :pdf), class: "btn", target: "_blank" do %>
      <%= icon_tag "printer" %>
      <span class="for-screen-reader">Stampa</span>
    <% end %>

    <%= link_to documento_path(@documento, format: :xlsx), class: "btn", target: "_blank" do %>
      <%= icon_tag "table-cells" %>
      <span class="for-screen-reader">Export Excel</span>
    <% end %>

    <%= button_to documenti_path(@documento), method: :delete, class: "btn",
        form: { data: { turbo_confirm: "Sei sicuro di voler eliminare questo documento?" } } do %>
      <%= icon_tag "trash" %>
      <span class="for-screen-reader">Elimina</span>
    <% end %>
  </div>
<% end %>

<div class="documento-detail">
  <div class="documento-detail__info">

        <div class="documento-detail__cliente">
            <%= render partial: "clientables/#{@documento.clientable.class.name.underscore}_card", locals: { clientable: @documento.clientable } %>
        </div>

        <div class="documento-detail__referente">
            <%= @documento.referente %>
        </div>
        <div class="documento-detail__notes">
            <%= simple_format @documento.note %>
        </div>

        <%= tag.div class: "documento-detail__status" do %>
            <%= render "shared/inline_edit", model: @documento, method: :stato_e_pagamento do %>
                <%= tag.div @documento.status&.titleize, class: "text-sm text-gray-500 font-semibold" %>
                <%= tag.div l(@documento.consegnato_il, format: "%d-%m"), class: "text-sm text-gray-500 font-semibold" if @documento.consegnato_il %>
                <%= tag.div @documento.tipo_pagamento&.titleize, class: "text-sm text-gray-500 font-semibold" %>
                <%= tag.div l(@documento.pagato_il, format: "%d-%m"), class: "text-sm text-gray-500 font-semibold" if @documento.pagato_il %>
            <% end %>

        <% end %>

        <% if @documento.documento_righe.size > 15 %>
          <div id="top" class="documento-detail__scroll-nav">
            <%= link_to "#bottom", class: "btn btn--ghost", data: { controller: "scroll-to", scroll_to_offset_value: "300", scroll_to_behavior_value: "smooth" } do %>
              <%= icon_tag "chevron-double-down" %>
            <% end %>
          </div>
        <% end %>
    </div>

    <div class="documento-detail__table-container">
      <table class="documento-detail__table">
        <colgroup>
          <col class="documento-detail__col--title">
          <col class="documento-detail__col--numeric">
          <col class="documento-detail__col--numeric">
          <col class="documento-detail__col--numeric">
          <col class="documento-detail__col--numeric">
        </colgroup>

        <thead class="documento-detail__thead">
          <tr>
            <th scope="col" class="documento-detail__th documento-detail__th--first">Titolo</th>
            <th scope="col" class="documento-detail__th documento-detail__th--right documento-detail__th--hidden-mobile">Prezzo</th>
            <th scope="col" class="documento-detail__th documento-detail__th--right">Quantita</th>
            <th scope="col" class="documento-detail__th documento-detail__th--right documento-detail__th--hidden-mobile">Sconto</th>
            <th scope="col" class="documento-detail__th documento-detail__th--right documento-detail__th--last">Importo</th>
          </tr>
        </thead>

        <tbody>

          <%
            # Helper per raccogliere tutte le righe dei documenti derivati
            def collect_all_descendant_righe_recursive(doc, collected = {})
              doc.documenti_derivati.each do |figlio|
                figlio.righe.each { |riga| collected[riga.id] = riga }
                collect_all_descendant_righe_recursive(figlio, collected)
              end
              collected
            end

            # Righe del documento che NON sono nei derivati
            tutte_righe_derivati = collect_all_descendant_righe_recursive(@documento)
            righe_solo_documento = @documento.righe.reject { |riga| tutte_righe_derivati.key?(riga.id) }
          %>

          <!-- Righe esclusive del documento (non condivise con derivati) -->
          <% if righe_solo_documento.any? %>
            <tr class="documento-detail__section documento--<%= causale_bem_modifier(@documento.causale) %>">
              <td colspan="5">
                <div class="documento-detail__section-content">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="documento-detail__section-icon">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
                  </svg>

                </div>
              </td>
            </tr>
            <% righe_solo_documento.each do |riga| %>
              <%= render partial: "righe/riga", locals: { riga: riga } %>
            <% end %>
          <% end %>

          <!-- Righe raggruppate per documento derivato -->
          <% @documento.documenti_derivati.order(:data_documento).each do |doc_derivato| %>
            <%
              # Righe del documento che appartengono a questo derivato
              righe_derivato_ids = doc_derivato.righe.pluck(:id)
              righe_per_derivato = @documento.righe.select { |riga| righe_derivato_ids.include?(riga.id) }
            %>

            <!-- Documenti nipoti (livello 2) -->
            <% if doc_derivato.documenti_derivati.any? %>
              <!-- Header documento derivato di livello 1 (es. DDT) -->
              <tr class="documento-detail__section documento-detail__section--derivato documento--<%= causale_bem_modifier(doc_derivato.causale) %>">
                <td colspan="5">
                  <div class="documento-detail__section-content">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="documento-detail__section-icon">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                    </svg>
                    <%= doc_derivato.causale&.causale %> #<%= doc_derivato.numero_documento %> del <%= doc_derivato.data_documento&.strftime("%d-%m-%Y") %>
                    <span class="documento-detail__section-badge">
                      <%= doc_derivato.documenti_derivati.count %> sotto-documenti
                    </span>
                    <%= link_to "Vedi", documento_path(doc_derivato), class: "documento-detail__section-link", data: { turbo_frame: :_top } %>
                  </div>
                </td>
              </tr>

              <!-- Documenti nipoti con le loro righe -->
              <% doc_derivato.documenti_derivati.order(:data_documento).each do |doc_nipote| %>
                <%
                  # Righe del documento che appartengono a questo nipote
                  righe_nipote_ids = doc_nipote.righe.pluck(:id)
                  righe_per_nipote = @documento.righe.select { |riga| righe_nipote_ids.include?(riga.id) }
                %>

                <% if righe_per_nipote.any? %>
                  <!-- Header documento nipote (es. Ordine) -->
                  <tr class="documento-detail__section documento-detail__section--nipote documento--<%= causale_bem_modifier(doc_nipote.causale) %>">
                    <td colspan="5">
                      <div class="documento-detail__section-content">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="documento-detail__section-icon documento-detail__section-icon--small">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                        </svg>
                        <%= doc_nipote.causale&.causale %> #<%= doc_nipote.numero_documento %> del <%= doc_nipote.data_documento&.strftime("%d-%m-%Y") %>
                        <% if doc_nipote.status.present? %>
                          <span class="documento-detail__section-badge">[<%= doc_nipote.status.titleize %>]</span>
                        <% end %>
                        <%= link_to "Vedi", documento_path(doc_nipote), class: "documento-detail__section-link", data: { turbo_frame: :_top } %>
                      </div>
                    </td>
                  </tr>

                  <!-- Righe del nipote -->
                  <% righe_per_nipote.each do |riga| %>
                    <%= render partial: "righe/riga", locals: { riga: riga } %>
                  <% end %>
                <% end %>
              <% end %>

            <% else %>
              <!-- Documento derivato senza nipoti - mostra direttamente le sue righe -->
              <% if righe_per_derivato.any? %>
                <!-- Header documento derivato -->
                <tr class="documento-detail__section documento-detail__section--derivato documento--<%= causale_bem_modifier(doc_derivato.causale) %>">
                  <td colspan="5">
                    <div class="documento-detail__section-content">
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="documento-detail__section-icon">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                      </svg>
                      <%= doc_derivato.causale&.causale %> #<%= doc_derivato.numero_documento %> del <%= doc_derivato.data_documento&.strftime("%d-%m-%Y") %>
                      <% if doc_derivato.status.present? %>
                        <span class="documento-detail__section-badge">[<%= doc_derivato.status.titleize %>]</span>
                      <% end %>
                      <%= link_to "Vedi", documento_path(doc_derivato), class: "documento-detail__section-link", data: { turbo_frame: :_top } %>
                    </div>
                  </td>
                </tr>

                <!-- Righe del derivato -->
                <% righe_per_derivato.each do |riga| %>
                  <%= render partial: "righe/riga", locals: { riga: riga } %>
                <% end %>
              <% end %>
            <% end %>
          <% end %>

        </tbody>

        <tfoot class="documento-detail__tfoot">
          <tr>
            <th scope="row" colspan="4" class="documento-detail__totals-label documento-detail__totals-label--hidden-mobile">Totale copie</th>
            <th scope="row" colspan="2" class="documento-detail__totals-label documento-detail__totals-label--mobile-only">Totale copie</th>
            <td class="documento-detail__totals-value">
              <%= @documento.righe.sum(&:quantita) %>
            </td>
          </tr>
          <tr>
            <th scope="row" colspan="4" class="documento-detail__totals-label documento-detail__totals-label--bold documento-detail__totals-label--hidden-mobile">Totale importo</th>
            <th scope="row" colspan="2" class="documento-detail__totals-label documento-detail__totals-label--bold documento-detail__totals-label--mobile-only">Totale importo</th>
            <td class="documento-detail__totals-value documento-detail__totals-value--bold">
              <%= number_to_currency @documento.righe.sum(&:importo), locale: :it %>
            </td>
          </tr>
        </tfoot>
      </table>

      <% if @documento.documento_righe.size > 20 %>
        <div id="bottom" class="documento-detail__scroll-nav">
          <%= link_to "#top", class: "btn btn--ghost", data: { controller: "scroll-to", scroll_to_offset_value: "300", scroll_to_behavior_value: "smooth" } do %>
            <%= icon_tag "chevron-double-up" %>
          <% end %>
        </div>
      <% end %>

    </div>

    <%= link_to "Esporta XML", esporta_xml_documento_path(@documento, format: :xml),
                class: "btn" %>
</div>
