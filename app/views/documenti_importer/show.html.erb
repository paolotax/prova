<% @page_title = "Importazione Completata" %>

<% content_for :header do %>
  <div class="header__actions header__actions--start">
    <%= link_to imports_path, class: "btn" do %>
      <%= icon_tag "arrow-left", size: "small" %>
      <span class="for-screen-reader">Torna alle importazioni</span>
    <% end %>
  </div>
  <h1 class="header__title"><%= @page_title %></h1>
  <div class="header__actions header__actions--end"></div>
<% end %>

<section class="panel panel--wide shadow center">
  <div class="flex align-center gap margin-block-end">
    <% if @import.errors.any? %>
      <%= icon_tag "exclamation-triangle", class: "txt-notice", size: "large" %>
      <h2 class="txt-large margin-none font-weight-black txt-notice">Completata con avvisi</h2>
    <% else %>
      <%= icon_tag "check-circle", class: "txt-positive", size: "large" %>
      <h2 class="txt-large margin-none font-weight-black txt-positive">Importazione riuscita</h2>
    <% end %>
  </div>

  <div class="flex gap flex-wrap">
    <div class="flex flex-column align-center pad" style="flex: 1; min-width: 100px;">
      <span class="txt-xx-large font-weight-black txt-positive"><%= @import.imported_count %></span>
      <span class="txt-small txt-subtle">Righe importate</span>
    </div>
    <div class="flex flex-column align-center pad" style="flex: 1; min-width: 100px;">
      <span class="txt-xx-large font-weight-black txt-link"><%= @import.updated_count %></span>
      <span class="txt-small txt-subtle">Aggiornate</span>
    </div>
    <div class="flex flex-column align-center pad" style="flex: 1; min-width: 100px;">
      <span class="txt-xx-large font-weight-black <%= @import.errors_count > 0 ? 'txt-negative' : 'txt-subtle' %>"><%= @import.errors_count %></span>
      <span class="txt-small txt-subtle">Errori</span>
    </div>
  </div>
</section>

<% if @import.documento.present? %>
  <section class="panel panel--wide shadow center margin-block-start">
    <h3 class="divider divider--fade txt-medium font-weight-black">Documento</h3>

    <div class="flex flex-wrap gap full-width">
      <div class="flex-item-grow" style="flex-basis: 120px;">
        <span class="txt-x-small txt-subtle txt-uppercase">Numero</span>
        <div class="txt-medium font-weight-bold"><%= @import.documento.numero_documento %></div>
      </div>
      <div class="flex-item-grow" style="flex-basis: 120px;">
        <span class="txt-x-small txt-subtle txt-uppercase">Causale</span>
        <div class="txt-medium"><%= @import.documento.causale&.causale || "—" %></div>
      </div>
      <div class="flex-item-grow" style="flex-basis: 120px;">
        <span class="txt-x-small txt-subtle txt-uppercase">Data</span>
        <div class="txt-medium"><%= @import.documento.data_documento&.strftime('%d/%m/%Y') || "—" %></div>
      </div>
      <div class="flex-item-grow" style="flex-basis: 120px;">
        <span class="txt-x-small txt-subtle txt-uppercase">Cliente</span>
        <div class="txt-medium"><%= @import.documento.clientable&.denominazione || "—" %></div>
      </div>
      <div class="flex-item-grow" style="flex-basis: 120px;">
        <span class="txt-x-small txt-subtle txt-uppercase">Righe</span>
        <div class="txt-medium"><%= @import.documento.documento_righe.count %></div>
      </div>
    </div>

    <div class="flex gap-half margin-block-start">
      <%= link_to documento_path(@import.documento), class: "btn btn--positive" do %>
        Visualizza documento
      <% end %>
    </div>
  </section>
<% end %>

<% if @import.errors.any? %>
  <section class="panel panel--wide shadow center margin-block-start">
    <h3 class="divider divider--fade txt-medium font-weight-black txt-notice">Avvisi</h3>
    <ul class="flex flex-column gap-quarter unpad margin-none">
      <% @import.errors.full_messages.each do |error| %>
        <li class="list-style-none txt-small pad-block-quarter" style="border-block-end: 1px solid var(--color-ink-lighter);">
          <%= error %>
        </li>
      <% end %>
    </ul>
  </section>
<% end %>

<section class="panel panel--wide center margin-block-start">
  <div class="flex gap">
    <%= link_to imports_path, class: "btn" do %>
      <%= icon_tag "arrow-down-tray" %>
      <span>Nuova importazione</span>
    <% end %>
    <%= link_to documenti_path, class: "btn" do %>
      <%= icon_tag "document" %>
      <span>Vai ai documenti</span>
    <% end %>
  </div>
</section>
