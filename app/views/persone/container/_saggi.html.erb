<%# locals: (persona:) -%>

<% scuola = persona.scuola %>
<% saggi = scuola ? persona.saggi.per_scuola(scuola).includes(:libro).order(created_at: :desc) : persona.saggi.includes(:libro).order(created_at: :desc) %>

<div id="<%= dom_id(persona, :saggi) %>">
<section class="group">
  <h3 class="divider divider--fade txt-medium font-weight-black margin-block-end">
    Saggi
    <% if saggi.any? %>
      <span class="txt-x-small txt-subtle font-weight-normal">(<%= saggi.size %>)</span>
    <% end %>
  </h3>

  <% if saggi.any? %>
    <ul class="popup__list gap-quarter">
      <% saggi.each do |saggio| %>
        <li class="popup__item flex align-center gap-half padding-block-quarter padding-inline-half">
          <div class="flex-item-grow" style="min-width: 0;">
            <div class="font-weight-bold txt-small overflow-ellipsis"><%= link_to saggio.libro.titolo, saggio.libro, class: "txt-link" %></div>
            <div class="txt-xx-small txt-subtle"><%= saggio.libro.editore&.editore %></div>
          </div>

          <span class="txt-xx-small txt-subtle">x<%= saggio.quantita %></span>

          <span class="badge <%= saggio.consegnato? ? 'txt-positive' : 'txt-accent' %> txt-xx-small">
            <%= saggio.stato %>
          </span>

          <% if saggio.prenotato? %>
            <%= button_to persona_saggio_path(persona, saggio),
                method: :patch,
                params: { saggio: { stato: :consegnato, data_consegna: Date.today } },
                class: "btn btn--circle txt-positive borderless fill-transparent txt-x-small",
                title: "Segna consegnato" do %>
              <%= icon_tag "check", size: "small" %>
            <% end %>
          <% end %>

          <% unless saggio.scaricato? %>
            <%= button_to persona_saggio_path(persona, saggio),
                method: :delete,
                class: "btn btn--circle txt-negative borderless fill-transparent txt-x-small",
                title: "Elimina" do %>
              <%= icon_tag "trash", size: "small" %>
            <% end %>
          <% end %>
        </li>
      <% end %>
    </ul>
  <% end %>

  <%= form_with model: Saggio.new,
      url: persona_saggi_path(persona),
      class: "flex gap align-center margin-block-start" do |f| %>
    <div class="flex-item-grow cb-tax">
      <%= f.combobox :libro_id, libri_path,
          placeholder: "Cerca libro...",
          name_when_new: "libro_search" %>
    </div>
    <div>
      <%= f.select :stato, [["Prenotato", "prenotato"], ["Consegnato", "consegnato"]],
          {}, class: "input input--select txt-small" %>
    </div>
    <div style="inline-size: 3.5em;">
      <%= f.number_field :quantita, value: 1, min: 1, class: "input txt-small", placeholder: "Qt" %>
    </div>
    <%= f.submit "Aggiungi", class: "btn btn--primary btn--small" %>
  <% end %>
</section>
</div>
