<%# locals: (categoria:) -%>

<%= form_with(model: categoria) do |form| %>
  <div class="flex flex-column gap">
    <% if categoria.errors.any? %>
      <div class="form-errors txt-small">
        <% categoria.errors.full_messages.each do |message| %>
          <p><%= message %></p>
        <% end %>
      </div>
    <% end %>

    <div class="form-field">
      <%= form.label :nome_categoria, "Nome Categoria", class: "form-label" %>
      <%= form.text_field :nome_categoria, class: "input full-width", required: true %>
    </div>

    <div class="form-field">
      <%= form.label :descrizione, class: "form-label" %>
      <%= form.text_area :descrizione, rows: 4, class: "input full-width" %>
    </div>

    <div class="flex gap-half justify-center margin-block-start-half">
      <%= form.submit "Salva", class: "btn btn--primary" %>
      <%= link_to "Annulla", categoria.persisted? ? categoria_path(categoria) : categorie_path, class: "btn btn--ghost" %>
    </div>
  </div>
<% end %>
