<% @page_title = @categoria.nome_categoria %>

<% content_for :header do %>
  <div class="header__actions header__actions--start">
    <%= link_to categorie_path, class: "btn" do %>
      <%= icon_tag "arrow-left", size: "small" %>
      <span class="for-screen-reader">Indietro</span>
    <% end %>
  </div>

  <h1 class="header__title divider divider--fade full-width">
    <span class="overflow-ellipsis"><%= @categoria.nome_categoria %></span>
  </h1>

  <div class="header__actions header__actions--end">
    <%= link_to edit_categoria_path(@categoria),
        class: "btn" do %>
      <%= icon_tag "pencil", size: "small" %>
      <span class="for-screen-reader">Modifica</span>
    <% end %>
    <%= button_to categoria_path(@categoria),
        method: :delete,
        class: "btn btn--negative",
        data: { turbo_confirm: "Sei sicuro di voler eliminare questa categoria?" } do %>
      <%= icon_tag "trash", size: "small" %>
      <span class="for-screen-reader">Elimina</span>
    <% end %>
  </div>
<% end %>

<section class="panel panel--wide shadow center">
  <dl class="dl-grid pad">
    <dt>Nome Categoria</dt>
    <dd><%= @categoria.nome_categoria %></dd>

    <% if @categoria.descrizione.present? %>
      <dt>Descrizione</dt>
      <dd><%= @categoria.descrizione %></dd>
    <% end %>

    <dt>Numero di libri</dt>
    <dd><%= @categoria.libri.count %></dd>
  </dl>

  <% if @page.used? %>
    <div class="flex justify-space-between align-center pad-inline">
      <h2 class="txt-medium">Libri in questa categoria</h2>
      <span class="txt-subtle txt-small"><%= @total_count %> libri</span>
    </div>

    <div class="table-wrapper">
      <table class="table">
        <thead>
          <tr>
            <th>Titolo</th>
            <th>ISBN</th>
            <th>Editore</th>
            <th class="txt-align-end">Prezzo</th>
          </tr>
        </thead>
        <%= with_automatic_pagination :categoria_libri, @page, tag_element: :tbody do %>
          <% @page.records.each do |libro| %>
            <tr id="<%= dom_id(libro) %>">
              <td class="font-weight-bold">
                <%= link_to libro.titolo, libro_path(libro), class: "txt-link" %>
              </td>
              <td class="txt-subtle"><%= libro.codice_isbn %></td>
              <td class="txt-subtle"><%= libro.editore&.editore %></td>
              <td class="txt-align-end"><%= number_to_currency(libro.prezzo, unit: "€ ") %></td>
            </tr>
          <% end %>
        <% end %>
      </table>
    </div>
  <% else %>
    <p class="txt-subtle txt-small pad txt-align-center">
      Nessun libro associato a questa categoria.
    </p>
  <% end %>
</section>
