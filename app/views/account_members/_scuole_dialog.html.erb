<%
  account_zone = Current.account.zone.where(stato: "attiva").order(:provincia, :grado)
  assigned_ids = membership.scuola_ids.to_set
  scuole_by_zona = Current.account.scuole.attive.order(:comune, :denominazione).group_by { |s| "#{s.provincia}-#{s.grado}" }
%>

<div style="overflow-y: auto; max-height: 60vh;" class="flex-column gap">
  <% account_zone.each do |zona| %>
    <% key = "#{zona.provincia}-#{zona.grado}" %>
    <% zone_scuole = scuole_by_zona[key] || [] %>
    <% next if zone_scuole.empty? %>

    <% assigned_count = zone_scuole.count { |s| assigned_ids.include?(s.id) } %>
    <% all_assigned = assigned_count == zone_scuole.size %>

    <details class="pad-block-half"  style="border-bottom: var(--border);">
      <summary class="list-style-none flex gap justify-space-between align-center pad-half cursor-pointer">
        <span class="txt-small txt-bold"><%= zona.provincia %> — <%= zona.grado_label %></span>

        <span class="flex align-center gap-double">
          <span class="txt-x-small txt-subtle"><%= assigned_count %>/<%= zone_scuole.size %></span>      
 
          <% if all_assigned %>
            <%= button_to account_member_bulk_scuole_path(account_member_id: membership.id),
                  method: :delete,
                  params: { provincia: zona.provincia, grado: zona.grado },
                  class: "btn btn--small" do %>
              Rimuovi tutte
            <% end %>
          <% else %>
            <%= button_to account_member_bulk_scuole_path(account_member_id: membership.id),
                  params: { provincia: zona.provincia, grado: zona.grado },
                  class: "btn btn--small" do %>
              Assegna tutte
            <% end %>
          <% end %>
        </span>
      </summary>
    </details>
  <% end %>

  <% if account_zone.empty? %>
    <p class="txt-small txt-subtle pad">Nessuna zona attiva. Aggiungi zone prima di assegnare scuole.</p>
  <% end %>
</div>
