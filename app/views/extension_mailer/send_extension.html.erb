<%= render Email::Bg::Container.new do |email| %>
  <% email.with_masthead_text(text: "ScagnoZZ", href: "https://scagnozz.com") %>
  <%= render Email::Heading.new(
    text: "Estensione WhatsApp → ScagnoZZ",
    size: "26px",
    align: "center",
    margin: "20px auto 30px auto"
  ) %>
  <%= render Email::Divider.new(color: Email::Colors::RED_500, thickness: "4px") %>
  <%= render Email::Text.new do %>
    Ciao <b><%= @user.name %></b>,
  <% end %>
  <%= render Email::Text.new do %>
    in allegato trovi l'estensione Chrome <b>WhatsApp → ScagnoZZ</b> che ti permette di salvare appunti direttamente dalle chat di WhatsApp.
  <% end %>
  <%= render Email::Text.new do %>
    Scarica e decomprimi il file <b>zip</b> allegato. All'interno troverai il file <b>GUIDA-INSTALLAZIONE.html</b> con tutte le istruzioni passo passo.
  <% end %>
  <%= render Email::Button.new(
    text: "Vai a ScagnoZZ →",
    href: "https://scagnozz.com",
  ) %>
  <%= render Email::Colorblock.new(
    color: Email::Colors::RED_50,
    border_width: "0",
    border_radius: "12px",
    margin: "64px auto auto auto",
    padding: "16px 24px",
  ) do %>
    <%= render Email::Text.new(text: "ScagnoZZ", bold: true, letter_spacing: "-0.0375rem", margin: "8px auto", color: Email::Colors::GRAY_700) %>
    <%= render Email::Text.new(size: "12px", margin: "4px auto", color: Email::Colors::GRAY_600) do %>
      Visita <%= link_to "ScagnoZZ", "https://scagnozz.com" %> per saperne di più.
    <% end %>
    <%= render Email::Text.new(text: "© #{Time.now.year} ScagnoZZ", margin: "4px auto", size: "12px", color: Email::Colors::GRAY_600) %>
  <% end %>
<% end %>
