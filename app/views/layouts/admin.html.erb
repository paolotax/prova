<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>ScagnoZZ Admin</title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <style>
      /* Le tabelle admin sono più larghe degli schermi piccoli: la pagina
         deve poter scorrere in orizzontale (reset.css clippa l'overflow).
         Solo qui, per non toccare il resto dell'app. */
      html, body { overflow-x: auto; }
    </style>
  </head>

  <body>
    <div class="admin-container">
      <header class="admin-header">
        <h1 class="margin-none txt-medium">
          <%= link_to "ScagnoZZ Admin", admin_root_path, class: "txt-ink" %>
        </h1>
        <nav class="admin-header__nav txt-small">
          <%= link_to "Dashboard", admin_root_path, class: "txt-link" %>
          <%= link_to "Account", admin_accounts_path, class: "txt-link" %>
          <%= link_to "Extension Mail", admin_extension_mails_path, class: "txt-link" %>
          <%= link_to "Inviti Account", admin_account_invitations_path, class: "txt-link" %>
          <%= link_to "← App", root_path, class: "txt-subtle" %>
        </nav>
      </header>

      <%= render "layouts/shared/flash" %>

      <%= yield %>
    </div>
  </body>
</html>
