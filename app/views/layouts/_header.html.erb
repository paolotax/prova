<nav data-controller="nav-dialog"
     data-action="keydown.esc->nav-dialog#close click@document->nav-dialog#closeOnClickOutside">

  <header class="fixed top-0 left-0 right-0 h-14 bg-white border-b border-gray-200 z-50">
    <div class="flex items-center justify-center h-full px-4">

      <%# Logo centrato - apre popup menu %>
      <button data-controller="hotkey"
              data-action="click->nav-dialog#toggle keydown.m@document->hotkey#click"
              class="flex items-center gap-2 px-3 py-1.5 rounded-lg hover:bg-gray-100 transition-colors">
        <%= image_tag "logo.svg", class: "h-8", alt: "Logo" rescue tag.span("ScagnoZZ", class: "font-bold text-xl text-gray-800") %>
        <kbd class="hidden sm:inline-block px-2 py-0.5 text-xs bg-gray-100 text-gray-500 rounded border border-gray-200">M</kbd>
      </button>

      <%# Voice notes button - posizione assoluta a destra %>
      <% if Current.account %>
      <div class="absolute right-4">
        <%= link_to new_voice_note_path(Current.account),
            class: "p-2 rounded-full hover:bg-gray-100 transition-colors text-gray-600",
            data: { turbo_frame: "modal" } do %>
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z" />
          </svg>
        <% end %>
      </div>
      <% end %>

    </div>
  </header>

  <%# Popup Menu Dialog %>
  <dialog data-nav-dialog-target="dialog"
          data-controller="filter navigable-list nav-section-expander"
          data-action="keydown->navigable-list#navigate filter:changed->navigable-list#reset filter:changed->nav-section-expander#showWhileFiltering"
          data-navigable-list-focus-on-selection-value="false"
          data-navigable-list-actionable-items-value="true"
          class="fixed inset-0 m-auto w-full max-w-sm max-h-[80vh] p-0 rounded-xl shadow-2xl border-0 bg-white overflow-hidden backdrop:bg-black/50 z-[9999]">

    <%# Header con close button %>
    <div class="flex items-center justify-between p-4 border-b border-gray-100">
      <span class="font-semibold text-gray-900">Menu</span>
      <button data-action="nav-dialog#close" class="p-1 rounded hover:bg-gray-100">
        <svg class="w-5 h-5 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <%# Search field %>
    <div class="p-4 border-b border-gray-100">
      <%= jump_field_tag %>
    </div>

    <%# Scroll container %>
    <div class="overflow-y-auto max-h-[calc(80vh-180px)]">

      <% if Current.account %>
        <%# Hot buttons - orizzontali come fizzy %>
        <div class="flex gap-2 p-3 border-b border-gray-100" role="list">
          <%= filter_hotkey_link "Oggi", giorno_path(Current.account, Date.today), 1, "calendar" %>
          <%= filter_hotkey_link "Appunti", appunti_path(Current.account), 2, "note" %>
          <%= filter_hotkey_link "Scuole", import_scuole_path(Current.account), 3, "school" %>
        </div>

        <%# Sezione Navigazione %>
        <%= collapsible_nav_section "Navigazione" do %>
          <%= nav_menu_item "Home", account_root_path(Current.account), "home" %>
          <%= nav_menu_item "Adozioni", import_adozioni_path(Current.account), "cash" %>
          <%= nav_menu_item "Libri", libri_path(Current.account), "book" %>
          <%= nav_menu_item "Giri", giri_path(Current.account), "truck" %>
          <%= nav_menu_item "Documenti", documenti_path(Current.account), "document" %>
          <%= nav_menu_item "Clienti", clienti_path(Current.account), "people" %>
          <%= nav_menu_item "Stats", stats_path(Current.account), "chart" %>
        <% end %>
      <% end %>

      <% if current_user&.admin? %>
        <%# Sezione Utilities (solo admin) %>
        <%= collapsible_nav_section "Utilities" do %>
          <%= nav_menu_item "Avo Admin", "/avo", "shield" %>
          <%= nav_menu_item "Sidekiq", "/sidekiq", "server" %>
          <%= nav_menu_item "Blazer", "/blazer", "chart" %>
          <%= nav_menu_item "Performance", "/rails/performance", "speedometer" %>
        <% end %>
      <% end %>

      <%# Sezione Impostazioni %>
      <%= collapsible_nav_section "Impostazioni" do %>
        <% if Current.account %>
          <%= nav_menu_item "Profilo", profilo_path(Current.account), "person" %>
        <% end %>
        <%= nav_menu_item "Account", accounts_path, "building" %>
        <%= nav_menu_item "Esci", logout_path, "logout", method: :delete %>
      <% end %>

      <%# Blank slate quando nessun risultato - mostrato via CSS :has() %>
      <div class="nav-blank-slate p-8 text-center text-gray-500">
        Nessun risultato
      </div>

    </div>

  </dialog>
</nav>
