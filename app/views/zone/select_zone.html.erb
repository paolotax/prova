<%= turbo_frame_tag :zone_select, class: "flex flex-wrap gap-half" do %>
    <%= form_with url: select_zone_zone_path, method: :get, data: { controller: "tax-select",
                                                            action: "change->tax-select#submit"
                                                        } do |f| %>

        <div class="flex flex-wrap gap-half">
            <div>
                <%= f.select :regione, options_from_collection_for_select(@regioni, "regione", "regione", params[:regione]),
                                    { prompt: "scegli la regione" },
                                    { class: "input input--select txt-small", data: { tax_select_target: "regione" } } %>
            </div>
            <div>
                <%= f.select :provincia, options_from_collection_for_select(@province, "provincia", "provincia", params[:provincia]),
                                { prompt: "tutte" },
                                { class: "input input--select txt-small", data: { tax_select_target: "provincia" } } %>
            </div>
            <div>
                <%= f.select :grado, options_for_select(@gradi, params[:grado]),
                                { prompt: "tutti" },
                                { class: "input input--select txt-small", data: { tax_select_target: "grado" } } %>
            </div>
            <% if @tipi.present? %>
                <div>
                    <%= f.select :tipo, options_from_collection_for_select(@tipi, "tipo", "tipo", params[:tipo]),
                                    { prompt: "tutti" },
                                    { class: "input input--select txt-small", data: { tax_select_target: "tipo" } } %>
                </div>
            <% end %>
        </div>

    <% end %>
<% end %>
