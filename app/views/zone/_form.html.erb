<div class="flex flex-wrap gap-half align-center margin-block-start">

    <%= turbo_frame_tag :zone_select, class: "flex flex-wrap gap-half" do %>
        <%= form_with url: new_zona_path, method: :get, data: { controller: "tax-select",
                                                                action: "change->tax-select#submit" } do |f| %>
            <div class="flex flex-wrap gap-half">
                <div>
                    <%= f.select :regione, options_from_collection_for_select(regioni, "regione", "regione"),
                                        { prompt: "scegli la regione" },
                                        { class: "input input--select txt-small", data: { tax_select_target: "regione" } } %>
                </div>
            </div>
        <% end %>
    <% end %>

    <%= form_with url: zone_path, method: :post, class: "flex" do |f| %>
        <%= hidden_field_tag "regione", nil, id: "hregione" %>
        <%= hidden_field_tag "provincia", nil, id: "hprovincia" %>
        <%= hidden_field_tag "grado", nil, id: "hgrado" %>
        <%= f.button type: "submit", class: "btn btn--circle btn--link", aria: { label: "Aggiungi zona" } do %>
            <%= icon_tag "add" %>
        <% end %>
    <% end %>

</div>
