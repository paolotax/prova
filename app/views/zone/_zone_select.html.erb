<%= turbo_frame_tag :zone_select do %>
    <%= form_with url: select_zone_zone_path, method: :get, data: { controller: "tax-select",
                                                            action: "change->tax-select#submit"
                                                        } do |f| %>

        <div class="flex flex-col sm:flex-row sm:justify-left sm:gap-x-4" >
            <div class="mt-2 sm:w-56">
                <%= f.label :regione, class: "label" %>
                <div>
                    <%= f.select :regione, options_from_collection_for_select(regioni, "regione", "regione"),
                                        { prompt: "scegli la regione" },
                                        { class: "field", data: { tax_select_target: "regione" } } %>
                </div>
            </div>
            <div class="mt-2 sm:w-56">
                <%= f.label :provincia, class: "label" %>
                <div>
                    <%= f.select :provincia, options_from_collection_for_select(province, "provincia", "provincia"),
                                    { prompt: "tutte" },
                                    { class: "field", data: { tax_select_target: "provincia" } } %>
                </div>
            </div>
            <div class="mt-2 sm:w-56">
                <%= f.label :grado, class: "label" %>
                <div>
                    <%= f.select :grado, options_for_select(gradi),
                                    { prompt: "tutti" },
                                    { class: "field", data: { tax_select_target: "grado" } } %>
                </div>
            </div>
        </div>

    <% end %>
<% end %>
