<%= form_with(model: azienda, url: azienda_path, method: azienda&.persisted? ? :patch : :post, class: "flex flex-column gap") do |form| %>
  <% if azienda.errors.any? %>
    <div class="panel pad border-radius txt-negative fill-shade">
      <h3 class="font-weight-black"><%= pluralize(azienda.errors.count, "errore", "errori") %> da correggere:</h3>
      <ul class="margin-block-start-half txt-small">
        <% azienda.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <!-- Dati Fiscali -->
  <section class="panel shadow center" style="--panel-size: 55ch;">
    <strong class="divider txt-large">Dati fiscali</strong>
    <div class="flex flex-column gap">
      <div class="form-field">
        <%= form.label :ragione_sociale, class: "form-label" %>
        <%= form.text_field :ragione_sociale, class: "input", placeholder: "Nome Azienda SRL" %>
      </div>

      <div class="form-grid">
        <div class="form-field">
          <%= form.label :partita_iva, "Partita IVA", class: "form-label" %>
          <%= form.text_field :partita_iva, class: "input mono", placeholder: "12345678901", maxlength: 11 %>
        </div>

        <div class="form-field">
          <%= form.label :codice_fiscale, class: "form-label" %>
          <%= form.text_field :codice_fiscale, class: "input mono txt-uppercase", placeholder: "RSSMRA80A01H501U", maxlength: 16 %>
        </div>
      </div>

      <div class="form-field">
        <%= form.label :regime_fiscale, class: "form-label" %>
        <%= form.select :regime_fiscale,
              Azienda.regime_fiscales.map { |k, v| [v, k] },
              { include_blank: "Seleziona regime fiscale..." },
              class: "input input--select" %>
      </div>
    </div>

    <!-- Indirizzo -->
    <strong class="divider txt-large">Indirizzo</strong>

    <div class="flex flex-column gap">
      <div class="form-field">
        <%= form.label :indirizzo, class: "form-label" %>
        <%= form.text_field :indirizzo, class: "input", placeholder: "Via Roma 1" %>
      </div>

      <div class="form-grid form-grid--3">
        <div class="form-field">
          <%= form.label :cap, "CAP", class: "form-label" %>
          <%= form.text_field :cap, class: "input mono", placeholder: "00100", maxlength: 5 %>
        </div>

        <div class="form-field" style="grid-column: span 2;">
          <%= form.label :comune, class: "form-label" %>
          <%= form.text_field :comune, class: "input", placeholder: "Roma" %>
        </div>
      </div>

      <div class="form-grid">
        <div class="form-field">
          <%= form.label :provincia, class: "form-label" %>
          <%= form.text_field :provincia, class: "input mono txt-uppercase", placeholder: "RM", maxlength: 2 %>
        </div>

        <div class="form-field">
          <%= form.label :nazione, class: "form-label" %>
          <%= form.text_field :nazione, class: "input mono txt-uppercase", placeholder: "IT", maxlength: 2, value: azienda.nazione || "IT" %>
        </div>
      </div>
    </div>
  </section>

  <!-- Contatti -->
  <section class="panel shadow center" style="--panel-size: 55ch;">
    <strong class="divider txt-large">Contatti</strong>
    
    <div class="flex flex-column gap">
      <div class="form-grid">
        <div class="form-field">
          <%= form.label :email, class: "form-label" %>
          <%= form.email_field :email, class: "input", placeholder: "info@azienda.it" %>
        </div>

        <div class="form-field">
          <%= form.label :telefono, class: "form-label" %>
          <%= form.telephone_field :telefono, class: "input", placeholder: "+39 06 1234567" %>
        </div>
      </div>

      <div class="form-field">
        <%= form.label :indirizzo_telematico, "Codice SDI / PEC", class: "form-label" %>
        <%= form.text_field :indirizzo_telematico, class: "input mono txt-uppercase", placeholder: "0000000", maxlength: 7 %>
        <p class="txt-x-small txt-subtle margin-block-start-half">Codice destinatario SDI (7 caratteri)</p>
      </div>
    </div>

    <!-- Dari bancari -->
    <strong class="divider txt-large">Dati bancari</strong>

    <div class="flex flex-column gap">
      <div class="form-field">
        <%= form.label :iban, "IBAN", class: "form-label" %>
        <%= form.text_field :iban, class: "input mono txt-uppercase", placeholder: "IT60X0542811101000000123456", maxlength: 27 %>
      </div>

      <div class="form-field">
        <%= form.label :banca, "Nome Banca", class: "form-label" %>
        <%= form.text_field :banca, class: "input", placeholder: "Banca Esempio" %>
      </div>
    </div>
  </section>

  <div class="flex f-align-center gap center" style="max-inline-size: 55ch;">
    <%= form.submit azienda.persisted? ? "Aggiorna" : "Salva", class: "btn btn--reversed" %>
    <%= link_to "Annulla", azienda_path, class: "btn" %>
  </div>
<% end %>
