<%# locals: (appunto:) -%>

<% if appunto.nome.present? %>
  <span class="txt-large" style="margin-top: 1ch;"><%= appunto.nome %></span>
<% end %>

<% if appunto.appuntabile.present? %>
  <h1 class="card__title overflow-line-clamp">
    <% if appunto.appuntabile.is_a?(Classe) %>
      <%= link_to polymorphic_path(appunto.appuntabile), class: "card__title-link", data: { turbo_frame: "_top" } do %>
        <%= appunto.appuntabile.nome_breve %> <%= appunto.appuntabile.scuola.denominazione %>
      <% end %>
    <% else %>
      <%= link_to polymorphic_path(appunto.appuntabile), class: "card__title-link", data: { turbo_frame: "_top" } do %>
        <%= appunto.appuntabile.try(:denominazione) || appunto.appuntabile.to_s %>
      <% end %>
    <% end %>
  </h1>
  <% scuola = appunto.appuntabile.is_a?(Classe) ? appunto.appuntabile.scuola : appunto.appuntabile %>
  <% if scuola.respond_to?(:comune) && scuola.comune.present? %>
    <span class="card__subtitle"><%= scuola.comune.upcase %></span>
  <% end %>

  <% if appunto.appuntabile.is_a?(Persona) && appunto.appuntabile.scuola.present? %>
    <%= link_to appunto.appuntabile.scuola.denominazione.upcase,
        scuola_path(appunto.appuntabile.scuola),
        class: "card__subtitle txt-undecorated", style: "color: inherit;",
        data: { turbo_frame: "_top" } %>
  <% end %>

<% else %>
  <h1 class="card__title overflow-line-clamp">
    <span class="txt-muted"><%= appunto.nome.presence || "Nessun destinatario" %></span>
  </h1>
<% end %>

<% if appunto.content.present? %>
  <div class="card__description rich-text-content margin-inline-start margin-block-start">
    <%= appunto.content %>
  </div>
<% elsif appunto.body.present? %>
  <div class="card__description margin-inline-start">
    <%= simple_format(appunto.body) %>
  </div>
<% end %>
