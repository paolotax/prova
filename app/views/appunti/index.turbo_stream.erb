<%= turbo_stream.append :appunti do %>
  <%= render @page.records %>
<% end %>
<%= turbo_stream.replace :pagination do %>
  <% if @page.before_last? %>
    <%= turbo_frame_tag :pagination,
                loading: :lazy,
          src: appunti_path(request.query_parameters.merge(format: :turbo_stream, page: @page.next_param)) do %>
        <div role="status">
          <div class="flex justify-center">
            <%= icon "bouncing-dots", library: :animated, class: "mx-auto w-8 h-8 text-gray-500 fill-gray-600" %>
            <span class="sr-only">Loading...</span>
          </div>
        </div>
      <% end %>
  <% end %>
<% end %>
