<% @page_title = "Appunti" %>
<% @body_class = "contained-scrolling" %>

<% content_for :head do %>
  <%= combobox_style_tag "data-turbo-track": "reload" %>
<% end %>

<% content_for :header do %>
  <div class="header__actions header__actions--start">
    <%= link_to appunti_path(format: :xlsx, params: request.query_parameters), class: "btn",
        data: { controller: "link-modifier", link_modifier_target: "link" } do %>
      <%= icon_tag "document" %>
      <span class="for-screen-reader">Esporta in excel</span>
    <% end %>

    <%= link_to filtra_appunti_path(params: request.query_parameters), class: "btn",
        data: { controller: "link-modifier", link_modifier_target: "link", turbo_frame: "slide-over" } do %>
      <%= icon_tag "filter" %>
      <span class="for-screen-reader">Filtra</span>
    <% end %>
  </div>

  <h1 class="header__title divider divider--fade full-width">
    <span class="overflow-ellipsis">Appunti</span>
  </h1>

  <div class="header__actions header__actions--end">
    <%= link_to new_appunto_path, class: "btn" do %>
      <%= icon_tag "add" %>
      <span class="for-screen-reader">Nuovo appunto</span>
    <% end %>
  </div>
<% end %>

<%= turbo_stream_from current_user, "appunti" %>

<% if hotwire_native_app? %>
  <%= link_to "Nuovo Appunto", new_appunto_path,
      data: { controller: "bridge--button", bridge_title: "Nuovo" },
      class: "hidden" %>

  <%= render "shared/native_search_filter",
      url: appunti_path,
      filter_url: filtra_appunti_path(params: request.query_parameters),
      placeholder: "Cerca appunti..." %>
<% end %>

<%= render "filters/settings",
      filter_url: appunti_path,
      user_filtering: @user_filtering,
      no_filtering_url: appunti_path,
      filter_type: "appunto" %>

<%= turbo_frame_tag "search_results" do %>
  <% if @appunti.any? %>
    <p class="txt-small txt-subtle margin-block-end-half">
      <%= @pagy.count %> <%= @pagy.count == 1 ? "appunto trovato" : "appunti trovati" %>
    </p>

    <%= tag.div class: "flex flex-column", data: { controller: "bulk-actions" } do %>
      <%= render "appunti/bulk_actions/form" %>

      <%= turbo_frame_tag :appunti,
          data: { controller: "list-observer",
              list_observer_counter_id_value: "collection_counter",
              list_observer_item_selector_value: ".item",
              list_observer_target: "list"
            },
          class: "cards cards--list",
          style: "display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem;" do %>

        <%= render @appunti %>
      <% end %>

      <% if @pagy.next %>
        <%= turbo_frame_tag :pagination,
            src: appunti_path(request.query_parameters.merge(format: :turbo_stream, page: @pagy.next)),
            loading: :lazy do %>
          <div role="status" class="flex justify-center" style="grid-column: 1 / -1;">
            <%= icon "bouncing-dots", library: :animated, class: "txt-subtle", style: "width: 2rem; height: 2rem;" %>
            <span class="sr-only">Loading...</span>
          </div>
        <% end %>
      <% end %>
    <% end %>
  <% else %>
    <div class="blank-slate blank-slate--empty">
      <%= icon_tag "note", size: "large", class: "txt-subtle margin-block-end-half" %>
      <h3 class="txt-large font-weight-bold">Nessun appunto trovato</h3>
      <p class="txt-small txt-subtle margin-block-end">
        <% if @user_filtering.filters_active? %>
          Prova a modificare i filtri di ricerca.
        <% else %>
          Inizia aggiungendo il primo appunto.
        <% end %>
      </p>
      <% unless @user_filtering.filters_active? %>
        <%= link_to new_appunto_path, class: "btn btn--primary" do %>
          <%= icon_tag "plus", size: "small" %>
          Aggiungi Appunto
        <% end %>
      <% end %>
    </div>
  <% end %>
<% end %>
