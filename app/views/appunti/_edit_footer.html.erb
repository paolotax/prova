<%# locals: (appunto:) -%>

<%= button_tag class: "btn btn--positive", type: :submit, form: dom_id(appunto, :edit_form) do %>
  <%= icon_tag "check" %>
  <span>Salva</span>
<% end %>

<%= link_to appunto_path(appunto), class: "btn btn--reversed",
    data: { turbo_method: :get, turbo_stream: true } do %>
  <span>Annulla</span>
<% end %>
