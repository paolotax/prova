<%# locals: (appunto:, entry: nil, draggable: false) -%>

<% entry ||= appunto.entry rescue nil %>
<% draggable = draggable && appunto.published? %>

<% card_data = {
  navigable_list_target: "item",
  action: "mouseenter->navigable-list#hoverSelect contextmenu->navigable-list#toggleSelection"
} %>

<% if entry && draggable %>
  <% card_data[:id] = entry.id %>
  <% card_data[:drag_and_drop_target] = "item" %>
  <% card_data[:css_variable_counter_target] = "item" %>
<% end %>

<%= tag.article id: (entry ? dom_id(entry) : dom_id(appunto)),
    class: class_names("card", appunto_stato_modifier(appunto), appunto_golden_class(appunto)),
    style: "--card-color: #{appunto_color(appunto)};",
    tabindex: 0,
    draggable: (draggable && entry.present?),
    data: card_data do %>
  <label class="card__checkbox">
    <%= check_box_tag "ids[]", appunto.id, false, data: { action: "change->bulk-actions#count" } %>
  </label>
  <div class="flex flex-column flex-item-grow max-inline-size">
    <%= link_to appunto_path(appunto), draggable: false, class: "card__link", data: { action: "dialog#close", turbo_frame: "_top" } do %>
      <span class="for-screen-reader"><%= appunto.nome %></span>
    <% end %>

    <header class="card__header">
      <%= render "appunti/display/preview/board", appunto: appunto %>

      <% if appunto.appuntabile.is_a?(Classe) %>
        <span class="card__classe-badge"><%= appunto.appuntabile.anno_corso %><%= appunto.appuntabile.sezione %></span>
      <% end %>

      <% if appunto.triaged? %>
        <span class="btn justify-start card__column-name card__column-name--current txt-uppercase min-width max-width">
          <span class="overflow-ellipsis"><%= appunto.column.name %></span>
        </span>
      <% end %>
    </header>

    <div class="card__body justify-space-between">
      <div class="card__content">
        <% if appunto.nome.present? %>
          <h3 class="card__title overflow-line-clamp"><%= appunto.nome %></h3>
          <% if appunto.appuntabile.present? %>
            <span class="card__subtitle overflow-ellipsis"><%= appunto.appuntabile.denominazione %></span>
          <% end %>
        <% elsif appunto.appuntabile.present? %>
          <h3 class="card__title overflow-line-clamp"><%= appunto.appuntabile.denominazione %></h3>
          <% if appunto.appuntabile.respond_to?(:comune) && appunto.appuntabile.comune.present? %>
            <span class="card__subtitle overflow-ellipsis"><%= appunto.appuntabile.comune.upcase %></span>
          <% end %>
        <% end %>

        <% if appunto.content.present? %>
          <div class="txt-x-small margin-inline-start-half overflow-line-clamp" style="margin-top: 0.5ch; --lines: 2; color: var(--card-content-color)">
            <%= tag.span appunto.content %>
          </div>
        <% end %>

        <% if appunto.body.present? %>
          <div class="txt-x-small margin-block-start-half overflow-line-clamp" style="--lines: 2; color: var(--card-content-color)">
            <%= tag.span appunto.body, class: "overflow-line-clamp" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <footer class="card__footer">
    <%= render "appunti/display/preview/meta", appunto: appunto %>
  </footer>
<% end %>
