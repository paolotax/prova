<%# locals: ( appunto: ) -%>

<div class="flex align-center gap full-width">
  <!-- Badge classe -->
  <% if appunto.import_adozione %>
    <%
      anno_style = case appunto.import_adozione&.anno
      when "8" then "background: var(--color-ink-lightest); color: var(--color-ink); border-color: var(--color-ink-lighter);"
      when "2" then "background: var(--color-warning-lighter); color: var(--color-warning-dark); border-color: var(--color-warning);"
      when "6" then "background: var(--color-positive-lighter); color: var(--color-positive-dark); border-color: var(--color-positive);"
      when "1" then "background: var(--color-link-lighter); color: var(--color-link); border-color: var(--color-link);"
      when "3" then "background: var(--color-negative-lighter); color: var(--color-negative-dark); border-color: var(--color-negative);"
      when "4" then "background: var(--color-notice-lighter); color: var(--color-notice-dark); border-color: var(--color-notice);"
      else "background: var(--color-ink-lightest); color: var(--color-ink); border-color: var(--color-ink-lighter);"
      end
    %>
    <span class="badge txt-xx-small font-weight-bold" style="<%= anno_style %> border: 1px solid;">
      <%= appunto.import_adozione&.classe_e_sezione %>
    </span>
  <% end %>

  <!-- Avatar e info scuola -->
  <div class="flex align-center full-width">
    <!-- Avatar con checkbox bulk action -->
    <div class="flex-shrink-0" style="width: 2.5rem; height: 2.5rem; position: relative;">
      <label class="cursor-pointer">
        <%= check_box_tag "appunto_ids[]", appunto.id, nil,
            form: "bulk-actions",
            class: "bulk-checkbox for-screen-reader",
            data: { action: "input->bulk-actions#count", bulk_actions_target: "checkbox" } %>

        <!-- Avatar normale -->
        <div class="avatar-circle <%= string_to_tailwind_color(appunto.appuntabile.try(:comune) || appunto.appuntabile.try(:citta_scuola)) %>"
            style="width: 2.5rem; height: 2.5rem;">
          <%= appuntabile_avatar_abbreviation(appunto.appuntabile) if appunto.appuntabile %>
        </div>

        <!-- Checkmark quando selezionato (gestito via CSS) -->
        <div class="avatar-checked border-radius flex align-center justify-center"
            style="position: absolute; top: 0; left: 0; width: 2.5rem; height: 2.5rem; background: var(--color-link);">
          <%= icon_tag "check", size: "small", style: "color: white;" %>
        </div>
      </label>
    </div>

    <!-- Nome e scuola -->
    <div class="flex-item-grow" style="margin-left: 0.75rem;">
      <h3 class="font-weight-bold" style="color: var(--color-ink);">
        <%= appunto.nome_e_classe %>
      </h3>
      <% if appunto.appuntabile %>
        <%= link_to appunto.appuntabile.to_combobox_display.titleize,
            polymorphic_path(appunto.appuntabile),
            class: "txt-small txt-link",
            data: { turbo_frame: :_top } %>
      <% end %>
    </div>
  </div>
</div>
