<% @page_title = @appunto.nome.presence || "Appunto" %>

<% content_for :header do %>
  <div class="header__actions header__actions--start">
    <%= back_link_to "Appunti", appunti_path, "keydown.left@document->hotkey#click keydown.esc@document->hotkey#click" %>
  </div>

  <h1 class="header__title divider divider--fade full-width">
    <span class="overflow-ellipsis"><%= @appunto.nome.presence || "Appunto" %></span>
  </h1>

  <div class="header__actions header__actions--end">
    <%= link_to edit_appunto_path(@appunto), class: "btn" do %>
      <%= icon_tag "pencil" %>
      <span class="for-screen-reader">Modifica appunto</span>
    <% end %>
  </div>
<% end %>

<div class="full-width card-grid pad group show-navigator">
  <%= render @appunto %>
</div>
