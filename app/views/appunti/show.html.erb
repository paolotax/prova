<% @page_title = @appunto.nome.presence || "Appunto" %>
<% @header_class = "header--card" %>
<% content_for :head, tag.meta(name: "turbo-cache-control", content: "no-cache") %>

<% content_for :header do %>
  <div class="header__actions header__actions--start">
    <% info = referrer_back_info || { label: "Appunti", path: appunti_path } %>
    <%= back_link_to info[:label], info[:path] %>
  </div>
<% end %>

<%= turbo_stream_from @appunto.entry if @appunto.entry %>
<%= tag.meta name: "entry-id", content: @appunto.entry&.id if @appunto.entry %>

<div class="full-width pad group">
  <%= render "appunti/container", appunto: @appunto %>
</div>

<footer class="txt-align-center full-width flex flex-column margin-block-start-double">
  <hr class="separator--horizontal full-width margin-block" style="--border-color: var(--color-ink-lighter)">
  <%= render "shared/container/delete", record: @appunto, path: appunto_path(@appunto), label: @appunto.drafted? ? "questa bozza" : "questo appunto" %>
</footer>
