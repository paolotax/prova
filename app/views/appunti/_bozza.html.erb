<%# locals: (bozza:) -%>

<div class="tray__item tray__item--pin" id="<%= dom_id bozza, :bozza %>" data-navigable-list-target="item">
  <%= render partial: "appunti/appunto", locals: { appunto: bozza, entry: bozza.entry, draggable: false } %>
  <%= button_to appunto_path(bozza), method: :delete, 
      class: "tray__remove-pin-btn btn btn--circle borderless" do %>
    <%= icon_tag "trash" %> 
    <span class="for-screen-reader">Elimina bozza</span>
  <% end %>
</div>
