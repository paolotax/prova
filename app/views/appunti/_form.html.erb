<%= form_with(model: appunto, class: "flex flex-column gap") do |form| %>
  <% if appunto.errors.any? %>
    <div class="panel pad border-radius txt-negative fill-shade">
      <h3 class="font-weight-black"><%= pluralize(appunto.errors.count, "errore", "errori") %> da correggere:</h3>
      <ul class="margin-block-start-half txt-small">
        <% appunto.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <section class="panel shadow center" style="--panel-size: 55ch;">
    <div class="flex flex-column gap">
      <div class="form-field">
        <%= form.text_field :nome, class: "input", placeholder: "Titolo o destinatario...", autofocus: true %>
      </div>

      <div class="form-field cb-tax">
        <%= form.label :appuntabile_value, "Destinatario", class: "form-label" %>
        <% if appunto.appuntabile.present? %>
          <%# Per record esistenti, mostra selezione attuale con possibilità di cambiare %>
          <div class="flex gap align-center">
            <span class="badge badge--small badge--<%= appunto.appuntabile.class.name.downcase %>">
              <%= appunto.appuntabile.class.model_name.human %>
            </span>
            <span class="txt-small"><%= appunto.appuntabile.to_combobox_display %></span>
          </div>
          <%= form.hidden_field :appuntabile_value %>
          <details class="margin-block-start-half">
            <summary class="txt-x-small txt-link cursor-pointer">Cambia destinatario</summary>
            <div class="margin-block-start-half">
              <%= combobox_tag "appunto[appuntabile_value]", destinatari_index_path,
                  id: "appunto_appuntabile_value_new",
                  placeholder: "cerca scuola, cliente, classe o persona...",
                  mobile_at: "0px" %>
            </div>
          </details>
        <% else %>
          <%= form.combobox :appuntabile_value, destinatari_index_path,
              placeholder: "cerca scuola, cliente, classe o persona...",
              mobile_at: "0px" %>
        <% end %>
        <p class="txt-x-small txt-subtle margin-block-start-quarter">
          Cerca tra scuole, clienti, classi o persone
        </p>
      </div>

      <div class="form-field">
        <%= form.label :content, "Contenuto", class: "form-label" %>
        <%= form.rich_text_area :content, placeholder: "Scrivi...", class: "input", style: "min-height: 150px;" %>
      </div>
    </div>

    <header>
      <h2 class="divider txt-large margin-block-start">Contatti</strong>
    </header>

    <div class="flex flex-column gap">
      <div class="form-grid">
        <div class="form-field">
          <%= form.label :telefono, class: "form-label" %>
          <%= form.telephone_field :telefono, class: "input", placeholder: "333 1234567" %>
        </div>

        <div class="form-field">
          <%= form.label :email, class: "form-label" %>
          <%= form.email_field :email, class: "input", placeholder: "email@esempio.it" %>
        </div>
      </div>
    </div>

    <header>
      <h2 class="divider txt-large margin-block-start">Allegati</strong>
    </header>

    <div class="flex flex-column gap">
      <div class="form-field">
        <div class="flex align-center gap-half pad-half border-radius" style="border: 1px dashed var(--color-ink-lighter);">
          <%= form.file_field :attachments, multiple: true, class: "txt-small" %>
        </div>
        <% if appunto.attachments.attached? %>
          <p class="txt-small txt-subtle margin-block-start-half">
            <%= pluralize(appunto.attachments.size, "file allegato", "file allegati") %>
          </p>
        <% end %>
      </div>
    </div>
  </section>

  <div class="flex align-center justify-center gap center" style="--panel-size: 55ch; inline-size: var(--panel-size); max-inline-size: 100%;">
    <%= link_to "Annulla", appunto.persisted? ? appunto_path(appunto) : appunti_path, class: "btn" %>
    <%= form.submit appunto.persisted? ? "Salva Modifiche" : "Crea Appunto", class: "btn btn--link" %>
  </div>
<% end %>
