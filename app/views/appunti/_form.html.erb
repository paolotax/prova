<%= form_with model: appunto, class: "flex flex-column gap" do |f| %>
  <% if appunto.errors.any? %>
    <div class="panel pad" style="background: var(--color-negative-lighter); border: 1px solid var(--color-negative);">
      <div class="flex gap-half">
        <%= icon_tag "alert-triangle", size: "small", style: "color: var(--color-negative-dark);" %>
        <div>
          <h3 class="txt-small font-weight-bold" style="color: var(--color-negative-dark);">
            <%= pluralize(appunto.errors.count, "errore", "errori") %> <%= appunto.errors.count == 1 ? "impedisce" : "impediscono" %> il salvataggio:
          </h3>
          <ul class="txt-small margin-block-start-half" style="color: var(--color-negative-dark); padding-inline-start: 1em;">
            <% appunto.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
  <% end %>

  <%= f.hidden_field :user_id, value: current_user.id %>

  <!-- Nome/Titolo -->
  <div class="form-field">
    <%= f.label :nome, "Titolo", class: "form-label" %>
    <%= f.text_field :nome,
        class: "input",
        placeholder: "Titolo o destinatario...",
        autofocus: true %>
  </div>

  <!-- Scuola -->
  <div class="form-field">
    <%= f.label :import_scuola_id, "Scuola", class: "form-label" %>
    <%= f.collection_select :import_scuola_id,
        current_user.import_scuole.order(:DENOMINAZIONESCUOLA),
        :id, :denominazione,
        { include_blank: "Seleziona scuola...", selected: appunto.import_scuola_id },
        { class: "input input--select" } %>
  </div>

  <!-- Contenuto -->
  <div class="form-field">
    <%= f.label :content, "Contenuto", class: "form-label" %>
    <%= f.rich_text_area :content,
        placeholder: "Scrivi...",
        class: "input",
        style: "min-height: 150px;" %>
  </div>

  <!-- Stato e Telefono -->
  <div class="form-grid">
    <div class="form-field">
      <%= f.label :stato, class: "form-label" %>
      <%= f.select :stato,
          options_for_select(Appunto::STATO_APPUNTI, appunto.stato),
          { include_blank: "Seleziona stato..." },
          { class: "input input--select" } %>
    </div>

    <div class="form-field">
      <%= f.label :telefono, class: "form-label" %>
      <%= f.telephone_field :telefono,
          class: "input",
          placeholder: "333 1234567" %>
    </div>
  </div>

  <!-- Email -->
  <div class="form-field">
    <%= f.label :email, class: "form-label" %>
    <%= f.email_field :email,
        class: "input",
        placeholder: "email@esempio.it" %>
  </div>

  <!-- Allegati -->
  <div class="form-field">
    <%= f.label :attachments, "Allegati", class: "form-label" %>
    <div class="flex align-center gap-half pad-half border-radius" style="border: 1px dashed var(--color-ink-lighter);">
      <%= f.file_field :attachments, multiple: true, class: "txt-small" %>
    </div>
    <% if appunto.attachments.attached? %>
      <p class="txt-small txt-subtle margin-block-start-quarter">
        <%= pluralize(appunto.attachments.size, "file allegato", "file allegati") %>
      </p>
    <% end %>
  </div>

  <!-- Actions -->
  <div class="flex align-center justify-end gap margin-block-start" style="border-top: 1px solid var(--color-ink-lighter); padding-top: var(--block-space);">
    <% cancel_path = appunto.persisted? ? appunto_path(appunto) : appunti_path %>
    <%= link_to "Annulla", cancel_path, class: "btn" %>
    <%= f.submit appunto.persisted? ? "Salva Modifiche" : "Crea Appunto", class: "btn btn--primary" %>
  </div>
<% end %>
