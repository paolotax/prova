<% @page_title = "Modifica appunto" %>

<% content_for :header do %>
  <div class="header__actions header__actions--start">
    <%= back_link_to "appunto", appunto_path(@appunto), "keydown.left@document->hotkey#click keydown.esc@document->hotkey#click" %>
  </div>

  <h1 class="header__title divider divider--fade full-width">
    <span class="overflow-ellipsis">Modifica appunto</span>
  </h1>
<% end %>

<%= render "form", appunto: @appunto %>
