<%# locals: ( appunto:, mostra_scuola: true ) -%>

<div class="full-width flex flex-column">
  <!-- Tipo e titolo -->
  <div class="pad-half flex align-baseline gap-quarter txt-small">
    <span class="txt-medium font-weight-bold"><%= appunto.nome.capitalize %></span>
    <span>del testo</span>
    <span class="txt-medium" style="color: var(--color-link);"><%= appunto.import_adozione.titolo %></span>
  </div>

  <!-- Classe -->
  <div class="pad-half flex align-baseline gap-quarter txt-small">
    <span>per la classe</span>
    <span class="txt-medium font-weight-bold"><%= appunto.import_adozione.classe_e_sezione %></span>
  </div>

  <!-- Scuola -->
  <% if mostra_scuola && appunto.import_adozione.import_scuola %>
    <div class="pad-half flex align-baseline gap-quarter txt-small">
      <span>della scuola</span>
      <span class="txt-medium" style="color: var(--color-link);"><%= appunto.import_adozione.import_scuola.scuola %></span>
    </div>
  <% end %>

  <!-- Body -->
  <% if appunto.body.present? %>
    <div class="pad-half group">
      <div data-controller="tax-trix-clipboard" data-tax-trix-clipboard-success-content-value="fatto!">
        <div data-tax-trix-clipboard-target="source" class="overflow-hidden">
          <%= appunto.body %>
        </div>
        <button type="button" data-action="tax-trix-clipboard#copy" data-tax-trix-clipboard-target="button"
          class="txt-xx-small font-weight-bold border-radius copy-btn"
          style="background: var(--color-warning-lighter); color: var(--color-warning-dark); padding: 0.125rem 0.5rem;">
          copia
        </button>
      </div>
    </div>
  <% end %>

  <!-- Content -->
  <% if appunto.content.present? %>
    <div class="pad-half group">
      <div data-controller="tax-trix-clipboard" data-tax-trix-clipboard-success-content-value="fatto!">
        <div data-tax-trix-clipboard-target="source" class="overflow-hidden">
          <%= appunto.content %>
        </div>
        <button type="button" data-action="tax-trix-clipboard#copy" data-tax-trix-clipboard-target="button"
          class="txt-xx-small font-weight-bold border-radius copy-btn"
          style="background: var(--color-warning-lighter); color: var(--color-warning-dark); padding: 0.125rem 0.5rem;">
          copia
        </button>
      </div>
    </div>
  <% end %>

  <!-- Footer -->
  <div class="flex justify-space-between align-center gap-half pad-half">
    <!-- Elimina -->
    <%= button_to appunto_path(appunto),
        method: :delete,
        class: "btn",
        style: "background: var(--color-negative); color: white;" do %>
      <%= icon_tag "trash", size: "small" %>
    <% end %>

    <!-- Data -->
    <span class="txt-xx-small txt-subtle"><%= appunto.created_at.strftime('%d-%m-%y') %></span>

    <!-- Stato -->
    <span class="txt-xx-small"><%= appunto.stato %></span>

    <!-- Stato dropdown -->
    <%= render partial: "appunti/appunto_stato", locals: { appunto: appunto } %>
  </div>
</div>
