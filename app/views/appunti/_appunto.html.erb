<%# locals: ( appunto:, mostra_scuola: true ) -%>

<% if local_assigns[:appunto].present? && appunto.persisted? %>
  <%= tag.div id: dom_id(appunto), class: "item panel shadow flex border-radius" do %>

    <% if appunto.is_ssk? %>
      <%= render partial: "appunti/appunto_ssk", locals: { appunto: appunto, mostra_scuola: mostra_scuola } %>
    <% else %>

      <div class="flex-item-grow pad-half flex flex-column justify-space-between gap-half txt-left">
        <div class="flex flex-column">
          <!-- Scuola info -->
          <div class="flex align-center gap-half">
            <%= render partial: "appunti/appunto_scuola", locals: { appunto: appunto } %>
          </div>

          <!-- Contenuto -->
          <% if appunto.content.present? %>
            <div class="margin-block-start-half group">
              <div data-controller="tax-trix-clipboard" data-tax-trix-clipboard-success-content-value="fatto!">
                <div data-tax-trix-clipboard-target="source" class="overflow-hidden">
                  <%= appunto.content %>
                </div>
                <button type="button" data-action="tax-trix-clipboard#copy" data-tax-trix-clipboard-target="button"
                  class="txt-xx-small font-weight-bold border-radius copy-btn"
                  style="background: var(--color-warning-lighter); color: var(--color-warning-dark); padding: 0.125rem 0.5rem;">
                  copia
                </button>
              </div>
            </div>
          <% elsif appunto.body.present? %>
            <div class="margin-block-start-half group">
              <div data-controller="tax-trix-clipboard" data-tax-trix-clipboard-success-content-value="fatto!">
                <div data-tax-trix-clipboard-target="source" class="overflow-hidden">
                  <%= simple_format(appunto.body) %>
                </div>
                <button type="button" data-action="tax-trix-clipboard#copy" data-tax-trix-clipboard-target="button"
                  class="txt-xx-small font-weight-bold border-radius copy-btn"
                  style="background: var(--color-warning-lighter); color: var(--color-warning-dark); padding: 0.125rem 0.5rem;">
                  copia
                </button>
              </div>
            </div>
          <% end %>

          <!-- Telefono -->
          <% if appunto.telefono.present? %>
            <div class="margin-block-start-half" style="color: var(--color-notice);">
              <%= phone_to appunto.telefono %>
            </div>
          <% end %>

          <!-- Data completamento -->
          <% if appunto.completed_at %>
            <div class="txt-small" style="color: var(--color-notice);">
              <%= link_to giorno_path(giorno: appunto.completed_at.to_date.to_s), data: { turbo_frame: :_top } do %>
                <%= l(appunto.completed_at.to_date, format: "%A %d/%m/%Y", locale: :it) %>
              <% end %>
            </div>
          <% end %>

          <!-- Allegati -->
          <%= render partial: "appunti/attachments", locals: { appunto: appunto } %>
        </div>

        <!-- Footer -->
        <div class="flex justify-space-between align-center">
          <!-- Tappe -->
          <%= tag.div id: "tappa-appunto-#{appunto.id}",
              class: "tappe-import_scuola-#{appunto.import_scuola_id} flex align-center",
              style: "margin-left: -0.5rem;" do %>
            <% if appunto.import_scuola %>
              <%= render partial: "clientables/lista_tappe", locals: { tappe: appunto.import_scuola.tappe } %>
            <% end %>
          <% end %>

          <!-- Creato -->
          <span class="txt-xx-small txt-subtle font-style-italic">
            creato <%= time_ago_in_words appunto.created_at %> fa
          </span>

          <!-- Stato badge -->
          <span class="txt-xx-small"><%= appunto.stato %></span>
        </div>
      </div>

      <!-- Actions sidebar -->
      <div class="flex flex-column align-center justify-space-between pad-half">
        <!-- Menu dropdown -->
        <div data-controller="dialog" data-action="keydown.esc->dialog#close click@document->dialog#closeOnClickOutside">
          <button type="button" data-action="click->dialog#toggle" class="btn btn--icon txt-subtle">
            <%= icon_tag "more-vertical" %>
          </button>

          <dialog class="popup panel flex-column" data-dialog-target="dialog">
            <ul class="popup__list">
              <li class="popup__item">
                <%= link_to edit_appunto_path(appunto),
                    class: "popup__btn flex align-center gap-half",
                    data: { turbo_frame: "_top" } do %>
                  <%= icon_tag "pencil", size: "small" %>
                  <span>Modifica</span>
                <% end %>
              </li>
              <li class="popup__item">
                <%= link_to appunto_path(appunto, format: :pdf),
                    target: "_blank",
                    class: "popup__btn flex align-center gap-half" do %>
                  <%= icon_tag "document", size: "small" %>
                  <span>Stampa</span>
                <% end %>
              </li>
              <li class="popup__item">
                <%= button_to appunto_path(appunto), method: :delete,
                    class: "popup__btn flex align-center gap-half",
                    style: "color: var(--color-negative);" do %>
                  <%= icon_tag "trash", size: "small" %>
                  <span>Elimina</span>
                <% end %>
              </li>
            </ul>
          </dialog>
        </div>

        <!-- Stato dropdown -->
        <%= render partial: "appunti/appunto_stato", locals: { appunto: appunto } %>
      </div>

    <% end %>
  <% end %>
<% end %>
