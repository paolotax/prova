<%= turbo_frame_tag :import_form do %>
  <article class="panel panel--wide shadow center txt-align-start">
    <%= form_with model: import, url: imports_path, method: :post, html: { class: "flex flex-column gap", multipart: true }, data: { controller: "form", turbo: false } do |f| %>
      <%= f.hidden_field :import_type, value: "documenti" %>

      <div class="flex align-center gap">
        <%= icon_tag "document", class: "txt-feature", size: "large" %>
        <h2 class="txt-large margin-none font-weight-black">Importa Documenti</h2>
      </div>

      <p class="txt-subtle margin-none">
        Carica un file XML (fattura elettronica) o Excel contenente righe documento con ISBN e quantità.
      </p>

      <div class="flex flex-column gap-half">
        <strong><%= f.label :file, "Seleziona file" %></strong>
        <%= f.file_field :file,
            accept: 'text/xml,application/xml,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet',
            class: "input",
            required: true,
            data: { action: "keydown.esc@document->form#cancel" } %>
      </div>

      <%= f.button type: :submit, class: "btn btn--link center txt-medium" do %>
        <%= icon_tag "arrow-down-tray" %>
        <span>Importa Documenti</span>
      <% end %>

      <%= link_to "Annulla", imports_path, data: { form_target: "cancel" }, hidden: true %>
    <% end %>
  </article>

  <article class="panel panel--wide center txt-align-start margin-block-start">
    <div class="flex flex-column gap-half txt-small txt-subtle">
      <strong class="txt-ink">Formati supportati</strong>
      <p class="margin-none">XML fattura elettronica, Excel (.xlsx)</p>

      <strong class="txt-ink margin-block-start-half">Per file XML</strong>
      <p class="margin-none">Viene parsata la fattura elettronica e creato automaticamente il documento con le righe.</p>

      <strong class="txt-ink margin-block-start-half">Per file Excel</strong>
      <p class="margin-none">Colonne: codice_isbn, quantita, prezzo_unitario</p>

      <strong class="txt-ink margin-block-start-half">Nota</strong>
      <p class="margin-none">I libri devono già esistere nel sistema. Il cliente viene cercato tramite P.IVA presente nella fattura.</p>
    </div>
  </article>
<% end %>
