<%= turbo_frame_tag :import_form do %>
  <article class="panel panel--wide shadow center txt-align-start">
    <%= form_with model: import, url: imports_path, method: :post, html: { class: "flex flex-column gap", multipart: true }, data: { controller: "form", turbo: false } do |f| %>
      <%= f.hidden_field :import_type, value: "clienti" %>

      <div class="flex align-center gap">
        <%= icon_tag "users", class: "txt-positive", size: "large" %>
        <h2 class="txt-large margin-none font-weight-black">Importa Clienti</h2>
      </div>

      <p class="txt-subtle margin-none">
        Carica un file CSV o Excel contenente i dati dei clienti. Il sistema aggiorna automaticamente i clienti esistenti in base alla Partita IVA o Codice Fiscale.
      </p>

      <div class="flex flex-column gap-half">
        <strong><%= f.label :file, "Seleziona file" %></strong>
        <%= f.file_field :file,
            accept: 'text/csv,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/vnd.ms-excel',
            class: "input",
            required: true,
            data: { action: "keydown.esc@document->form#cancel" } %>
      </div>

      <%= f.button type: :submit, class: "btn btn--link center txt-medium" do %>
        <%= icon_tag "arrow-down-tray" %>
        <span>Importa Clienti</span>
      <% end %>

      <%= link_to "Annulla", imports_path, data: { form_target: "cancel" }, hidden: true %>
    <% end %>
  </article>

  <article class="panel panel--wide center txt-align-start margin-block-start">
    <div class="flex flex-column gap-half txt-small txt-subtle">
      <strong class="txt-ink">Formati supportati</strong>
      <p class="margin-none">CSV (.csv), Excel (.xlsx, .xls)</p>

      <strong class="txt-ink margin-block-start-half">Colonne richieste</strong>
      <p class="margin-none">denominazione, partita_iva o codice_fiscale</p>

      <strong class="txt-ink margin-block-start-half">Colonne opzionali</strong>
      <p class="margin-none">indirizzo, cap, citta, provincia, email, telefono</p>

      <strong class="txt-ink margin-block-start-half">Gestione duplicati</strong>
      <p class="margin-none">Il sistema cerca clienti esistenti tramite P.IVA o CF. Se trova un match, aggiorna i dati; altrimenti crea un nuovo cliente.</p>
    </div>
  </article>
<% end %>
