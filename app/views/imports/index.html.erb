<% @page_title = "Storico Importazioni" %>

<% content_for :header do %>
  <div class="header__actions header__actions--start">
    <%= header_back_link account_root_path, label: "Dashboard" %>
  </div>

  <h1 class="header__title"><%= @page_title %></h1>

  <div class="header__actions header__actions--end">
    <%= link_to new_import_path, class: "btn btn--link" do %>
      <%= icon_tag "plus" %>
      <span>Nuova importazione</span>
    <% end %>
  </div>
<% end %>

<% if @imports.any? %>
  <div class="flex flex-column gap-half">
    <% @imports.each do |import| %>
      <%= link_to import_path(import), class: "panel panel--wide center txt-align-start" do %>
        <div class="flex align-center justify-between gap">
          <div class="flex align-center gap">
            <div class="fill-shade border-radius pad-half flex align-center justify-center">
              <%= icon_tag import_type_icon(import.import_type), class: import_type_text_class(import.import_type) %>
            </div>
            <div>
              <p class="font-weight-bold margin-none"><%= import.import_type.humanize %></p>
              <p class="txt-small txt-subtle margin-none"><%= time_ago_in_words(import.created_at) %> fa</p>
            </div>
          </div>

          <div class="flex align-center gap">
            <% if import.completed? || import.failed? %>
              <div class="flex gap txt-small txt-align-center">
                <div>
                  <p class="font-weight-bold txt-positive margin-none"><%= import.imported_count %></p>
                  <p class="txt-subtle txt-x-small margin-none">Nuovi</p>
                </div>
                <div>
                  <p class="font-weight-bold txt-link margin-none"><%= import.updated_count %></p>
                  <p class="txt-subtle txt-x-small margin-none">Aggiornati</p>
                </div>
                <div>
                  <p class="font-weight-bold <%= import.errors_count > 0 ? 'txt-negative' : 'txt-subtle' %> margin-none"><%= import.errors_count %></p>
                  <p class="txt-subtle txt-x-small margin-none">Errori</p>
                </div>
              </div>
            <% else %>
              <span class="flex align-center gap-half txt-subtle txt-small">
                <svg class="animate-spin" style="width: 1rem; height: 1rem;" viewBox="0 0 24 24">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none"></circle>
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
                In corso...
              </span>
            <% end %>

            <%= icon_tag "chevron-right", class: "txt-subtle" %>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>
<% else %>
  <article class="panel panel--wide shadow center txt-align-center">
    <div class="flex flex-column gap align-center">
      <div class="fill-shade border-radius pad">
        <%= icon_tag "arrow-down-tray", class: "txt-subtle", size: "large" %>
      </div>
      <div>
        <h3 class="txt-large font-weight-bold margin-none">Nessuna importazione</h3>
        <p class="txt-subtle margin-none margin-block-start-half">Non hai ancora effettuato importazioni.</p>
      </div>
      <%= link_to new_import_path, class: "btn btn--link" do %>
        <%= icon_tag "plus", size: "small" %>
        <span>Nuova importazione</span>
      <% end %>
    </div>
  </article>
<% end %>
