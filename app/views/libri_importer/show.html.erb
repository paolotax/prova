<% @page_title = "Importazione Completata" %>

<% content_for :header do %>
  <div class="header__actions header__actions--start">
    <%= link_to imports_path, class: "btn" do %>
      <%= icon_tag "arrow-left", size: "small" %>
      <span class="for-screen-reader">Torna</span>
    <% end %>
  </div>

  <h1 class="header__title divider divider--fade full-width">
    <span class="overflow-ellipsis">Importazione Completata</span>
  </h1>

  <div class="header__actions header__actions--end"></div>
<% end %>

<div class="center" style="max-width: 60ch;">
  <article class="panel shadow margin-block-start">
    <div class="flex align-center gap margin-block-end">
      <% if @import.errors.any? %>
        <span class="txt-large"><%= icon_tag "exclamation-triangle", class: "txt-negative" %></span>
      <% else %>
        <span class="txt-large"><%= icon_tag "check-circle", class: "txt-positive" %></span>
      <% end %>
      <div>
        <h2 class="txt-large font-weight-black margin-none">
          <%= @import.errors.any? ? "Completata con errori" : "Importazione riuscita" %>
        </h2>
        <p class="txt-small txt-subtle margin-none">
          <%= @import.errors.any? ? "Alcuni problemi durante l'importazione." : "Dati importati correttamente." %>
        </p>
      </div>
    </div>

    <div class="flex gap flex-wrap margin-block-end">
      <div class="flex flex-column align-center pad" style="flex: 1; min-width: 8ch;">
        <span class="txt-xx-large font-weight-black txt-positive"><%= @import.imported_count %></span>
        <span class="txt-xx-small txt-subtle">Importati</span>
      </div>

      <div class="flex flex-column align-center pad" style="flex: 1; min-width: 8ch;">
        <span class="txt-xx-large font-weight-black" style="color: var(--color-link);"><%= @import.updated_count %></span>
        <span class="txt-xx-small txt-subtle">Aggiornati</span>
      </div>

      <% if @import.respond_to?(:created_count) && @import.created_count.to_i > 0 %>
        <div class="flex flex-column align-center pad" style="flex: 1; min-width: 8ch;">
          <span class="txt-xx-large font-weight-black" style="color: var(--color-purple);"><%= @import.created_count %></span>
          <span class="txt-xx-small txt-subtle">Creati</span>
        </div>
      <% end %>

      <div class="flex flex-column align-center pad" style="flex: 1; min-width: 8ch;">
        <span class="txt-xx-large font-weight-black <%= @import.errors_count.to_i > 0 ? 'txt-negative' : 'txt-subtle' %>"><%= @import.errors_count %></span>
        <span class="txt-xx-small txt-subtle">Errori</span>
      </div>
    </div>

    <% if @import.errors.any? %>
      <div class="border-top pad-block-start margin-block-end">
        <h3 class="txt-small font-weight-bold txt-negative margin-block-end-half">
          <%= icon_tag "exclamation-triangle", class: "icon--small" %>
          Errori riscontrati
        </h3>
        <ul class="flex flex-column gap-quarter" style="list-style: none; padding: 0; margin: 0;">
          <% @import.errors.full_messages.each do |error| %>
            <li class="txt-x-small pad-half" style="background: var(--color-canvas); border-radius: 4px;">
              <%= error %>
            </li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="border-top pad-block-start flex gap-half flex-wrap">
      <%= link_to imports_path, class: "btn flex-item-grow" do %>
        <%= icon_tag "arrow-down-tray" %>
        <span>Nuova importazione</span>
      <% end %>
      <%= link_to libri_path, class: "btn btn--link flex-item-grow" do %>
        <%= icon_tag "book" %>
        <span>Vai ai libri</span>
      <% end %>
    </div>
  </article>
</div>
