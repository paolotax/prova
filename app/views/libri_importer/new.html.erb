<% @page_title = "Importa Libri" %>

<% content_for :header do %>
  <div class="header__actions header__actions--start">
    <%= link_to imports_path, class: "btn" do %>
      <%= icon_tag "arrow-left" %>
      <span class="for-screen-reader">Torna</span>
    <% end %>
  </div>

  <h1 class="header__title divider divider--fade full-width">
    <span class="overflow-ellipsis">Importa Libri</span>
  </h1>

  <div class="header__actions header__actions--end"></div>
<% end %>

<div class="center" style="max-width: 70ch;">
  <p class="txt-small txt-subtle margin-block-end">Scegli il metodo di importazione.</p>

  <div class="flex flex-column gap">

    <%# Importa da File %>
    <article class="panel shadow">
      <div class="flex align-center gap margin-block-end">
        <%= icon_tag "document", class: "txt-large" %>
        <div>
          <h2 class="txt-medium font-weight-black margin-none">Importa da File</h2>
          <p class="txt-x-small txt-subtle margin-none">CSV o Excel con i dati dei libri</p>
        </div>
      </div>

      <%= form_for @import, url: libri_importer_index_path, method: :post, multipart: true,
          html: { class: "flex flex-column gap-half" } do |f| %>
        <div>
          <strong class="txt-x-small"><%= f.label :file, "Seleziona file" %></strong>
          <%= f.file_field :file,
              accept: "text/csv,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/vnd.ms-excel",
              class: "input", required: true %>
        </div>
        <button type="submit" class="btn btn--link">
          <%= icon_tag "arrow-down-tray" %>
          <span>Importa file</span>
        </button>
      <% end %>

      <p class="txt-xx-small txt-subtle margin-block-start border-top pad-block-start-half margin-none">
        Formati: CSV (.csv), Excel (.xlsx, .xls)
      </p>
    </article>

    <%# Importa da A.I.E. %>
    <article class="panel shadow">
      <div class="flex align-center gap margin-block-end">
        <%= icon_tag "arrow-down-tray", class: "txt-large" %>
        <div>
          <h2 class="txt-medium font-weight-black margin-none">Importa da A.I.E.</h2>
          <p class="txt-x-small txt-subtle margin-none">Dati ministeriali dal database A.I.E.</p>
        </div>
      </div>

      <%= form_with url: import_ministeriali_libri_importer_index_path, method: :post,
          html: { class: "flex flex-column gap-half" } do |f| %>
        <div class="txt-x-small">
          <p class="margin-none margin-block-end-half font-weight-bold">Cosa verrà importato:</p>
          <ul class="flex flex-column gap-quarter" style="list-style: none; padding: 0; margin: 0;">
            <li><%= icon_tag "check", class: "icon--small txt-positive" %> Catalogo completo dei libri</li>
            <li><%= icon_tag "check", class: "icon--small txt-positive" %> ISBN e codici ministeriali</li>
            <li><%= icon_tag "check", class: "icon--small txt-positive" %> Prezzi aggiornati</li>
            <li><%= icon_tag "check", class: "icon--small txt-positive" %> Informazioni editoriali</li>
          </ul>
        </div>
        <button type="submit" class="btn btn--link">
          <%= icon_tag "arrow-down-tray" %>
          <span>Avvia importazione A.I.E.</span>
        </button>
      <% end %>

      <p class="txt-xx-small txt-subtle margin-block-start border-top pad-block-start-half margin-none">
        L'importazione può richiedere alcuni minuti.
      </p>
    </article>

    <div class="flex gap flex-wrap">
      <%# Importa Confezioni %>
      <article class="panel shadow" style="flex: 1; min-width: 25ch;">
        <div class="flex align-center gap margin-block-end">
          <%= icon_tag "cube", class: "txt-large" %>
          <div>
            <h2 class="txt-medium font-weight-black margin-none">Importa Confezioni</h2>
            <p class="txt-x-small txt-subtle margin-none">Relazioni confezione-fascicolo</p>
          </div>
        </div>

        <%= form_for @import, url: import_confezioni_libri_importer_index_path, method: :post, multipart: true,
            html: { class: "flex flex-column gap-half" } do |f| %>
          <div>
            <strong class="txt-x-small"><%= f.label :file, "Seleziona file Excel" %></strong>
            <%= f.file_field :file,
                accept: "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/vnd.ms-excel",
                class: "input", required: true %>
          </div>
          <button type="submit" class="btn btn--link">
            <%= icon_tag "arrow-down-tray" %>
            <span>Importa confezioni</span>
          </button>
        <% end %>
      </article>

      <%# Esporta Confezioni %>
      <article class="panel shadow" style="flex: 1; min-width: 25ch;">
        <div class="flex align-center gap margin-block-end">
          <%= icon_tag "document", class: "txt-large" %>
          <div>
            <h2 class="txt-medium font-weight-black margin-none">Esporta Confezioni</h2>
            <p class="txt-x-small txt-subtle margin-none">Scarica relazioni in Excel</p>
          </div>
        </div>

        <p class="txt-x-small margin-block-end">
          Esporta le relazioni confezione-fascicolo per trasferirle ad un altro utente.
        </p>

        <%= link_to export_confezioni_libri_importer_index_path(format: :xlsx), class: "btn btn--link full-width" do %>
          <%= icon_tag "document" %>
          <span>Scarica File Excel</span>
        <% end %>
      </article>
    </div>

  </div>
</div>
