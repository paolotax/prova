#!/usr/bin/env sh

docker compose up -d
docker compose exec app sh -c 'until bundle exec rails runner "puts \"Ready\""; do echo "Waiting..."; sleep 2; done'
docker compose exec -it app bin/rails server -b 0.0.0.0

