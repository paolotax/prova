#!/bin/bash
set -euo pipefail

CLI_DIR="$(dirname "$0")/../../scagnozz-cli"
OUT_DIR="$(dirname "$0")/../public/cli"
VERSION="${1:-0.1.0}"

if [ ! -d "$CLI_DIR" ]; then
  echo "Errore: directory scagnozz-cli non trovata in $CLI_DIR" >&2
  exit 1
fi

echo "Building Scagnozz CLI v${VERSION}..."

mkdir -p "$OUT_DIR"

LDFLAGS="-s -w -X main.version=${VERSION}"

GOOS=linux  GOARCH=amd64 go build -C "$CLI_DIR" -ldflags "$LDFLAGS" -o "$(realpath "$OUT_DIR")/scagnozz-linux-amd64"   ./cmd/scagnozz/
GOOS=linux  GOARCH=arm64 go build -C "$CLI_DIR" -ldflags "$LDFLAGS" -o "$(realpath "$OUT_DIR")/scagnozz-linux-arm64"   ./cmd/scagnozz/
GOOS=darwin GOARCH=amd64 go build -C "$CLI_DIR" -ldflags "$LDFLAGS" -o "$(realpath "$OUT_DIR")/scagnozz-darwin-amd64"  ./cmd/scagnozz/
GOOS=darwin GOARCH=arm64 go build -C "$CLI_DIR" -ldflags "$LDFLAGS" -o "$(realpath "$OUT_DIR")/scagnozz-darwin-arm64"  ./cmd/scagnozz/
GOOS=windows GOARCH=amd64 go build -C "$CLI_DIR" -ldflags "$LDFLAGS" -o "$(realpath "$OUT_DIR")/scagnozz-windows-amd64.exe" ./cmd/scagnozz/

cp "$CLI_DIR/scripts/install.sh" "$OUT_DIR/"

echo "Done! Binaries in $OUT_DIR:"
ls -lh "$OUT_DIR"
